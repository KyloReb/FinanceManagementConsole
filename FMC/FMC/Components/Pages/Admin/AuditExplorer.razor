@page "/admin/audit"
@using MudBlazor
@using FMC.Shared.Auth
@using FMC.Shared.DTOs.Admin
@using FMC.Components.Pages.Admin.Dialogs
@attribute [Authorize(Roles = Roles.SuperAdmin)]
@inject OrganizationApiService OrgService
@inject ISnackbar Snackbar
@inject IBrowserViewportService ViewportService
@inject IDialogService DialogService
@implements IAsyncDisposable
@implements IBrowserViewportObserver

<PageTitle>Audit Intelligence | FMC</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mt-md-8 mb-12">
    @* PLATINUM HEADER AREA *@
    <div class="fmc-audit-header mb-8 flex-wrap gap-4">
        <div class="d-flex align-center">
            <div class="fmc-audit-bar mr-4"></div>
            <div>
                <MudText Typo="Typo.h4" Class="fmc-audit-hero-text">Audit Intelligence Explorer</MudText>
                <MudText Typo="Typo.body1" Class="fmc-audit-subtitle d-none d-sm-block">Securing the network through forensic visibility and financial compliance.</MudText>
            </div>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FileDownload" 
                   Size="Size.Large" Class="fmc-audit-action-btn">Export Forensic Log</MudButton>
    </div>

    @* ANALYTICS GLASS CARDS *@
    <MudGrid Spacing="3" Class="mb-10">
        <MudItem xs="4" sm="4">
            <div class="fmc-audit-glass-card accent-info">
                <MudText Typo="Typo.subtitle2" Class="fmc-audit-card-label">TOTAL EVENTS</MudText>
                <MudText Typo="Typo.h4" Class="fmc-audit-kpi-val">@_searchResult.TotalCount.ToString("N0")</MudText>
                <div class="fmc-audit-card-icon"><MudIcon Icon="@Icons.Material.Filled.Timeline" /></div>
            </div>
        </MudItem>
        <MudItem xs="4" sm="4">
            <div class="fmc-audit-glass-card accent-success">
                <MudText Typo="Typo.subtitle2" Class="fmc-audit-card-label">FINANCIAL</MudText>
                <MudText Typo="Typo.h4" Class="fmc-audit-kpi-val">@_financialCount.ToString("N0")</MudText>
                <div class="fmc-audit-card-icon"><MudIcon Icon="@Icons.Material.Filled.AccountBalance" /></div>
            </div>
        </MudItem>
        <MudItem xs="4" sm="4">
            <div class="fmc-audit-glass-card accent-warning">
                <MudText Typo="Typo.subtitle2" Class="fmc-audit-card-label">SECURITY</MudText>
                <MudText Typo="Typo.h4" Class="fmc-audit-kpi-val">@_authCount.ToString("N0")</MudText>
                <div class="fmc-audit-card-icon"><MudIcon Icon="@Icons.Material.Filled.VpnKey" /></div>
            </div>
        </MudItem>
    </MudGrid>

    @* FILTER ENGINE *@
    <div class="fmc-audit-filter-panel pa-4 mb-6">
        <MudGrid Spacing="2" Class="align-center">
            <MudItem xs="12" md="4">
                <MudDateRangePicker Label="Date Boundary" @bind-DateRange="_dateRange" 
                                   PlaceholderStart="Start" PlaceholderEnd="End"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Class="fmc-input-field" />
            </MudItem>
            <MudItem xs="6" md="2">
                <MudSelect T="string" Label="Category" @bind-Value="_query.Category" 
                          Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Class="fmc-input-field">
                    <MudSelectItem Value="@((string?)null)">Integrated (All)</MudSelectItem>
                    <MudSelectItem Value="@("financial")">💱 Financial</MudSelectItem>
                    <MudSelectItem Value="@("auth")">🔐 Security</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" md="3">
                <MudTextField @bind-Value="_query.Action" Label="Action" 
                             Placeholder="e.g. CREDIT..." Variant="Variant.Outlined" 
                             Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="fmc-input-field" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" 
                           StartIcon="@Icons.Material.Filled.FilterAlt" OnClick="PerformSearch"
                           Style="height:42px; border-radius:12px; font-weight:800; text-transform:none;">Apply Scrutiny</MudButton>
            </MudItem>
        </MudGrid>
    </div>

    @if (_loading)
    {
        <div class="d-flex flex-column align-center justify-center py-20">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="mb-4" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary">Scanning forensic clusters...</MudText>
        </div>
    }
    else
    {
        @if (!_isMobile)
        {
            @* DESKTOP ANALYTICS TABLE *@
            <div class="fmc-audit-surface">
                <MudDataGrid T="AuditLogDto" Items="@_searchResult.Items" Loading="@_loading" 
                            RowClick="@(args => ShowDetail(args.Item))"
                            Hover="true" Striped="false" Elevation="0" Class="fmc-audit-grid pointer-grid"
                            FixedHeader="true" Height="600px">
                    <Columns>
                        <PropertyColumn Property="x => x.CreatedAt" Title="TIME" InitialDirection="SortDirection.Descending">
                            <CellTemplate>
                                <div class="d-flex flex-column">
                                    <MudText Style="font-weight:950; font-size:0.75rem;">@context.Item.CreatedAt.ToLocalTime().ToString("HH:mm")</MudText>
                                    <MudText Typo="Typo.caption" Style="font-size:0.6rem; opacity:0.5; font-weight:800;">@context.Item.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</MudText>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>
                        <PropertyColumn Property="x => x.Action" Title="EVENT IDENTITY">
                            <CellTemplate>
                                <div class="d-flex align-center gap-2">
                                    @{
                                        var isCredit = context.Item.Action == "CREDIT";
                                        var isDebit = context.Item.Action == "DEBIT";
                                        var color = isCredit ? Color.Success : (isDebit ? Color.Error : Color.Info);
                                        var icon = isCredit ? Icons.Material.Filled.AddCircle : (isDebit ? Icons.Material.Filled.RemoveCircle : Icons.Material.Filled.Hub);
                                    }
                                    <MudIcon Icon="@icon" Color="@color" Size="Size.Small" />
                                    <MudText Style="font-weight:900; letter-spacing:0.04em; font-size:0.7rem; text-transform:uppercase;">@context.Item.Action</MudText>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>
                        <PropertyColumn Property="x => x.EntityName" Title="CONTEXT">
                            <CellTemplate>
                                <MudText Style="font-weight:800; font-size:0.75rem;" Class="text-truncate">@(context.Item.EntityName ?? context.Item.Organization ?? "System Boundary")</MudText>
                            </CellTemplate>
                        </PropertyColumn>
                        <PropertyColumn Property="x => x.Amount" Title="MAGNITUDE" Sortable="true" HeaderStyle="text-align:right">
                            <CellTemplate>
                                <div class="text-right">
                                @if (context.Item.Amount.HasValue)
                                {
                                    <MudText Style="font-weight:950; font-family:'JetBrains Mono',monospace; font-size:0.85rem;" 
                                             Color="@(context.Item.Action == "CREDIT" ? Color.Success : Color.Error)">
                                        @(context.Item.Action == "CREDIT" ? "+" : "-")₱@context.Item.Amount.Value.ToString("N2")
                                    </MudText>
                                }
                                else
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-disabled" Style="font-weight:900; font-size:0.65rem;">N/A</MudText>
                                }
                                </div>
                            </CellTemplate>
                        </PropertyColumn>
                        <PropertyColumn Property="x => x.IpAddress" Title="TELEMETRY">
                            <CellTemplate>
                                <div class="d-flex flex-column">
                                    <MudText Style="font-size:0.65rem; font-family:'JetBrains Mono',monospace; font-weight:700;">@context.Item.IpAddress</MudText>
                                    <MudText Typo="Typo.caption" Style="font-size:0.55rem; opacity:0.6; font-weight:800;" Class="text-truncate">@context.Item.Device</MudText>
                                </div>
                            </CellTemplate>
                        </PropertyColumn>
                    </Columns>
                    <PagerContent>
                        <MudDataGridPager T="AuditLogDto" />
                    </PagerContent>
                </MudDataGrid>
            </div>
        }
        else
        {
            @* MOBILE FOrensIC DOSSIER LIST *@
            <div class="d-flex flex-column gap-2 mb-10">
                @foreach (var log in _searchResult.Items)
                {
                    <div class="fmc-audit-mobile-card" @onclick="@(() => ShowDetail(log))">
                        <div class="fmc-mobile-top pa-3 d-flex justify-space-between align-center">
                            <div class="d-flex align-center gap-2">
                                @{
                                    var isCredit = log.Action == "CREDIT";
                                    var isDebit = log.Action == "DEBIT";
                                    var colorClass = isCredit ? "success" : (isDebit ? "error" : "info");
                                }
                                <div class="fmc-audit-pulse @colorClass"></div>
                                <MudText Style="font-weight:950; font-size:0.75rem; text-transform:uppercase;">@log.Action</MudText>
                            </div>
                            <div class="text-right d-flex flex-column">
                                <MudText Style="font-weight:950; font-size:0.7rem;">@log.CreatedAt.ToLocalTime().ToString("HH:mm")</MudText>
                                <MudText Style="font-size:0.55rem; opacity:0.6; font-weight:800; margin-top:-2px;">@log.CreatedAt.ToLocalTime().ToString("MM/dd")</MudText>
                            </div>
                        </div>
                        <div class="fmc-mobile-mid px-3 pb-3 pt-1">
                            <div class="d-flex justify-space-between align-end">
                                <div class="flex-grow-1 mr-4 overflow-hidden">
                                     <MudText Style="font-size:0.55rem; font-weight:900; opacity:0.5; letter-spacing:0.05em; text-transform:uppercase; display:block;">Context</MudText>
                                     <MudText Style="font-weight:800; font-size:0.75rem;" Class="text-truncate">@(log.EntityName ?? log.Organization ?? "System")</MudText>
                                </div>
                                <div class="text-right">
                                    @if (log.Amount.HasValue)
                                    {
                                        <MudText Style="font-weight:950; font-family:'JetBrains Mono',monospace; font-size:0.8rem;" 
                                                 Color="@(isCredit ? Color.Success : Color.Error)">
                                            @(isCredit ? "+" : "-")₱@log.Amount.Value.ToString("N0")
                                        </MudText>
                                    }
                                    else
                                    {
                                         <MudText Style="font-size:0.7rem; font-weight:950; opacity:0.3;">TRACE ONLY</MudText>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
                
                @if (_searchResult.Items.Any())
                {
                    <div class="pa-4 text-center">
                        <MudText Typo="Typo.caption" Style="font-weight:900; opacity:0.4; letter-spacing:0.1em; text-transform:uppercase;">End of forensic cluster</MudText>
                    </div>
                }
            </div>
        }
    }
</MudContainer>

<style>
    /* AUDIT INTELLIGENCE PREMIUM DESIGN */
    .fmc-audit-header { display: flex; align-items: center; justify-content: space-between; }
    .fmc-audit-bar { width: 6px; height: 50px; background: linear-gradient(to bottom, var(--mud-palette-primary), var(--mud-palette-info)); border-radius: 4px; }
    .fmc-audit-hero-text { font-weight: 950; letter-spacing: -0.05em; color: var(--mud-palette-text-primary); }
    .fmc-audit-subtitle { color: var(--mud-palette-text-secondary); opacity: 0.7; font-weight: 600; margin-top:-4px; }
    .fmc-audit-action-btn { border-radius: 12px; text-transform:none; font-weight: 800; padding: 10px 24px !important; }

    /* Glass KPI Cards */
    .fmc-audit-glass-card {
        padding: 20px; border-radius: 20px; background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider); position: relative; overflow: hidden;
        transition: transform 0.3s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.02);
    }
    .fmc-audit-card-label { letter-spacing: 0.1em; opacity: 0.5; font-weight: 900; font-size: 0.55rem; text-transform: uppercase; margin-bottom: 4px; }
    .fmc-audit-kpi-val { font-weight: 950; letter-spacing: -0.02em; }
    .fmc-audit-card-icon { position: absolute; right: -8px; bottom: -8px; opacity: 0.05; font-size: 4rem !important; transform: rotate(-5deg); }
    .fmc-audit-glass-card.accent-info { border-top: 4px solid var(--mud-palette-info); }
    .fmc-audit-glass-card.accent-success { border-top: 4px solid var(--mud-palette-success); }
    .fmc-audit-glass-card.accent-warning { border-top: 4px solid var(--mud-palette-warning); }

    /* Filter Panel */
    .fmc-audit-filter-panel { background: var(--mud-palette-background-grey); border-radius: 16px; border: 1px solid var(--mud-palette-divider); }
    .fmc-input-field .mud-input-outlined { border-radius: 12px; background: var(--mud-palette-surface); }

    /* Data Presentation */
    .fmc-audit-surface { border-radius: 20px; border: 1px solid var(--mud-palette-divider); overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.02); }
    .fmc-audit-grid .mud-table-head { background: var(--mud-palette-background-grey); }
    .fmc-audit-grid .mud-th { font-weight: 950 !important; font-size: 0.65rem !important; letter-spacing: 0.1em; color: var(--mud-palette-text-secondary); padding: 16px 24px !important; }
    .fmc-audit-grid .mud-td { padding: 12px 24px !important; border-bottom: 1px solid var(--mud-palette-divider) !important; }

    /* Mobile Dossier Card */
    .fmc-audit-mobile-card { 
        background: var(--mud-palette-surface); border-radius: 16px; border: 1px solid var(--mud-palette-divider); 
        box-shadow: 0 2px 8px rgba(0,0,0,0.02); transition: transform 0.2s; cursor: pointer;
    }
    .fmc-audit-mobile-card:active { transform: scale(0.98); }
    .fmc-audit-pulse { width: 8px; height: 8px; border-radius: 50%; position: relative; }
    .fmc-audit-pulse.success { background: var(--mud-palette-success); }
    .fmc-audit-pulse.error { background: var(--mud-palette-error); }
    .fmc-audit-pulse.info { background: var(--mud-palette-info); }
    .fmc-audit-pulse::after { 
        content: ''; position: absolute; width:100%; height:100%; background: inherit; 
        border-radius: 50%; opacity: 0.4; animation: pulse-ring 2s infinite ease-in-out; 
    }
    @@keyframes pulse-ring { 0% { transform: scale(0.8); opacity: 0.8; } 100% { transform: scale(2.5); opacity: 0; } }

    @@media (max-width: 600px) {
        .fmc-audit-hero-text { font-size: 1.5rem !important; }
        .fmc-audit-header { flex-direction: column; align-items: stretch; gap: 16px; }
        .fmc-audit-action-btn { width: 100%; order: -1; }
        .fmc-audit-glass-card { padding: 12px; }
        .fmc-audit-kpi-val { font-size: 1.5rem !important; }
    }
</style>

@code {
    private bool _loading = true;
    private bool _isMobile;
    private AuditLogQueryDto _query = new() { PageSize = 100 };
    private AuditLogSearchResultDto _searchResult = new();
    private DateRange _dateRange = new(DateTime.Today.AddDays(-7), DateTime.Today);

    private int _financialCount => _searchResult.Items.Count(i => i.Action == "CREDIT" || i.Action == "DEBIT");
    private int _authCount => _searchResult.Items.Count(i => i.Action != "CREDIT" && i.Action != "DEBIT");

    protected override async Task OnInitializedAsync()
    {
        if (!RendererInfo.IsInteractive) return;
        await PerformSearch();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isMobile = await ViewportService.GetCurrentBreakpointAsync() <= Breakpoint.Sm;
            await ViewportService.SubscribeAsync(this, fireImmediately: true);
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        await ViewportService.UnsubscribeAsync(this);
    }

    Guid IBrowserViewportObserver.Id { get; } = Guid.NewGuid();

    MudBlazor.Services.ResizeOptions? IBrowserViewportObserver.ResizeOptions { get; } = new()
    {
        ReportRate = 100,
        NotifyOnBreakpointOnly = true
    };

    Task IBrowserViewportObserver.NotifyBrowserViewportChangeAsync(BrowserViewportEventArgs args)
    {
        var mobile = args.Breakpoint <= Breakpoint.Sm;
        if (_isMobile != mobile)
        {
            _isMobile = mobile;
            return InvokeAsync(StateHasChanged);
        }
        return Task.CompletedTask;
    }

    private void ShowDetail(AuditLogDto log)
    {
        var parameters = new DialogParameters<AuditDetailDialog> { { x => x.Log, log } };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        DialogService.ShowAsync<AuditDetailDialog>("Forensic Data Trace", parameters, options);
    }

    private async Task PerformSearch()
    {
        try
        {
            _loading = true;
            _query.FromDate = _dateRange.Start;
            _query.ToDate = _dateRange.End?.AddDays(1).AddTicks(-1); // End of the day

            _searchResult = await OrgService.SearchAuditLogsAsync(_query);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Forensic Retrieval Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
