@page "/transactions"
@using FMC.Application.Interfaces
@using FMC.Components.Pages.Admin.Dialogs
@attribute [Authorize]
@implements IAsyncDisposable
@implements IBrowserViewportObserver

@inject ThemeService ThemeService
@inject IBrowserViewportService BrowserViewportService

@* ══════════════════════════════════════════════════════════════════════
   PAGE: Transaction History / Forensic Settlement Ledger
   Displays a sortable/filterable table (desktop) or card list (mobile)
   of financial transactions with search, date filtering, and export.
   ════════════════════════════════════════════════════════════════════ *@

<div class="fmc-ledger-root @(ThemeService.IsDarkMode ? "fmc-dark-mode" : "fmc-light-mode")">
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8">

    @* ── HERO HEADER ── *@
    <div class="d-flex align-center justify-space-between mb-4">
        <div class="d-flex align-center">
            <div class="fmc-header-accent mr-5"></div>
            <div class="d-flex flex-column">
                <MudText Typo="Typo.h3" Class="fmc-hero-text">Transaction History</MudText>
            </div>
        </div>
    </div>

    <MudPaper Elevation="0" Class="fmc-main-surface">

        @* ── FILTER HEADER: Search, Date Range, Export ── *@
        <div class="fmc-header-area">

            @* TOP ROW: Icon + Label | Search Bar *@
            <div class="fmc-identity-row mb-3">
                 <div class="d-flex align-center">
                    <div class="fmc-header-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.HistoryEdu" Color="Color.Primary" /></div>
                    <div class="mr-6">
                        <MudText Typo="Typo.h6" Style="font-weight: 800; letter-spacing: -0.01em;">Forensic Settlement History</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Authorized audit stream of financial adjustments</MudText>
                    </div>
                </div>

                <div class="fmc-identity-search ml-auto" style="min-width: 320px;">
                    <div class="fmc-search-pill">
                        <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" Class="fmc-search-pill-icon" />
                        <input type="text" class="fmc-search-pill-input" placeholder="Search transactions..." 
                               value="@_searchString" @oninput="OnSearchChanged" />
                    </div>
                </div>
            </div>

            @* BOTTOM ROW: Date Quick-select + Custom Dates | Export Buttons *@
            <div class="fmc-orchestration-row">
                <div class="fmc-temporal-filter">
                    @* Quick date range buttons *@
                    <div class="fmc-date-group mr-3">
                        <button class="fmc-date-btn @(_activeDateRange == "all" ? "active" : "")" @onclick='() => SetQuickDate("all")'>ALL</button>
                        <button class="fmc-date-btn @(_activeDateRange == "today" ? "active" : "")" @onclick='() => SetQuickDate("today")'>TODAY</button>
                        <button class="fmc-date-btn @(_activeDateRange == "7d" ? "active" : "")" @onclick='() => SetQuickDate("7d")'>7D</button>
                        <button class="fmc-date-btn @(_activeDateRange == "30d" ? "active" : "")" @onclick='() => SetQuickDate("30d")'>30D</button>
                        <button class="fmc-date-btn @(_activeDateRange == "1y" ? "active" : "")" @onclick='() => SetQuickDate("1y")'>1Y</button>
                    </div>
                    @* Custom date range inputs *@
                    <div class="fmc-custom-date-wrap">
                        <div class="fmc-date-input-box">
                            <span class="fmc-date-label">STARTING PERIOD</span>
                            <input type="date" value="@(_startDate?.ToString("yyyy-MM-dd"))" @onchange='(e) => UpdateDate(e, true)' class="fmc-raw-date" />
                        </div>
                        <div class="fmc-date-sep"></div>
                        <div class="fmc-date-input-box">
                            <span class="fmc-date-label">ENDING PERIOD</span>
                            <input type="date" value="@(_endDate?.ToString("yyyy-MM-dd"))" @onchange='(e) => UpdateDate(e, false)' class="fmc-raw-date" />
                        </div>
                    </div>
                </div>

                @* Export action buttons *@
                <div class="fmc-action-toolbar ml-3">
                    <button class="fmc-premium-action excel" @onclick="ExportExcel">
                        <MudIcon Icon="@Icons.Material.Filled.CloudDownload" Size="Size.Small" Class="mr-2" />
                        <span>XLS EXPORT</span>
                    </button>
                    <button class="fmc-premium-action pdf" @onclick="ExportPdf">
                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Small" Class="mr-2" />
                        <span>PDF AUDIT</span>
                    </button>
                </div>
            </div>
        </div>

        @* ── VIEW: Desktop Table vs Mobile Cards ── *@
        @if (!_isMobile)
        {

        @* ─── DESKTOP: MudTable with sortable columns, hover tooltips, pagination ─── *@
        <MudTable @ref="_table" Items="@_transactions" Hover="true" Elevation="0" Loading="@_loading" 
                 OnRowClick="OnRowClick" T="TransactionDto" 
                 Striped="true" Dense="true" FixedHeader="true" Height="auto" HorizontalScrollbar="false"
                 SortMode="SortMode.Multiple" OnSelectedItemChanged="OnSelectedItemChanged" SelectionChanged="null">

            @* Column width distribution *@
            <ColGroup>
                <col style="width: 18%;" />
                <col style="width: 25%;" />
                <col style="width: 12%;" />
                <col style="width: 15%;" />
                <col style="width: 20%;" />
            </ColGroup>

            @* Skeleton loading rows shown while data loads *@
            <LoadingContent>
                @for (int i = 0; i < 8; i++)
                {
                    <div class="d-flex align-center pa-4 px-6" style="border-bottom: 1px solid var(--mud-palette-divider); gap: 24px;">
                        <div style="flex:1;" class="d-flex align-center gap-3">
                            <div class="fmc-skel" style="width:4px; height:24px;"></div>
                            <div style="flex:1;">
                                <div class="fmc-skel fmc-skel-line mb-2" style="width:70%;"></div>
                                <div class="fmc-skel fmc-skel-line" style="width:40%;"></div>
                            </div>
                        </div>
                        <div style="flex:1;">
                            <div class="fmc-skel fmc-skel-line mb-2" style="width:80%;"></div>
                            <div class="fmc-skel fmc-skel-line" style="width:50%;"></div>
                        </div>
                        <div style="flex:1;" class="d-flex justify-center">
                            <div class="fmc-skel fmc-skel-pill"></div>
                        </div>
                        <div style="flex:1;" class="d-flex justify-center">
                            <div class="fmc-skel fmc-skel-pill"></div>
                        </div>
                        <div style="flex:1;" class="text-right">
                            <div class="fmc-skel fmc-skel-line ml-auto" style="width:80px; height: 18px;"></div>
                        </div>
                    </div>
                }
            </LoadingContent>

            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Date)">TIMESTAMP</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Subscriber)">SUBSCRIBER / BATCH</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Category)">CATEGORY</MudTableSortLabel></MudTh>
                <MudTh Style="text-align:center;"><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Status)">STATUS</MudTableSortLabel></MudTh>
                <MudTh Style="text-align:right;"><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Amount)">AMOUNT</MudTableSortLabel></MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd>
                    @* Hover tooltip with full transaction telemetry *@
                    @{
                        var isCredit = context!.Amount > 0;
                        var isDebit = context.Amount < 0;
                        var isNeutral = context.Amount == 0;
                        var icon = isCredit ? Icons.Material.Filled.AddCircle : (isDebit ? Icons.Material.Filled.RemoveCircle : Icons.Material.Filled.Info);
                        var severityClass = isCredit ? "credit" : (isDebit ? "debit" : "neutral");
                    }
                    <div class="fmc-row-tooltip">
                        <div class="tooltip-header @severityClass">
                            <MudIcon Icon="@icon" Size="Size.Small" Class="mr-1" />
                            <span>TRANSACTION TELEMETRY</span>
                        </div>
                        <div class="tooltip-body">
                            <div class="tooltip-row">
                                <span class="tooltip-lbl">TYPE / CATEGORY:</span>
                                <span class="tooltip-val @severityClass" style="text-transform: uppercase;">@context.Category</span>
                            </div>
                            <div class="tooltip-row">
                                <span class="tooltip-lbl">SUBSCRIBER:</span>
                                <span class="tooltip-val">@(context.Subscriber ?? "N/A")</span>
                            </div>
                            <div class="tooltip-row">
                                <span class="tooltip-lbl">ACCOUNT REFERENCE:</span>
                                <span class="tooltip-val mono">@(context.AccountNumber ?? "N/A")</span>
                            </div>
                            <div class="tooltip-row">
                                <span class="tooltip-lbl">INITIATING MAKER:</span>
                                <span class="tooltip-val">@(context.MakerName ?? "System")</span>
                            </div>
                            <div class="tooltip-row">
                                <span class="tooltip-lbl">MAGNITUDE VALUE:</span>
                                <span class="tooltip-val highlighted-val @severityClass">₱@Math.Abs(context.Amount).ToString("N2")</span>
                            </div>
                            <div class="tooltip-row">
                                <span class="tooltip-lbl">ISO TIMESTAMP:</span>
                                <span class="tooltip-val highlighted-val">@context.Date.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss.fff")</span>
                            </div>
                            <div class="tooltip-row">
                                <span class="tooltip-lbl">SYSTEM LABEL:</span>
                                <span class="tooltip-val">@(context.Label ?? "FMC Settlement")</span>
                            </div>
                        </div>
                        <div class="tooltip-footer">
                            <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Size="Size.Small" Class="mr-1" style="font-size: 0.6rem;" />
                            <span>CLICK ROW FOR FULL EVENT LEDGER TRACE</span>
                        </div>
                    </div>

                    @* Timestamp column with ledger bar *@
                    <div class="d-flex align-center gap-3">
                        <div class="fmc-ledger-bar" style="background: var(--mud-palette-divider);"></div>
                        @{
                            var displayTime = (context!.ActionDate ?? context!.Date).ToLocalTime();
                        }
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.body2" Style="font-weight:900; letter-spacing: -0.02em;">@displayTime.ToString("MMM dd, yyyy")</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700; opacity: 0.6;">@displayTime.ToString("HH:mm:ss")</MudText>
                        </div>
                    </div>
                </MudTd>

                @* Subscriber / Batch column *@
                <MudTd>
                    <div class="d-flex flex-column">
                        <div class="d-flex align-center gap-2">
                            @if (context.SubTransactions?.Any() == true || context.AccountNumber == "BATCH_SUMMARY")
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Layers" Size="Size.Small" Color="Color.Info" Style="font-size: 1rem;" />
                            }
                            <MudText Typo="Typo.body2" Style="font-weight:900;">@context!.Subscriber</MudText>
                        </div>
                        @{
                            var acc = context.AccountNumber;
                            if (string.IsNullOrEmpty(acc) || acc == "N/A")
                            {
                                var subscriberName = context.Subscriber?.Replace(" (Bulk)", "");
                                var u = _allUsers.FirstOrDefault(x => x.DisplayName.Equals(subscriberName, StringComparison.OrdinalIgnoreCase)
                                                                   || x.UserName?.Equals(subscriberName, StringComparison.OrdinalIgnoreCase) == true);
                                if (u != null) acc = u.AccountNumber;
                            }
                        }
                        @if (!string.IsNullOrEmpty(acc))
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-family: 'JetBrains Mono', monospace; letter-spacing: 0.05em;">
                                @(acc == "BATCH_SUMMARY" ? "BATCH FORENSIC SUMMARY" : GetMaskedAccount(acc))
                            </MudText>
                        }
                    </div>
                </MudTd>

                @* Category badge *@
                <MudTd>
                    <span class="fmc-status-badge mixed" style="font-size: 0.6rem; padding: 2px 8px; border-radius: 4px;">
                        @context!.Category.ToUpper()
                    </span>
                </MudTd>

                @* Status badge with icon *@
                <MudTd>
                    <div class="d-flex justify-center">
                        <div class="fmc-status-badge @(context!.Status.ToLower())">
                            <MudIcon Icon="@GetStatusIcon(context!.Status)" Size="Size.Small" Class="mr-1" Style="font-size: 0.85rem;" />
                            <span>@context.Status.ToUpper()</span>
                        </div>
                    </div>
                </MudTd>

                @* Amount column — color-coded (green=credit, red=debit) *@
                <MudTd Style="text-align:right">
                    <MudText Color="@(context!.Amount < 0 ? Color.Error : Color.Success)" 
                             Class="fmc-money" Style="font-size: 1.15rem; letter-spacing: -0.04em;">
                        @(context!.Amount > 0 ? "+" : "")@context!.Amount.ToString("C2")
                    </MudText>
                </MudTd>
            </RowTemplate>

            @* Empty state when no records match filters *@
            <NoRecordsContent>
                <div class="fmc-empty-state">
                    <div class="fmc-empty-glow"></div>
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Class="fmc-empty-icon" />
                    <MudText Typo="Typo.h6" Class="fmc-empty-title">No matching forensic records</MudText>
                    <MudText Typo="Typo.body2" Class="fmc-empty-subtitle">Your tactical query did not yield any results in the current stream.</MudText>
                </div>
            </NoRecordsContent>

            <FooterContent>
            </FooterContent>

            @* Pagination + end-of-stream marker *@
            <PagerContent>
                @if (!_loading && _transactions.Any(FilterFunc1) && _table != null && ((_table.CurrentPage + 1) * _table.RowsPerPage >= _table.GetFilteredItemsCount()))
                {
                    <div class="fmc-end-of-stream-wrap" style="padding: 20px 0;">
                        <div class="fmc-end-indicator">
                            <div class="fmc-end-line"></div>
                            <span class="fmc-end-text">END OF FORENSIC AUDIT STREAM</span>
                            <div class="fmc-end-line"></div>
                        </div>
                    </div>
                }
                <MudTablePager />
            </PagerContent>
        </MudTable>
        }
        else
        {

        @* ─── MOBILE: Scrollable cards with pagination, skeleton loading, premium empty state ─── *@
            <div class="fmc-mobile-tx-list">

                @* Show skeleton cards while data loads *@
                @if (_loading)
                {
                    <div class="fmc-mobile-loading">
                        @for (int i = 0; i < 4; i++)
                        {
                            <div class="fmc-tx-card fmc-skel-card">
                                <div class="fmc-tx-card-top">
                                    <div class="fmc-tx-card-date" style="gap:6px;">
                                        <div class="fmc-skel" style="width:100px;height:14px;"></div>
                                        <div class="fmc-skel" style="width:50px;height:10px;"></div>
                                    </div>
                                    <div class="fmc-skel" style="width:3px;height:18px;"></div>
                                </div>
                                <div class="fmc-tx-card-body" style="gap:8px;">
                                    <div class="fmc-skel" style="width:80%;height:12px;"></div>
                                    <div class="fmc-skel" style="width:60%;height:10px;"></div>
                                    <div class="fmc-tx-card-badges">
                                        <div class="fmc-skel" style="width:70px;height:16px;border-radius:4px;"></div>
                                        <div class="fmc-skel" style="width:80px;height:16px;border-radius:6px;"></div>
                                    </div>
                                </div>
                                <div class="fmc-tx-card-footer" style="padding:8px 12px;">
                                    <div class="fmc-skel" style="width:120px;height:16px;margin-bottom:2px;"></div>
                                    <div class="fmc-skel" style="width:50px;height:8px;"></div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    @* Compute pagination variables from filtered results *@
                    var pageSizes = new[] { 10, 20, 30, 0 };
                    var mobileItems = _transactions.Where(FilterFunc1).ToList();
                    var totalItems = mobileItems.Count;
                    var ps = _mobileTxPageSize == 0 ? totalItems : _mobileTxPageSize;
                    var totalPages = ps == 0 ? 1 : ((totalItems - 1) / ps) + 1;
                    if (_mobileTxPage >= totalPages) _mobileTxPage = 0;
                    var pagedItems = mobileItems.Skip(_mobileTxPage * ps).Take(ps).ToList();
                    var showingStart = totalItems == 0 ? 0 : _mobileTxPage * ps + 1;
                    var showingEnd = ps == 0 ? totalItems : Math.Min((_mobileTxPage + 1) * ps, totalItems);

                    @if (totalItems > 0)
                    {

                        @* ── Rows-per-page selector + page summary + nav ── *@
                        <div class="d-flex justify-space-between align-center mb-2 px-1">
                            @* Page size buttons: 10 | 20 | 30 | All *@
                            <div class="d-flex align-center gap-1" style="font-size:0.5rem;">
                                @foreach (var sz in pageSizes)
                                {
                                    var label = sz == 0 ? "All" : sz.ToString();
                                    var isActive = (_mobileTxPageSize == sz);
                                    <button @onclick="() => { _mobileTxPageSize = sz; _mobileTxPage = 0; }"
                                            style="padding:2px 6px; border-radius:4px; border:1px solid var(--mud-palette-divider); background:@(isActive ? "var(--mud-palette-primary)" : "transparent"); color:@(isActive ? "white" : "var(--mud-palette-text-primary)"); font-weight:900; font-size:0.5rem; cursor:pointer;">@label</button>
                                }
                            </div>
                            @* Showing X–Y of Z counter *@
                            <MudText Typo="Typo.caption" Style="font-size:0.5rem; opacity:0.5;">
                                @if (totalItems > 0 && ps > 0) { <text>@showingStart–@showingEnd of @totalItems</text> }
                            </MudText>
                            @* Top pagination: first | prev | page count | next | last *@
                            @if (totalItems > ps && ps > 0)
                            {
                                var isFirstPage = _mobileTxPage <= 0;
                                var isLastPage = _mobileTxPage >= totalPages - 1;
                                <div class="d-flex gap-1">
                                    <MudIconButton Icon="@Icons.Material.Filled.FirstPage" Size="Size.Small"
                                                   Disabled="@isFirstPage"
                                                   OnClick="@(() => { _mobileTxPage = 0; })"
                                                   Style="width:24px;height:24px;" />
                                    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small"
                                                   Disabled="@isFirstPage"
                                                   OnClick="@(() => { if (_mobileTxPage > 0) { _mobileTxPage--; } })"
                                                   Style="width:24px;height:24px;" />
                                    <MudText Typo="Typo.caption" Style="font-size:0.5rem; opacity:0.5; align-self:center;">
                                        @(_mobileTxPage + 1) / @totalPages
                                    </MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"
                                                   Disabled="@isLastPage"
                                                   OnClick="@(() => { if (_mobileTxPage < totalPages - 1) { _mobileTxPage++; } })"
                                                   Style="width:24px;height:24px;" />
                                    <MudIconButton Icon="@Icons.Material.Filled.LastPage" Size="Size.Small"
                                                   Disabled="@isLastPage"
                                                   OnClick="@(() => { _mobileTxPage = totalPages - 1; })"
                                                   Style="width:24px;height:24px;" />
                                </div>
                            }
                        </div>

                        @* ── Mobile transaction cards ── *@
                        @foreach (var tx in pagedItems)
                        {
                            var isCredit = tx.Amount > 0;
                            var isDebit = tx.Amount < 0;
                            var creditClass = isCredit ? "credit" : (isDebit ? "debit" : "neutral");
                            var displayTime = (tx.ActionDate ?? tx.Date).ToLocalTime();
                            <div class="fmc-tx-card" @onclick="() => OpenTransactionDialog(tx)">
                                <div class="fmc-tx-card-top">
                                    <div class="fmc-tx-card-date">
                                        <span class="fmc-tx-card-date-text">@displayTime.ToString("MMM dd, yyyy")</span>
                                        <span class="fmc-tx-card-time-text">@displayTime.ToString("HH:mm:ss")</span>
                                    </div>
                                    <span class="fmc-tx-card-status-tag @tx.Status.ToLower()">
                                        <MudIcon Icon="@GetStatusIcon(tx.Status)" Size="Size.Small" Style="font-size:0.6rem;" />
                                        <span>@tx.Status.ToUpper()</span>
                                    </span>
                                </div>
                                <div class="fmc-tx-card-body">
                                    <div class="fmc-tx-card-subscriber">
                                        @if (tx.SubTransactions?.Any() == true || tx.AccountNumber == "BATCH_SUMMARY")
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Layers" Size="Size.Small" Color="Color.Info" Style="font-size:0.75rem;margin-right:4px;" />
                                        }
                                        <span class="fmc-tx-card-subscriber-text">@tx.Subscriber</span>
                                        <span class="fmc-tx-card-cat-tag">@tx.Category.ToUpper()</span>
                                    </div>
                                    @{
                                        var acc = tx.AccountNumber;
                                        if (string.IsNullOrEmpty(acc) || acc == "N/A")
                                        {
                                            var subscriberName = tx.Subscriber?.Replace(" (Bulk)", "");
                                            var u = _allUsers.FirstOrDefault(x => x.DisplayName.Equals(subscriberName, StringComparison.OrdinalIgnoreCase)
                                                                               || x.UserName?.Equals(subscriberName, StringComparison.OrdinalIgnoreCase) == true);
                                            if (u != null) acc = u.AccountNumber;
                                        }
                                    }
                                    @if (!string.IsNullOrEmpty(acc))
                                    {
                                        <div class="fmc-tx-card-account">@(acc == "BATCH_SUMMARY" ? "BATCH FORENSIC SUMMARY" : GetMaskedAccount(acc))</div>
                                    }
                                </div>
                                <div class="fmc-tx-card-footer @creditClass">
                                    <span class="fmc-tx-card-amount">@(tx.Amount > 0 ? "+" : "")@tx.Amount.ToString("C2")</span>
                                    <span class="fmc-tx-card-amount-label">AMOUNT</span>
                                </div>
                            </div>
                        }

                        @* ── End-of-stream marker when on the last page ── *@
                        @if (totalItems > 0 && ps > 0 && (_mobileTxPage + 1) * ps >= totalItems)
                        {
                            <div class="d-flex align-center justify-center gap-3 my-4" style="opacity:0.5;">
                                <div style="flex:1; height:1px; background: linear-gradient(90deg, transparent, var(--mud-palette-divider), transparent); max-width:100px;"></div>
                                <MudText Typo="Typo.caption" Style="font-family:'JetBrains Mono',monospace; font-size:0.55rem; font-weight:950; letter-spacing:0.3em;">END OF FORENSIC AUDIT STREAM</MudText>
                                <div style="flex:1; height:1px; background: linear-gradient(90deg, transparent, var(--mud-palette-divider), transparent); max-width:100px;"></div>
                            </div>
                        }

                        @* ── Bottom pagination: first | prev | page count | next | last ── *@
                        if (totalItems > ps)
                        {
                            var isFirstPage = _mobileTxPage <= 0;
                            var isLastPage = _mobileTxPage >= totalPages - 1;
                            <div class="d-flex justify-center align-center gap-2 mt-3">
                                <MudIconButton Icon="@Icons.Material.Filled.FirstPage" Disabled="@isFirstPage"
                                               OnClick="@(() => { _mobileTxPage = 0; })"
                                               Variant="Variant.Outlined" Size="Size.Small" />
                                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Disabled="@isFirstPage"
                                               OnClick="@(() => { if (_mobileTxPage > 0) { _mobileTxPage--; } })"
                                               Variant="Variant.Outlined" Size="Size.Small" />
                                <MudText Typo="Typo.caption" Style="font-size:0.6rem; font-weight:800;">@(_mobileTxPage + 1) / @totalPages</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Disabled="@isLastPage"
                                               OnClick="@(() => { if (_mobileTxPage < totalPages - 1) { _mobileTxPage++; } })"
                                               Variant="Variant.Outlined" Size="Size.Small" />
                                <MudIconButton Icon="@Icons.Material.Filled.LastPage" Disabled="@isLastPage"
                                               OnClick="@(() => { _mobileTxPage = totalPages - 1; })"
                                               Variant="Variant.Outlined" Size="Size.Small" />
                            </div>
                        }
                    }
                    else
                    {
                        @* ── Premium animated empty state when no results ── *@
                        <div class="fmc-empty-state premium-empty-state pa-6 d-flex flex-column align-center justify-center">
                            <div class="fmc-empty-glow"></div>
                            <div class="fmc-scanner-container mb-3">
                                <div class="fmc-scanner-ring ring-1"></div>
                                <div class="fmc-scanner-ring ring-2"></div>
                                <div class="fmc-scanner-line"></div>
                                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Class="fmc-premium-empty-icon" />
                            </div>
                            <MudText Typo="Typo.h6" Class="fmc-empty-title fmc-gradient-text" Style="font-weight: 900; letter-spacing: -0.02em;">No Matching Forensic Traces</MudText>
                            <MudText Typo="Typo.body2" Class="fmc-empty-subtitle mt-2">Your tactical query did not yield any results in the current stream.</MudText>
                        </div>
                    }
                }
            </div>
        }
    </MudPaper>
</MudContainer>
</div>

@* ══════════════════════════════════════════════════════════════════════
   CODE-BEHIND
   ════════════════════════════════════════════════════════════════════ *@
@code {

    /* ── Private State ── */
    private MudTable<TransactionDto> _table = default!;
    private List<TransactionDto> _transactions = new();
    private string _searchString = "";
    private TransactionDto? _selectedItem;

    /* ── Dependency Injection ── */
    [Inject] private ApiFinanceService FinanceService { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private ICurrentUserService CurrentUserService { get; set; } = default!;
    [Inject] private AdminService AdminService { get; set; } = default!;

    /* ── IBrowserViewportObserver ── */
    Guid IBrowserViewportObserver.Id { get; } = Guid.NewGuid();

    private bool _loading = true;
    private bool _isMobile;
    private MudBlazor.Breakpoint _breakpoint;
    private List<UserDto> _allUsers = new();

    /* ── Mobile pagination state ── */
    private int _mobileTxPage = 0;
    private int _mobileTxPageSize = 10;

    /* ── Lifecycle ── */

    protected override async Task OnInitializedAsync()
    {
        if (!RendererInfo.IsInteractive) return;
        try {
            _allUsers = await AdminService.GetUsersAsync();
        } catch { }
        await LoadTransactions();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _breakpoint = await BrowserViewportService.GetCurrentBreakpointAsync();
            await BrowserViewportService.SubscribeAsync(this);
            _isMobile = _breakpoint <= MudBlazor.Breakpoint.Sm;
            StateHasChanged();
        }
    }

    public async Task NotifyBrowserViewportChangeAsync(BrowserViewportEventArgs args)
    {
        _breakpoint = args.Breakpoint;
        _isMobile = _breakpoint <= MudBlazor.Breakpoint.Sm;
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        await BrowserViewportService.UnsubscribeAsync(this);
    }

    /* ── Data Loading ── */

    /// <summary>
    /// Fetches recent transactions from the API, groups bulk allotments by batch,
    /// and applies the temporal filter.
    /// </summary>
    private async Task LoadTransactions()
    {
        try
        {
            _loading = true;
            var raw = await FinanceService.GetRecentTransactionsAsync(200);
            
            // ── AGGREGATION LOGIC ──
            // Group by BatchId (if present) or by matching timestamps for "Bulk Allotment" items.
            // Each group is collapsed into a single summary row with summed Amount and a derived Status.
            var processed = new List<TransactionDto>();

            var bulkGroups = raw
                .Where(t => (t.BatchId.HasValue && t.BatchId != Guid.Empty) || t.Category.Equals("Bulk Allotment", StringComparison.OrdinalIgnoreCase))
                .GroupBy(t => new { 
                    BatchId = t.BatchId ?? Guid.Empty, 
                    t.Date,
                    IsBulk = t.Category.Equals("Bulk Allotment", StringComparison.OrdinalIgnoreCase)
                });

            var individuals = raw.Where(t => !t.BatchId.HasValue && !t.Category.Equals("Bulk Allotment", StringComparison.OrdinalIgnoreCase));

            foreach (var group in bulkGroups)
            {
                var rep = group.OrderByDescending(x => x.ActionDate ?? x.Date).First();
                var count = group.Count();
                var allStatuses = group.Select(b => b.Status).Distinct().ToList();
                var batchStatus = allStatuses.Count == 1
                    ? allStatuses[0]
                    : group.All(b => b.Status == "Approved") ? "Approved"
                    : group.All(b => b.Status == "Rejected") ? "Rejected"
                    : group.Any(b => b.Status == "Pending")  ? "Pending"
                    : "Mixed";

                processed.Add(new TransactionDto
                {
                    Id             = rep.Id,
                    BatchId        = rep.BatchId,
                    Date           = group.Key.Date,
                    Amount         = group.Sum(x => x.Amount),
                    Category       = "Bulk Allotment",
                    Subscriber     = count == 1 && string.IsNullOrEmpty(rep.Subscriber) == false
                                        ? $"{rep.Subscriber} (Bulk)"
                                        : $"{count} Cardholders (Bulk)",
                    Label          = rep.Label,
                    MakerName      = rep.MakerName,
                    MakerId        = rep.MakerId,
                    ApproverName   = rep.ApproverName,
                    Status         = batchStatus,
                    OrganizationId = rep.OrganizationId,
                    AccountNumber  = "BATCH_SUMMARY",
                    SubTransactions = group.ToList(),
                    ActionDate     = rep.ActionDate,
                    RejectionReason = rep.RejectionReason
                });
            }

            processed.AddRange(individuals);
            _transactions = processed.OrderByDescending(t => t.ActionDate ?? t.Date).ToList();
            
            ApplyTemporalFilter();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading transactions: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnSelectedItemChanged(TransactionDto? item)
    {
        _selectedItem = item;
    }

    /* ── Date Filtering ── */

    private string _activeDateRange = "all";
    private DateTime? _startDate;
    private DateTime? _endDate;
    private List<TransactionDto> _allTransactions = new();

    /// <summary>
    /// Sets a quick date range (Today, 7D, 30D, 1Y, All) and re-applies the filter.
    /// </summary>
    private void SetQuickDate(string range)
    {
        _activeDateRange = range;
        _mobileTxPage = 0;
        var today = DateTime.Today;
        
        switch (range)
        {
            case "today":
                _startDate = today;
                _endDate = today.AddDays(1).AddTicks(-1);
                break;
            case "7d":
                _startDate = today.AddDays(-7);
                _endDate = today.AddDays(1).AddTicks(-1);
                break;
            case "30d":
                _startDate = today.AddDays(-30);
                _endDate = today.AddDays(1).AddTicks(-1);
                break;
            case "1y":
                _startDate = today.AddYears(-1);
                _endDate = today.AddDays(1).AddTicks(-1);
                break;
            default:
                _startDate = null;
                _endDate = null;
                break;
        }
        ApplyTemporalFilter();
    }

    /// <summary>
    /// Updates the start or end date from the date inputs.
    /// </summary>
    private void UpdateDate(ChangeEventArgs e, bool isStart)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
        {
            if (isStart) _startDate = dt;
            else _endDate = dt.AddDays(1).AddTicks(-1);
            _activeDateRange = "custom";
            _mobileTxPage = 0;
            ApplyTemporalFilter();
        }
    }

    /* ── Search ── */

    private void OnSearchChanged(ChangeEventArgs e)
    {
        _searchString = e.Value?.ToString() ?? "";
        _mobileTxPage = 0;
    }

    /* ── Filtering ── */

    /// <summary>
    /// Placeholder — currently all data is loaded client-side.
    /// In production this would trigger an API call with date parameters.
    /// </summary>
    private void ApplyTemporalFilter()
    {
    }

    /// <summary>
    /// Combined filter: date range + search string.
    /// Used by MudTable (FilterFunc1) and mobile card list.
    /// </summary>
    private bool FilterFunc1(TransactionDto? transaction) 
    {
        if (transaction == null) return false;
        
        var effectiveDate = transaction.ActionDate ?? transaction.Date;
        if (_startDate.HasValue && effectiveDate < _startDate.Value) return false;
        if (_endDate.HasValue && effectiveDate > _endDate.Value) return false;

        return FilterFunc(transaction, _searchString);
    }

    /// <summary>
    /// Text search filter — matches Subscriber, Category, or Status.
    /// </summary>
    private bool FilterFunc(TransactionDto transaction, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (transaction.Subscriber.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (transaction.Category.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (transaction.Status.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    /* ── Dialogs ── */

    private async Task OpenAddDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<AddTransactionDialog>("Add Transaction", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is TransactionDto newTransaction)
        {
            await FinanceService.AddTransactionAsync(newTransaction);
            await LoadTransactions();
            Snackbar.Add("Transaction added successfully", Severity.Success);
        }
    }

    /* ── Export Helpers ── */

    /// <summary>
    /// Builds a human-readable filter summary string for the export file metadata.
    /// </summary>
    private string GetActiveFilterString()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(_searchString)) parts.Add($"Query: '{_searchString.Trim()}'");
        if (_startDate.HasValue || _endDate.HasValue)
        {
            var startStr = _startDate?.ToString("MM/dd/yyyy") ?? "Any";
            var endStr = _endDate?.ToString("MM/dd/yyyy") ?? "Any";
            parts.Add($"Date: {startStr} to {endStr}");
        }
        else
        {
            parts.Add("Date: ALL");
        }
        return string.Join(" | ", parts);
    }

    private async Task ExportExcel()
    {
        var filteredData = _table?.FilteredItems?.ToList() ?? _transactions.Where(FilterFunc1).ToList();
        if (!filteredData.Any()) return;
        var bytes = ReportService.GenerateExcel("Fiscal Transaction Ledger", filteredData, GetActiveFilterString());
        await DownloadFile("Transactions.xlsx", bytes, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private async Task ExportPdf()
    {
        var filteredData = _table?.FilteredItems?.ToList() ?? _transactions.Where(FilterFunc1).ToList();
        if (!filteredData.Any()) return;
        var bytes = ReportService.GeneratePdf("Forensic Settlement History", filteredData, GetActiveFilterString());
        await DownloadFile("Transactions.pdf", bytes, "application/pdf");
    }

    private async Task DownloadFile(string fileName, byte[] content, string contentType)
    {
        using var streamRef = new DotNetStreamReference(new MemoryStream(content));
        await JS.InvokeVoidAsync("fmc_downloadFile", fileName, contentType, streamRef);
    }

    /* ── Utility ── */

    private string GetStatusIcon(string status) => status?.ToLower() switch
    {
        "successful" or "approved" or "completed" => Icons.Material.Filled.CheckCircle,
        "pending" => Icons.Material.Filled.AccessTimeFilled,
        "mixed" => Icons.Material.Filled.Flaky,
        "error" or "failed" or "rejected" => Icons.Material.Filled.Error,
        "cancelled" => Icons.Material.Filled.Cancel,
        _ => Icons.Material.Filled.Help
    };

    /// <summary>
    /// Masks the middle digits of an account number for display:
    /// "123456******7890"
    /// </summary>
    private string GetMaskedAccount(string? acc)
    {
        if (string.IsNullOrEmpty(acc) || acc == "BATCH_SUMMARY") return acc == "BATCH_SUMMARY" ? "BATCH SUMMARY" : "N/A";
        if (acc.Length < 10) return acc;
        return $"{acc.Substring(0, 6)}******{acc.Substring(acc.Length - 4)}";
    }

    /* ── Row Interaction ── */

    private async Task OpenTransactionDialog(TransactionDto transaction)
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var parameters = new DialogParameters<PendingDetailDialog>
        {
            { x => x.Transaction, transaction },
            { x => x.IsOwnTransaction, transaction.MakerId == CurrentUserService.UserId }
        };

        var dialog = await DialogService.ShowAsync<PendingDetailDialog>("Forensic Audit Investigation", parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
        {
            await LoadTransactions();
        }
    }

    private async Task OnRowClick(TableRowClickEventArgs<TransactionDto> args)
    {
        await OpenTransactionDialog(args.Item!);
    }

    /* ── Injected Services ── */
    [Inject] private IReportService ReportService { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
}
