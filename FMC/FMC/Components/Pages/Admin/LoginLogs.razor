@page "/admin/login-logs"
@using FMC.Shared.Auth
@using FMC.Shared.DTOs.Admin
@using FMC.Services.Api
@attribute [Authorize(Roles = Roles.SuperAdmin)]
@inject AdminService AdminService
@inject ISnackbar Snackbar

<PageTitle>Login Logs - FMC</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <div class="mb-8">
        <MudText Typo="Typo.h4" Style="font-weight: 800; letter-spacing: -0.02em;">Security Logs</MudText>
        <MudText Typo="Typo.body1" Class="mud-text-secondary">Track user access and authentication events</MudText>
    </div>

    <MudPaper Elevation="0" Class="pa-6 d-none d-md-block" Style="border-radius: 16px; border: 1px solid var(--mud-palette-divider); background: var(--mud-palette-surface);">
        <MudDataGrid @ref="_grid" Items="@_logs" Loading="@_loading" Hover="true" Bordered="false" Striped="false" 
                      Filterable="true" SortMode="SortMode.Multiple" Groupable="true" DragDropColumnReordering="true" ColumnResizeMode="ResizeMode.None"
                      ShowColumnOptions="true" Elevation="0" T="AuditLogDto" Class="fmc-admin-grid">
            <ToolBarContent>
                <MudText Typo="Typo.h6" Style="font-weight: 600;">System Logs</MudText>
                <MudSpacer />
                <MudSelect T="string" Label="Group Events By" @bind-Value="_currentGroup" @bind-Value:after="StateHasChanged"
                            Variant="Variant.Outlined" Margin="Margin.Dense" Class="max-width: 200px;">
                    <MudSelectItem Value="@((string)null)">No Grouping</MudSelectItem>
                    <MudSelectItem Value="@("UserName")">Username</MudSelectItem>
                    <MudSelectItem Value="@("Organization")">Organization</MudSelectItem>
                    <MudSelectItem Value="@("Action")">Event Type</MudSelectItem>
                    <MudSelectItem Value="@("CreatedDate")">Day</MudSelectItem>
                </MudSelect>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadLogsAsync" />
                <MudMenu Icon="@Icons.Material.Filled.ViewColumn" IconColor="Color.Primary" Class="ml-2" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" AriaLabel="Column Visibility Menu">
                    <div class="px-4 py-2">
                        <MudText Typo="Typo.subtitle2" Style="font-weight: 800; color: var(--mud-palette-primary)">DISPLAY COLUMNS</MudText>
                    </div>
                    <MudDivider />
                    @if (_grid != null)
                    {
                        @foreach (var col in _grid.RenderedColumns.Where(x => !string.IsNullOrWhiteSpace(x.Title) && !x.Title.Contains("[System]")))
                        {
                            <MudMenuItem AutoClose="false" OnClick="@(() => { col.SetState(x => x.Hidden, !col.GetState(x => x.Hidden)); StateHasChanged(); })">
                                <div class="d-flex align-center cursor-pointer">
                                    <MudCheckBox T="bool" Value="@(!col.GetState(x => x.Hidden))" Color="Color.Primary" Dense="true" Size="Size.Small" ReadOnly="true" />
                                    <MudText Typo="Typo.body2" Class="ml-2">@col.Title</MudText>
                                </div>
                            </MudMenuItem>
                        }
                    }
                </MudMenu>
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="x => x.CreatedAt.ToLocalTime()" Title="Timestamp" Format="yyyy-MM-dd HH:mm:ss" Sortable="true" Groupable="false" Hideable="false" Resizable="true" />
                <PropertyColumn Property="x => x.UserName" Title="Username" Grouping="@(_currentGroup == "UserName")" Hideable="false" Resizable="true" />
                <PropertyColumn Property="x => x.Organization" Title="Organization" Grouping="@(_currentGroup == "Organization")" Hideable="true" Resizable="true" />
                <PropertyColumn Property="x => x.IpAddress" Title="IP Address" Groupable="false" Hideable="true" Resizable="true" />
                <TemplateColumn Title="Device" SortBy="@(x => x.Device)" Sortable="true" Filterable="true" Hideable="false" Resizable="true">
                    <CellTemplate>
                        <MudTooltip Text="@context.Item.Device" Arrow="true" Placement="Placement.Top">
                            <div class="d-flex align-center">
                                <MudIcon Icon="@GetDeviceIcon(context.Item.Device)" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">@GetDeviceName(context.Item.Device)</MudText>
                            </div>
                        </MudTooltip>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.CreatedAt.Date" Title="[System] Day" Hidden="true" Grouping="@(_currentGroup == "CreatedDate")" Hideable="true" Resizable="true" />
                <TemplateColumn Title="Event" SortBy="@(x => x.Action)" Sortable="true" Filterable="true" Grouping="@(_currentGroup == "Action")" Hideable="false" Resizable="true">
                    <CellTemplate>
                        @GetEventChip(context.Item.Action)
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Additional Details" SortBy="@(x => x.Details)" Sortable="true" Filterable="true" Hideable="true" Resizable="true">
                    <CellTemplate>
                        <MudTooltip Text="@context.Item.Details">
                            <MudText Typo="Typo.body2" Style="max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; cursor: pointer;" Class="mud-text-secondary">
                                @context.Item.Details
                            </MudText>
                        </MudTooltip>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="AuditLogDto" />
            </PagerContent>
        </MudDataGrid>
    </MudPaper>

    <!-- Mobile-Optimized Card View -->
    <div class="d-block d-md-none">
        <div class="d-flex flex-column gap-4 mb-4">
            <div class="d-flex align-center">
                 <MudText Typo="Typo.h6" Style="font-weight: 700;">Auth History</MudText>
                 <MudSpacer />
                 <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadLogsAsync" Size="Size.Small" />
            </div>
            
            <MudTextField @bind-Value="_searchString" Placeholder="Search Logs..." Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Small" 
                          Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Immediate="true" />
            
            <div class="d-flex gap-2">
                <MudSelect T="String" Label="Sort/Group" Value="@_currentGroup" ValueChanged="OnGroupChanged" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined">
                    <MudSelectItem Value="@("")">Default</MudSelectItem>
                    <MudSelectItem Value="@("UserName")">By User</MudSelectItem>
                    <MudSelectItem Value="@("Action")">By Event Type</MudSelectItem>
                </MudSelect>
                 <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Text" OnClick="LoadLogsAsync">Latest</MudChip>
            </div>
        </div>
        
        @if (_loading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (!FilteredLogs.Any())
        {
            <div class="pa-10 text-center">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Default" Size="Size.Large" Class="mb-4" />
                <MudText Typo="Typo.body1" Class="mud-text-secondary">No logs match your search.</MudText>
            </div>
        }
        else
        {
            @foreach (var log in FilteredLogs)
            {
                <MudCard Elevation="0" Class="mb-4" Style="border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
                    <MudCardHeader Class="pa-3" Style="border-bottom: 1px solid var(--mud-palette-divider);">
                        <CardHeaderContent>
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@log.CreatedAt.ToLocalTime().ToString("MMM dd, HH:mm:ss")</MudText>
                                @GetEventChip(log.Action)
                            </div>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-3">
                        <div class="grid-pair mb-2">
                             <MudText Typo="Typo.caption" Class="label">User:</MudText>
                             <MudText Typo="MudBlazor.Typo.body2" Style="font-weight: 600;">@log.UserName</MudText>
                        </div>
                        <div class="grid-pair mb-2">
                             <MudText Typo="Typo.caption" Class="label">Org:</MudText>
                             <MudText Typo="MudBlazor.Typo.body2">@log.Organization</MudText>
                        </div>
                        <div class="grid-pair mb-2">
                             <MudText Typo="Typo.caption" Class="label">Device:</MudText>
                             <div class="d-flex align-center">
                                 <MudIcon Icon="@GetDeviceIcon(log.Device)" Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Primary" Class="mr-1" Style="font-size: 0.9rem;" />
                                 <MudText Typo="Typo.caption">@GetDeviceName(log.Device)</MudText>
                             </div>
                        </div>
                        <div class="grid-pair mb-2">
                             <MudText Typo="Typo.caption" Class="label">IP:</MudText>
                             <MudText Typo="Typo.body2">@log.IpAddress</MudText>
                        </div>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mt-2">@log.Details</MudText>
                    </MudCardContent>
                </MudCard>
            }
        }
    </div>
</MudContainer>

<style>
    .fmc-admin-grid { width: 100% !important; }
    .fmc-admin-grid .mud-table-head { background-color: var(--mud-palette-background-grey); }
    .fmc-admin-grid .mud-table-row:hover { background-color: var(--mud-palette-action-hover) !important; }

    /* Mobile specific styles */
    .grid-pair { display: grid; grid-template-columns: 70px 1fr; align-items: center; }
    .label { font-weight: 700; color: var(--mud-palette-text-disabled); text-transform: uppercase; letter-spacing: 0.05em; }
</style>

@code {
    private MudDataGrid<AuditLogDto> _grid = default!;
    private List<AuditLogDto> _logs = new();
    private bool _loading = true;
    private string _currentGroup = "";
    private string _searchString = "";

    private IEnumerable<AuditLogDto> FilteredLogs
    {
        get
        {
            var query = _logs.AsEnumerable();
            
            if (!string.IsNullOrWhiteSpace(_searchString))
            {
                query = query.Where(x => 
                    (x.UserName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (x.Action?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (x.IpAddress?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (x.Details?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
                );
            }

            // Apply manual sorting/grouping for mobile view if needed
            if (_currentGroup == "UserName") query = query.OrderBy(x => x.UserName).ThenByDescending(x => x.CreatedAt);
            else if (_currentGroup == "Organization") query = query.OrderBy(x => x.Organization).ThenByDescending(x => x.CreatedAt);
            else if (_currentGroup == "Action") query = query.OrderBy(x => x.Action).ThenByDescending(x => x.CreatedAt);
            else query = query.OrderByDescending(x => x.CreatedAt);

            return query;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadLogsAsync();
    }

    private void OnGroupChanged(string value)
    {
        _currentGroup = value;
        // The MudDataGrid will automatically react if we bind Grouping to columns
    }

    private async Task LoadLogsAsync()
    {
        try
        {
            _loading = true;
            _logs = await AdminService.GetAuthLogsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading logs: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private RenderFragment GetEventChip(string action) => __builder => {
        switch (action)
        {
            case "Login Success":
                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text">Login Success</MudChip>
                break;
            case "Login Failed":
                <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text">Login Failed</MudChip>
                break;
            case "Logout":
                <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Text">Logout</MudChip>
                break;
            case "Password Reset":
                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Text">Password Reset</MudChip>
                break;
            case "Password Changed":
                 <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Text">Password Changed</MudChip>
                 break;
            case "Registration":
                <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">Registration</MudChip>
                break;
            default:
                <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Text">@action</MudChip>
                break;
        }
    };

    private string GetDeviceName(string? ua)
    {
        if (string.IsNullOrEmpty(ua)) return "System/Internal";
        
        // If it was already resolved (e.g. "MY-LAPTOP-PC") or contains No Mozilla signatures
        if (!ua.Contains("Mozilla/", StringComparison.OrdinalIgnoreCase) && !ua.Contains("Postman", StringComparison.OrdinalIgnoreCase)) 
        {
            return ua;
        }

        string os = "Other OS";
        if (ua.Contains("Windows NT 10.0", StringComparison.OrdinalIgnoreCase)) os = "Windows 10/11";
        else if (ua.Contains("Windows NT 6.3", StringComparison.OrdinalIgnoreCase)) os = "Windows 8.1";
        else if (ua.Contains("Windows NT 6.2", StringComparison.OrdinalIgnoreCase)) os = "Windows 8";
        else if (ua.Contains("Windows NT 6.1", StringComparison.OrdinalIgnoreCase)) os = "Windows 7";
        else if (ua.Contains("Android", StringComparison.OrdinalIgnoreCase)) os = "Android";
        else if (ua.Contains("iPhone", StringComparison.OrdinalIgnoreCase)) os = "iOS (iPhone)";
        else if (ua.Contains("iPad", StringComparison.OrdinalIgnoreCase)) os = "iOS (iPad)";
        else if (ua.Contains("Macintosh", StringComparison.OrdinalIgnoreCase)) os = "macOS";
        else if (ua.Contains("Linux", StringComparison.OrdinalIgnoreCase)) os = "Linux";

        string browser = "Browser";
        if (ua.Contains("Edg/", StringComparison.OrdinalIgnoreCase)) browser = "MS Edge";
        else if (ua.Contains("Chrome/", StringComparison.OrdinalIgnoreCase)) browser = "Chrome";
        else if (ua.Contains("Firefox/", StringComparison.OrdinalIgnoreCase)) browser = "Firefox";
        else if (ua.Contains("Safari/", StringComparison.OrdinalIgnoreCase) && !ua.Contains("Chrome", StringComparison.OrdinalIgnoreCase)) browser = "Safari";
        else if (ua.Contains("Postman", StringComparison.OrdinalIgnoreCase)) browser = "Postman";

        return $"{browser} on {os}";
    }

    private string GetDeviceIcon(string? ua)
    {
        if (string.IsNullOrEmpty(ua)) return Icons.Material.Filled.Settings;
        if (ua.Contains("Windows NT", StringComparison.OrdinalIgnoreCase)) return Icons.Material.Filled.DesktopWindows;
        if (ua.Contains("iPhone", StringComparison.OrdinalIgnoreCase) || ua.Contains("iPad", StringComparison.OrdinalIgnoreCase)) return Icons.Material.Filled.Smartphone;
        if (ua.Contains("Android", StringComparison.OrdinalIgnoreCase)) return Icons.Material.Filled.PhoneAndroid;
        if (ua.Contains("Macintosh", StringComparison.OrdinalIgnoreCase)) return Icons.Material.Filled.DesktopMac;
        if (ua.Contains("Linux", StringComparison.OrdinalIgnoreCase)) return Icons.Custom.Brands.Linux;
        if (ua.Contains("Postman", StringComparison.OrdinalIgnoreCase)) return Icons.Material.Filled.Dns;
        return Icons.Material.Filled.Devices;
    }
}
