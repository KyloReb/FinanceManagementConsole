@code {
    private bool _loading = true;
    private bool _auditLoading = true;
    private bool _isCeo;
    private bool _isSuperAdmin;
    private List<OrganizationDto> _organizations = new();
    private List<UserDto> _users = new();
    private List<AuditLogDto> _auditLogs = new();
    private int _auditLogLimit = 20;
    
    // Legacy metrics
    private decimal _totalBalance = 0;
    private decimal _monthlyExpenses = 0;
    private int _activeBudgetsCount = 0;
    private List<TransactionDto> _recentTransactions = new();
    private double[] _chartData = Array.Empty<double>();
    private string[] _chartLabels = Array.Empty<string>();
    private List<ChartSeries<double>> _donutSeries = new();

    // SuperAdmin Chart Data
    private List<ChartSeries<double>> _lineChartSeries = new();
    private string[] _lineChartLabels = Array.Empty<string>();
    private ChartOptions _lineChartOptions = new() { 
        ChartPalette = new[] { "#2ecc71", "#e74c3c" }
    };
    private string _selectedTimeframe = "Daily";

    [Inject] private ApiFinanceService FinanceService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        if (!RendererInfo.IsInteractive) return;
        try 
        {
            _loading = true;
            
            // 1. Check Role
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            _isCeo = user.IsInRole(Roles.CEO);
            _isSuperAdmin = user.IsInRole(Roles.SuperAdmin);
            
            if (_isSuperAdmin || _isCeo || user.IsInRole(Roles.Maker) || user.IsInRole(Roles.Approver))
            {
                // Security: Organization-bound roles see their own organization, SuperAdmins see all.
                if (!user.IsInRole(Roles.SuperAdmin))
                {
                    var orgIdClaim = user.FindFirst("OrganizationId")?.Value;
                    if (Guid.TryParse(orgIdClaim, out var orgId))
                    {
                        var orgTask = OrgService.GetByIdAsync(orgId);
                        var usersTask = OrgService.GetUsersAsync(orgId);
                        var auditTask = OrgService.GetRecentAuditLogsAsync(_auditLogLimit, "financial");
                        
                        await Task.WhenAll(orgTask, usersTask, auditTask);
                        
                        var org = await orgTask;
                        if (org != null) 
                        {
                            _organizations = new List<OrganizationDto> { org };
                            _totalBalance = org.TotalBalance;
                        }
                        
                        _users = (await usersTask).ToList();
                        _auditLogs = (await auditTask).ToList();
                    }
                }
                else // SuperAdmin
                {
                    var orgsTask = OrgService.GetOrganizationsAsync();
                    var auditTask = OrgService.GetRecentAuditLogsAsync(_auditLogLimit, "financial");
                    
                    await Task.WhenAll(orgsTask, auditTask);
                    
                    _organizations = (await orgsTask).ToList();
                    _auditLogs = (await auditTask).ToList();
                }
                
                // Process chart data
                PrepareLineChartData();
                
                _auditLoading = false;
            }
            else 
            {
                // Load Standard Dashboard
                _totalBalance = await FinanceService.GetTotalBalanceAsync();
                _monthlyExpenses = await FinanceService.GetMonthlyExpensesAsync();
                var budgets = await FinanceService.GetAccountsAsync();
                _activeBudgetsCount = budgets.Count;
                _recentTransactions = await FinanceService.GetRecentTransactionsAsync(5);

                var groupedData = _recentTransactions
                    .Where(t => t.Amount < 0)
                    .GroupBy(t => t.Category)
                    .Select(g => new { Category = g.Key, Amount = (double)Math.Abs(g.Sum(t => t.Amount)) })
                    .ToList();

                _chartData = groupedData.Select(d => d.Amount).ToArray();
                _chartLabels = groupedData.Select(d => d.Category).ToArray();
                _donutSeries = new List<ChartSeries<double>> { new ChartSeries<double> { Name = "Allocation", Data = _chartData } };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Dashboard Load Failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshDashboard()
    {
        await OnInitializedAsync();
    }

    private async Task ChangeTimeframe(string timeframe)
    {
        _selectedTimeframe = timeframe;
        PrepareLineChartData();
        StateHasChanged();
    }

    private async Task OnAuditLogLimitChanged(int newLimit)
    {
        _auditLogLimit = newLimit;
        _auditLoading = true;
        StateHasChanged(); 
        
        var auditLogs = await OrgService.GetRecentAuditLogsAsync(_auditLogLimit, "financial");
        _auditLogs = auditLogs.ToList();
        
        PrepareLineChartData();
        
        _auditLoading = false;
        StateHasChanged();
    }

    [Inject] private OrganizationApiService OrgService { get; set; } = default!;
      private void PrepareLineChartData()
    {
        _lineChartSeries.Clear();
        int count = _selectedTimeframe switch { "Daily" => 14, "Monthly" => 12, "Quarterly" => 8, "Yearly" => 5, _ => 14 };
        DateTime now = DateTime.Today;
        
        var timeSlices = new List<(DateTime start, DateTime end, string label)>();
        for (int i = 0; i < count; i++)
        {
            DateTime start, end;
            string label;

            if (_selectedTimeframe == "Daily")
            {
                start = now.AddDays(-(count - 1 - i));
                end = start.AddDays(1);
                label = start.ToString("MMM dd");
            }
            else if (_selectedTimeframe == "Monthly")
            {
                start = new DateTime(now.Year, now.Month, 1).AddMonths(-(count - 1 - i));
                end = start.AddMonths(1);
                label = start.ToString("MMM");
            }
            else if (_selectedTimeframe == "Quarterly")
            {
                DateTime currentQuarterStart = new DateTime(now.Year, ((now.Month - 1) / 3) * 3 + 1, 1);
                start = currentQuarterStart.AddMonths(-(count - 1 - i) * 3);
                end = start.AddMonths(3);
                label = $"Q{((start.Month - 1) / 3) + 1} '{start.ToString("yy")}";
            }
            else // Yearly
            {
                start = new DateTime(now.Year, 1, 1).AddYears(-(count - 1 - i));
                end = start.AddYears(1);
                label = start.ToString("yyyy");
            }
            timeSlices.Add((start, end, label));
        }

        _lineChartLabels = timeSlices.Select(x => x.label).ToArray();

        // 1. Identify the Top 4 moving tenants in the requested total span
        var firstStart = timeSlices.First().start;
        var relevantLogs = _auditLogs.Where(l => l.CreatedAt >= firstStart).ToList();

        var topTenants = relevantLogs
            .GroupBy(l => string.IsNullOrWhiteSpace(l.EntityName) ? "System" : l.EntityName)
            .Select(g => new { Name = g.Key, Volume = g.Sum(l => Math.Abs(l.Amount ?? 0)) })
            .OrderByDescending(t => t.Volume)
            .Take(4)
            .Select(t => t.Name)
            .ToList();

        var trackedEntities = new List<string>();
        if (_isSuperAdmin)
        {
            trackedEntities.Add("TOTAL SYSTEM");
        }
        trackedEntities.AddRange(topTenants);
        if (_isSuperAdmin)
        {
            trackedEntities.Add("Others");
        }

        foreach (var tenant in trackedEntities)
        {
            var dataPoints = new double[count];
            
            // 2. Identify the current real-time balance for this entity group
            double runningBalance = 0;
            if (tenant == "TOTAL SYSTEM")
            {
                runningBalance = (double)_organizations.Sum(o => o.TotalBalance);
            }
            else if (tenant == "Others")
            {
                runningBalance = (double)_organizations
                    .Where(o => !topTenants.Contains(string.IsNullOrWhiteSpace(o.Name) ? "System" : o.Name))
                    .Sum(o => o.TotalBalance);
            }
            else
            {
                var org = _organizations.FirstOrDefault(o => o.Name == tenant);
                runningBalance = (double)(org?.TotalBalance ?? 0);
            }

            // 3. Trace balance backwards to create a trend.
            // Each dataPoint[i] represents the balance at the END of that timeframe slice.
            for (int i = count - 1; i >= 0; i--)
            {
                dataPoints[i] = runningBalance;
                
                var slice = timeSlices[i];
                var sliceLogs = relevantLogs.Where(l => l.CreatedAt >= slice.start && l.CreatedAt < slice.end);
                
                double sliceMovement = 0;
                if (tenant == "TOTAL SYSTEM")
                {
                    sliceMovement = (double)sliceLogs
                        .Sum(l => l.Action == "DEBIT" ? -(l.Amount ?? 0) : (l.Amount ?? 0));
                }
                else if (tenant == "Others") 
                {
                    sliceMovement = (double)sliceLogs
                        .Where(l => !topTenants.Contains(string.IsNullOrWhiteSpace(l.EntityName) ? "System" : l.EntityName))
                        .Sum(l => l.Action == "DEBIT" ? -(l.Amount ?? 0) : (l.Amount ?? 0));
                }
                else 
                {
                    sliceMovement = (double)sliceLogs
                        .Where(l => (string.IsNullOrWhiteSpace(l.EntityName) ? "System" : l.EntityName) == tenant)
                        .Sum(l => l.Action == "DEBIT" ? -(l.Amount ?? 0) : (l.Amount ?? 0));
                }
                
                // For the prior point in time, remove the movement that happened during this slice.
                runningBalance -= sliceMovement;
            }

            // Bind each resulting line array to its corresponding Tenant Series name to satisfy tooltip requirements intelligently.
            if (dataPoints.Any(d => d != 0) || (tenant == "Others" && _isSuperAdmin)) 
            {
                var shortTenant = tenant.Length > 15 ? tenant.Substring(0, 15) + ".." : tenant;
                _lineChartSeries.Add(new ChartSeries<double> { Name = shortTenant, Data = dataPoints });
            }
        }

        // Apply distinct colors to easily identify disparate top subscribers
        _lineChartOptions = new ChartOptions { 
            ChartPalette = new[] { "#3b82f6", "#10b981", "#f59e0b", "#8b5cf6", "#64748b" }
        };

        // Trigger JS formatting for axis labels
        _ = Task.Delay(50).ContinueWith(_ => JS.InvokeVoidAsync("chartHelper.formatYAxis"));
    }
}
