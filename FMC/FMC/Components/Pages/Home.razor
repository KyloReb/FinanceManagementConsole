@page "/"
@using FMC.Shared.Auth
@using FMC.Shared.DTOs.Organization
@using FMC.Shared.DTOs.User
@using FMC.Shared.DTOs.Admin
@inject AuthenticationStateProvider AuthProvider
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@using FMC.Components.Dashboard

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <AuthorizeView Roles="@(Roles.SuperAdmin + "," + Roles.CEO)">
        <Authorized>
            @* ENTERPRISE COMMAND CENTER HEADER *@
            <MudItem xs="12" sm="8" Class="pb-2">
                <div class="d-flex align-center">
                    <div class="fmc-header-accent mr-5"></div>
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.h3" Class="fmc-hero-text">@(context.User.IsInRole(Roles.CEO) ? "Corporate Dashboard" : "Control Center")</MudText>
                        <MudText Typo="Typo.subtitle1" Class="fmc-subtitle">@(context.User.IsInRole(Roles.CEO) ? "Organization Capital & Workforce Oversight" : "System Health & Multi-Tenant Capital Oversight")</MudText>
                    </div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-center justify-sm-end pb-2">
                <div class="d-flex gap-3 w-100 justify-sm-end">
                    @if (context.User.IsInRole(Roles.SuperAdmin))
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.CloudSync" 
                                   Class="fmc-header-btn secondary d-none d-md-flex">
                            Logs
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Href="/admin/organizations" 
                                   Class="fmc-header-btn primary w-100 w-sm-auto">
                            Provision Tenant
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Business" Href="/ceo/dashboard" 
                                   Class="fmc-header-btn primary w-100 w-sm-auto">
                            Global Overview
                        </MudButton>
                    }
                </div>
            </MudItem>

            <MudGrid Spacing="2" Class="mb-8">
                @* HIGH-LEVEL PERFORMANCE CARDS *@
                @if (context.User.IsInRole(Roles.SuperAdmin))
                {
                    <MudItem xs="6" sm="6" md="3">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">ACTIVE SUBSCRIBERS</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h3" Class="fmc-kpi-val" Style="font-weight: 900; line-height: 1;">@_organizations.Count</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Success" Style="font-weight: 700; margin-bottom: 2px;">+18% WoW</MudText>
                                </div>
                            </div>
                            <div class="fmc-card-icon-bg"><MudIcon Icon="@Icons.Material.Filled.CorporateFare" /></div>
                            <div class="fmc-card-progress primary"></div>
                        </div>
                    </MudItem>
                    <MudItem xs="6" sm="6" md="3">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">AVAILABLE CAPITAL</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h4" Class="fmc-kpi-val fmc-responsive-val">@_organizations.Sum(o => o.TotalBalance).ToString("C0")</MudText>
                                </div>
                            </div>
                            <div class="fmc-card-icon-bg success"><MudIcon Icon="@Icons.Material.Filled.AccountBalance" /></div>
                            <div class="fmc-card-progress success"></div>
                        </div>
                    </MudItem>
                    <MudItem xs="6" sm="6" md="3">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">NETWORK UPTIME</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h3" Class="fmc-kpi-val" Style="font-weight: 900; line-height: 1;">99.9%</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700; margin-bottom: 2px;">SECURE</MudText>
                                </div>
                            </div>
                            <div class="fmc-card-icon-bg info"><MudIcon Icon="@Icons.Material.Filled.FlashOn" /></div>
                            <div class="fmc-card-progress info"></div>
                        </div>
                    </MudItem>
                    <MudItem xs="6" sm="6" md="3">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">LAST RECONCILIATION</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h3" Class="fmc-kpi-val" Style="font-weight: 900; line-height: 1;">@DateTime.Now.ToString("HH:mm")</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700; margin-bottom: 2px;">LIVE</MudText>
                                </div>
                            </div>
                            <div class="fmc-card-icon-bg warning"><MudIcon Icon="@Icons.Material.Filled.ManageHistory" /></div>
                            <div class="fmc-card-progress warning"></div>
                        </div>
                    </MudItem>
                }
                else
                {
                    var ceoOrg = _organizations.FirstOrDefault();
                    var walletBalance = ceoOrg?.WalletLimit ?? (ceoOrg?.TotalBalance ?? 0); // Using TotalBalance safely fallback
                    walletBalance = ceoOrg?.TotalBalance ?? 0; // Total credited 
                    var balanceUsed   = ceoOrg?.Usage ?? 0;
                    var currentBal    = walletBalance - balanceUsed;
                    var usedPct       = walletBalance > 0 ? (balanceUsed / walletBalance) * 100m : 0m;
                    var remainPct     = 100m - usedPct;
                    var balColor      = usedPct >= 80m ? Color.Error : (usedPct >= 60m ? Color.Warning : Color.Success);

                    @* CEO: Wallet Balance — total credited by SuperAdmin *@
                    <MudItem xs="12" sm="4">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">WALLET BALANCE</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h4" Class="fmc-kpi-val fmc-responsive-val">@walletBalance.ToString("C")</MudText>
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:700;">Total credited by admin</MudText>
                            </div>
                            <div class="fmc-card-icon-bg primary"><MudIcon Icon="@Icons.Material.Filled.Wallet" /></div>
                            <div class="fmc-card-progress primary"></div>
                        </div>
                    </MudItem>
                    @* CEO: Current Balance — remaining available *@
                    <MudItem xs="12" sm="4">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">CURRENT BALANCE</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h4" Class="fmc-kpi-val fmc-responsive-val" Color="@balColor">
                                        @currentBal.ToString("C")
                                    </MudText>
                                </div>
                                <div class="d-flex align-center gap-1 mt-1">
                                    <MudProgressLinear Value="@((double)remainPct)" Max="100" Color="@balColor" Rounded="true" Style="height:6px; flex:1;" />
                                    <MudText Typo="Typo.caption" Style="font-weight:900; font-size:0.65rem; white-space:nowrap;">@remainPct.ToString("F0")% left</MudText>
                                </div>
                            </div>
                            <div class="fmc-card-icon-bg success"><MudIcon Icon="@Icons.Material.Filled.AccountBalance" /></div>
                            <div class="fmc-card-progress success"></div>
                        </div>
                    </MudItem>
                    @* CEO: Balance Used — distributed to cardholders *@
                    <MudItem xs="12" sm="4">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">BALANCE USED</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h4" Class="fmc-kpi-val fmc-responsive-val" Color="Color.Info">@balanceUsed.ToString("C")</MudText>
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:700;">@usedPct.ToString("F1")% of wallet allocated</MudText>
                            </div>
                            <div class="fmc-card-icon-bg info"><MudIcon Icon="@Icons.Material.Filled.Payments" /></div>
                            <div class="fmc-card-progress info"></div>
                        </div>
                    </MudItem>
                }

                @* ── SYSTEM ALERT PANEL ── *@
                <MudItem xs="12">
                    @if (context.User.IsInRole(Roles.SuperAdmin))
                    {
                        <ExecutiveAlertPanel Organizations="_organizations" 
                                             Loading="_loading" 
                                             OnActionCompleted="RefreshDashboard" />
                    }
                    else if (context.User.IsInRole(Roles.CEO))
                    {
                        @* Show the workflow/intelligence alerts geared for CEO operations *@
                        <WorkflowAlertPanel Loading="_loading" IsCeo="true" />
                        
                        @* Also optionally keep the executive alert panel so CEO can see low liquidity anomalies *@
                        <ExecutiveAlertPanel Organizations="_organizations" Loading="_loading" OnActionCompleted="RefreshDashboard" />
                    }
                </MudItem>

                @* MAIN REPOSITORY TABLE *@
                <MudItem xs="12">
                        @if (context.User.IsInRole(Roles.CEO))
                    {
                        <PersonnelRepository Users="_users" 
                                             RecentLogs="_auditLogs"
                                             Loading="_loading" 
                                             OnActionCompleted="RefreshDashboard" />
                    }
                    else
                    {
                        <OrganizationRepository Organizations="_organizations"
                                                Loading="_loading"
                                                OnActionCompleted="RefreshDashboard" />
                    }
                </MudItem>

                @* ── ENTERPRISE FINANCIAL VELOCITY (Line Chart) ── *@
                <MudItem xs="12">
                    <FinancialVelocityChart Series="_lineChartSeries" 
                                            Labels="_lineChartLabels" 
                                            Loading="_auditLoading"
                                            SelectedTimeframe="_selectedTimeframe"
                                            OnTimeframeChanged="ChangeTimeframe" />
                </MudItem>

                @* ── LEDGER ADJUSTMENT LOG (Audit Feed) ── *@
                <MudItem xs="12">
                    <div class="fmc-audit-surface">
                        <div class="fmc-audit-header">
                            <div class="fmc-audit-header-inner">
                                <div class="fmc-audit-title">
                                    <div class="fmc-audit-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.HistoryEdu" Color="Color.Info" /></div>
                                    <div class="fmc-alert-title-text">
                                        <MudText Typo="Typo.h6" Style="font-weight: 800;">Portfolio Health Warnings</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700; color: var(--mud-palette-warning);">Persistent issues that cannot be cleared until the wallet balance is restored.</MudText>
                                    </div>
                                </div>
                                <div class="fmc-audit-controls">
                                    <div class="d-flex align-center gap-2">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary fmc-audit-showing-txt" Style="font-weight:700;">SHOWING LAST</MudText>
                                        <MudSelect T="int" Value="@_auditLogLimit" ValueChanged="@OnAuditLogLimitChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Style="background-color:var(--mud-palette-surface); font-weight:700; width:85px; height:32px;">
                                            <MudSelectItem Value="10">10</MudSelectItem>
                                            <MudSelectItem Value="20">20</MudSelectItem>
                                            <MudSelectItem Value="50">50</MudSelectItem>
                                            <MudSelectItem Value="100">100</MudSelectItem>
                                        </MudSelect>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary fmc-audit-showing-txt" Style="font-weight:700;">ENTRIES</MudText>
                                    </div>
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.FileDownload" 
                                               Style="text-transform:none; border-radius:8px; font-weight:700;">Export CSV</MudButton>
                                </div>
                            </div>
                        </div>

                        <div class="fmc-audit-body">
                            @if (_auditLoading)
                            {
                                <div class="pa-10 d-flex justify-center">
                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Medium" />
                                </div>
                            }
                            else if (!_auditLogs.Any())
                            {
                                <div class="pa-12 d-flex flex-column align-center mud-text-secondary">
                                    <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Large" Style="opacity:0.3;" />
                                    <MudText Class="mt-2">No adjustment history found.</MudText>
                                </div>
                            }
                            else
                            {
                                <div class="fmc-audit-list">
                                    @foreach (var log in _auditLogs)
                                    {
                                        bool isCredit = log.Action == "CREDIT";
                                        var localTime = log.CreatedAt.ToLocalTime();
                                        <div class="fmc-audit-item @(isCredit ? "credit" : "debit")">
                                            <div class="fmc-audit-indicator"></div>
                                            <div class="fmc-audit-type-icon">
                                                <MudIcon Icon="@(isCredit ? Icons.Material.Filled.ArrowUpward : Icons.Material.Filled.ArrowDownward)"
                                                         Color="@(isCredit ? Color.Success : Color.Error)" Size="Size.Small" />
                                            </div>
                                            <div class="fmc-audit-body-content">
                                                @* Row 1: Name + Badge *@
                                                <div class="fmc-audit-row1">
                                                    <MudText Typo="Typo.body2" Class="fmc-audit-entity">@log.EntityName</MudText>
                                                    <span class="fmc-audit-badge @(isCredit ? "credit" : "debit")">@log.Action</span>
                                                </div>
                                                @* Row 2: Actor · date on left, amount on right *@
                                                <div class="fmc-audit-row2">
                                                    <span class="fmc-audit-actor mud-text-secondary">
                                                        @log.PerformedBy&nbsp;<span class="fmc-audit-dot">·</span>&nbsp;@localTime.ToString("MMM dd · HH:mm")
                                                    </span>
                                                    <span class="fmc-audit-amt @(isCredit ? "credit" : "debit")">
                                                        @(isCredit ? "+" : "-")@log.Amount?.ToString("N2")
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="fmc-audit-footer">
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Style="text-transform:none; font-weight:700;">Load Historical Archives</MudButton>
                                </div>
                            }
                        </div>
                    </div>
                </MudItem>
            </MudGrid>
        </Authorized>
        <NotAuthorized>
            @if (context.User.IsInRole(Roles.Maker) || context.User.IsInRole(Roles.Approver))
            {
                <MakerDashboard Organization="@(_organizations.FirstOrDefault() ?? new())"
                                Users="_users"
                                Loading="_loading"
                                OnActionCompleted="RefreshDashboard" />
            }
            else
            {
                @* STANDARD USER DASHBOARD (KEEP CLEAN BUT MATCH STYLE) *@
                <div class="d-flex align-center justify-space-between mb-8">
                    <MudText Typo="Typo.h4" Style="font-weight: 800; letter-spacing: -0.01em;">Financial Overview</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Href="/transactions/add"
                               Style="border-radius: 12px; padding: 10px 24px;">
                        Log Settlement
                    </MudButton>
                </div>

                <MudGrid Spacing="4">
                    @if (_loading)
                    {
                        @for (int i = 0; i < 3; i++)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MudSkeleton Width="100%" Height="180px" SkeletonType="SkeletonType.Rectangle" Style="border-radius: 16px;" />
                            </MudItem>
                        }
                    }
                    else
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <div class="fmc-glass-card static">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">AVAILABLE CAPITAL</MudText>
                                <MudText Typo="Typo.h3" Style="font-weight: 900; margin: 8px 0; font-family: 'JetBrains Mono', monospace;">@_totalBalance.ToString("C")</MudText>
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Primary" Size="Size.Large" Class="fmc-static-icon" />
                                <div class="fmc-card-progress primary"></div>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <div class="fmc-glass-card static">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">MONTHLY DISBURSEMENTS</MudText>
                                <MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 900; margin: 8px 0; font-family: 'JetBrains Mono', monospace;">@_monthlyExpenses.ToString("C")</MudText>
                                <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Color="Color.Error" Size="Size.Large" Class="fmc-static-icon" />
                                <div class="fmc-card-progress error"></div>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <div class="fmc-glass-card static">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">ACTIVE ALLOCATIONS</MudText>
                                <MudText Typo="Typo.h3" Color="Color.Info" Style="font-weight: 900; margin: 8px 0;">@_activeBudgetsCount</MudText>
                                <MudIcon Icon="@Icons.Material.Filled.PivotTableChart" Color="Color.Info" Size="Size.Large" Class="fmc-static-icon" />
                                <div class="fmc-card-progress info"></div>
                            </div>
                        </MudItem>

                        <MudItem xs="12" md="8">
                            <MudPaper Class="pa-8 fmc-main-surface" Elevation="0">
                                <div class="d-flex align-center justify-space-between mb-8">
                                    <div class="d-flex align-center">
                                        <div class="fmc-header-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Primary" /></div>
                                        <MudText Typo="Typo.h5" Style="font-weight: 700;">Recent Settlements</MudText>
                                    </div>
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward" Href="/transactions">Open Ledger</MudButton>
                                </div>
                                <MudTable Items="@_recentTransactions" Hover="true" Dense="true" Elevation="0" Class="fmc-table-transparent">
                                    <HeaderContent>
                                        <MudTh>SETTLEMENT DATE</MudTh>
                                        <MudTh>MEMO</MudTh>
                                        <MudTh>CATEGORY</MudTh>
                                        <MudTh Style="text-align: right;">AMOUNT</MudTh>
                                    </HeaderContent>
                                    <RowTemplate Context="txItem">
                                        <MudTd DataLabel="Date">@(((TransactionDto)txItem).Date.ToShortDateString())</MudTd>
                                        <MudTd DataLabel="Label"><b>@(((TransactionDto)txItem).Label)</b></MudTd>
                                        <MudTd DataLabel="Category">
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info" Style="font-weight: 700;">@(((TransactionDto)txItem).Category)</MudChip>
                                        </MudTd>
                                        <MudTd DataLabel="Amount" Style="text-align: right;">
                                            <MudText Color="@(((TransactionDto)txItem).Amount < 0 ? Color.Error : Color.Success)" Style="font-weight: 800; font-family: 'JetBrains Mono', monospace;">
                                                @(((TransactionDto)txItem).Amount.ToString("C"))
                                            </MudText>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudPaper Class="pa-8 fmc-main-surface" Elevation="0">
                                <div class="d-flex align-center mb-8">
                                    <div class="fmc-header-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.QueryStats" Color="Color.Primary" /></div>
                                    <MudText Typo="Typo.h5" Style="font-weight: 700;">Capital Allocation</MudText>
                                </div>
                                <div class="d-flex flex-column align-center">
                                    <MudChart T="double" ChartType="ChartType.Donut" ChartSeries="@_donutSeries" ChartLabels="@_chartLabels" Width="100%" Height="280px" />
                                </div>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
        </NotAuthorized>

    </AuthorizeView>
</MudContainer>

<style>
    /* Dynamic Enterprise Theme Adaptation */
    .fmc-dashboard-header { display: flex; align-items: center; justify-content: space-between; }
    .fmc-header-accent { width: 6px; height: 48px; background: var(--mud-palette-primary); border-radius: 4px; }
    .fmc-hero-text { font-weight: 900; letter-spacing: -0.04em; color: var(--mud-palette-text-primary); font-size: clamp(1.5rem, 4vw, 3rem) !important; }
    .fmc-subtitle { color: var(--mud-palette-text-secondary); opacity: 0.8; font-weight: 500; font-size: clamp(0.75rem, 1.5vw, 1rem); }
    
    .fmc-header-btn { border-radius: 12px !important; text-transform: none !important; font-weight: 700 !important; }
    .fmc-header-btn.primary { padding: 12px 28px !important; box-shadow: var(--mud-elevation-4) !important; }
    .fmc-header-btn.secondary { border: 1px solid var(--mud-palette-divider) !important; }

    .fmc-responsive-val {
        line-height: 1 !important; 
        font-size: clamp(1rem, 3.5vw, 2.2rem) !important;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }


    /* Performance Panels - Adaptive Glass */
    .fmc-glass-card {
        position: relative; overflow: hidden; padding: 24px;
        background-color: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider); border-radius: 20px;
        height: 100%; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }
    .fmc-glass-card:hover { transform: translateY(-4px); box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08); border-color: var(--mud-palette-primary); }
    .fmc-glass-card.static { cursor: default; }
    .fmc-glass-card.static:hover { transform: none; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05); }
    
    .fmc-card-label { font-weight: 800; letter-spacing: 0.12em; color: var(--mud-palette-text-secondary); opacity: 0.7; font-size: 0.7rem; }
    .fmc-card-icon-bg { position: absolute; right: -8px; top: -8px; opacity: 0.04; font-size: 6rem !important; }
    .fmc-static-icon { position: absolute; right: 24px; bottom: 24px; opacity: 0.3; }
    
    .fmc-card-progress { position: absolute; bottom: 0; left: 0; height: 4px; width: 35%; border-radius: 0 10px 10px 0; }
    .fmc-card-progress.primary { background: var(--mud-palette-primary); }
    .fmc-card-progress.success { background: var(--mud-palette-success); }
    .fmc-card-progress.info { background: var(--mud-palette-info); }
    .fmc-card-progress.warning { background: var(--mud-palette-warning); }
    .fmc-card-progress.error { background: var(--mud-palette-error); }

    /* Main Repository Surface */
    .fmc-main-surface { 
        border-radius: 24px; border: 1px solid var(--mud-palette-divider); 
        background-color: var(--mud-palette-surface); overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
    }
    .fmc-header-area { 
