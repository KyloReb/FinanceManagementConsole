<!DOCTYPE html>
<html lang="en">
@using static Microsoft.AspNetCore.Components.Web.RenderMode

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["FMC.styles.css"]" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <ImportMap />
    <style>
        /* GLOBAL FINANCIAL TYPOGRAPHY */
        .fmc-monetary, .fmc-money, .fmc-responsive-val, .fmc-financial-value, .fmc-financial-value-small, .fmc-financial-mono {
            font-family: 'Roboto Mono', monospace !important;
            font-weight: 700 !important;
            letter-spacing: -0.02em !important;
        }

        /* Prevent the initial flash of unstyled content by setting a default background */
        html {
            background-color: #ffffff; /* Matches default light theme */
            min-height: 100%;
        }
        body {
            background-color: inherit;
            min-height: 100vh;
        }
        html.dark {
            background-color: #11111b; /* Matches default dark theme */
        }
    </style>
    <script>
        window.cookieHelper = {
            setCookie: function (name, value, days, secure, sameSite) {
                var expires = "";
                if (days) {
                    var date = new Date();
                    date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
                    expires = "; expires=" + date.toUTCString();
                }
                var cookieString = name + "=" + (value || "") + expires + "; path=/";
                if (secure) cookieString += "; Secure";
                if (sameSite) cookieString += "; SameSite=" + sameSite;
                document.cookie = cookieString;
            },
            deleteCookie: function (name) {
                document.cookie = name + '=; Path=/; Expires=Thu, 01 Jan 1970 00:00:01 GMT; Secure; SameSite=Lax';
            }
        };

        window.clipboardHelper = {
            copyText: function(text) {
                navigator.clipboard.writeText(text);
            }
        };

        window.fmcPreloader = {
            hide: function() {
                const loader = document.getElementById('fmc-preloader');
                if (loader) {
                    loader.classList.add('fade-out');
                    setTimeout(() => {
                        if (loader.parentNode) loader.parentNode.removeChild(loader);
                    }, 800);
                }
            }
        };

        (function () {
            try {
                var theme = null;
                var cookieArr = document.cookie.split(";");
                for (var i = 0; i < cookieArr.length; i++) {
                    var cookiePair = cookieArr[i].split("=");
                    if ("theme_preference" == cookiePair[0].trim()) {
                        theme = decodeURIComponent(cookiePair[1]);
                        break;
                    }
                }
                if (!theme) theme = localStorage.getItem('theme_preference');
                
                if (theme === 'dark') {
                    document.documentElement.classList.add('dark');
                    document.documentElement.style.backgroundColor = '#11111b';
                    document.documentElement.style.color = '#ffffff';
                } else {
                    document.documentElement.classList.remove('dark');
                    document.documentElement.style.backgroundColor = '#ffffff';
                    document.documentElement.style.color = '#000000';
                }
            } catch (e) { }
        })();
    </script>
    <HeadOutlet />
</head>

@*
    The main HTML entry point for the application.
    Handles initial document structure, resource loading, and early theme initialization to prevent flickers.
*@
<body>
    <div id="fmc-preloader">
        <div class="preloader-content">
            <img src="nlkLogo.png" alt="NLK Logo" class="preloader-logo" />
        </div>
        <div class="preloader-footer">
            <span class="preloader-from">from</span>
            <span class="preloader-brand">Nationlink/INFOSERVE</span>
        </div>
    </div>

    <Routes @rendermode="@InteractiveServer" />
    <ReconnectModal />
    <script src="https://cdn.jsdelivr.net/npm/mermaid@11.4.1/dist/mermaid.min.js"></script>
    <script>
        window.mermaidHelper = {
            _initialized: false,
            _observer: null,
            _themeObserver: null,
            init: function() {
                if (window.mermaid && !this._initialized) {
                    try {
                        this.reinit();
                        this._initialized = true;
                        this.startObserving();
                        this.startThemeObserving();
                        console.log("%c[Mermaid] " + (mermaid.version ? "v" + mermaid.version : "Engine") + " Armed & Monitoring", "color: #3b82f6; font-weight: bold;");
                    } catch (e) {
                        console.error("[Mermaid] Init Fail:", e);
                    }
                }
            },
            reinit: function() {
                if (!window.mermaid) return;
                const isDark = document.documentElement.classList.contains('dark');
                mermaid.initialize({ 
                    startOnLoad: false,
                    theme: isDark ? 'dark' : 'default',
                    securityLevel: 'loose',
                    fontFamily: 'Inter, system-ui, sans-serif',
                    flowchart: { useMaxWidth: true, htmlLabels: true, curve: 'basis' }
                });
                
                // If we're already initialized, force a re-render of existing diagrams
                if (this._initialized) {
                    this.render(true);
                }
            },
            startObserving: function() {
                if (this._observer) return;
                this._observer = new MutationObserver(() => this.render());
                const target = document.querySelector('body');
                if (target) this._observer.observe(target, { childList: true, subtree: true });
            },
            startThemeObserving: function() {
                if (this._themeObserver) return;
                // Watch for 'dark' class changes on the html element
                this._themeObserver = new MutationObserver((mutations) => {
                    for (const mutation of mutations) {
                        if (mutation.attributeName === 'class') {
                            console.log("[Mermaid] Theme transition detected, re-syncing diagams...");
                            this.reinit();
                        }
                    }
                });
                this._themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
            },
            render: async function(force = false) {
                if (!window.mermaid) return;
                
                try {
                    // Logic A: Find explicit blocks to convert
                    const blocks = Array.from(document.querySelectorAll('pre code.language-mermaid, pre code'));
                    for (let block of blocks) {
                        const txt = block.textContent.trim();
                        if (txt.includes('graph ') || txt.includes('sequenceDiagram') || txt.includes('flowchart ')) {
                            const pre = block.parentElement;
                            if (pre.getAttribute('data-mermaid-processed')) continue;
                            pre.setAttribute('data-mermaid-processed', 'true');

                            const container = document.createElement('div');
                            container.className = 'mermaid';
                            container.setAttribute('data-mermaid-code', txt); // Store original code
                            container.textContent = txt;
                            pre.parentElement.replaceChild(container, pre);
                        }
                    }

                    // Logic B: Run on all containers
                    const selector = force ? '.mermaid' : '.mermaid:not([data-processed="true"])';
                    const targets = document.querySelectorAll(selector);
                    
                    if (targets.length > 0) {
                        if (force) {
                            // Restore original code to containers before re-running
                            targets.forEach(t => {
                                const code = t.getAttribute('data-mermaid-code');
                                if (code) {
                                    t.removeAttribute('data-processed');
                                    t.innerHTML = code;
                                }
                            });
                        }
                        await mermaid.run();
                    }
                } catch (e) { 
                    console.error("[Mermaid] Render Error:", e);
                }
            }
        };

        window.chartHelper = {
            formatYAxis: function() {
                setTimeout(() => {
                    const labels = document.querySelectorAll('.mud-charts-yaxis text');
                    labels.forEach(label => {
                        const raw = label.textContent.trim().replace(/[^\d.-]/g, '');
                        if (!isNaN(raw) && raw !== '') {
                            const val = parseFloat(raw);
                            // Format as currency (Peso)
                            label.textContent = val.toLocaleString('en-PH', { 
                                style: 'currency', 
                                currency: 'PHP', 
                                maximumFractionDigits: 0 
                            });
                        }
                    });
                }, 150);
            }
        };

        window.scrollToSection = (id) => {
            const element = document.getElementById(id);
            if (element) {
                // Offset for sticky header
                const top = element.getBoundingClientRect().top + window.pageYOffset - 150;
                window.scrollTo({ top: top, behavior: 'smooth' });
            }
        };

        window._scrollObserver = null;
        window.initScrollSync = (dotNetRef) => {
            const handler = () => {
                const headers = Array.from(document.querySelectorAll('h1[id], h2[id], h3[id]'));
                if (!headers.length) return;
                
                // Detection threshold (offset for sticky nav)
                const detectionLine = 220; 
                let activeId = headers[0].id;
                
                // Find the header closest to the detection line from above
                for (let i = 0; i < headers.length; i++) {
                    if (headers[i].getBoundingClientRect().top <= detectionLine) {
                        activeId = headers[i].id;
                    } else {
                        break; // Sorted order, no need to check further
                    }
                }
                
                dotNetRef.invokeMethodAsync('SetActiveSection', activeId);
            };
            
            if (window._scrollHandler) {
                window.removeEventListener('scroll', window._scrollHandler);
            }
            window._scrollHandler = handler;
            window.addEventListener('scroll', handler, { passive: true });
            handler(); 
        };
    </script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="js/download.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override void OnInitialized()
    {
        var cookieToken = HttpContext?.Request.Cookies["authToken"];
        Console.WriteLine($"[App] OnInitialized - HttpContext: {HttpContext != null}, Cookie Found: {!string.IsNullOrEmpty(cookieToken)}");
    }
}
