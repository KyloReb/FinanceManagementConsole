@using FMC.Shared.DTOs
@using FMC.Shared.Auth
@using FMC.Services.Api
@using MudBlazor
@inject OrganizationApiService OrgService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <!-- Header Section -->
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Color="Color.Info" />
            <MudText Typo="Typo.h6">Transaction Details</MudText>
        </div>
    </TitleContent>
    
    <DialogContent>
        <div class="fmc-details-container pa-4">
            
            <!-- Summary Header: Amount and Status -->
            <div class="d-flex justify-space-between align-center mb-6">
                <div>
                    <MudText Typo="Typo.h5" Class="fmc-financial-mono" Color="@(Transaction.Amount < 0 ? Color.Error : Color.Success)">
                        @Transaction.Amount.ToString("C")
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">ESTABLISHED @Transaction.Date.ToString("MMM dd, yyyy HH:mm")</MudText>
                </div>
                <MudChip T="string" Color="@GetStatusColor(Transaction.Status)" Variant="Variant.Filled" Size="Size.Small" Style="font-weight: 900;">
                    @Transaction.Status.ToUpper()
                </MudChip>
            </div>

            <MudDivider Class="my-4" />

            <!-- Detailed Information Grid -->
            <MudGrid Spacing="2">
                
                <!-- Subscriber Info -->
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">SUBSCRIBER</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 800;">@Transaction.Subscriber</MudText>
                </MudItem>
                
                <!-- Account Number with Toggle Masking -->
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">ACCOUNT NUMBER</MudText>
                    <div class="d-flex align-center gap-1">
                        <MudText Typo="Typo.body2" Style="font-weight: 700; font-family: 'Roboto Mono', monospace;">
                            @GetMaskedAccount(Transaction.AccountNumber)
                        </MudText>
                        <MudIconButton Icon="@(_showFullAccount ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)" 
                                       Size="Size.Small" 
                                       OnClick="ToggleAccountMask" 
                                       Class="pa-0" 
                                       Style="opacity: 0.5;" 
                                       aria-label="Toggle full account number visibility" />
                    </div>
                </MudItem>
                
                <!-- Transaction Description -->
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">DESCRIPTION / LABEL</MudText>
                    <MudText Typo="Typo.body2">@Transaction.Label</MudText>
                </MudItem>
                
                <!-- Maker and Reference Details -->
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">MAKER / INITIATOR</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 700;">@Transaction.MakerName</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">REFERENCE ID</MudText>
                    <MudText Typo="Typo.body2" Style="font-size: 0.7rem; font-family: 'Roboto Mono', monospace;">@Transaction.Id.ToString().ToUpper()</MudText>
                </MudItem>
                
                <!-- Approver Details (Hidden while Pending) -->
                @if (Transaction.Status != "Pending")
                {
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">RESOLUTION AUTHORITY</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight: 800; color: var(--mud-palette-info);">
                            @(Transaction.ApproverName ?? "System Auto-Settlement")
                        </MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">COMPLETION TIMESTAMP</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight: 700;">
                            @(Transaction.ActionDate?.ToString("MMM dd, yyyy HH:mm") ?? "N/A")
                        </MudText>
                    </MudItem>
                }
            </MudGrid>

            <!-- Rejection Feedback Alert -->
            @if (!string.IsNullOrEmpty(Transaction.RejectionReason))
            {
                <div class="mt-4 pa-4 mud-alert-error" style="border-radius: 12px; border: 1px solid rgba(var(--mud-palette-error-rgb), 0.2);">
                    <MudText Typo="Typo.caption" Style="font-weight: 950; color: var(--mud-palette-error); letter-spacing: 0.05em;">DENIAL REASON</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 500;">@Transaction.RejectionReason</MudText>
                </div>
            }

            @* ── BULK BREAKDOWN SECTION ── *@
            @if (Transaction.SubTransactions != null && Transaction.SubTransactions.Any())
            {
                <div class="mt-6">
                    <div class="d-flex align-center gap-2 mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle2" Style="font-weight: 900; letter-spacing: 0.02em;">BATCH BREAKDOWN</MudText>
                    </div>
                    
                    <div style="max-height: 300px; overflow-y: auto; border: 1px solid var(--mud-palette-divider); border-radius: 12px;">
                        <MudTable Items="@Transaction.SubTransactions" Dense="true" Hover="true" Elevation="0" Style="background: transparent;">
                            <HeaderContent>
                                <MudTh Style="font-size: 0.65rem; font-weight: 900; opacity: 0.6;">CARDHOLDER</MudTh>
                                <MudTh Style="font-size: 0.65rem; font-weight: 900; opacity: 0.6; text-align: right;">AMOUNT</MudTh>
                                <MudTh Style="font-size: 0.65rem; font-weight: 900; opacity: 0.6; text-align: center;">STATUS</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="sub">
                                <MudTd>
                                    <div class="d-flex flex-column">
                                        <MudText Typo="Typo.body2" Style="font-weight: 700; font-size: 0.8rem;">@sub.Subscriber</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.65rem;">@GetMaskedAccount(sub.AccountNumber)</MudText>
                                    </div>
                                </MudTd>
                                <MudTd Style="text-align: right;">
                                    <MudText Typo="Typo.body2" Class="fmc-financial-mono" Style="font-weight: 800; font-size: 0.85rem;" 
                                             Color="@(sub.Amount < 0 ? Color.Error : Color.Success)">
                                        @sub.Amount.ToString("C2")
                                    </MudText>
                                </MudTd>
                                <MudTd Style="text-align: center;">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@GetStatusColor(sub.Status)" 
                                             Style="font-weight: 900; font-size: 0.6rem; margin: 0;">
                                        @sub.Status.ToUpper()
                                    </MudChip>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>
                </div>
            }
        </div>

        @if (_showSuccessOverlay)
        {
            <div class="fmc-success-overlay @(_isRejection ? "rejected" : "")">
                <div class="fmc-success-icon-container">
                    <MudIcon Icon="@(_isRejection ? Icons.Material.Filled.Gavel : Icons.Material.Filled.Verified)" Class="fmc-success-icon" />
                </div>
                <MudText Typo="Typo.h5" Class="fmc-success-text">@_successMessage</MudText>
                <MudText Typo="Typo.body1" Class="fmc-success-subtext">@_successSubtext</MudText>
            </div>
        }

        @if (_showErrorOverlay)
        {
            <div class="fmc-success-overlay fmc-error-overlay">
                <div class="fmc-success-icon-container" style="background: rgba(211,47,47,0.12); box-shadow: 0 0 40px rgba(211,47,47,0.25);">
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Class="fmc-success-icon" Style="color: #ef5350;" />
                </div>
                <MudText Typo="Typo.h5" Class="fmc-success-text" Style="color: #ef5350;">@_errorMessage</MudText>
                <MudText Typo="Typo.body1" Class="fmc-success-subtext">@_errorSubtext</MudText>
            </div>
        }
    </DialogContent>
    
    <DialogActions>
        @if (_showSuccessOverlay)
        {
            <MudButton Variant="Variant.Filled"
                       Style="background-color: #2e7d32; color: #fff; font-weight: 900; text-transform: none; border-radius: 8px; min-width: 120px;"
                       OnClick="@(() => MudDialog.Close(DialogResult.Ok(true)))">Done</MudButton>
        }
        else if (_showErrorOverlay)
        {
            <MudButton Variant="Variant.Filled"
                       Style="background-color: #c62828; color: #fff; font-weight: 900; text-transform: none; border-radius: 8px; min-width: 120px;"
                       OnClick="@(() => { _showErrorOverlay = false; StateHasChanged(); })">Dismiss</MudButton>
        }
        else
        {
            <MudButton OnClick="CloseDialog" Variant="Variant.Text" Style="font-weight: 800; text-transform:none;">Close</MudButton>
            <MudSpacer />
            
            <!-- Action Buttons Contextual to User Role and Status -->
        @if (Transaction.Status == "Pending")
        {
            @if (IsOwnTransaction)
            {
                <!-- Makers can cancel their own pending requests -->
                <MudButton Color="Color.Error" 
                           Variant="Variant.Filled" 
                           StartIcon="@Icons.Material.Filled.DeleteForever" 
                           OnClick="CancelTransactionAsync"
                           Disabled="@_processing"
                           Style="font-weight: 800; text-transform:none; border-radius: 8px;">
                    @(_processing ? "Processing..." : "Cancel Request")
                </MudButton>
            }
            else if (_isApprover)
            {
                <!-- Approvers can deny or authorize the request -->
                <MudButton Color="Color.Error" 
                           Variant="Variant.Outlined" 
                           OnClick="@(() => ProcessDecisionAsync(approve: false))"
                           Disabled="@_processing"
                           Style="font-weight: 700; text-transform:none;">Reject</MudButton>
                           
                <MudButton Variant="Variant.Filled" 
                           OnClick="@(() => ProcessDecisionAsync(approve: true))"
                           Disabled="@_processing"
                           Style="background-color: #2e7d32; color: #ffffff; font-weight: 900; text-transform:none; border-radius: 8px;">Approve</MudButton>
            }
            }
        }
    </DialogActions>
</MudDialog>

@code {
    #region Parameters & Injections

    /// <summary>
    /// The dialog instance required for MudBlazor to manage visibility and return results.
    /// </summary>
    [CascadingParameter] 
    public IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>
    /// The transaction payload to display and interact with.
    /// </summary>
    [Parameter] 
    public TransactionDto Transaction { get; set; } = default!;

    /// <summary>
    /// Indicates whether the currently logged-in user is the original creator of this transaction.
    /// Used to enforce the 4-eyes policy and permit cancellations.
    /// </summary>
    [Parameter] 
    public bool IsOwnTransaction { get; set; }

    [CascadingParameter] 
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    #endregion

    #region State Variables

    private bool _processing;
    private bool _showFullAccount;
    private bool _isApprover;
    private bool _showSuccessOverlay;
    private bool _isRejection;
    private string _successMessage = "";
    private string _successSubtext = "";
    private bool _showErrorOverlay;
    private string _errorMessage = "";
    private string _errorSubtext = "";

    #endregion

    #region Lifecycle Methods

    protected override async Task OnInitializedAsync()
    {
        // Resolve user roles once during component initialization
        var authState = await AuthStateTask;
        _isApprover = authState.User.IsInRole(Roles.Approver);
    }

    #endregion

    #region UI Helpers

    /// <summary>
    /// Toggles the visibility of the full account number for sensitive data handling.
    /// </summary>
    private void ToggleAccountMask()
    {
        _showFullAccount = !_showFullAccount;
    }

    /// <summary>
    /// Masks the account number leaving only the first 6 and last 4 digits visible.
    /// </summary>
    /// <param name="account">The full raw account string</param>
    /// <returns>A masked string</returns>
    private string GetMaskedAccount(string? account)
    {
        if (string.IsNullOrEmpty(account)) return "N/A";
        if (_showFullAccount) return account;
        if (account.Length <= 10) return account; // Too short to effectively mask the middle

        return $"{account[..6]}{new string('*', account.Length - 10)}{account[^4..]}";
    }

    /// <summary>
    /// Maps a transaction status string to its corresponding MudBlazor theme color.
    /// </summary>
    private Color GetStatusColor(string status) => status switch
    {
        "Pending"   => Color.Warning,
        "Approved"  => Color.Success,
        "Successful"=> Color.Success,
        "Rejected"  => Color.Error,
        "Cancelled" => Color.Default,
        _           => Color.Info
    };

    private void ShowSuccessOverlay(string title, string subtext, bool isRejection = false)
    {
        _successMessage = title;
        _successSubtext = subtext;
        _isRejection = isRejection;
        _showSuccessOverlay = true;
        StateHasChanged();
    }

    private void ShowErrorOverlay(string title, string subtext)
    {
        _errorMessage = title;
        _errorSubtext = subtext;
        _showErrorOverlay = true;
        StateHasChanged();
    }

    #endregion

    #region Action Handlers

    /// <summary>
    /// Closes the dialog without taking any action.
    /// </summary>
    private void CloseDialog() => MudDialog.Cancel();

    /// <summary>
    /// Allows the Maker to withdraw their pending transaction request.
    /// </summary>
    private async Task CancelTransactionAsync()
    {
        bool isBatch = Transaction.SubTransactions != null && Transaction.SubTransactions.Any();
        string typeLabel = isBatch ? "batch" : "individual transaction";

        string markup = $@"
            <div class='d-flex flex-column align-center text-center pt-6 pb-2 px-2'>
                <div class='mb-4' style='background: rgba(var(--mud-palette-error-rgb), 0.1); border-radius: 50%; padding: 16px; width: 72px; height: 72px; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 20px rgba(var(--mud-palette-error-rgb), 0.2);'>
                    <svg style='width:36px;height:36px;color:var(--mud-palette-error);' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
                        <path d='M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z'></path>
                        <line x1='12' y1='9' x2='12' y2='13'></line>
                        <line x1='12' y1='17' x2='12.01' y2='17'></line>
                    </svg>
                </div>
                <h3 style='font-weight: 900; letter-spacing: 0.05em; font-size: 1.15rem; color: var(--mud-palette-text-primary); margin-bottom: 8px;'>WITHDRAW REQUEST</h3>
                <p style='color: var(--mud-palette-text-secondary); font-size: 0.85rem; line-height: 1.6; max-width: 280px;'>
                    Are you sure you want to cancel this <b>{typeLabel}</b>?<br/>This action is permanent and cannot be undone.
                </p>
            </div>
        ";

        var options = new DialogOptions { 
            CloseButton = false, 
            MaxWidth = MaxWidth.ExtraSmall, 
            FullWidth = true, 
            NoHeader = true,
            BackgroundClass = "fmc-dialog-blur"
        };

        bool? confirm = await DialogService.ShowMessageBoxAsync(
            title: default,
            markupMessage: new MarkupString(markup),
            yesText: "Confirm", 
            cancelText: "Go Back",
            options: options);

        if (confirm != true) return;

        try 
        {
            _processing = true;
            
            bool success = isBatch 
                ? await OrgService.CancelBatchAsync(Transaction.Id)
                : await OrgService.CancelTransactionAsync(Transaction.Id);
            
            if (success)
            {
                ShowSuccessOverlay("REQUEST WITHDRAWN", isBatch ? "Batch has been removed from the queue." : "Transaction has been removed.");
            }
            else 
            {
                ShowErrorOverlay("WITHDRAWAL BLOCKED", isBatch ? "Unable to cancel batch at this time." : "Unable to cancel transaction.");
            }
        }
        catch (Exception ex)
        {
            ShowErrorOverlay("OPERATION FAILED", ex.Message);
        }
        finally
        {
            _processing = false;
        }
    }

    /// <summary>
    /// Handles the authorization workflow (Approve or Reject) for Approvers.
    /// </summary>
    /// <param name="approve">True if authorizing, False if denying</param>
    private async Task ProcessDecisionAsync(bool approve)
    {
        try
        {
            _processing = true;
            bool success = false;
            
            if (approve)
            {
                // Step-up Security Verification: Require password for all approvals
                var secOpts = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, BackdropClick = false };
                var secDialog = await DialogService.ShowAsync<SecurityVerificationDialog>("Security Verification", new DialogParameters(), secOpts);
                var secResult = await secDialog.Result;
                
                if (secResult is null || secResult.Canceled)
                {
                    _processing = false;
                    return;
                }

                bool isBatch = Transaction.SubTransactions != null && Transaction.SubTransactions.Any();
                success = isBatch 
                    ? await OrgService.ApproveBatchAsync(Transaction.Id)
                    : await OrgService.ApproveTransactionAsync(Transaction.Id);

                if (success) 
                {
                    ShowSuccessOverlay("TRANSACTION AUTHORIZED", "Decision has been securely logged to the ledger.");
                }
            }
            else
            {
                // Confirmation Prompt for Rejection
                bool? confirm = await DialogService.ShowMessageBoxAsync(
                    "Confirm Rejection", 
                    "Are you sure you want to reject this request?", 
                    yesText: "Yes, Reject", cancelText: "No, Cancel");
                
                if (confirm != true)
                {
                    _processing = false;
                    return;
                }

                // Prompt the Approver for a mandatory/optional denial reason
                var parameters = new DialogParameters { ["ContentText"] = "Please provide a reason for rejecting this transaction." };
                var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small };
                
                var dialog = await DialogService.ShowAsync<RejectionDialog>("Reject Transaction", parameters, options);
                var result = await dialog.Result;

                if (result is not null && !result.Canceled)
                {
                    // Proceed with rejection using the provided reason
                    var reason = result.Data as string ?? "Rejected by approver.";
                    bool isBatch = Transaction.SubTransactions != null && Transaction.SubTransactions.Any();
                    
                    success = isBatch
                        ? await OrgService.RejectBatchAsync(Transaction.Id, reason)
                        : await OrgService.RejectTransactionAsync(Transaction.Id, reason);

                    if (success)
                    {
                        ShowSuccessOverlay("DECISION LOGGED", "Transaction has been rejected and archived.", isRejection: true);
                    }
                }
                else 
                {
                    // The user cancelled the rejection reason dialog, so abort the rejection process entirely
                    _processing = false;
                    return;
                }
            }

            if (!success)
            {
                ShowErrorOverlay("SETTLEMENT BLOCKED", "Unable to process. Verify balance and permissions.");
            }
        }
        catch (Exception ex)
        {
            bool isLiquidityError = ex.Message.Contains("insufficient", StringComparison.OrdinalIgnoreCase)
                                 || ex.Message.Contains("liquidity", StringComparison.OrdinalIgnoreCase);

            if (isLiquidityError)
            {
                var batchCount = (Transaction.SubTransactions != null && Transaction.SubTransactions.Any()) 
                                 ? Transaction.SubTransactions.Count : 0;
                var batchNote = batchCount > 0 ? $" ({batchCount} settlements)" : string.Empty;

                ShowErrorOverlay(
                    "INSUFFICIENT LIQUIDITY",
                    $"The organization's corporate float does not have enough balance to cover this settlement{batchNote}. Contact your SuperAdmin to top-up the wallet.");
            }
            else
            {
                ShowErrorOverlay("AUTHORIZATION FAILED", ex.Message);
            }
        }
        finally
        {
            _processing = false;
        }
    }

    #endregion
}
