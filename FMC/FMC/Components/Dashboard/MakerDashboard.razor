@code {
    [Parameter] public OrganizationDto Organization { get; set; } = new();
    [Parameter] public List<UserDto> Users { get; set; } = new();
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback OnActionCompleted { get; set; }

    private List<TransactionDto> _pendingTransactions = new();
    private List<TransactionDto> _todayTransactions = new();
    private List<AuditLogDto> _allAuditLogs = new();
    private bool _loadingData;
    private bool _auditLoading;
    private bool _isApprover;
    private bool _isMaker;
    private string? _currentUserId;
    private string _cardholderSearch = "";
    private string _roleDisplay = "Operations";

    private bool FilterCardholders(UserDto user)
    {
        if (string.IsNullOrWhiteSpace(_cardholderSearch)) return true;
        if (user.DisplayName.Contains(_cardholderSearch, StringComparison.OrdinalIgnoreCase)) return true;
        if ((user.AccountNumber ?? "").Contains(_cardholderSearch, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    }

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var user = authState.User;
        _isApprover = user.IsInRole(Roles.Approver);
        _isMaker = user.IsInRole(Roles.Maker);
        _currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        
        if (user.IsInRole(Roles.Maker)) _roleDisplay = "MAKER";
        else if (user.IsInRole(Roles.Approver)) _roleDisplay = "APPROVER";
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Organization.Id != Guid.Empty)
        {
            await LoadDashboardData();
        }
    }

    private async Task LoadDashboardData()
    {
        if (_loadingData) return;
        _loadingData = true;
        _auditLoading = true;
        try
        {
            var pendingTask = OrgService.GetPendingTransactionsAsync(Organization.Id);
            var todayTask = OrgService.GetTodayTransactionsAsync(Organization.Id);
            var auditTask = OrgService.GetRecentAuditLogsAsync(count: 20);
            
            await Task.WhenAll(pendingTask, todayTask, auditTask);
            
            _pendingTransactions = await pendingTask;
            _todayTransactions = await todayTask;
            _allAuditLogs = await auditTask;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to sync operational queue: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingData = false;
            _auditLoading = false;
        }
    }

    private async Task HandleApproval(TransactionDto tx, bool approve)
    {
        if (approve)
        {
            // Security gate: require password re-verification before committing any approval
            var secOpts = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, BackdropClick = false };
            var secDialog = await DialogService.ShowAsync<SecurityVerificationDialog>("Security Verification", new DialogParameters(), secOpts);
            var secResult = await secDialog.Result;
            if (secResult is null || secResult.Canceled) return;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Confirm Rejection", 
                "Are you sure you want to reject this transaction?", 
                yesText: "Yes, Reject", cancelText: "No, Cancel");
            if (result != true) return;
        }

        try
        {
            bool success = false;
            if (approve)
            {
                success = await OrgService.ApproveTransactionAsync(tx.Id);
            }
            else
            {
                success = await OrgService.RejectTransactionAsync(tx.Id, "Rejected by Approver");
            }

            if (success)
            {
                Snackbar.Add(approve ? "Transaction approved and ledger updated." : "Transaction rejected.", Severity.Success);
                await LoadDashboardData();
                await OnActionCompleted.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Action failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenTransactionDetail(TransactionDto tx)
    {
        var parameters = new DialogParameters 
        { 
            ["Transaction"] = tx,
            ["IsOwnTransaction"] = tx.MakerId == _currentUserId
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<PendingDetailDialog>("Transaction Context", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadDashboardData();
            await OnActionCompleted.InvokeAsync();
        }
    }

    private async Task OpenUserSelection(bool isCredit)
    {
        var parameters = new DialogParameters { ["OrgId"] = Organization.Id };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<UserSelectionDialog>("Identity Resolution", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is UserDto selectedUser)
        {
            await OpenBalanceAdjustment(selectedUser, isCredit);
        }
    }

    private async Task OpenBalanceAdjustment(UserDto user, bool isCredit)
    {
        var adjustParams = new DialogParameters { ["User"] = user, ["IsCredit"] = isCredit };
        var adjustDialog = await DialogService.ShowAsync<UserBalanceDialog>(isCredit ? "Credit Wallet" : "Debit Wallet", adjustParams, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var adjustResult = await adjustDialog.Result;
        
        if (adjustResult is not null && !adjustResult.Canceled)
        {
            await LoadDashboardData();
            await OnActionCompleted.InvokeAsync();
        }
    }

    private async Task OpenBulkUpload()
    {
        var parameters = new DialogParameters { ["OrgId"] = Organization.Id };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<BulkUploadDialog>("Bulk Cardholder Upload", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadDashboardData();
            await OnActionCompleted.InvokeAsync();
        }
    }

    private string MaskAccount(string? account)
    {
        if (string.IsNullOrEmpty(account)) return "ACCOUNT N/A";
        if (account.Length <= 10) return account;
        return $"{account[..6]}{new string('*', account.Length - 10)}{account[^4..]}";
    }

    private IEnumerable<TransactionGroup> GroupTransactions(IEnumerable<TransactionDto> txs)
    {
        return txs.GroupBy(t => t.BatchId ?? Guid.Empty)
            .Select(g => new TransactionGroup
            {
                BatchId = g.Key == Guid.Empty ? null : g.Key,
                Transactions = g.ToList(),
                TotalAmount = g.Sum(t => t.Amount),
                IsBatch = g.Key != Guid.Empty
            });
    }

    private async Task HandleBatchApproval(Guid batchId, bool approve)
    {
        if (approve)
        {
            // Security gate: require password re-verification before committing batch approval
            var secOpts = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, BackdropClick = false };
            var secDialog = await DialogService.ShowAsync<SecurityVerificationDialog>("Security Verification", new DialogParameters(), secOpts);
            var secResult = await secDialog.Result;
            if (secResult is null || secResult.Canceled) return;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Confirm Batch Rejection", 
                "Are you sure you want to reject this entire batch? This action cannot be undone.", 
                yesText: "Yes, Reject", cancelText: "No, Cancel");
            if (result != true) return;
        }

        try
        {
            bool success = false;
            if (approve)
            {
                success = await OrgService.ApproveBatchAsync(batchId);
            }
            else
            {
                success = await OrgService.RejectBatchAsync(batchId, "Rejected via Dashboard");
            }

            if (success)
            {
                Snackbar.Add(approve ? "Batch approved successfully!" : "Batch rejected.", Severity.Success);
                await LoadDashboardData();
                await OnActionCompleted.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Action failed: {ex.Message}", Severity.Error);
        }
    }

    private class TransactionGroup
    {
        public Guid? BatchId { get; set; }
        public List<TransactionDto> Transactions { get; set; } = new();
        public decimal TotalAmount { get; set; }
        public bool IsBatch { get; set; }
    }
}
