@page "/register"
@layout Layout.BlankLayout
@attribute [AllowAnonymous]
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@using FMC.Services.Api
@using FMC.Shared.DTOs.Organization
@inject OrganizationApiService OrganizationService

<PageTitle>Register</PageTitle>

<div class="d-flex justify-center align-center py-8" style="min-height: 100vh; background-color: var(--mud-palette-background);">
    <MudCard Elevation="4" Class="pa-8 d-flex flex-column align-center mx-4" Style="width: 100%; max-width: 500px; border-radius: 12px;">
        <MudImage Src="nlklogo.png" Height="36" ObjectFit="ObjectFit.Contain" Class="mb-4" />
        <MudText Typo="Typo.h5" Class="mb-5 fw-bold">Create Account</MudText>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="w-100 mb-4">@_errorMessage</MudAlert>
        }

        <EditForm Model="@_model" OnValidSubmit="HandleRegisterAsync" class="w-100">
            <DataAnnotationsValidator />

            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.FirstName" For="@(() => _model.FirstName)" Label="First Name" Variant="Variant.Outlined" FullWidth="true" Class="mb-2" Disabled="@_isLoading" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.LastName" For="@(() => _model.LastName)" Label="Last Name" Variant="Variant.Outlined" FullWidth="true" Class="mb-2" Disabled="@_isLoading" />
                </MudItem>
            </MudGrid>

            <MudTextField @bind-Value="_model.Email" For="@(() => _model.Email)" Label="Email" Variant="Variant.Outlined" FullWidth="true" Class="mb-3" Disabled="@_isLoading" />
            <MudTextField @bind-Value="_model.Username" For="@(() => _model.Username)" Label="Username" Variant="Variant.Outlined" FullWidth="true" Class="mb-3" Disabled="@_isLoading" />
            <MudSelect T="string" @bind-Value="_model.Organization" For="@(() => _model.Organization)" Label="Organization" Variant="Variant.Outlined" FullWidth="true" Class="mb-3" Disabled="@_isLoading" AnchorOrigin="Origin.BottomCenter">
                <MudSelectItem Value="@((string)null)" Disabled="true">Select Organization</MudSelectItem>
                @foreach (var org in _organizations)
                {
                    <MudSelectItem Value="@org.Name">@org.Name</MudSelectItem>
                }
            </MudSelect>
            
            <MudTextField @bind-Value="_model.Password" For="@(() => _model.Password)" Label="Password" Variant="Variant.Outlined" FullWidth="true" 
                          InputType="@_passwordInput" Class="mb-3" Adornment="Adornment.End" AdornmentIcon="@_passwordIcon" OnAdornmentClick="TogglePasswordVisibility" Disabled="@_isLoading" />
            
            <MudTextField @bind-Value="_model.ConfirmPassword" For="@(() => _model.ConfirmPassword)" Label="Confirm Password" Variant="Variant.Outlined" FullWidth="true" 
                          InputType="@_confirmPasswordInput" Class="mb-4" Adornment="Adornment.End" AdornmentIcon="@_confirmPasswordIcon" OnAdornmentClick="ToggleConfirmPasswordVisibility" Disabled="@_isLoading" />

            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" Disabled="@_isLoading" Style="border-radius: 8px; height: 50px;">
                @if (_isLoading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Creating account...</MudText>
                }
                else
                {
                    <MudText>Register</MudText>
                }
            </MudButton>

            <div class="d-flex justify-center mt-6">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Already have an account?</MudText>
                <MudLink href="/login" Underline="Underline.None" Typo="Typo.body2" Class="ml-1 fw-bold" Color="Color.Primary" Disabled="@_isLoading">Back to Login</MudLink>
            </div>
        </EditForm>
    </MudCard>
</div>

@code {
    private RegisterRequestDto _model = new();
    private List<OrganizationDto> _organizations = new();
    private bool _isLoading = false;
    private string _errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _organizations = await OrganizationService.GetAllAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Could not retrieve organizations.", Severity.Error);
        }
    }

    private bool _passwordVisibility;
    private InputType _passwordInput = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;

    private bool _confirmPasswordVisibility;
    private InputType _confirmPasswordInput = InputType.Password;
    private string _confirmPasswordIcon = Icons.Material.Filled.VisibilityOff;

    private void TogglePasswordVisibility()
    {
        if (_passwordVisibility)
        {
            _passwordVisibility = false;
            _passwordIcon = Icons.Material.Filled.VisibilityOff;
            _passwordInput = InputType.Password;
        }
        else
        {
            _passwordVisibility = true;
            _passwordIcon = Icons.Material.Filled.Visibility;
            _passwordInput = InputType.Text;
        }
    }

    private void ToggleConfirmPasswordVisibility()
    {
        if (_confirmPasswordVisibility)
        {
            _confirmPasswordVisibility = false;
            _confirmPasswordIcon = Icons.Material.Filled.VisibilityOff;
            _confirmPasswordInput = InputType.Password;
        }
        else
        {
            _confirmPasswordVisibility = true;
            _confirmPasswordIcon = Icons.Material.Filled.Visibility;
            _confirmPasswordInput = InputType.Text;
        }
    }

    private async Task HandleRegisterAsync()
    {
        if (_isLoading) return;
        _isLoading = true;
        _errorMessage = "";

        try
        {
            var success = await AuthService.Register(_model);
            if (success)
            {
                Snackbar.Add("Account created! Please verify your email.", Severity.Info);
                NavigationManager.NavigateTo($"/verify-email?email={_model.Email}");
            }
            else
            {
                _errorMessage = "Registration failed. Email or Username may already be in use.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
