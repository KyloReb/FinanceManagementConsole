@inherits LayoutComponentBase
@implements IDisposable
@inject AuthService AuthService
@inject NavigationManager NavigationManager

@*
    The main layout for the Finance Management Console.

    Provides the top AppBar with navigation controls, theme toggling, and the side Drawer.
*@
<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Color="Color.Inherit" Fixed="true" Style="border-bottom: 1px solid var(--mud-palette-divider);">
        @* Sidebar Toggle Control *@
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />

        @* Desktop View Logo and Title (Clickable) *@
        <MudHidden Breakpoint="Breakpoint.Xs">
            <div class="d-flex align-center ml-2 mr-4 cursor-pointer brand-link" @onclick='() => NavigationManager.NavigateTo("/", true)' 
                 style="user-select: none; transition: opacity 0.2s;">
                <MudImage Src="favicon.png" Width="30" Height="30" Class="mr-2" />
                <MudText Typo="Typo.h6">Finance Management Console</MudText>
            </div>
        </MudHidden>

        @* Mobile View Logo and Title (Clickable) *@
        <MudHidden Breakpoint="Breakpoint.SmAndUp">
             <div class="d-flex align-center ml-2 cursor-pointer brand-link" @onclick='() => NavigationManager.NavigateTo("/", true)'>
                <MudImage Src="favicon.png" Width="24" Height="24" Class="mr-2" />
                <MudText Typo="Typo.h6">FMC</MudText>
            </div>
        </MudHidden>
        
        <MudSpacer />

        <AuthorizeView Context="authState">
            <Authorized>
                @* ACCOUNT DROPDOWN (Avatar & Name as Trigger) *@
                <MudMenu @bind-Open="_userMenuOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" 
                         Dense="true" Class="ml-1" PopoverClass="mud-elevation-25">
                    <ActivatorContent>
                        <div class="d-flex align-center cursor-pointer pa-1 rounded-pill user-menu-trigger" @onclick="ToggleUserMenu" @onclick:stopPropagation="true">
                            <MudText Typo="Typo.body2" Class="mr-3 ml-2 d-none d-sm-block">@GetDisplayName(authState.User)</MudText>
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Style="font-weight: 600;">
                                @GetInitials(authState.User)
                            </MudAvatar>
                        </div>
                    </ActivatorContent>
                    <ChildContent>
                            <div class="pa-4" style="min-width: 220px; background-color: var(--mud-palette-surface); border-bottom: 1px solid var(--mud-palette-divider);">
                                <MudText Typo="Typo.body2" Color="Color.Primary"><b>@GetDisplayName(authState.User)</b></MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="text-transform: uppercase; letter-spacing: 1px; font-weight: 500;">@GetRoleName(authState.User)</MudText>
                            </div>
                            <div class="py-2" style="background-color: var(--mud-palette-surface);">
                                <MudMenuItem Icon="@Icons.Material.Filled.Person" OnClick="@(() => NavigationManager.NavigateTo("/profile"))">Edit Profile</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Settings" OnClick="@(() => NavigationManager.NavigateTo("/settings"))">Account Settings</MudMenuItem>
                                <MudDivider Class="my-2" />
                                <MudMenuItem Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error" OnClick="LogoutAsync"><b>Logout</b></MudMenuItem>
                            </div>
                        </ChildContent>
                    </MudMenu>
                </Authorized>
            <NotAuthorized>
                <MudButton Href="/login" Variant="Variant.Text" Color="Color.Inherit" Class="mr-2">Log In</MudButton>
                <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Primary" Class="mr-3">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    @* Navigation Sidebar - Wrapped in AuthorizeView to prevent guest visibility *@
    <AuthorizeView>
        <Authorized>
            <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Anchor="Anchor.Left" Style="border-right: 1px solid var(--mud-palette-divider);">
                <NavMenu />
            </MudDrawer>
        </Authorized>
    </AuthorizeView>

    @* Main Page Content *@
    <MudMainContent Class="pa-4 pt-16">
        @Body
    </MudMainContent>
</MudLayout>

<style>
    .brand-link:hover {
        opacity: 0.8;
    }
    .user-menu-trigger:hover {
        background-color: var(--mud-palette-action-default-hover);
        border-radius: 20px;
    }
</style>

@code {
    private bool _drawerOpen = true;
    private bool _userMenuOpen = false;

    private void ToggleUserMenu() => _userMenuOpen = !_userMenuOpen;

    private async Task LogoutAsync()
    {
        // Force a UI refresh after logout to clear any potential caches
        await AuthService.Logout("current");
        NavigationManager.NavigateTo("/login", true);
    }

    protected override void OnInitialized()
    {
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private string GetDisplayName(System.Security.Claims.ClaimsPrincipal user)
    {
        var firstName = user.FindFirst("firstName")?.Value;
        var lastName = user.FindFirst("lastName")?.Value;
        
        if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
        {
            return $"{firstName} {lastName}".Trim();
        }
        
        return user.Identity?.Name ?? "User";
    }

    private string GetInitials(System.Security.Claims.ClaimsPrincipal user)
    {
        var firstName = user.FindFirst("firstName")?.Value;
        var lastName = user.FindFirst("lastName")?.Value;
        
        if (!string.IsNullOrWhiteSpace(firstName) && !string.IsNullOrWhiteSpace(lastName))
        {
            if (firstName.Length > 0 && lastName.Length > 0)
                return $"{firstName[0]}{lastName[0]}".ToUpper();
        }
        
        var name = user.Identity?.Name ?? "U";
        return name.Length > 0 ? name[0].ToString().ToUpper() : "U";
    }

    private string GetRoleName(System.Security.Claims.ClaimsPrincipal user)
    {
        var role = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value 
                ?? user.FindFirst("role")?.Value 
                ?? "User";
        return role;
    }

    public void Dispose()
    {
    }
}
