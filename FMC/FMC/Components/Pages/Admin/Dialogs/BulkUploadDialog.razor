@using FMC.Shared.DTOs
@using FMC.Services.Api
@using Microsoft.Extensions.Configuration
@using MudBlazor
@inject OrganizationApiService OrgService
@inject BulkUploadStateService StateService
@inject ISnackbar Snackbar
@inject IConfiguration Config
@inject NavigationManager Navigation

@*
    Bulk Upload Dialog
    -------------------
    This dialog facilitates the initial phase of the bulk upload workflow.
    It handles Excel file parsing, identity validation, and basic previewing.
*@

<MudDialog Class="fmc-premium-dialog compact">
    <TitleContent>
        <div class="fmc-dialog-header">
            <div class="fmc-icon-wrapper">
                <MudIcon Icon="@Icons.Material.Filled.AutoFixHigh" Class="fmc-header-icon" />
            </div>
            <div class="ml-3">
                <MudText Typo="Typo.h6" Class="fmc-title">Bulk Upload</MudText>
                <MudText Typo="Typo.caption" Class="fmc-subtitle">Batch processing portal</MudText>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="fmc-dialog-body">
            @if (_step == 1)
            {
                <div class="fmc-step-container animate__animated animate__fadeIn">
                    <div class="fmc-upload-card">
                        @if (_isLoading)
                        {
                            <div class="fmc-loader-overlay-compact glass" style="z-index: 30;">
                                <div class="fmc-loader-content">
                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" StrokeWidth="5" />
                                    <MudText Typo="Typo.subtitle2" Class="mt-4 fmc-loader-text">Analyzing Ledger Data...</MudText>
                                    <MudText Typo="Typo.caption" Class="fmc-loader-subtext">Validating cardholder identities</MudText>
                                </div>
                            </div>
                        }

                        <div class="fmc-upload-art-mini">
                            <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Class="fmc-cloud-icon-mini" />
                        </div>
                        
                        <MudText Typo="Typo.subtitle1" Class="fmc-upload-title mt-2">Prepare Your Data</MudText>
                        <MudText Typo="Typo.caption" Class="fmc-upload-desc px-4">
                            Select Excel (.xlsx) | Max 10,000 rows
                        </MudText>
                        
                        <div class="fmc-action-row mt-4">
                            <MudButton HtmlTag="label"
                                       Variant="Variant.Filled" 
                                       Color="Color.Primary"
                                       Class="fmc-btn-primary-compact"
                                       StartIcon="@Icons.Material.Filled.FileOpen"
                                       for="fmc-bulk-file-input">
                                Drag & Drop or Browse
                            </MudButton>
                            <InputFile id="fmc-bulk-file-input" 
                                       OnChange="@(async (InputFileChangeEventArgs e) => await HandleFileUpload(e.File))" 
                                       accept=".xlsx"
                                       style="position: absolute; width: 100%; height: 100%; top: 0; left: 0; opacity: 0; cursor: pointer; z-index: 10;" />
                        </div>

                        <div class="mt-4 fmc-template-link" style="position: relative; z-index: 20;">
                            <MudLink Href="@GetTemplateUrl()" Target="_blank" Underline="Underline.None">
                                <div class="d-flex align-center justify-center">
                                    <MudIcon Icon="@Icons.Material.Filled.FileDownload" Size="Size.Small" Class="mr-1" />
                                    <span>Download Template</span>
                                </div>
                            </MudLink>
                        </div>
                    </div>
                </div>
            }
            else if (_step == 2)
            {
                <div class="fmc-step-container animate__animated animate__slideInRight">
                    <div class="d-flex align-center justify-space-between mb-4 fmc-preview-header-refined">
                        <div class="fmc-status-pill-group">
                            <div class="fmc-status-pill valid">
                                <span class="count">@_rows.Count(r => r.ValidationError == null)</span>
                                <span class="label">VALID</span>
                            </div>
                            @if (_rows.Any(r => r.ValidationError != null))
                            {
                                <div class="fmc-status-pill fail">
                                    <span class="count">@_rows.Count(r => r.ValidationError != null)</span>
                                    <span class="label">FAIL</span>
                                </div>
                            }
                        </div>
                        
                        <div class="d-flex align-center gap-2">
                            <MudButton Variant="Variant.Text" Color="Color.Primary" 
                                       StartIcon="@Icons.Material.Filled.OpenInNew" 
                                       OnClick="OpenFullManager"
                                       Class="fmc-btn-ghost-sm-icon">
                                Manage Full Page
                            </MudButton>
                            
                            <MudToggleGroup T="bool" @bind-Value="_isCredit" Color="Color.Primary" Class="fmc-compact-toggle-mini">
                                <MudToggleItem Value="true" Text="Credit" />
                                <MudToggleItem Value="false" Text="Debit" />
                            </MudToggleGroup>
                        </div>
                    </div>

                    <div class="fmc-table-wrapper-compact">
                        <MudTable Items="_rows.Take(20)" Dense="true" Hover="true" FixedHeader="true" Height="220px" Elevation="0" Class="fmc-custom-table">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>SUBSCRIBER</MudTh>
                                <MudTh>CARD</MudTh>
                                <MudTh>AMOUNT</MudTh>
                                <MudTh>STATUS</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="row">
                                <MudTd>@row.RowNumber</MudTd>
                                <MudTd><b class="fmc-text-sm" style="white-space: nowrap;">@row.Subscriber</b></MudTd>
                                <MudTd><code class="fmc-card-code-mini" style="white-space: nowrap;">@MaskCard(row.CardNumber)</code></MudTd>
                                <MudTd>
                                    <span class="fmc-amount-sm fmc-financial-mono @(_isCredit ? "credit" : "debit")" style="white-space: nowrap;">
                                        @(_isCredit ? "+" : "-")₱@row.Amount.ToString("N2")
                                    </span>
                                </MudTd>
                                <MudTd>
                                    @if (row.ValidationError != null)
                                    {
                                        <MudTooltip Text="@row.ValidationError">
                                            <div class="fmc-badge-mini error">ERR</div>
                                        </MudTooltip>
                                    }
                                    else
                                    {
                                        <div class="fmc-badge-mini success">OK</div>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>

                        @if (_rows.Count > 20)
                        {
                            <div class="fmc-view-all-container">
                                <MudButton Variant="Variant.Text" Color="Color.Primary" 
                                           OnClick="OpenFullManager" 
                                           StartIcon="@Icons.Material.Filled.OpenInNew"
                                           Class="fmc-view-all-btn">
                                    View All @_rows.Count Rows in Full Manager
                                </MudButton>
                            </div>
                        }
                    </div>
                </div>
            }
            else if (_step == 3)
            {
                <div class="fmc-step-container fmc-success-state animate__animated animate__zoomIn">
                    <div class="fmc-success-art-mini">
                        @if (_result?.Failed > 0)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Large" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
                        }
                    </div>
                    <MudText Typo="Typo.h6" Class="fmc-success-title mt-n4">Batch Processed</MudText>
                    
                    <div class="fmc-result-grid-mini mb-4">
                        <div class="fmc-result-card-mini success">
                            <span class="val fmc-financial-mono">@_result?.Submitted</span>
                            <span class="lbl">SUBMITTED</span>
                        </div>
                        <div class="fmc-result-card-mini error">
                            <span class="val fmc-financial-mono">@_result?.Failed</span>
                            <span class="lbl">FAILED</span>
                        </div>
                    </div>

                    @* RESULT LOGS *@
                    <div class="fmc-result-logs">
                        <MudText Typo="Typo.caption" Class="fmc-log-title">TRANSACTION LEDGER LOGS</MudText>
                        <div class="fmc-log-container mt-1">
                            @if (_result?.Rows != null)
                            {
                                @foreach (var row in _result.Rows)
                                {
                                    <div class="fmc-log-entry @(row.ValidationError == null ? "success" : "error")">
                                        <div class="d-flex justify-space-between w-100">
                                            <span class="fmc-log-sub">#@row.RowNumber @row.Subscriber</span>
                                            <span class="fmc-log-status">@(row.ValidationError ?? "SUCCESSFULLY QUEUED")</span>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <div class="fmc-dialog-actions-compact">
            @if (_step == 1)
            {
                <MudButton OnClick="Cancel" Variant="Variant.Text" Class="fmc-btn-ghost-sm">Cancel</MudButton>
            }
            @if (_step == 2)
            {
                <MudButton OnClick="@(() => _step = 1)" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Class="fmc-btn-ghost-sm">Back</MudButton>
                <MudSpacer />
                <MudButton OnClick="SubmitBatch" Variant="Variant.Filled" 
                           Disabled="@(!_rows.Any(r => r.ValidationError == null) || _isLoading)" 
                           Class="fmc-btn-action-sm">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Submit Batch
                </MudButton>
            }
            @if (_step == 3)
            {
                <MudSpacer />
                <MudButton OnClick="Done" Variant="Variant.Filled" Class="fmc-btn-action-sm">Done</MudButton>
            }
        </div>
    </DialogActions>
</MudDialog>

