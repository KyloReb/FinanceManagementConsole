    /// <summary>
    /// Primary handler for processing authorizations on single transactions.
    /// </summary>
    private async Task HandleApprovalAsync(TransactionDto tx, bool approve)
    {
        if (approve)
        {
            // Step-up Security Verification: Require password for authorization
            var secOpts = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, BackdropClick = false };
            var secDialog = await DialogService.ShowAsync<SecurityVerificationDialog>("Security Verification", new DialogParameters(), secOpts);
            var secResult = await secDialog.Result;
            if (secResult is null || secResult.Canceled) return;
        }
        else
        {
            bool? result = await DialogService.ShowMessageBoxAsync(
                "Confirm Rejection", 
                "Are you sure you want to reject this transaction?", 
                yesText: "Yes, Reject", cancelText: "No, Cancel");
            if (result != true) return;

            // Prompt for rejection reason
            var reasonParams = new DialogParameters { ["ContentText"] = "Please provide a reason for rejecting this transaction. (optional)" };
            var reasonDialog = await DialogService.ShowAsync<RejectionDialog>("Reject Transaction", reasonParams, new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small });
            var reasonResult = await reasonDialog.Result;
            if (reasonResult is null || reasonResult.Canceled) return;
            _rejectionReason = (reasonResult.Data as string)?.Trim();
        }

        try
        {
            _processingGroupId = tx.Id.ToString();
            _processingIsApprove = approve;
            StateHasChanged();

            var success = approve 
                ? await OrgService.ApproveTransactionAsync(tx.Id)
                : await OrgService.RejectTransactionAsync(tx.Id, _rejectionReason ?? $"Rejected by {_currentUserName}.");

            if (success)
            {
                ShowSuccessOverlayAsync(approve ? "EXECUTION SUCCESSFUL" : "REQUEST DENIED",
                                      approve ? "The transaction has been securely authorized and logged." : "The transaction has been denied and removed from the queue.");
                await LoadQueueDataAsync();
            }
        }
        catch (Exception ex)
        {
            ShowApprovalErrorAsync(ex.Message, isBatch: false);
        }
        finally
        {
            _processingGroupId = null;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Secondary handler for processing bulk batch approvals/rejections from the UI.
    /// </summary>
    private async Task HandleGroupApprovalAsync(TransactionGroup group, bool approve)
    {
        // Security gate: require password re-verification for all approval actions
        if (approve)
        {
            var secOpts = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, BackdropClick = false };
            var secDialog = await DialogService.ShowAsync<SecurityVerificationDialog>("Security Verification", new DialogParameters(), secOpts);
            var secResult = await secDialog.Result;
            if (secResult is null || secResult.Canceled) return;
        }

        try
        {
            _processingGroupId = group.BatchId?.ToString() ?? group.Transactions.FirstOrDefault()?.Id.ToString();
            _processingIsApprove = approve;
            StateHasChanged();

            if (group.BatchId.HasValue)
            {
                if (approve)
                {
                    await OrgService.ApproveBatchAsync(group.BatchId.Value);
                    ShowSuccessOverlayAsync("BATCH AUTHORIZED", "The entire settlement batch has been processed successfully.");
                }
                else
                {
                    string rejectMarkup = $@"
                        <div class='d-flex flex-column align-center text-center pt-6 pb-2 px-2'>
                            <div class='mb-4' style='background: rgba(239,68,68,0.1); border-radius: 50%; width:72px; height:72px; display:flex; align-items:center; justify-content:center; box-shadow: 0 0 20px rgba(239,68,68,0.2);'>
                                <svg style='width:36px;height:36px;color:#ef4444;' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'></circle><line x1='15' y1='9' x2='9' y2='15'></line><line x1='9' y1='9' x2='15' y2='15'></line></svg>
                            </div>
                            <h3 style='font-weight:900;letter-spacing:0.05em;font-size:1.1rem;color:var(--mud-palette-text-primary);margin-bottom:8px;'>REJECT BATCH ALLOTMENT</h3>
                            <p style='color:var(--mud-palette-text-secondary);font-size:0.85rem;line-height:1.6;max-width:280px;'>Are you sure you want to reject this entire batch of {group.Transactions.Count} requests? This action cannot be reversed.</p>
                        </div>
                    ";
                    var rejectOptions = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, NoHeader = true };
                    bool? confirm = await DialogService.ShowMessageBoxAsync(title: default, markupMessage: new MarkupString(rejectMarkup), yesText: "Confirm Reject", cancelText: "Go Back", options: rejectOptions);
                    
                    if (confirm != true) 
                    {
                        _processingGroupId = null;
                        return;
                    }

                    // Require rejection reasoning for entire batches
                    var parameters = new DialogParameters { ["ContentText"] = "Enter rejection reason for this entire batch." };
                    var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small };
                    
                    var dialog = await DialogService.ShowAsync<RejectionDialog>("Batch Rejection", parameters, options);
                    var result = await dialog.Result;

                    if (result is not null && !result.Canceled)
                    {
                        var reason = result.Data as string ?? $"Batch rejected by {_currentUserName}.";
                        await OrgService.RejectBatchAsync(group.BatchId.Value, reason);
                        ShowSuccessOverlayAsync("BATCH DENIED", "The batch has been rejected and removed from the active queue.");
                    }
                    else return; // Cancelled reasoning prompt
                }
            }
            else
            {
                var tx = group.Transactions.First();
                await HandleApprovalAsync(tx, approve);
            }
            
            await LoadQueueDataAsync();
        }
        catch (Exception ex)
        {
            ShowApprovalErrorAsync(ex.Message, isBatch: group.BatchId.HasValue, batchCount: group.Transactions.Count);
        }
        finally
        {
            _processingGroupId = null;
            StateHasChanged();
        }
    }

    #endregion

    #region Premium Error Handling

    private void ShowApprovalErrorAsync(string rawMessage, bool isBatch, int batchCount = 0)
    {
        bool isLiquidityError = rawMessage.Contains("insufficient", StringComparison.OrdinalIgnoreCase)
                             || rawMessage.Contains("liquidity", StringComparison.OrdinalIgnoreCase);

        var batchNote = isBatch && batchCount > 0
            ? $" ({batchCount} settlement{(batchCount > 1 ? "s" : "")})"
            : string.Empty;

        _errorTitle = isLiquidityError ? "INSUFFICIENT LIQUIDITY" : (isBatch ? "BATCH FAILED" : "ACTION FAILED");
        
        if (isLiquidityError)
        {
            _errorSubtext = $"The organization's corporate float does not have enough balance to cover this settlement{batchNote}. Contact your SuperAdmin to top-up the wallet.";
        }
        else
        {
            _errorSubtext = rawMessage;
        }

        _showErrorOverlay = true;
        StateHasChanged();
    }

    private void ShowSuccessOverlayAsync(string title, string subtext)
    {
        _successTitle = title;
        _successSubtext = subtext;
        _showSuccessOverlay = true;
        StateHasChanged();
    }

