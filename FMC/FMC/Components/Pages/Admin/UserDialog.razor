@using FMC.Shared.Auth
@using FMC.Shared.DTOs.User
@using FMC.Services.Api
@using FMC.Shared.DTOs.Organization
@inject AdminService AdminService
@inject OrganizationApiService OrganizationService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider

<MudDialog Class="fmc-theme-dialog">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(User == null ? Icons.Material.Filled.PersonAdd : Icons.Material.Filled.Edit)" Class="mr-3 mb-n1" />
            @(User == null ? "Create New System Account" : $"Update Details for {User.DisplayName}")
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_showSuccessOverlay || _showErrorOverlay)
        {
            <div class="fmc-success-overlay @(_showErrorOverlay ? "fmc-error-overlay" : "")">
                <div class="fmc-success-inner">
                    <div class="fmc-success-icon-container @(_showErrorOverlay ? "fmc-error-icon" : "")">
                        <div class="fmc-glow-pulse"></div>
                        <MudIcon Icon="@(_showErrorOverlay ? Icons.Material.Filled.Error : Icons.Material.Filled.Verified)" Class="fmc-success-icon" Style="color: inherit;" />
                    </div>
                    <MudText Typo="Typo.h5" Class="fmc-success-text" Style="@(_showErrorOverlay ? "color:#ef5350;" : "")">@(_showErrorOverlay ? _errorTitle : _successTitle)</MudText>
                    <MudText Typo="Typo.body1" Class="fmc-success-subtext">@(_showErrorOverlay ? _errorMessage : _successMessage)</MudText>

                    <MudButton Variant="Variant.Filled"
                               Color="@(_showErrorOverlay ? Color.Error : Color.Success)"
                               OnClick="DismissOverlay"
                               Style="margin-top:24px; text-transform:none; font-weight:800; border-radius:12px; height:48px; min-width:160px;">
                        @(_showErrorOverlay ? "Dismiss" : "Done")
                    </MudButton>
                </div>
            </div>
        }
        <MudForm @ref="_form" @bind-IsValid="@_success" @bind-Errors="@_errors">
            <MudGrid Spacing="2">
                @* ── ACCOUNT STATUS CARD (Edit mode only, shown at top for immediate context) ── *@
                @if (User != null)
                {
                    <MudItem xs="12">
                        <div style="border: 2px solid @(_model.IsActive ? "rgba(76, 175, 80, 0.4)" : "rgba(244, 67, 54, 0.4)"); border-radius: 14px; padding: 14px 16px; background: @(_model.IsActive ? "rgba(76, 175, 80, 0.05)" : "rgba(244, 67, 54, 0.05)"); transition: all 0.3s ease;">
                            <div class="d-flex align-center justify-space-between">
                                <div class="d-flex align-center gap-3">
                                    <div style="position: relative; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: @(_model.IsActive ? "rgba(76,175,80,0.12)" : "rgba(244,67,54,0.12)"); border-radius: 50%;">
                                        <MudIcon Icon="@(_model.IsActive ? Icons.Material.Filled.VerifiedUser : Icons.Material.Filled.PersonOff)" 
                                                 Style="@($"color: {(_model.IsActive ? "var(--mud-palette-success)" : "var(--mud-palette-error)")}; font-size: 1.3rem;")" />
                                        @if (_model.IsActive)
                                        {
                                            <div style="position: absolute; bottom: 1px; right: 1px; width: 10px; height: 10px; background: var(--mud-palette-success); border-radius: 50%; border: 2px solid var(--mud-palette-surface); animation: pulse 2s infinite;"></div>
                                        }
                                        else
                                        {
                                            <div style="position: absolute; bottom: 1px; right: 1px; width: 10px; height: 10px; background: var(--mud-palette-error); border-radius: 50%; border: 2px solid var(--mud-palette-surface);"></div>
                                        }
                                    </div>
                                    <div>
                                        <div class="d-flex align-center gap-2">
                                            <MudText Style="font-weight: 900; font-size: 0.9rem;">Account Status</MudText>
                                            <MudChip T="string" Size="Size.Small" 
                                                     Color="@(_model.IsActive ? Color.Success : Color.Error)" 
                                                     Variant="Variant.Filled"
                                                     Style="height: 18px; font-size: 0.6rem; font-weight: 900; letter-spacing: 0.06em; padding: 0 8px; margin: 0; text-transform: uppercase;">
                                                @(_model.IsActive ? "ACTIVE" : "SUSPENDED")
                                            </MudChip>
                                        </div>
                                        <MudText Typo="Typo.caption" Style="opacity: 0.65; font-weight: 700;">
                                            @(_model.IsActive ? "User can log in and access the system." : "Login blocked. Access is fully revoked.")
                                        </MudText>
                                    </div>
                                </div>
                                <MudSwitch @bind-Value="_model.IsActive" Color="Color.Success" 
                                           Disabled="@(User != null && User.Role == Roles.SuperAdmin)" />
                            </div>
                        </div>
                    </MudItem>
                    <MudItem xs="12"><MudDivider /></MudItem>
                }

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.FirstName" Label="First Name" 
                                  Variant="Variant.Outlined" Required="true" RequiredError="First name is required" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.LastName" Label="Last Name" 
                                  Variant="Variant.Outlined" Required="true" RequiredError="Last name is required" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Email" Label="Email Address" 
                                  Variant="Variant.Outlined" Required="true" RequiredError="Email is required" 
                                  InputType="InputType.Email" 
                                  TextChanged="OnEmailChanged" />
                </MudItem>

                @if (User == null)
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.UserName" Label="System Login Identifier (Username)" 
                                      Variant="Variant.Outlined" Required="true" RequiredError="User name is required" 
                                      HelperText="Used for system authentication" />
                    </MudItem>
                }

                <MudItem xs="12">
                    <MudSelect T="string" @bind-Value="_model.Organization" Label="Organization Affiliation" 
                               Variant="Variant.Outlined" Required="true" RequiredError="Organization is required" 
                               AnchorOrigin="Origin.BottomCenter" Disabled="@(_isCEO || (User != null && User.Role == Roles.SuperAdmin))">
                        @if (!_isCEO)
                        {
                            <MudSelectItem Value="@((string?)null)" Disabled="true">Select Organization</MudSelectItem>
                            @foreach (var org in _organizations)
                            {
                                <MudSelectItem Value="@org.Name">@org.Name</MudSelectItem>
                            }
                        }
                        else
                        {
                            <MudSelectItem Value="@_model.Organization">@_model.Organization</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_password" Label="Password" 
                                  Variant="Variant.Outlined" 
                                  InputType="@_passwordInput" 
                                  Required="@(User == null)" 
                                  Disabled="@(User != null && User.Role == Roles.SuperAdmin)"
                                  RequiredError="Password is required"
                                  Adornment="Adornment.End" AdornmentIcon="@_passwordIcon" OnAdornmentClick="TogglePasswordVisibility"
                                  HelperText="@(User != null && User.Role == Roles.SuperAdmin ? "Password changes disabled for SuperAdmin accounts" : User != null ? "Leave blank to keep current password" : "Minimum 6 characters")" />
                </MudItem>

                <MudItem xs="12">
                    <MudSelect T="string" Label="System Role" @bind-Value="_selectedRole"
                               Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter"
                               Disabled="@(User != null && User.Role == Roles.SuperAdmin)"
                               PopoverClass="fmc-roles-select" offsety="true" Dense="true">
                        @if (!_isCEO)
                        {
                            <MudSelectItem Value="@Roles.SuperAdmin">Super Administrator</MudSelectItem>
                            <MudSelectItem Value="@Roles.CEO">CEO (Primary Subscriber)</MudSelectItem>
                        }
                        <MudSelectItem Value="@Roles.Maker">Maker</MudSelectItem>
                        <MudSelectItem Value="@Roles.Approver">Approver</MudSelectItem>
                        @if (!_isCEO)
                        {
                            <MudSelectItem Value="@Roles.User">Standard User (Principal)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <style>
                    .fmc-roles-select { 
                        min-width: 250px !important; 
                        max-width: 350px !important;
                    }
                    .fmc-roles-select .mud-list-item { padding-top: 4px; padding-bottom: 4px; }
                </style>
            </MudGrid>
        </MudForm>

        <style>
            .fmc-theme-dialog {
                position: relative !important;
                overflow: hidden !important;
            }
            .fmc-theme-dialog .mud-dialog-content {
                position: static !important;
            }
            .fmc-success-overlay {
                position: absolute !important;
                top: 0 !important;
                left: 0 !important;
                right: 0 !important;
                bottom: 0 !important;
                width: 100% !important;
                height: 100% !important;
                display: flex;
                align-items: center;
                justify-content: center;
                background: rgba(15, 23, 42, 0.45);
                backdrop-filter: blur(10px);
                z-index: 2000;
                animation: fmc-fade-in 0.18s ease both;
            }
            .fmc-success-inner {
                width: min(420px, calc(100% - 32px));
                background: var(--mud-palette-surface) !important;
                border: 1px solid var(--mud-palette-divider);
                border-radius: 20px;
                padding: 32px 24px;
                text-align: center;
                box-shadow: 0 20px 50px rgba(0,0,0,0.3);
                animation: fmc-modal-pop 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) both;
                position: relative;
                overflow: hidden;
            }
            .fmc-success-icon-container{
                width: 72px;
                height: 72px;
                border-radius: 24px;
                margin: 0 auto 18px auto;
                display: flex;
                align-items: center;
                justify-content: center;
                background: rgba(46,125,50,0.12);
                color: #2e7d32;
                position: relative;
            }
            .fmc-error-icon{
                background: rgba(239,68,68,0.12);
                color: #ef4444;
            }
            .fmc-success-icon{ font-size: 2.8rem !important; }
            .fmc-success-text{ font-weight: 950 !important; letter-spacing: 0.03em !important; margin-bottom: 8px !important; }
            .fmc-success-subtext{ opacity: 0.72; max-width: 420px; margin: 0 auto; line-height: 1.6; }
            .fmc-glow-pulse{
                position:absolute;
                inset:-4px;
                border-radius: 28px;
                opacity: 0;
                animation: fmc-pulse-ring 2s cubic-bezier(0.24,0,0.38,1) infinite;
                border: 2px solid currentColor;
            }
            @@keyframes fmc-fade-in { from { opacity: 0; } to { opacity: 1; } }
            @@keyframes fmc-modal-pop { from { opacity: 0; transform: translateY(10px) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
            @@keyframes fmc-pulse-ring { 0% { transform: scale(0.98); opacity: 0.7; } 50% { transform: scale(1.10); opacity: 0; } 100% { transform: scale(0.98); opacity: 0; } }
        </style>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(_isLoading || !_success || _showSuccessOverlay || _showErrorOverlay)">
            @if (_isLoading)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Processing...</MudText>
            }
            else
            {
                <MudText>@(User == null ? "Create User" : "Save Changes")</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public UserDto? User { get; set; }

    private MudForm _form = default!;
    private bool _success;
    private string[] _errors = { };
    private bool _isLoading;

    private UserDto _model = new() { IsActive = true };
    private List<OrganizationDto> _organizations = new();
    private string _password = "";
    private string _selectedRole = Roles.Maker;
    private bool _isCEO = false;
    private bool _isSuperAdmin = false;

    private bool _passwordVisibility;
    private InputType _passwordInput = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;

    private bool _showSuccessOverlay;
    private bool _showErrorOverlay;
    private string _successTitle = "Account Security Provisioned";
    private string _successMessage = "";
    private string _errorTitle = "Provisioning Action Failed";
    private string _errorMessage = "";

    private void TogglePasswordVisibility()
    {
        if (_passwordVisibility)
        {
            _passwordVisibility = false;
            _passwordIcon = Icons.Material.Filled.VisibilityOff;
            _passwordInput = InputType.Password;
        }
        else
        {
            _passwordVisibility = true;
            _passwordIcon = Icons.Material.Filled.Visibility;
            _passwordInput = InputType.Text;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _isCEO = user.IsInRole(Roles.CEO);
        _isSuperAdmin = user.IsInRole(Roles.SuperAdmin);

        try
        {
            if (!_isCEO)
            {
                _organizations = await OrganizationService.GetAllAsync();
            }
            else if (User == null)
            {
                // For new users created by CEO, pre-fill their organization
                _model.Organization = user.FindFirst("organization")?.Value;
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to initialize active tenants.", Severity.Error);
        }

        if (User != null)
        {
            _model = new UserDto
            {
                Id = User.Id,
                UserName = User.UserName,
                Email = User.Email,
                FirstName = User.FirstName,
                LastName = User.LastName,
                Organization = User.Organization,
                IsActive = User.IsActive,
                Role = User.Role
            };
            _selectedRole = User.Role;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        // SuperAdmin and CEO must pass security verification before committing account changes.
        if ((_isSuperAdmin || _isCEO) && !_showSuccessOverlay && !_showErrorOverlay)
        {
            var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
            var secDialog = await DialogService.ShowAsync<SecurityVerificationDialog>("Security Verification", options);
            var secResult = await secDialog.Result;
            if (secResult is null || secResult.Canceled) return;
        }

        _isLoading = true;
        try
        {
            _model.Role = _selectedRole;
            (bool Succeeded, string? Error) result;

            if (User == null)
            {
                var createDto = new CreateUserDto
                {
                    UserName = _model.UserName!,
                    Email = _model.Email!,
                    FirstName = _model.FirstName!,
                    LastName = _model.LastName!,
                    Organization = _model.Organization!,
                    Password = _password,
                    Role = _model.Role
                };
                result = await AdminService.CreateUserAsync(createDto);
            }
            else
            {
                var updateDto = new UpdateUserDto
                {
                    Id = _model.Id,
                    Email = _model.Email!,
                    FirstName = _model.FirstName!,
                    LastName = _model.LastName!,
                    Organization = _model.Organization!,
                    Password = string.IsNullOrWhiteSpace(_password) ? null : _password,
                    Role = _model.Role,
                    IsActive = _model.IsActive
                };
                result = await AdminService.UpdateUserAsync(updateDto);
            }

            if (result.Succeeded)
            {
                _successMessage = User == null
                    ? $"Account created securely for {_model.FirstName} {_model.LastName}."
                    : $"Account changes saved securely for {_model.FirstName} {_model.LastName}.";
                _showSuccessOverlay = true;
                StateHasChanged();
            }
            else
            {
                _errorMessage = result.Error ?? "Unable to process this request. Please try again.";
                _showErrorOverlay = true;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _showErrorOverlay = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void DismissOverlay()
    {
        if (_showSuccessOverlay)
        {
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            _showErrorOverlay = false;
            StateHasChanged();
        }
    }

    private void OnEmailChanged(string value)
    {
        if (User == null && (string.IsNullOrWhiteSpace(_model.UserName) || _model.UserName == _model.Email))
        {
            _model.UserName = value;
        }
        _model.Email = value;
    }
}
