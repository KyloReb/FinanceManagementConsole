@using FMC.Shared.DTOs.Organization
@using MudBlazor
@using FMC.Services.Api
@using Microsoft.AspNetCore.Components.Authorization

<MudDialog Class="fmc-balance-dialog">
    <TitleContent>
        <div class="d-flex align-center px-2 pt-2">
            <MudIcon Icon="@(IsCredit ? Icons.Material.Filled.AccountBalanceWallet : Icons.Material.Filled.Payments)" 
                     Color="@(IsCredit ? Color.Success : Color.Error)" Class="mr-3" />
            <MudText Typo="Typo.h6" Style="font-weight: 800;">@(IsCredit ? "Credit Institutional Wallet" : "Debit Institutional Wallet")</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="pa-4">
            @* SUBSCRIBER IDENTITY SECTION *@
            <div class="fmc-subscriber-header mb-8">
                <div class="d-flex align-center">
                    <MudAvatar Color="@(IsCredit ? Color.Success : Color.Error)" Variant="Variant.Filled" Size="Size.Large" Class="mr-4" Style="font-weight: 800;">
                        @Organization.Name?[0]
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight: 900; line-height: 1.1;">@Organization.Name</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">TENANT: @Organization.Id.ToString().ToUpper()</MudText>
                    </div>
                </div>
            </div>

            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2" Class="mb-1" Style="font-weight: 800; color: var(--mud-palette-text-secondary); opacity: 0.8;">ADJUSTMENT AMOUNT (PHP)</MudText>
                    <MudNumericField T="decimal?"
                                     Value="_amount"
                                     ValueChanged="OnAmountChanged"
                                     Variant="Variant.Outlined" 
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Payments"
                                     Format="N2" HideSpinButtons="true" Min="0.01m"
                                     Placeholder="0.00" Class="fmc-dashboard-amount-field"
                                     Validation="@(new Func<decimal?, string?>(ValidateAmount))" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudTextField @bind-Value="_label" Label="Transaction Memo / Justification (Optional)" 
                                  Placeholder="Specify the reason for this manual ledger update..."
                                  Variant="Variant.Outlined" Lines="2" />
                </MudItem>
            </MudGrid>

            @* IMPACT ANALYTICS *@
            <div class="mt-8 fmc-impact-summary">
                <div class="d-flex justify-space-between mb-2">
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Current Liquidity:</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 700;">@Organization.TotalBalance.ToString("C")</MudText>
                </div>
                <div class="d-flex justify-space-between align-center">
                    <MudText Typo="Typo.body1" Style="font-weight: 800;">Pro-forma Result:</MudText>
                    <MudText Typo="Typo.h5" Style="font-weight: 900; font-family: 'JetBrains Mono', monospace;" 
                             Color="@((CalculateNewBalance() ?? 0) < 0 ? Color.Error : Color.Success)">
                        @((CalculateNewBalance() ?? 0).ToString("C"))
                    </MudText>
                </div>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="px-8 pb-8 d-flex w-100 gap-3">
            <MudButton OnClick="Cancel" Variant="Variant.Text" Style="text-transform:none; font-weight: 700;">Discard</MudButton>
            <MudSpacer />
            <MudButton Color="@(IsCredit ? Color.Success : Color.Error)" 
                       Variant="Variant.Filled" 
                       Disabled="@(!IsFormValid())" 
                       OnClick="HandleSubmitClick"
                       Style="text-transform:none; font-weight: 800; border-radius: 12px; height: 48px; min-width: 180px;">
                @if (_isProcessing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Processing...</span>
                }
                else
                {
                    <span>Confirm @(IsCredit ? "Credit" : "Debit") Selection</span>
                }
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
    .fmc-balance-dialog { border-radius: 20px !important; overflow: hidden; background-color: var(--mud-palette-surface) !important; max-width: 480px !important; }
    
    .fmc-subscriber-header { padding: 12px; background: var(--mud-palette-background-grey); border-radius: 16px; border: 1px solid var(--mud-palette-divider); }
    
    .fmc-dashboard-amount-field .mud-input-root { font-size: 2rem !important; font-weight: 900 !important; color: var(--mud-palette-text-primary) !important; }
    
    .fmc-impact-summary { background: var(--mud-palette-background-grey); border-radius: 16px; padding: 20px; border: 1px solid var(--mud-palette-divider); }
</style>

@code {
    [Inject] private OrganizationApiService OrgService { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public OrganizationDto Organization { get; set; } = default!;
    [Parameter] public bool IsCredit { get; set; }

    private decimal? _amount;
    private string _label = "";
    private bool _isProcessing;

    private string? ValidateAmount(decimal? value)
    {
        if (value == null || value <= 0) return "Amount must be greater than 0";
        return null;
    }

    private void OnAmountChanged(decimal? value)
    {
        _amount = value;
        StateHasChanged();
    }

    private bool IsFormValid()
    {
        return (_amount ?? 0) > 0 && !_isProcessing;
    }

    private decimal? CalculateNewBalance()
    {
        if (_amount == null) return Organization.TotalBalance;
        return IsCredit ? Organization.TotalBalance + _amount : Organization.TotalBalance - _amount;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task HandleSubmitClick()
    {
        if (!IsFormValid()) return;

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<SecurityVerificationDialog>("", options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await SubmitFinalAsync();
        }
    }

    private async Task SubmitFinalAsync()
    {
        try
        {
            _isProcessing = true;
            decimal adjustment = IsCredit ? (_amount ?? 0) : -(_amount ?? 0);
            var success = await OrgService.AdjustBalanceAsync(Organization.Id, adjustment, _label);
            
            if (success)
            {
                OrgService.NotifyDataChanged();
                Snackbar.Add($"Institutional ledger updated successfully for {Organization.Name}", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Failed to commit organization ledger adjustment.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"System Infrastructure Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }
}
