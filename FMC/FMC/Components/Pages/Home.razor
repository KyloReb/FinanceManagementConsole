@page "/"
@using FMC.Shared.Auth
@using FMC.Shared.DTOs.Organization
@using FMC.Shared.DTOs.User
@using FMC.Shared.DTOs.Admin
@using FMC.Components.Dashboard
@using FMC.Services.Api
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthProvider
@inject ISnackbar Snackbar
@inject ApiFinanceService FinanceService
@inject OrganizationApiService OrgService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ThemeService ThemeService
@inject FMC.Services.Api.AuthService AuthService
@implements IDisposable

<div class="fmc-dashboard-root @(ThemeService.IsDarkMode ? "fmc-dark-mode" : "fmc-light-mode")">
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <AuthorizeView Roles="@(Roles.SuperAdmin + "," + Roles.CEO + "," + Roles.SuperAdminApprover)">
        <Authorized>
            <MudGrid Class="mb-4">
                <MudItem xs="12">
                    <div class="d-flex align-center">
                        <div class="fmc-header-accent mr-5"></div>
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.h3" Class="fmc-hero-text">@(context.User.IsInRole(Roles.CEO) ? "Corporate Dashboard" : context.User.IsInRole(Roles.SuperAdminApprover) ? "Approval Control Center" : "Control Center")</MudText>
                            <MudText Typo="Typo.subtitle1" Class="fmc-subtitle">@(context.User.IsInRole(Roles.CEO) ? "Organization Capital & Workforce Oversight" : context.User.IsInRole(Roles.SuperAdminApprover) ? "Cross-Organizational Approval & Oversight" : "System Health & Multi-Tenant Capital Oversight")</MudText>
                        </div>
                    </div>
                </MudItem>
            </MudGrid>
            
            <MudGrid Spacing="2" Class="mb-8">
                @if (!context.User.IsInRole(Roles.SuperAdmin) && !context.User.IsInRole(Roles.SuperAdminApprover))
                {
                    var ceoOrg = _organizations.FirstOrDefault();
                    var walletLimit   = ceoOrg?.WalletLimit ?? 0;              // Authorized ceiling
                    var totalBalance  = ceoOrg?.TotalBalance ?? 0;             // Aggregate cash (org + users)
                    var balanceUsed   = ceoOrg?.Usage ?? 0;                    // Distributed to cardholders
                    var currentBal    = ceoOrg?.RemainingBalance ?? 0;         // Mother-account cash
                    var usedPct       = walletLimit > 0 ? (balanceUsed / walletLimit) * 100m : 0m;
                    var remainPct     = walletLimit > 0 ? (currentBal / walletLimit) * 100m : 0m; // Cash as % of limit
                    var balColor      = remainPct <= 20m ? Color.Error : (remainPct <= 40m ? Color.Warning : Color.Success);

                    @* CEO: Wallet Balance — authorized capacity *@
                    <MudItem xs="6" sm="4">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">WALLET BALANCE</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h4" Class="fmc-kpi-val fmc-responsive-val">
                                        @walletLimit.ToString("C0")
                                    </MudText>
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:700;">Authorized wallet capacity</MudText>
                            </div>
                            <div class="fmc-card-icon-bg primary"><MudIcon Icon="@Icons.Material.Filled.Wallet" /></div>
                            <div class="fmc-card-progress primary"></div>
                        </div>
                    </MudItem>
                    @* CEO: Usage — distributed to cardholders *@
                    <MudItem xs="6" sm="4">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">USAGE</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h4" Class="fmc-kpi-val fmc-responsive-val" Color="Color.Info">@balanceUsed.ToString("C0")</MudText>
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:700;">@usedPct.ToString("F1")% of balance allocated</MudText>
                            </div>
                            <div class="fmc-card-icon-bg info"><MudIcon Icon="@Icons.Material.Filled.Payments" /></div>
                            <div class="fmc-card-progress info"></div>
                        </div>
                    </MudItem>
                    @* CEO: Remaining Balance — remaining available *@
                    <MudItem xs="6" sm="4">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">REMAINING BALANCE</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h4" Class="fmc-kpi-val fmc-responsive-val" Color="@balColor">
                                        @currentBal.ToString("C0")
                                    </MudText>
                                </div>
                                <div class="d-flex align-center gap-1 mt-1">
                                    <MudProgressLinear Value="@((double)remainPct)" Max="100" Color="@balColor" Rounded="true" Style="height:6px; flex:1;" />
                                    <MudText Typo="Typo.caption" Style="font-weight:900; font-size:0.65rem; white-space:nowrap;">@remainPct.ToString("F0")% left</MudText>
                                </div>
                            </div>
                            <div class="fmc-card-icon-bg success"><MudIcon Icon="@Icons.Material.Filled.AccountBalance" /></div>
                            <div class="fmc-card-progress success"></div>
                        </div>
                    </MudItem>
                }
            </MudGrid>

            @* ── INTELLIGENCE OVERSIGHT + PENDING (SuperAdmin / SuperAdminApprover: side-by-side) ── *@
            @if (_isSuperAdmin || _isSuperAdminApprover)
            {
                <div class="fmc-equal-row">
                    @if (_showOversightPanel)
                    {
                        <div class="fmc-equal-col">
                            <div class="fmc-oversight-wrapper">
                                <ExecutiveAlertPanel Organizations="_organizations" 
                                                     Loading="_loading" 
                                                     OnActionCompleted="RefreshDashboard"
                                                     OnDismissed="HandleOversightDismissed" />
                            </div>
                        </div>
                    }
                    <div class="fmc-equal-col">
                        <div class="fmc-pending-surface fmc-pending-panel" style="padding: 24px;">
                            <div style="margin-bottom: 12px;">
                                <div class="d-flex align-center justify-space-between">
                                    <div class="d-flex align-center">
                                        <div class="fmc-header-icon fmc-warning-icon-bg mr-3" style="display:flex; align-items:center; justify-content:center;">
                                            <svg xmlns="http://www.w3.org/2000/svg" height="20" width="20" viewBox="0 0 24 24" fill="#f57c00"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                                        </div>
                                        <div>
                                            <div style="font-weight: 900; font-size: 1rem; line-height: 1.5;">Pending Requests</div>
                                            <div style="font-size: 0.75rem; color: var(--mud-palette-text-secondary); font-weight: 600;">Awaiting authorization</div>
                                        </div>
                                    </div>
                                    <div class="d-flex align-center gap-2">
                                        <div class="fmc-pending-count-badge">
                                            <span class="fmc-pending-count-num">@_pendingCount</span>
                                            <span class="fmc-pending-count-lbl">total</span>
                                        </div>
                                        <button title="Refresh Pending Requests"
                                                class="@(_pendingLoading ? "fmc-spin" : "")"
                                                style="background: rgba(var(--mud-palette-primary-rgb), 0.05); border-radius: 8px; width: 32px; height: 32px; flex-shrink: 0; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;"
                                                @onclick="(() => _ = RefreshPendingRequests())">
                                            <svg xmlns="http://www.w3.org/2000/svg" height="18" width="18" viewBox="0 0 24 24" fill="var(--mud-palette-primary)"><path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
                                        </button>
                                        <button title="Sort requests"
                                                style="background: rgba(var(--mud-palette-primary-rgb), 0.05); border-radius: 8px; width: 32px; height: 32px; flex-shrink: 0; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;"
                                                @onclick="TogglePendingSort">
                                            <svg xmlns="http://www.w3.org/2000/svg" height="18" width="18" viewBox="0 0 24 24" fill="var(--mud-palette-primary)" style="transition: transform 0.2s;">
                                                <path d="M12 5.83L15.17 9l1.41-1.41L12 3 7.41 7.59 8.83 9 12 5.83zm0 12.34L8.83 15l-1.41 1.41L12 21l4.59-4.59L15.17 15 12 18.17z"/>
                                            </svg>
                                        </button>
                                        <a href="/pending-requests"
                                           title="View all pending requests"
                                           style="background: rgba(var(--mud-palette-primary-rgb), 0.05); border-radius: 8px; width: 32px; height: 32px; flex-shrink: 0; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; text-decoration: none;">
                                            <svg xmlns="http://www.w3.org/2000/svg" height="18" width="18" viewBox="0 0 24 24" fill="var(--mud-palette-primary)"><path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                                        </a>
                                    </div>
                                </div>
                            </div>
                            @if (_pendingLoading)
                            {
                                <div class="d-flex flex-column gap-2" style="padding:4px 0;">
                                    @for (int i = 0; i < 3; i++)
                                    {
                                        <div class="d-flex align-center gap-3 pa-3" style="border-radius:10px; background:var(--mud-palette-background-grey);">
                                            <div class="fmc-pending-skel" style="width:32px; height:32px; border-radius:8px;"></div>
                                            <div style="flex:1;">
                                                <div class="fmc-pending-skel" style="width:60%; height:12px; margin-bottom:6px;"></div>
                                                <div class="fmc-pending-skel" style="width:40%; height:10px;"></div>
                                            </div>
                                            <div class="fmc-pending-skel" style="width:80px; height:14px;"></div>
                                        </div>
                                    }
                                </div>
                            }
                            else if (_pendingCount == 0)
                            {
                                <div class="d-flex flex-column align-center justify-center pa-6" style="opacity: 0.5;">
                                    <svg xmlns="http://www.w3.org/2000/svg" height="32" width="32" viewBox="0 0 24 24" fill="var(--mud-palette-text-primary)"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                                    <div class="mt-2" style="font-weight: 800;">All clear — no pending requests.</div>
                                </div>
                            }
                            else
                            {
                                <div style="max-height: 370px; overflow-y: auto; padding-right: 4px;" class="fmc-pending-list" id="fmc-pending-list">
                                    @foreach (var pt in _pendingTransactions)
                                        {
                                            var initials = string.IsNullOrEmpty(pt.MakerName) ? "S" : string.Concat(pt.MakerName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(w => w[0]))[..Math.Min(2, pt.MakerName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length)];
                                            var isApproving = _homeApprovingId == pt.Id;
                                            <div class="fmc-pending-row fmc-pending-clickable" style="display: block; margin-bottom: 6px;" @onclick="(() => OpenPendingDetail(pt))">
                                                <div class="fmc-pending-indicator" style="top: 6px; bottom: 6px;"></div>
                                                <div class="d-flex flex-column" style="flex: 1; min-width: 0;">
                                                    <div class="d-flex align-center justify-space-between mb-1">
                                                        <div class="d-flex align-center gap-2" style="min-width: 0; flex: 1;">
                                                            <div class="fmc-pending-avatar">@initials</div>
                                                            <div style="min-width: 0;">
                                                                <div style="font-weight: 900; font-size: 0.875rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.3;">
                                                                    @(string.IsNullOrEmpty(pt.Subscriber) ? "Organization" : pt.Subscriber)
                                                                </div>
                                                                <div style="font-size: 0.75rem; color: var(--mud-palette-text-secondary); font-weight: 600;">by @(pt.MakerName ?? "System")</div>
                                                            </div>
                                                        </div>
                                                        <div class="d-flex flex-column align-end" style="flex-shrink: 0;">
                                                            <div style="font-weight: 900; font-family: 'Roboto Mono', monospace; line-height: 1.3; font-size: 0.875rem; color: @(pt.Amount >= 0 ? "var(--mud-palette-success)" : "var(--mud-palette-error)");">
                                                                @(pt.Amount >= 0 ? "+" : "")₱@(Math.Abs(pt.Amount).ToString("N2"))
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="d-flex align-center" style="gap: 8px; padding-left: 40px;">
                                                        <span class="fmc-pending-badge">@(pt.Category == "Org Adjustment Pending" ? "ORG ADJUSTMENT" : "PENDING")</span>
                                                        <span style="font-size: 0.75rem; color: var(--mud-palette-text-secondary); font-weight: 600;">@pt.Date.ToLocalTime().ToString("MMM dd HH:mm")</span>
                                                        <span style="font-size: 0.75rem; font-weight: 700; color: var(--mud-palette-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 140px;">@(pt.Label ?? "")</span>
                                                    </div>
                                                </div>
                                                <div class="d-flex align-center" style="flex-shrink: 0; margin-left: 4px;">
                                                    <a href="/pending-requests" onclick="event.stopPropagation();" style="display:flex; align-items:center;">
                                                        <svg xmlns="http://www.w3.org/2000/svg" height="18" width="18" viewBox="0 0 24 24" fill="var(--mud-palette-text-primary)" style="opacity: 0; transition: opacity 0.2s;" class="fmc-pending-arrow"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                                                    </a>
                                                </div>
                                                @if (_isSuperAdminApprover && pt.Category == "Org Adjustment Pending")
                                                {
                                                    <div class="d-flex gap-2 mt-2" style="width:100%;" @onclick:stopPropagation="true">
                                                        <button class="fmc-home-reject-btn" @onclick="(() => HandleHomeRejectAsync(pt.Id))" disabled="@(_homeApprovingId != null)">
                                                            <svg xmlns="http://www.w3.org/2000/svg" height="16" width="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                                                            <span>Reject</span>
                                                        </button>
                                                        @if (isApproving)
                                                        {
                                                            <button class="fmc-home-approve-btn" disabled>
                                                                <span class="fmc-spinner" style="display:inline-block; width:16px; height:16px; border:2px solid currentColor; border-top-color:transparent; border-radius:50%; animation: fmc-rotation 0.6s linear infinite;"></span>
                                                                <span>Processing...</span>
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <button class="fmc-home-approve-btn" @onclick="(() => HandleHomeApproveAsync(pt.Id))" disabled="@(_homeApprovingId != null)">
                                                                <svg xmlns="http://www.w3.org/2000/svg" height="16" width="16" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                                                                <span>Approve</span>
                                                            </button>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                        </div>
                    </div>
                </div>
            }
            else if (context.User.IsInRole(Roles.CEO))
            {
                <MudGrid Class="mb-4">
                    <MudItem xs="12">
                        <ExecutiveAlertPanel Organizations="_organizations" Loading="_loading" OnActionCompleted="RefreshDashboard" />
                    </MudItem>
                </MudGrid>
            }
            @* ── ROW: SUBSCRIBER WALLET HEALTH + SYSTEM ACTIVITY LOG ── *@
            <MudGrid Spacing="4">
                @* ── LEFT: Wallet Health (desktop 8/12, mobile full) ── *@
                <MudItem xs="12" md="8">
                    <div class="d-flex flex-column gap-6">

                        @* ── SUBSCRIBER WALLET HEALTH ── *@
                        <MudPaper Elevation="0" Class="fmc-main-surface pa-8">
                            <div class="d-flex flex-column mb-6">
                                @* ── Row 1: Header + Global Controls ── *@
                                <div class="d-flex align-center justify-space-between mb-3 fmc-wallet-header-row">
                                    <div class="d-flex align-center fmc-header-title-group">
                                        <div class="fmc-header-icon mr-4" style="background: rgba(var(--mud-palette-primary-rgb), 0.1); flex-shrink: 0;">
                                            <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Primary" />
                                        </div>
                                        <div style="flex:1; min-width:0;">
                                            <div class="d-flex align-center gap-2">
                                                <MudText Typo="Typo.h6" Style="font-weight: 950; letter-spacing: -0.02em; white-space: nowrap; font-size: 1.1rem;">Subscriber Wallet Health</MudText>
                                                @* Summary Risk Status *@
                                                @if (!_auditLoading && GetFilteredSubscribers().Any())
                                                {
                                                    var criticalCount = GetFilteredSubscribers().Count(o => o.WalletLimit > 0 && (o.Usage / o.WalletLimit) >= 0.9m);
                                                    var warnCount     = GetFilteredSubscribers().Count(o => o.WalletLimit > 0 && (o.Usage / o.WalletLimit) >= 0.7m && (o.Usage / o.WalletLimit) < 0.9m);
                                                    
                                                    <div class="d-flex align-center gap-1 ml-1">
                                                        @if (criticalCount > 0) { <span class="fmc-status-dot critical" title="@criticalCount CRITICAL"></span> }
                                                        @if (warnCount > 0)     { <span class="fmc-status-dot warning" title="@warnCount WARNING"></span> }
                                                    </div>
                                                }
                                            </div>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700; font-size: 0.7rem;">Real-time utilization & depletion risk per tenant</MudText>
                                        </div>
                                        @if (_isSuperAdmin || _isSuperAdminApprover)
                                        {
                                            <MudTooltip Text="Refresh Data" Arrow="true" Placement="Placement.Top">
                                                <MudIconButton Icon="@Icons.Material.Filled.Refresh" 
                                                               Color="Color.Primary" 
                                                               Size="Size.Small" 
                                                               OnClick="RefreshDashboard"
                                                               Class="@("d-flex d-sm-none " + (_loading || _auditLoading ? "fmc-spin" : ""))"
                                                               Style="background: rgba(var(--mud-palette-primary-rgb), 0.05); border-radius: 8px; width: 32px; height: 32px; flex-shrink: 0;" />
                                            </MudTooltip>
                                        }
                                    </div>
                                    
                                    @if (_isSuperAdmin || _isSuperAdminApprover)
                                    {
                                        <div class="d-flex align-center gap-2 fmc-header-controls">
                                            <MudTooltip Text="Refresh Data" Arrow="true" Placement="Placement.Top">
                                                <MudIconButton Icon="@Icons.Material.Filled.Refresh" 
                                                               Color="Color.Primary" 
                                                               Size="Size.Small" 
                                                               OnClick="RefreshDashboard"
                                                               Class="@("d-none d-sm-inline-flex " + (_loading || _auditLoading ? "fmc-spin" : ""))"
                                                               Style="background: rgba(var(--mud-palette-primary-rgb), 0.05); border-radius: 8px; width: 32px; height: 32px; flex-shrink: 0;" />
                                            </MudTooltip>
                                            <div class="fmc-search-pill" style="width:220px; flex-shrink:0;">
                                                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" Class="fmc-search-pill-icon" />
                                                <input @bind-value="_walletSearchQuery" @bind-value:event="oninput" 
                                                       placeholder="Search tenants..." 
                                                       class="fmc-search-pill-input" />
                                            </div>
                                        </div>
                                    }
                                </div>

                                @* ── Row 2: Tactical Sorting Toolbar ── *@
                                @if (_isSuperAdmin || _isSuperAdminApprover)
                                {
                                    @* Desktop: horizontal button toolbar *@
                                    <div class="fmc-filter-toolbar d-none d-sm-flex align-center gap-1 mt-2">
                                        <MudText Typo="Typo.caption" Style="font-weight: 900; opacity: 0.5; margin-right: 8px; letter-spacing: 0.05em; font-size: 0.65rem; white-space: nowrap;">OVERSIGHT PRIORITY:</MudText>
                                        <button class="fmc-filter-chip @(_walletSortOrder == "util_high" || _walletSortOrder == "util_low" ? "active" : "")" 
                                                data-sort="@(_walletSortOrder == "util_low" ? "util_low" : "util_high")"
                                                @onclick="ToggleUtilizationSort">
                                            <MudIcon Icon="@(_walletSortOrder == "util_low" ? Icons.Material.Filled.TrendingDown : Icons.Material.Filled.TrendingUp)" 
                                                     Size="Size.Small" Class="mr-2" Style="font-size: 0.9rem;" />
                                            @(_walletSortOrder == "util_low" ? "LOWEST UTILIZATION" : "HIGHEST UTILIZATION")
                                        </button>
                                        <button class="fmc-filter-chip" @onclick="ToggleAllCards">
                                            <MudIcon Icon="@(_allMinimized ? Icons.Material.Filled.UnfoldMore : Icons.Material.Filled.UnfoldLess)" 
                                                     Size="Size.Small" Class="mr-2" Style="font-size: 0.9rem;" />
                                            @(_allMinimized ? "SHOW ALL" : "MINIMIZE ALL")
                                        </button>
                                        <button class="fmc-filter-chip @(_walletSortOrder == "alpha" || _walletSortOrder == "alpha_desc" ? "active" : "")" 
                                                @onclick="ToggleAlphaSort">
                                            <MudIcon Icon="@Icons.Material.Filled.SortByAlpha" Size="Size.Small" Class="mr-2" Style="font-size: 0.9rem;" />
                                            @(_walletSortOrder == "alpha_desc" ? "Z-A" : "A-Z")
                                        </button>
                                        <button class="fmc-filter-chip @(_walletSortOrder == "recent" ? "active" : "")" 
                                                data-sort="recent" @onclick="@(() => _walletSortOrder = "recent")">
                                            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="mr-2" Style="font-size: 0.9rem;" />
                                            RECENTLY CREDITED
                                        </button>
                                    </div>

                                    @* Mobile: premium filter chips *@
                                    <div class="d-flex d-sm-none flex-wrap align-center gap-1 mt-2 fmc-mobile-filter-row">
                                        <button class="fmc-filter-chip @(_walletSortOrder == "util_high" || _walletSortOrder == "util_low" ? "active" : "")" 
                                                data-sort="@(_walletSortOrder == "util_low" ? "util_low" : "util_high")"
                                                @onclick="ToggleUtilizationSort">
                                            <MudIcon Icon="@(_walletSortOrder == "util_low" ? Icons.Material.Filled.TrendingDown : Icons.Material.Filled.TrendingUp)" 
                                                     Size="Size.Small" Style="font-size:0.8rem;" />
                                            <span>@(_walletSortOrder == "util_low" ? "LOWEST" : "HIGHEST")</span>
                                        </button>
                                        <button class="fmc-filter-chip @(_walletSortOrder == "alpha" || _walletSortOrder == "alpha_desc" ? "active" : "")" 
                                                @onclick="ToggleAlphaSort">
                                            <MudIcon Icon="@(_walletSortOrder == "alpha_desc" ? Icons.Material.Filled.SortByAlpha : Icons.Material.Filled.SortByAlpha)" Size="Size.Small" Style="font-size:0.8rem;" />
                                            <span>@(_walletSortOrder == "alpha_desc" ? "Z-A" : "A-Z")</span>
                                        </button>
                                        <button class="fmc-filter-chip @(_walletSortOrder == "recent" ? "active" : "")" 
                                                data-sort="recent" @onclick="@(() => _walletSortOrder = "recent")">
                                            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Style="font-size:0.8rem;" />
                                        </button>
                                        <MudTooltip Text="@(_allMinimized ? "Show All" : "Minimize All")" Arrow="true" Placement="Placement.Top">
                                            <MudIconButton Icon="@(_allMinimized ? Icons.Material.Filled.UnfoldMore : Icons.Material.Filled.UnfoldLess)"
                                                           Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Style="width:32px;height:32px;flex-shrink:0;"
                                                           OnClick="ToggleAllCards" />
                                        </MudTooltip>
                                    </div>
                                }
                            </div>

                            @if (_loading)
                            {
                                <div class="fmc-wallet-skel-list">
                                    @for (int i = 0; i < 3; i++)
                                    {
                                        <div class="fmc-wallet-skel-card">
                                            <div class="d-flex align-center justify-space-between mb-4">
                                                <div class="d-flex align-center gap-3" style="flex:1;">
                                                    <div class="fmc-wallet-skel fmc-wallet-skel-avatar"></div>
                                                    <div style="flex:1;">
                                                        <div class="fmc-wallet-skel fmc-wallet-skel-line" style="width:55%; margin-bottom:8px;"></div>
                                                        <div class="fmc-wallet-skel fmc-wallet-skel-line fmc-wallet-skel-sm" style="width:30%;"></div>
                                                    </div>
                                                </div>
                                                <div class="fmc-wallet-skel fmc-wallet-skel-pct"></div>
                                            </div>
                                            <div class="fmc-wallet-skel fmc-wallet-skel-bar mb-3"></div>
                                            <div class="d-flex justify-space-between">
                                                <div class="fmc-wallet-skel fmc-wallet-skel-line fmc-wallet-skel-sm" style="width:22%;"></div>
                                                <div class="fmc-wallet-skel fmc-wallet-skel-line fmc-wallet-skel-sm" style="width:22%;"></div>
                                                <div class="fmc-wallet-skel fmc-wallet-skel-line fmc-wallet-skel-sm" style="width:22%;"></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else if (GetFilteredSubscribers().Any())
                            {
                                @* Sort Logic based on Toolbar Selection *@
                                var sorted = GetFilteredSubscribers()
                                    .Select(o => new {
                                        Org       = o,
                                        UsedPct   = o.WalletLimit > 0 ? (double)(o.Usage / o.WalletLimit) * 100 : 0,
                                        Remaining = Math.Max(0, o.RemainingBalance),
                                        IsRecent  = HasRecentCredit(o)
                                    });

                                switch(_walletSortOrder)
                                {
                                        case "alpha": sorted = sorted.OrderBy(x => x.Org.Name); break;
                                        case "alpha_desc": sorted = sorted.OrderByDescending(x => x.Org.Name); break;
                                    case "util_high": sorted = sorted.OrderByDescending(x => x.UsedPct); break;
                                    case "util_low": sorted = sorted.OrderBy(x => x.UsedPct); break;
                                    case "recent": sorted = sorted.OrderByDescending(x => x.IsRecent).ThenByDescending(x => x.UsedPct); break;
                                    default: sorted = sorted.OrderByDescending(x => x.UsedPct); break;
                                }

                                var sortedList = sorted.ToList();

                                <div class="fmc-wallet-health-list">
                                    @{ int wi = 0; }
                                    @foreach (var item in sortedList)
                                    {
                                        var wIdx       = wi++;
                                        var pct        = item.UsedPct;
                                        var isDepleted = item.Remaining <= 0;
                                        var isLowFunds = !isDepleted && item.Remaining < 1000;
                                        var isCritical = pct >= 90 || isDepleted;
                                        var isWarning  = (pct >= 70 && pct < 90) || isLowFunds;
                                        var tierColor  = isCritical ? "var(--mud-palette-error)"
                                                        : isWarning  ? "var(--mud-palette-warning)"
                                                                     : "var(--mud-palette-success)";
                                        var tierLabel  = isDepleted ? "DEPLETED"
                                                        : isLowFunds ? "LOW FUNDS"
                                                        : isCritical ? "CRITICAL"
                                                        : isWarning  ? "WARNING"
                                                                     : "HEALTHY";
                                        var capturedId = item.Org.Id; // capture for lambda closures

                                        <div class="fmc-health-card @(isCritical ? "fmc-health-critical" : isWarning ? "fmc-health-warn" : "")">

                                            @* ── Row 1: Avatar + Name + Tier + Cardholder Count + Percentage ── *@
                                            <div class="d-flex justify-space-between align-center mb-3 fmc-health-row1">
                                                <div class="d-flex align-center gap-3" style="flex: 1; min-width: 0;">
                                                    <div class="fmc-health-avatar" style="background: @GetChartColor(wIdx);">
                                                        @item.Org.Name[0]
                                                    </div>
                                                    <div style="min-width: 0;">
                                                        <div class="d-flex align-center gap-2 flex-wrap">
                                                            <MudText Typo="Typo.body2" Style="font-weight: 900; line-height: 1.2;" Class="fmc-org-name-mobile">@item.Org.Name</MudText>
                                                            <span class="fmc-tier-badge tier-@(tierLabel.ToLower().Replace(" ", "-"))">@tierLabel</span>
                                                            @if (item.IsRecent)
                                                            {
                                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Style="font-size:0.6rem;height:18px;margin-left:4px;">Recently Credited</MudChip>
                                                            }
                                                        </div>
                                                        @* Cardholder count if available *@
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.65rem;">
                                                            <MudIcon Icon="@Icons.Material.Filled.Group" Style="font-size: 0.7rem; vertical-align: middle; margin-right: 2px;" />
                                                            @(_organizations.FirstOrDefault(o => o.Id == item.Org.Id)?.UserCount ?? 0) cardholders
                                                        </MudText>
                                                    </div>
                                                </div>
                                                    <div class="d-flex align-center gap-1 fmc-health-actions">
                                                        <div class="text-right mr-3">
                                                            <MudText Typo="Typo.h6" Style="@($"font-weight: 900; font-family: 'JetBrains Mono', monospace; color: {tierColor}; line-height:1;")">
                                                                @pct.ToString("F1")%
                                                            </MudText>
                                                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.62rem;">UTILIZED</MudText>
                                                        </div>
                                                    @* ── Manage Wallet (SuperAdmin only for Credit/Debit) ── *@
                                                    @if (_isSuperAdmin)
                                                    {
                                                        <MudTooltip Text="Credit Wallet" Arrow="true" Placement="Placement.Top">
                                                            <div @onclick:stopPropagation="true" style="display: inline-block;">
                                                                <MudIconButton Icon="@Icons.Material.Filled.Add"
                                                                               Size="Size.Small"
                                                                               Color="Color.Success"
                                                                               Variant="Variant.Outlined"
                                                                               Class="fmc-action-btn-mobile"
                                                                               OnClick="@(() => OpenAdjustmentDialog(item.Org, true))" />
                                                            </div>
                                                        </MudTooltip>
                                                        <MudTooltip Text="Debit Wallet" Arrow="true" Placement="Placement.Top">
                                                            <div @onclick:stopPropagation="true" style="display: inline-block;">
                                                                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                                                               Size="Size.Small"
                                                                               Color="Color.Error"
                                                                               Variant="Variant.Outlined"
                                                                               Class="fmc-action-btn-mobile"
                                                                               OnClick="@(() => OpenAdjustmentDialog(item.Org, false))" />
                                                            </div>
                                                        </MudTooltip>
                                                        <MudTooltip Text="Manage Organization" Arrow="true" Placement="Placement.Top">
                                                            <div @onclick:stopPropagation="true" style="display: inline-block;">
                                                                <MudIconButton Icon="@Icons.Material.Filled.Settings"
                                                                               Size="Size.Small"
                                                                               Color="Color.Primary"
                                                                               Variant="Variant.Outlined"
                                                                               Class="fmc-action-btn-mobile"
                                                                               OnClick="@(() => Navigation.NavigateTo($"/admin/organizations/{capturedId}"))" />
                                                            </div>
                                                        </MudTooltip>
                                                    }
                                                        
                                                        @* ── Minimize Toggle ── *@
                                                        <div @onclick:stopPropagation="true" style="display: inline-block;">
                                                            <MudIconButton Icon="@(_cardCollapsed.GetValueOrDefault(capturedId) ? Icons.Material.Filled.KeyboardArrowDown : Icons.Material.Filled.KeyboardArrowUp)"
                                                                           Size="Size.Small"
                                                                           Color="Color.Inherit"
                                                                           Class="ml-1"
                                                                           Style="opacity: 0.5;"
                                                                           OnClick="@(() => ToggleCardCollapse(capturedId))" />
                                                        </div>
                                                    </div>
                                                </div>

                                                <MudCollapse Expanded="!_cardCollapsed.GetValueOrDefault(capturedId)">
                                                    @* ── Row 2: Annotated Fuel Gauge with Draggable Scrubber ── *@
                                                    <div class="d-flex justify-space-between mb-1 mt-4">
                                                        <MudText Typo="Typo.caption" Style="font-size: 0.55rem; opacity: 0.4;">₱0</MudText>
                                                        <MudText Typo="Typo.caption" Style="font-size: 0.55rem; opacity: 0.5; font-weight: 800;">← drag to explore →</MudText>
                                                        <MudText Typo="Typo.caption" Style="font-size: 0.55rem; opacity: 0.4;">₱@item.Org.WalletLimit.ToString("N0")</MudText>
                                                    </div>

                                                    @* Scrubber wrapper: gauge fill behind, invisible range input on top *@
                                                    <div class="fmc-gauge-wrapper">
                                                        @* Fill responds to drag: uses scrub position when active, real pct when idle *@
                                                        @{
                                                            var isScrubbing = _scrubActive.GetValueOrDefault(capturedId);
                                                            var fillPct     = isScrubbing
                                                                ? _scrubPositions.GetValueOrDefault(capturedId, pct)
                                                                : pct;
                                                            var fillColor   = fillPct >= 90 ? "var(--mud-palette-error)"
                                                                            : fillPct >= 70 ? "var(--mud-palette-warning)"
                                                                                            : "var(--mud-palette-success)";
                                                            // Disable transition while dragging for instant feedback
                                                            var fillTransition = isScrubbing ? "none" : "width 0.6s cubic-bezier(0.4, 0, 0.2, 1)";
                                                        }
                                                        <div class="fmc-gauge-track">
                                                            <div class="fmc-gauge-fill @(fillPct >= 90 ? "fmc-gauge-pulse" : "")"
                                                                 style="width: @(Math.Min(fillPct, 100).ToString("F1"))%; background: @fillColor; transition: @fillTransition;">
                                                            </div>
                                                            @* Threshold markers with tooltips *@
                                                            <MudTooltip Text="⚠ 70% — Caution threshold" Arrow="true" Placement="Placement.Top">
                                                                <div class="fmc-gauge-marker" style="left: 70%;"></div>
                                                            </MudTooltip>
                                                            <MudTooltip Text="🔴 90% — Critical / Exhaustion risk" Arrow="true" Placement="Placement.Top">
                                                                <div class="fmc-gauge-marker fmc-gauge-marker-critical" style="left: 90%;"></div>
                                                            </MudTooltip>
                                                        </div>

                                                        @* Invisible range input overlaid for drag interaction *@
                                                        <input type="range" min="0" max="100" step="0.1"
                                                               value="@(_scrubPositions.GetValueOrDefault(capturedId, pct).ToString("F1"))"
                                                               class="fmc-gauge-scrubber"
                                                               @oninput="@((e) => OnGaugeScrub(e, capturedId, item.Org.WalletLimit))"
                                                               @onmouseenter="@(() => _scrubActive[capturedId] = true)"
                                                               @onmouseleave="@(() => { _scrubActive[capturedId] = false; _scrubPositions[capturedId] = pct; })" />

                                                        @* Floating tooltip showing peso amount at scrub position *@
                                                        @if (_scrubActive.GetValueOrDefault(capturedId))
                                                        {
                                                            var sp = _scrubPositions.GetValueOrDefault(capturedId, pct);
                                                            var sa = _scrubAmounts.GetValueOrDefault(capturedId, (decimal)(pct / 100.0) * item.Org.WalletLimit);
                                                            var tipLeft = Math.Max(8, Math.Min(sp, 88)); // clamp so tip doesn't go off edge
                                                            var isAboveReal = sp > pct;
                                                            <div class="fmc-scrub-tip" style="left: @tipLeft.ToString("F1")%;">
                                                                <div class="fmc-scrub-tip-pct" style="color: @(isAboveReal ? "var(--mud-palette-text-secondary)" : tierColor);">@sp.ToString("F1")%</div>
                                                                <div class="fmc-scrub-tip-amt">₱@sa.ToString("N0")</div>
                                                                <div class="fmc-scrub-tip-arrow"></div>
                                                            </div>
                                                        }
                                                    </div>

                                                    @* ── Row 3: Usage | Remaining | Wallet Balance ── *@
                                                    <div class="d-flex justify-space-between mt-3">
                                                        <div>
                                                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;">Usage</MudText>
                                                            <MudText Typo="Typo.body2" Style="font-weight: 900; font-family: 'JetBrains Mono', monospace; color: var(--mud-palette-error);">
                                                                @item.Org.Usage.ToString("N0")
                                                            </MudText>
                                                        </div>
                                                        <div class="text-center">
                                                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;">Remaining</MudText>
                                                            <MudText Typo="Typo.body2" Style="@($"font-weight: 900; font-family: 'JetBrains Mono', monospace; color: {tierColor};")">
                                                                @item.Remaining.ToString("N0")
                                                            </MudText>
                                                        </div>
                                                        <div class="text-right">
                                                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;">Wallet Balance</MudText>
                                                            <MudText Typo="Typo.body2" Style="font-weight: 900; font-family: 'JetBrains Mono', monospace;">
                                                                @item.Org.WalletLimit.ToString("N0")
                                                            </MudText>
                                                        </div>
                                                    </div>
                                                </MudCollapse>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="d-flex flex-column align-center pa-12 mud-text-secondary"
                                     style="opacity: 0.5; border: 2px dashed var(--mud-palette-divider); border-radius: 20px;">
                                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Large" />
                                    <MudText Class="mt-2" Style="font-weight: 800;">No subscriber data available.</MudText>
                                </div>
                            }
                        </MudPaper>
                        
                        @* ── SYSTEM HEALTH PULSE (SuperAdmin / SuperAdminApprover) ── *@
                        @if (_isSuperAdmin || _isSuperAdminApprover)
                        {
                            <FMC.Components.Admin.SystemHealthPanel IsLoading="@_auditLoading" />
                        }

                        @* ── REGISTERED CARDHOLDER REGISTRY (CEO/Approver/Maker only) ── *@
                        @{
                            var cardholders = _users.Where(u => !string.IsNullOrWhiteSpace(u.AccountNumber)).ToList();
                        }
                        @if (!_isSuperAdmin && cardholders.Any())
                        {
                            <MudPaper Elevation="0" Class="fmc-main-surface pa-8">
                                <div class="d-flex align-center justify-space-between mb-6">
                                    <div class="d-flex align-center">
                                        <div class="fmc-header-icon mr-4" style="background: rgba(var(--mud-palette-info-rgb), 0.1);">
                                            <MudIcon Icon="@Icons.Material.Filled.ContactPage" Color="Color.Info" />
                                        </div>
                                        <div>
                                            <MudText Typo="Typo.h6" Style="font-weight: 950; letter-spacing: -0.02em;">Registered Cardholder Registry</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700;">Enrolled personnel &amp; individual wallet allocation</MudText>
                                        </div>
                                    </div>
                                    <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small"
                                             Icon="@Icons.Material.Filled.Group"
                                             Style="font-weight: 900; font-size: 0.65rem;">
                                        @cardholders.Count ENROLLED
                                    </MudChip>
                                </div>

                                <MudTextField @bind-Value="_cardholderSearch" Placeholder="Search cardholders..." Adornment="Adornment.Start" 
                                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-4"
                                              Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" />

                                @* Desktop Table *@
                                <div class="d-none d-md-block">
                                    <MudTable Items="@cardholders" Hover="true" Elevation="0" Dense="true" Class="fmc-table-transparent" 
                                              Filter="new Func<UserDto,bool>(FilterCardholders)">
                                        <HeaderContent>
                                            <MudTh Style="font-size:0.65rem; font-weight:900; letter-spacing:0.08em; color:var(--mud-palette-text-secondary);">
                                                <MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.DisplayName)">CARDHOLDER</MudTableSortLabel>
                                            </MudTh>
                                            <MudTh Style="font-size:0.65rem; font-weight:900; letter-spacing:0.08em; color:var(--mud-palette-text-secondary); text-align:right;">
                                                <MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Balance)">WALLET BALANCE</MudTableSortLabel>
                                            </MudTh>
                                        </HeaderContent>
                                        <RowTemplate Context="ch">
                                            <MudTd>
                                                <div class="d-flex align-center gap-3">
                                                    <MudAvatar Color="Color.Info" Size="Size.Small" Style="font-size:0.75rem; font-weight:900;">
                                                        @(ch.FirstName?[0])@(ch.LastName?[0])
                                                    </MudAvatar>
                                                    <div>
                                                        <div class="d-flex align-center gap-2">
                                                            <MudText Style="font-weight:800; font-size:0.85rem;">@ch.DisplayName</MudText>
                                                            <MudChip T="string" Color="@(ch.IsActive ? Color.Success : Color.Error)" Size="Size.Small" Variant="Variant.Outlined" Style="font-size: 0.55rem; font-weight: 900; padding: 0 6px; height: 18px; line-height: 1.2; text-transform: uppercase; letter-spacing: 0.05em; background: rgba(var(--mud-palette-success-rgb), 0.1);">
                                                                @(ch.IsActive ? "ACTIVE" : "SUSPENDED")
                                                            </MudChip>
                                                        </div>
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-family:'JetBrains Mono',monospace; font-size:0.65rem;">
                                                            @MaskAccount(ch.AccountNumber)
                                                        </MudText>
                                                    </div>
                                                </div>
                                            </MudTd>
                                            <MudTd Style="text-align:right;">
                                                <MudText Style="font-family:'JetBrains Mono',monospace; font-weight:900;"
                                                         Color="@(ch.Balance < 0 ? Color.Error : Color.Success)">
                                                    @ch.Balance.ToString("C")
                                                </MudText>
                                            </MudTd>
                                        </RowTemplate>
                                        <PagerContent>
                                            <MudTablePager PageSizeOptions="new int[]{10, 25, 50}" />
                                        </PagerContent>
                                    </MudTable>
                                </div>

                                @* Mobile Cards *@
                                <div class="d-block d-md-none">
                                    @foreach (var ch in cardholders)
                                    {
                                        <div class="fmc-ch-mobile-card">
                                            <div class="d-flex align-center justify-space-between">
                                                <div class="d-flex align-center gap-3">
                                                    <MudAvatar Color="Color.Info" Size="Size.Small" Style="font-size:0.75rem; font-weight:900;">
                                                        @(ch.FirstName?[0])@(ch.LastName?[0])
                                                    </MudAvatar>
                                                    <div>
                                                        <div class="d-flex align-center gap-2">
                                                            <MudText Style="font-weight:800; font-size:0.85rem;">@ch.DisplayName</MudText>
                                                            <MudChip T="string" Color="@(ch.IsActive ? Color.Success : Color.Error)" Size="Size.Small" Variant="Variant.Outlined" Style="font-size: 0.55rem; font-weight: 900; padding: 0 6px; height: 18px; line-height: 1.2; text-transform: uppercase; letter-spacing: 0.05em; background: rgba(var(--mud-palette-success-rgb), 0.1);">
                                                                @(ch.IsActive ? "ACTIVE" : "SUSP")
                                                            </MudChip>
                                                        </div>
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-family:'JetBrains Mono',monospace; font-size:0.65rem;">
                                                            @MaskAccount(ch.AccountNumber)
                                                        </MudText>
                                                    </div>
                                                </div>
                                                <div class="text-right">
                                                    <MudText Style="font-family:'JetBrains Mono',monospace; font-weight:900;"
                                                             Color="@(ch.Balance < 0 ? Color.Error : Color.Success)">
                                                        @ch.Balance.ToString("C")
                                                    </MudText>
                                                </div>
                                            </div>
                                    </div>
                                }
                            </div>
                        </MudPaper>
                        }

                    </div>
                </MudItem>

                @* ── RIGHT: System Activity Log (desktop 4/12, mobile full) ── *@
                <MudItem xs="12" md="4">
                <div class="fmc-audit-surface">
                    <div class="fmc-audit-header">
                            <div class="d-flex align-center justify-space-between w-100">
                                <div class="fmc-audit-title">
                                    <div class="fmc-audit-icon mr-3"><MudIcon Icon="@Icons.Material.Filled.EventNote" Color="Color.Info" Size="Size.Small" /></div>
                                    <div class="fmc-audit-title-text">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 950; letter-spacing: -0.01em; line-height: 1.1;">System Activity Log</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700; line-height: 1.1;">Global audit feed</MudText>
                                    </div>
                                </div>
                                <div class="d-flex align-center gap-1">
                                    <MudTooltip Text="Full Intelligence Explorer">
                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Color="Color.Primary" Size="Size.Small" Href="/admin/audit" />
                                    </MudTooltip>
                                </div>
                            </div>
                        </div>
                        <div class="fmc-audit-section-label" style="display: flex; justify-content: flex-end; padding-top: 8px; padding-bottom: 8px;">
                            <div class="fmc-date-group w-100 d-flex justify-space-between">
                                <button class="fmc-date-btn @(_activeAuditRange == "all" ? "active" : "")" style="flex:1;" @onclick='() => SetAuditRange("all")'>ALL</button>
                                <button class="fmc-date-btn @(_activeAuditRange == "today" ? "active" : "")" style="flex:1;" @onclick='() => SetAuditRange("today")'>TODAY</button>
                                <button class="fmc-date-btn @(_activeAuditRange == "7d" ? "active" : "")" style="flex:1;" @onclick='() => SetAuditRange("7d")'>7D</button>
                                <button class="fmc-date-btn @(_activeAuditRange == "30d" ? "active" : "")" style="flex:1;" @onclick='() => SetAuditRange("30d")'>30D</button>
                            </div>
                        </div>

                        <div class="fmc-audit-scroll-area">
                            @if (_auditLoading)
                            {
                                <div class="fmc-audit-skel-list">
                                    @for (int i = 0; i < 6; i++)
                                    {
                                        <div class="fmc-audit-skel-item">
                                            <div class="fmc-audit-skel-indicator"></div>
                                            <div class="fmc-audit-skel-body">
                                                <div class="d-flex justify-space-between align-center mb-2">
                                                    <div class="fmc-audit-skel fmc-audit-skel-amt"></div>
                                                    <div class="fmc-audit-skel fmc-audit-skel-badge"></div>
                                                </div>
                                                <div class="fmc-audit-skel fmc-audit-skel-entity mb-2"></div>
                                                <div class="d-flex justify-space-between">
                                                    <div class="fmc-audit-skel fmc-audit-skel-meta" style="width: 30%;"></div>
                                                    <div class="fmc-audit-skel fmc-audit-skel-meta" style="width: 22%;"></div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else if (!_allAuditLogs.Any())
                            {
                                <div class="pa-12 d-flex flex-column align-center mud-text-secondary">
                                    <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Large" Style="opacity:0.3;" />
                                    <MudText Class="mt-2">No activity history found.</MudText>
                                </div>
                            }
                            else
                            {
                                <div class="fmc-audit-list">
                                    @foreach (var log in _allAuditLogs.Take(15))
                                    {
                                        var act = log.Action?.ToUpper() ?? "UNKNOWN";
                                        var isApproved = act == "TRANSACTION_APPROVED" || act == "BATCH_APPROVED" || act == "APPROVE" || act == "APPROVAL_SUCCESS";
                                        var isBatchSubmit = act == "BATCH_SUBMITTED";
                                        var isBatchCancel = act == "BATCH_CANCELLED";

                                        var isCredit = isApproved || act == "CREDIT" || act == "WALLET_ADJUSTED" || (act.Contains("SUCCESS") && !act.Contains("DEBIT") && !act.Contains("LOGIN"));
                                        var isDebit = isBatchCancel || act == "DEBIT" || act == "REJECT" || act == "REJECTED" || act == "EXHAUSTION_WARNING" || act == "BATCH_REJECTED" || act.Contains("FAILED");
                                        var isSecurity = isBatchSubmit || act.Contains("LOGIN") || act.Contains("AUTH") || act.Contains("SECURITY") || act.Contains("PASSWORD");
                                        var isFinancial = isCredit || isDebit || log.Amount > 0;
                                        
                                        var clr = isApproved ? "credit" :
                                                  (isBatchSubmit ? "info" :
                                                  (isBatchCancel ? "debit" :
                                                  (isCredit ? "credit" : 
                                                  (isDebit ? "debit" : 
                                                  (isSecurity ? "info" : "warning")))));

                                        var icon = isApproved ? Icons.Material.Filled.CheckCircle :
                                                   (isBatchSubmit ? Icons.Material.Filled.Backup :
                                                   (isBatchCancel ? Icons.Material.Filled.Cancel :
                                                   (isCredit ? Icons.Material.Filled.CheckCircle : 
                                                   (isDebit ? Icons.Material.Filled.Error : 
                                                   (isSecurity ? Icons.Material.Filled.Security : Icons.Material.Filled.Info)))));
                                        
                                        var localTime = log.CreatedAt.ToDisplayTime();
                                        var capturedLog = log;
                                        <div class="fmc-audit-item @clr fmc-audit-item-clickable"
                                             @onclick="@(() => OpenAuditLogDialog(capturedLog))">
                                             
                                            <!-- Premium Floating Forensic Tooltip -->
                                            <div class="fmc-row-tooltip">
                                                <div class="tooltip-header @clr">
                                                    <MudIcon Icon="@icon" Size="Size.Small" Class="mr-1" />
                                                    <span>FORENSIC TELEMETRY STREAM</span>
                                                </div>
                                                <div class="tooltip-body">
                                                    <div class="tooltip-row">
                                                        <span class="tooltip-lbl">OPERATION:</span>
                                                        <span class="tooltip-val @clr">@FormatAction(log.Action)</span>
                                                    </div>
                                                    <div class="tooltip-row">
                                                        <span class="tooltip-lbl">CONTEXT / ACTOR:</span>
                                                        <span class="tooltip-val">@(log.EntityName ?? log.Organization ?? "System Core Gateway")</span>
                                                    </div>
                                                    <div class="tooltip-row">
                                                        <span class="tooltip-lbl">TELEMETRY ENDPOINT:</span>
                                                        <span class="tooltip-val mono">@(log.IpAddress ?? "::1 (Local Loopback)")</span>
                                                    </div>
                                                    <div class="tooltip-row">
                                                        <span class="tooltip-lbl">PLATFORM CONSOLE:</span>
                                                        <span class="tooltip-val">@(log.Label ?? "FMC Secure Terminal")</span>
                                                    </div>
                                                    <div class="tooltip-row" style="margin-top: 4px; border-top: 1px dashed rgba(255,255,255,0.08); padding-top: 4px;">
                                                        <span class="tooltip-lbl">SESSION AUDITOR:</span>
                                                        <span class="tooltip-val">@(log.PerformedBy ?? "System Root")</span>
                                                    </div>
                                                    <div class="tooltip-row">
                                                        <span class="tooltip-lbl">MAGNITUDE VALUE:</span>
                                                        <span class="tooltip-val mono highlighted-val">@(log.Amount.HasValue ? $"₱{log.Amount.Value:N2}" : "NOT APPLICABLE")</span>
                                                    </div>
                                                    <div class="tooltip-row">
                                                        <span class="tooltip-lbl">ISO TIMESTAMP:</span>
                                                        <span class="tooltip-val mono highlighted-val">@log.CreatedAt.ToDisplayString("yyyy-MM-dd HH:mm:ss.fff")</span>
                                                    </div>
                                                </div>
                                                <div class="tooltip-footer">
                                                    <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Size="Size.Small" Class="mr-1" style="font-size: 0.6rem;" />
                                                    <span>CLICK ROW FOR FULL EVENT LEDGER TRACE</span>
                                                </div>
                                            </div>

                                            <div class="fmc-audit-indicator"></div>
                                            <div class="fmc-audit-body-content">
                                                <div class="d-flex justify-space-between align-center mb-1">
                                                    <span class="fmc-audit-amt @clr">
                                                        @(isFinancial && log.Amount.HasValue ? (isCredit ? "+" : isDebit ? "-" : "") + log.Amount?.ToString("N2") : "SYSTEM")
                                                    </span>
                                                    <span class="fmc-audit-badge @clr">@FormatAction(log.Action)</span>
                                                </div>
                                                <MudText Typo="Typo.body2" Class="fmc-audit-entity-compact">@log.EntityName</MudText>
                                                @if (!string.IsNullOrEmpty(log.Label))
                                                {
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block" Style="font-size: 0.6rem; font-weight: 700; line-height: 1.1; margin-top: 2px;">@log.Label</MudText>
                                                }
                                                <div class="d-flex justify-space-between mt-1" style="opacity: 0.6;">
                                                    <span style="font-size: 0.65rem; font-weight: 700;">
                                                        <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size: 0.6rem; margin-right: 2px; vertical-align: middle;" />
                                                        @(string.IsNullOrWhiteSpace(log.PerformedBy) ? "System" : log.PerformedBy)
                                                    </span>
                                                    <span style="font-size: 0.65rem; font-weight: 700;">@localTime.ToString("MMM dd HH:mm")</span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="fmc-audit-footer">
                                    <MudButton Variant="Variant.Text" 
                                               Color="Color.Primary" 
                                               FullWidth="true" 
                                               Style="text-transform:none; font-weight:800; padding: 12px 0;"
                                               Href="/admin/audit">
                                        View Full Audit Trail
                                    </MudButton>
                                </div>
                            }
                        </div>
                    </div>
                </MudItem>
            </MudGrid>

        </Authorized>
        <NotAuthorized>
