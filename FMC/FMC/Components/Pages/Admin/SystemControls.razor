@page "/admin/system"
@using FMC.Shared.Auth
@using FMC.Shared.DTOs.Admin
@using FMC.Services.Api
@using FMC.Services
@using Microsoft.JSInterop
@using MudBlazor
@attribute [Authorize(Roles = Roles.SuperAdmin)]
@inject AdminService AdminService
@inject ISnackbar Snackbar
@inject FMC.Services.ThemeService ThemeService
@inject IReportService ReportGen
@inject IJSRuntime JS
@inject IDialogService DialogService
@implements IDisposable

<PageTitle>System Controls | FMC</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="@GetContainerClass()">
    <div class="sc-premium-header mb-10">
        <div class="d-flex align-center flex-grow-1">
            <div class="sc-accent-line"></div>
            <div class="ml-5">
                <MudText Typo="Typo.h3" Class="sc-hero-title">System Controls</MudText>
                <MudText Typo="Typo.subtitle1" Class="sc-hero-subtitle">Infrastructure management &amp; governance toggles</MudText>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="sc-metric-hud">
            @for (int i = 0; i < 3; i++)
            {
                <div class="sc-metric-card">
                    <div class="sc-skeleton" style="height:10px;width:35%;"></div>
                    <div class="sc-skeleton mt-4" style="height:28px;width:45%;"></div>
                    <div class="sc-skeleton mt-2" style="height:8px;width:25%;"></div>
                </div>
            }
        </div>
        <div class="sc-card mt-8">
            <div class="sc-card-header">
                <div class="sc-card-header-left">
                    <div class="sc-skeleton" style="height:16px;width:180px;"></div>
                </div>
                <div class="sc-skeleton" style="height:20px;width:60px;border-radius:30px;"></div>
            </div>
            <div class="sc-card-body">
                <div class="sc-skeleton" style="height:14px;width:60%;"></div>
                <div class="sc-skeleton mt-4" style="height:36px;width:100%;"></div>
                <div class="sc-skeleton mt-6" style="height:80px;width:100%;"></div>
                <div class="sc-skeleton mt-4" style="height:44px;width:160px;"></div>
            </div>
        </div>
        <div class="sc-card mt-6">
            <div class="sc-card-header">
                <div class="sc-card-header-left">
                    <div class="sc-skeleton" style="height:14px;width:140px;"></div>
                </div>
            </div>
            <div class="sc-card-body">
                <div class="sc-skeleton" style="height:14px;width:80%;"></div>
                <div class="sc-skeleton mt-4" style="height:36px;width:100%;"></div>
                <div class="sc-skeleton mt-4" style="height:60px;width:100%;"></div>
                <div class="sc-skeleton mt-4" style="height:44px;width:180px;"></div>
            </div>
        </div>
        <div class="sc-card mt-6">
            <div class="sc-card-header">
                <div class="sc-card-header-left">
                    <div class="sc-skeleton" style="height:14px;width:160px;"></div>
                </div>
            </div>
            <div class="sc-card-body">
                <div class="sc-skeleton" style="height:14px;width:90%;"></div>
                <div class="sc-skeleton mt-3" style="height:14px;width:70%;"></div>
                <div class="sc-skeleton mt-3" style="height:14px;width:85%;"></div>
                <div class="sc-skeleton mt-3" style="height:14px;width:60%;"></div>
            </div>
        </div>
    }
    else if (_status == null)
    {
        <div class="sc-empty">
            <div class="sc-empty-icon">&#9888;</div>
            <h3>Unable to load system controls</h3>
            <p>The diagnostic service did not respond. Check that the API is running.</p>
            <button class="sc-btn sc-btn-primary mt-6" @onclick="LoadStatus">Retry</button>
        </div>
    }
    else
    {
        <div class="sc-metric-hud">
            <div class="sc-metric-card @(_status.IsActive ? "card-warning" : "card-ok")">
                <div class="sc-metric-icon @(_status.IsActive ? "warning" : "success")">
                    @if (_status.IsActive)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.ReportProblem" Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                    }
                </div>
                <div class="sc-metric-data">
                    <MudText Typo="Typo.h4">@(_status.IsActive ? "ACTIVE" : "OFF")</MudText>
                    <MudText Typo="Typo.caption">MAINTENANCE STATUS</MudText>
                </div>
            </div>
            <div class="sc-metric-card">
                <div class="sc-metric-icon muted">
                    <MudIcon Icon="@Icons.Material.Filled.Block" Size="Size.Small" />
                </div>
                <div class="sc-metric-data">
                    <MudText Typo="Typo.h4">@_status.BlockedCount</MudText>
                    <MudText Typo="Typo.caption">BLOCKED REQUESTS</MudText>
                </div>
            </div>
            <div class="sc-metric-card">
                <div class="sc-metric-icon muted">
                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" />
                </div>
                <div class="sc-metric-data">
                    <MudText Typo="Typo.h4" Style="font-size:1rem;">@FormatTimestamp(_status.ActivatedAt)</MudText>
                    <MudText Typo="Typo.caption">@(_status.IsActive ? "ACTIVATED" : "LAST EVENT")</MudText>
                </div>
            </div>
        </div>

        <div class="sc-card mt-8">
            <div class="sc-card-header">
                <div class="sc-card-header-left">
                    <span class="sc-card-icon">&#9881;</span>
                    <span class="sc-card-title">Maintenance Mode</span>
                </div>
                <div class="sc-status-pill @(_status.IsActive ? "active" : "inactive")">
                    <span class="sc-pill-dot"></span>
                    @(_status.IsActive ? "ACTIVE" : "OFF")
                </div>
            </div>
            <div class="sc-card-body">
                <div class="sc-toggle-row">
                    <div class="sc-toggle-info">
                        <span class="sc-toggle-label">@(_status.IsActive ? "Maintenance Mode is Active" : "Enable Maintenance Mode")</span>
                        <span class="sc-toggle-desc">@(_status.IsActive ? "The system is currently restricting access. Modify settings below or deactivate." : "When active, all non-admin users are shown a maintenance page.")</span>
                    </div>
                    <div class="sc-toggle-control">
                        <label class="sc-switch">
                            <input type="checkbox" checked="@_status.IsActive" @onchange="OnToggleChanged" disabled="@_toggling" />
                            <span class="sc-slider"></span>
                        </label>
                    </div>
                </div>

                @if (_status.IsActive)
                {
                    <div class="sc-active-banner">
                        <span class="sc-active-banner-icon">&#9888;</span>
                        <span class="sc-active-banner-text">Maintenance is currently <strong>ACTIVE</strong>. All non-admin users are being blocked.</span>
                    </div>
                }

                @if (_status.IsActive || _pendingToggle)
                {
                    <div class="sc-mode-selector mt-4">
                        <label class="sc-message-label">Maintenance type</label>
                        <div class="sc-mode-options">
                            <button type="button" class="sc-mode-btn @(_editModeType == "full" ? "selected" : "")" @onclick="@(() => SetModeType("full"))">
                                <span class="sc-mode-radio @(_editModeType == "full" ? "selected" : "")"></span>
                                <span class="sc-mode-text">
                                    <span class="sc-mode-label">Full Lock</span>
                                    <span class="sc-mode-desc">Blocks all access for non-admin users</span>
                                </span>
                            </button>
                            <button type="button" class="sc-mode-btn @(_editModeType == "readonly" ? "selected" : "")" @onclick="@(() => SetModeType("readonly"))">
                                <span class="sc-mode-radio @(_editModeType == "readonly" ? "selected" : "")"></span>
                                <span class="sc-mode-text">
                                    <span class="sc-mode-label">Read Only</span>
                                    <span class="sc-mode-desc">Users can view data but cannot submit transactions</span>
                                </span>
                            </button>
                        </div>
                    </div>

                    <div class="sc-message-area">
                        <label class="sc-message-label">Custom notice shown to users</label>
                        <div class="sc-message-input-wrap">
                            <textarea class="sc-message-input"
                                      placeholder="e.g. System is undergoing scheduled maintenance. We'll be back shortly."
                                      @bind="_editMessage"
                                      disabled="@_toggling"
                                      rows="3"></textarea>
                        </div>
                    </div>

                    <div class="sc-action-row">
                        <button class="sc-btn @(_status.IsActive ? "sc-btn-danger" : "sc-btn-primary")"
                                @onclick="ConfirmToggle"
                                disabled="@_toggling">
                            @if (_toggling)
                            {
                                <span class="sc-spinner"></span>
                                <span>Processing...</span>
                            }
                            else
                            {
                                <span>@(_status.IsActive ? "Deactivate Maintenance" : "Activate Maintenance")</span>
                            }
                        </button>
                    </div>
                }

                @if (_toggling)
                {
                    <MudAlert Severity="Severity.Info" Class="mt-4" Dense="true" Variant="Variant.Text">
                        <MudText Typo="Typo.body2" Style="font-weight:700;">
                            @(_status.IsActive ? "Deactivating maintenance mode..." : "Activating maintenance mode...")
                        </MudText>
                    </MudAlert>
                }
            </div>
        </div>

        @if (!_status.IsActive || _status.ScheduledAt.HasValue)
        {
            <div class="sc-card mt-6">
                <div class="sc-card-header">
                    <div class="sc-card-header-left">
                        <span class="sc-card-icon">&#9200;</span>
                        <span class="sc-card-title">Schedule Maintenance</span>
                    </div>
                    @if (_status.ScheduledAt.HasValue)
                    {
                        <div class="sc-schedule-pill">
                            <span class="sc-pill-dot"></span>
                            @FormatTimestamp(_status.ScheduledAt)
                        </div>
                    }
                </div>
                <div class="sc-card-body">
                    <div class="sc-toggle-desc mb-6">
                        Set a future date and time for maintenance to activate automatically. All non-admin users will be blocked once the time is reached.
                    </div>
                    <div class="sc-schedule-row">
                        <div class="sc-schedule-field">
                            <label class="sc-message-label">Date</label>
                            <input type="date" class="sc-schedule-input" value="@_scheduleDate" @onchange="OnDateChanged" disabled="@_toggling" />
                        </div>
                        <div class="sc-schedule-field">
                            <label class="sc-message-label">Time (UTC)</label>
                            <input type="time" class="sc-schedule-input" value="@_scheduleTime" @onchange="OnTimeChanged" disabled="@_toggling" />
                        </div>
                    </div>
                    <div class="sc-mode-selector mt-2 mb-4">
                        <label class="sc-message-label">Planned maintenance type</label>
                        <div class="sc-mode-options">
                            <button type="button" class="sc-mode-btn @(_editModeType == "full" ? "selected" : "")" @onclick="@(() => SetModeType("full"))">
                                <span class="sc-mode-radio @(_editModeType == "full" ? "selected" : "")"></span>
                                <span class="sc-mode-text">
                                    <span class="sc-mode-label">Full Lock</span>
                                    <span class="sc-mode-desc">Blocks all access</span>
                                </span>
                            </button>
                            <button type="button" class="sc-mode-btn @(_editModeType == "readonly" ? "selected" : "")" @onclick="@(() => SetModeType("readonly"))">
                                <span class="sc-mode-radio @(_editModeType == "readonly" ? "selected" : "")"></span>
                                <span class="sc-mode-text">
                                    <span class="sc-mode-label">Read Only</span>
                                    <span class="sc-mode-desc">View only, no transactions</span>
                                </span>
                            </button>
                        </div>
                    </div>
                    <div class="sc-message-area">
                        <label class="sc-message-label">Notification message</label>
                        <div class="sc-message-input-wrap">
                            <textarea class="sc-message-input"
                                      placeholder="e.g. Scheduled maintenance on Dec 25 at 02:00 UTC. The system will be unavailable for approximately 2 hours."
                                      @bind="_scheduleMsg"
                                      disabled="@_toggling"
                                      rows="2"></textarea>
                        </div>
                    </div>
                    <div class="sc-action-row">
                        @if (_status.ScheduledAt.HasValue)
                        {
                            <button class="sc-btn sc-btn-danger" @onclick="ClearSchedule" disabled="@_toggling" Style="margin-right:8px;">
                                Clear Schedule
                            </button>
                        }
                        <button class="sc-btn sc-btn-primary" @onclick="ScheduleMaintenance" disabled="@_toggling || string.IsNullOrWhiteSpace(_scheduleDate) || string.IsNullOrWhiteSpace(_scheduleTime)">
                            @if (_toggling)
                            {
                                <span class="sc-spinner"></span>
                            }
                            <span>@(_status.ScheduledAt.HasValue ? "Reschedule" : "Schedule Maintenance")</span>
                        </button>
                    </div>
                    @if (_scheduleError != null)
                    {
                        <div class="sc-schedule-error mt-4">@_scheduleError</div>
                    }
                </div>
            </div>
        }

        <div class="sc-card mt-6">
            <div class="sc-card-header">
                <div class="sc-card-header-left">
                    <span class="sc-card-icon">&#128196;</span>
                    <span class="sc-card-title">Maintenance History</span>
                    <span class="sc-schedule-pill" Style="font-size:9px;padding:3px 10px;">@(BuildTimelineWindows(_history).Count) windows</span>
                </div>
                <div class="sc-header-actions">
                    <button class="sc-icon-btn" title="Export as Excel" @onclick="ExportHistoryExcel" disabled="@(_history.Count == 0)">
                        <svg xmlns="http://www.w3.org/2000/svg" height="14" width="14" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 18H9v-2h4v2zm6-9h-5V4.5L19 11z"/></svg>
                        Excel
                    </button>
                    <button class="sc-icon-btn" title="Export as PDF" @onclick="ExportHistoryPdf" disabled="@(_history.Count == 0)">
                        <svg xmlns="http://www.w3.org/2000/svg" height="14" width="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-8.5 7.5c0 .83-.67 1.5-1.5 1.5H9v2H7.5V7H10c.83 0 1.5.67 1.5 1.5v1zm5 2c0 .83-.67 1.5-1.5 1.5h-2.5V7H15c.83 0 1.5.67 1.5 1.5v3zm4-3H19v1h1.5V11H19v2h-1.5V7h3v1.5zM9 9.5h1v-1H9v1zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm10 5.5h1v-3h-1v3z"/></svg>
                        PDF
                    </button>
                </div>
            </div>
            <div class="sc-card-body">
                @if (_historyLoading)
                {
                    <div class="sc-skeleton" style="height:60px;width:100%;"></div>
                }
                else if (_history.Count == 0)
                {
                    <div class="sc-empty" Style="padding:20px 0;">
                        <span style="opacity:0.3;font-size:24px;">&#128203;</span>
                        <p style="font-size:13px;margin-top:8px;">No maintenance events recorded yet</p>
                    </div>
                }
                else
                {
                    var allWindows = BuildTimelineWindows(_history).OrderByDescending(w => w.Start).ToList();
                    var totalWindows = allWindows.Count;
                    var totalPages = Math.Max(1, (int)Math.Ceiling((double)totalWindows / _pageSize));
                    if (_currentPage > totalPages) _currentPage = totalPages;
                    var pagedWindows = allWindows.Skip((_currentPage - 1) * _pageSize).Take(_pageSize).ToList();
                    <div class="sc-window-list">
                        @foreach (var win in pagedWindows)
                        {
                            var duration = (win.End - win.Start).TotalMinutes;
                            <button class="sc-window-card @(win.IsActive ? "active" : "")" @onclick="() => ShowWindowDetail(win)">
                                <div class="sc-window-card-left">
                                    <span class="sc-window-card-dot @(win.IsActive ? "active" : "resolved")"></span>
                                </div>
                                <div class="sc-window-card-body">
                                    <div class="sc-window-card-top">
                                        <span class="sc-window-card-status">@(win.IsActive ? "Active" : "Resolved")</span>
                                        <span class="sc-window-card-dur">@FormatDuration(duration)</span>
                                    </div>
                                    <div class="sc-window-card-row">
                                        <span class="sc-window-card-label">Activated</span>
                                        <span class="sc-window-card-time">@FormatTimestamp(win.Start)</span>
                                        <span class="sc-window-card-by">@(win.ActivatedBy ?? "System")</span>
                                    </div>
                                    @if (!win.IsActive)
                                    {
                                        <div class="sc-window-card-row">
                                            <span class="sc-window-card-label">Deactivated</span>
                                            <span class="sc-window-card-time">@FormatTimestamp(win.End)</span>
                                            <span class="sc-window-card-by">@(win.DeactivatedBy ?? "System")</span>
                                        </div>
                                    }
                                </div>
                                <span class="sc-window-card-arrow">&#8250;</span>
                            </button>
                        }
                    </div>
                    <div class="sc-pagination">
                        <div class="sc-pagination-info">
                            @((_currentPage - 1) * _pageSize + 1)&ndash;@(Math.Min(_currentPage * _pageSize, totalWindows)) of @totalWindows
                        </div>
                        <div class="sc-pagination-controls">
                            <button class="sc-page-btn" disabled="@(_currentPage <= 1)" @onclick="() => { _currentPage--; }">&#9664;</button>
                            @for (int p = 1; p <= totalPages; p++)
                            {
                                <button class="sc-page-btn @(p == _currentPage ? "active" : "")" @onclick="() => { _currentPage = p; }">@p</button>
                            }
                            <button class="sc-page-btn" disabled="@(_currentPage >= totalPages)" @onclick="() => { _currentPage++; }">&#9654;</button>
                        </div>
                        <select class="sc-page-size" @bind="_pageSize">
                            <option value="10">10</option>
                            <option value="20">20</option>
                            <option value="50">50</option>
                        </select>
                    </div>
                }
            </div>
        </div>

        <div class="sc-card mt-6">
            <div class="sc-card-header">
                <div class="sc-card-header-left">
                    <span class="sc-card-icon">&#9776;</span>
                    <span class="sc-card-title">About This Control</span>
                </div>
            </div>
            <div class="sc-card-body">
                <ul class="sc-info-list">
                    <li><strong>Middleware check:</strong> Every non-admin request is intercepted before reaching the application. Static assets (images, CSS) still load.</li>
                    <li><strong>No auto-logout:</strong> Active sessions remain valid. Users see the maintenance page on their next navigation or page refresh.</li>
                    <li><strong>Auto-recovery:</strong> The maintenance page refreshes every 30 seconds. When you deactivate, users regain access without re-logging in.</li>
                    <li><strong>Scheduled maintenance:</strong> Set a date/time in the future and the system auto-activates when the time is reached. The audit log records when it was scheduled and when it activated.</li>
                    <li><strong>Read-only mode:</strong> Users can view data but cannot submit transactions. Less disruptive than full lock.</li>
                    <li><strong>Blocked requests</strong> are counted in the metric card above. This helps gauge how many users were affected.</li>
                </ul>
            </div>
        </div>
    }
</MudContainer>

@code {
    private MaintenanceStatusDto? _status;
    private bool _loading = true;
    private bool _toggling;
    private bool _pendingToggle;
    private string _editMessage = "";
    private string _editModeType = "full";
    private string _scheduleDate = "";
    private string _scheduleTime = "";
    private string _scheduleMsg = "";
    private string? _scheduleError;
    private List<MaintenanceHistoryItem> _history = new();
    private bool _historyLoading;
    private int _pageSize = 10;
    private int _currentPage = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatus();
    }

    private async Task LoadStatus()
    {
        _loading = true;
        try
        {
            _status = await AdminService.GetMaintenanceStatusAsync();
            if (_status != null)
            {
                _editMessage = _status.Message ?? "";
                _editModeType = _status.ModeType ?? "full";
                _scheduleMsg = _status.ScheduledMessage ?? "";
                if (_status.ScheduledAt.HasValue)
                {
                    var local = _status.ScheduledAt.Value.ToLocalTime();
                    _scheduleDate = local.ToString("yyyy-MM-dd");
                    _scheduleTime = local.ToString("HH:mm");
                }
            }
        }
        catch
        {
            _status = null;
        }
        finally
        {
            _loading = false;
        }
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        _historyLoading = true;
        _currentPage = 1;
        try
        {
            _history = await AdminService.GetMaintenanceHistoryAsync();
        }
        catch
        {
            _history = new();
        }
        finally
        {
            _historyLoading = false;
        }
    }

    private string GetModeClass(string mode) => _editModeType == mode ? "selected" : "";

    private void SetModeType(string mode)
    {
        _editModeType = mode;
    }

    private void OnToggleChanged(ChangeEventArgs e)
    {
        _pendingToggle = (bool)(e.Value ?? false);
        if (!_status!.IsActive)
        {
            _editMessage = _status?.Message ?? "";
        }
    }

    private async Task<bool> RequireSecurityVerificationAsync(string action)
    {
        var options = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<SecurityVerificationDialog>(action, options);
        var result = await dialog.Result;
        return result is { Data: true };
    }

    private async Task ConfirmToggle()
    {
        if (!await RequireSecurityVerificationAsync("Maintenance Toggle"))
        {
            _pendingToggle = !_pendingToggle;
            return;
        }

        var isActive = _pendingToggle;
        _toggling = true;
        try
        {
            var (succeeded, error) = await AdminService.ToggleMaintenanceModeAsync(isActive, _editMessage, null, null, _editModeType);
            if (succeeded)
            {
                await LoadStatus();
                _pendingToggle = false;

                var title = isActive ? "Maintenance Activated" : "Maintenance Deactivated";
                var options = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.Small, FullWidth = true };
                await DialogService.ShowAsync<MaintenanceSuccessDialog>(title, new DialogParameters { ["Title"] = title, ["Status"] = _status ?? new() }, options);
            }
            else
            {
                Snackbar.Add(error ?? "Failed to update maintenance mode.", Severity.Error);
                _pendingToggle = !isActive;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _toggling = false;
        }
    }

    private async Task ScheduleMaintenance()
    {
        if (!await RequireSecurityVerificationAsync("Schedule Maintenance"))
            return;

        _scheduleError = null;
        if (string.IsNullOrWhiteSpace(_scheduleDate) || string.IsNullOrWhiteSpace(_scheduleTime))
        {
            _scheduleError = "Please select both a date and time.";
            return;
        }
        if (!DateTime.TryParse($"{_scheduleDate} {_scheduleTime}", out var localTime))
        {
            _scheduleError = "Invalid date or time format.";
            return;
        }
        var utcTime = localTime.Kind == DateTimeKind.Utc ? localTime : localTime.ToUniversalTime();
        if (utcTime <= DateTime.UtcNow)
        {
            _scheduleError = "Scheduled time must be in the future.";
            return;
        }

        _toggling = true;
        try
        {
            var (succeeded, error) = await AdminService.ToggleMaintenanceModeAsync(false, null, utcTime, _scheduleMsg, _editModeType);
            if (succeeded)
            {
                await LoadStatus();
                var options = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.Small, FullWidth = true };
                await DialogService.ShowAsync<MaintenanceSuccessDialog>("Maintenance Scheduled", new DialogParameters { ["Title"] = "Maintenance Scheduled", ["Status"] = _status ?? new() }, options);
            }
            else
            {
                Snackbar.Add(error ?? "Failed to schedule maintenance.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _toggling = false;
        }
    }

    private async Task ClearSchedule()
    {
        _toggling = true;
        try
        {
            var (succeeded, error) = await AdminService.ToggleMaintenanceModeAsync(false, null, null, null);
            if (succeeded)
            {
                Snackbar.Add("Scheduled maintenance cleared.", Severity.Success);
                await LoadStatus();
            }
            else
            {
                Snackbar.Add(error ?? "Failed to clear schedule.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _toggling = false;
        }
    }

    private static string FormatTimestamp(DateTime? dt)
    {
        if (dt == null) return "--";
        var local = dt.Value.ToLocalTime();
        return local.ToString("MMM dd, HH:mm");
    }

    private static List<TimelineWindow> BuildTimelineWindows(List<MaintenanceHistoryItem> history)
    {
        var windows = new List<TimelineWindow>();
        MaintenanceHistoryItem? activeEvent = null;

        foreach (var evt in history.OrderBy(h => h.CreatedAt))
        {
            if (evt.Action == "MAINTENANCE_ENABLED")
            {
                activeEvent = evt;
            }
            else if (evt.Action == "MAINTENANCE_DISABLED" && activeEvent != null)
            {
                windows.Add(new TimelineWindow
                {
                    Start = activeEvent.CreatedAt,
                    End = evt.CreatedAt,
                    Label = "Maintenance",
                    ActivatedBy = activeEvent.PerformedBy,
                    DeactivatedBy = evt.PerformedBy,
                    Details = activeEvent.Details
                });
                activeEvent = null;
            }
        }

        if (activeEvent != null)
        {
            windows.Add(new TimelineWindow
            {
                Start = activeEvent.CreatedAt,
                End = DateTime.UtcNow,
                Label = "Active",
                IsActive = true,
                ActivatedBy = activeEvent.PerformedBy,
                Details = activeEvent.Details
            });
        }

        return windows;
    }

    private static string FormatDuration(double totalMinutes)
    {
        if (totalMinutes < 1) return "<1m";
        if (totalMinutes < 60) return $"{(int)totalMinutes}m";
        var hours = (int)(totalMinutes / 60);
        var mins = (int)(totalMinutes % 60);
        return $"{hours}h {mins}m";
    }

    private static string FormatTimelineSpan(DateTime dt)
    {
        return dt.ToLocalTime().ToString("MMM dd HH:mm");
    }

    private async Task ExportHistoryExcel()
    {
        var data = await AdminService.GetMaintenanceHistoryAsync();
        if (data.Count == 0) return;
        var bytes = ReportGen.GenerateMaintenanceHistoryExcel("Maintenance History", data);
        var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
        await JS.InvokeVoidAsync("fmc_downloadFile", "maintenance-history.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", streamRef);
        Snackbar.Add("Maintenance history exported as Excel.", Severity.Success);
    }

