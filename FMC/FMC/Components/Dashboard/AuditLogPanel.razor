@using FMC.Shared.DTOs.Admin
@using FMC.Components.Pages.Admin.Dialogs
@inject OrganizationApiService OrgService
@inject IDialogService DialogService

<div class="fmc-audit-surface">
    <div class="fmc-audit-header">
        <div class="d-flex align-center justify-space-between w-100">
            <div class="fmc-audit-title">
                <div class="fmc-audit-icon mr-3"><MudIcon Icon="@Icons.Material.Filled.EventNote" Color="Color.Info" Size="Size.Small" /></div>
                <div class="fmc-audit-title-text">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 950; letter-spacing: -0.01em; line-height: 1.1;">System Activity Log</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700; line-height: 1.1;">Global audit feed · click a row for details</MudText>
                </div>
            </div>
            <div class="d-flex align-center gap-2">
                <MudTooltip Text="Refresh Log">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default" Size="Size.Small" OnClick="OnRefresh" Disabled="Loading" />
                </MudTooltip>
                <MudTooltip Text="Export &amp; View All">
                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Color="Color.Primary" Size="Size.Small" Href="/admin/audit" />
                </MudTooltip>
            </div>
        </div>
    </div>
    <div class="fmc-audit-section-label">
        <MudText Typo="Typo.caption" Style="font-weight:900; opacity: 0.6; letter-spacing: 0.05em;">LATEST ACTIVITY</MudText>
    </div>

    @if (Loading)
    {
        <div class="fmc-audit-scroll-area">
            <div class="fmc-audit-skel-list">
                @for (int i = 0; i < 6; i++)
                {
                    <div class="fmc-audit-skel-item">
                        <div class="fmc-audit-skel-indicator"></div>
                        <div class="fmc-audit-skel-body">
                            <div class="d-flex justify-space-between align-center mb-2">
                                <div class="fmc-audit-skel fmc-audit-skel-amt"></div>
                                <div class="fmc-audit-skel fmc-audit-skel-badge"></div>
                            </div>
                            <div class="fmc-audit-skel fmc-audit-skel-entity mb-2"></div>
                            <div class="d-flex justify-space-between">
                                <div class="fmc-audit-skel fmc-audit-skel-meta" style="width: 30%;"></div>
                                <div class="fmc-audit-skel fmc-audit-skel-meta" style="width: 22%;"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else if (!Logs.Any())
    {
        <div class="fmc-audit-scroll-area">
            <div class="pa-12 d-flex flex-column align-center mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Large" Style="opacity:0.3;" />
                <MudText Class="mt-2">No activity history found.</MudText>
            </div>
        </div>
    }
    else
    {
        <div class="fmc-audit-scroll-area">
            <div class="fmc-audit-list">
                @foreach (var log in Logs.Skip((_currentPage - 1) * _pageSize).Take(_pageSize))
                {
                    var act = log.Action?.ToUpper() ?? "UNKNOWN";
                    var isApproved = act == "TRANSACTION_APPROVED" || act == "BATCH_APPROVED" || act == "APPROVE" || act == "APPROVAL_SUCCESS";
                    var isBatchSubmit = act == "BATCH_SUBMITTED";
                    var isBatchCancel = act == "BATCH_CANCELLED";

                    var isCredit = isApproved || act == "CREDIT" || act == "WALLET_ADJUSTED" || (act.Contains("SUCCESS") && !act.Contains("DEBIT") && !act.Contains("LOGIN"));
                    var isDebit = isBatchCancel || act == "DEBIT" || act == "REJECTED" || act == "BATCH_REJECTED" || act.Contains("FAILED");
                    var isSecurity = isBatchSubmit || act.Contains("LOGIN") || act.Contains("AUTH") || act.Contains("SECURITY");
                    
                    var clr = isApproved ? "credit" :
                              (isBatchSubmit ? "info" :
                              (isBatchCancel ? "debit" :
                              (isCredit ? "credit" : 
                              (isDebit ? "debit" : 
                              (isSecurity ? "info" : "warning")))));

                    var icon = isApproved ? Icons.Material.Filled.CheckCircle :
                               (isBatchSubmit ? Icons.Material.Filled.Backup :
                               (isBatchCancel ? Icons.Material.Filled.Cancel :
                               (isCredit ? Icons.Material.Filled.AddCircle : 
                               (isDebit ? Icons.Material.Filled.RemoveCircle : 
                               (isSecurity ? Icons.Material.Filled.Shield : Icons.Material.Filled.Hub)))));
                    
                    var localTime = log.CreatedAt.ToDisplayTime();
                    var capturedLog = log;

                    <div class="fmc-audit-item @clr fmc-audit-item-clickable"
                         @onclick="@(() => OpenDetail(capturedLog))">
                        
                        <!-- Premium Floating Forensic Tooltip -->
                        <div class="fmc-row-tooltip">
                            <div class="tooltip-header @clr">
                                <MudIcon Icon="@icon" Size="Size.Small" Class="mr-1" />
                                <span>FORENSIC TELEMETRY STREAM</span>
                            </div>
                            <div class="tooltip-body">
                                <div class="tooltip-row">
                                    <span class="tooltip-lbl">OPERATION:</span>
                                    <span class="tooltip-val @clr">@FormatAction(log.Action)</span>
                                </div>
                                <div class="tooltip-row">
                                    <span class="tooltip-lbl">CONTEXT / ACTOR:</span>
                                    <span class="tooltip-val">@(string.IsNullOrWhiteSpace(log.EntityName) || log.EntityName == "N/A" ? (log.Organization ?? "System Core Gateway") : log.EntityName)</span>
                                </div>
                                <div class="tooltip-row">
                                    <span class="tooltip-lbl">TELEMETRY ENDPOINT:</span>
                                    <span class="tooltip-val mono">@(log.IpAddress ?? "::1 (Local Loopback)")</span>
                                </div>
                                <div class="tooltip-row">
                                    <span class="tooltip-lbl">PLATFORM CONSOLE:</span>
                                    <span class="tooltip-val">@(log.Label ?? "FMC Secure Terminal")</span>
                                </div>
                                <div class="tooltip-row" style="margin-top: 4px; border-top: 1px dashed rgba(255,255,255,0.08); padding-top: 4px;">
                                    <span class="tooltip-lbl">SESSION AUDITOR:</span>
                                    <span class="tooltip-val">@(log.PerformedBy ?? "System Root")</span>
                                </div>
                                <div class="tooltip-row">
                                    <span class="tooltip-lbl">MAGNITUDE VALUE:</span>
                                    <span class="tooltip-val mono highlighted-val">@(log.Amount.HasValue ? $"₱{log.Amount.Value:N2}" : "NOT APPLICABLE")</span>
                                </div>
                                <div class="tooltip-row">
                                    <span class="tooltip-lbl">TIMESTAMP (PHT):</span>
                                    <span class="tooltip-val mono highlighted-val">@log.CreatedAt.ToDisplayString("yyyy-MM-dd HH:mm:ss.fff")</span>
                                </div>
                            </div>
                            <div class="tooltip-footer">
                                <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Size="Size.Small" Class="mr-1" style="font-size: 0.6rem;" />
                                <span>CLICK ROW FOR FULL EVENT LEDGER TRACE</span>
                            </div>
                        </div>

                        <div class="fmc-audit-indicator"></div>
                        <div class="fmc-audit-body-content">
                            <div class="d-flex justify-space-between align-center mb-1">
                                <span class="fmc-audit-amt @clr">
                                    @(log.Amount > 0 ? (isCredit ? "+" : isDebit ? "-" : "") + log.Amount?.ToString("N2") : "SYSTEM")
                                </span>
                                <span class="fmc-audit-badge @clr">@FormatAction(log.Action)</span>
                            </div>
                            <MudText Typo="Typo.body2" Class="fmc-audit-entity-compact">@(string.IsNullOrWhiteSpace(log.EntityName) || log.EntityName == "N/A" ? (log.Organization ?? "System Boundary") : log.EntityName)</MudText>
                            @if (!string.IsNullOrEmpty(log.Label))
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block" Style="font-size: 0.6rem; font-weight: 700; line-height: 1.1; margin-top: 2px;">@log.Label</MudText>
                            }
                            <div class="d-flex justify-space-between mt-1" style="opacity: 0.6;">
                                <span style="font-size: 0.65rem; font-weight: 700;">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size: 0.6rem; margin-right: 2px; vertical-align: middle;" />
                                    @(string.IsNullOrWhiteSpace(log.PerformedBy) ? "System" : log.PerformedBy)
                                </span>
                                <span style="font-size: 0.65rem; font-weight: 700;">@localTime.ToString("MMM dd HH:mm")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="fmc-pagination-bar px-4 py-3 d-flex align-center justify-space-between">
            <div class="d-flex align-center gap-2">
                <span class="fmc-pagination-lbl">Rows per page:</span>
                <select class="fmc-pagination-select" @value="_pageSize" @onchange="OnPageSizeChanged">
                    <option value="10">10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
            </div>
            <div class="d-flex align-center gap-1">
                <button class="fmc-pager-btn" disabled="@(_currentPage <= 1)" @onclick="FirstPage" title="First Page">
                    <MudIcon Icon="@Icons.Material.Filled.FirstPage" Size="Size.Small" />
                </button>
                <button class="fmc-pager-btn" disabled="@(_currentPage <= 1)" @onclick="PrevPage" title="Previous Page">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small" />
                </button>
                <span class="fmc-pagination-info px-2">@_currentPage / @Math.Max(1, (int)Math.Ceiling((double)Logs.Count / _pageSize))</span>
                <button class="fmc-pager-btn" disabled="@(_currentPage >= Math.Ceiling((double)Logs.Count / _pageSize))" @onclick="NextPage" title="Next Page">
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                </button>
                <button class="fmc-pager-btn" disabled="@(_currentPage >= Math.Ceiling((double)Logs.Count / _pageSize))" @onclick="LastPage" title="Last Page">
                    <MudIcon Icon="@Icons.Material.Filled.LastPage" Size="Size.Small" />
                </button>
            </div>
        </div>

        <div class="fmc-audit-footer">
            <MudButton Variant="Variant.Text" 
                       Color="Color.Primary" 
                       FullWidth="true" 
                       Style="text-transform:none; font-weight:800; padding: 12px 0;"
                       Href="/admin/audit">
                View Full Audit Trail
            </MudButton>
        </div>
    }
</div>

<style>
    .fmc-audit-surface { background: var(--mud-palette-surface); border-radius: 20px; border: 1px solid var(--mud-palette-divider); overflow: visible !important; height: 100%; display: flex; flex-direction: column; }
    .fmc-audit-header { padding: 20px 24px; border-bottom: 1px solid var(--mud-palette-divider); background: rgba(var(--mud-palette-primary-rgb), 0.02); }
    .fmc-audit-title { display: flex; align-items: center; }
    .fmc-audit-icon { width: 32px; height: 32px; background: rgba(var(--mud-palette-info-rgb), 0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; }
    .fmc-audit-section-label { padding: 12px 24px; background: var(--mud-palette-background-grey); border-bottom: 1px solid var(--mud-palette-divider); }
    .fmc-audit-scroll-area { flex: 1; overflow-y: auto !important; min-height: 0; }
    .fmc-audit-list { padding: 0; overflow: visible; }
    
    /* Premium Floating Forensic Tooltip for System Activity Log */
    .fmc-audit-item {
        padding: 16px 24px;
        border-bottom: 1px solid var(--mud-palette-divider);
        display: flex;
        gap: 16px;
        position: relative !important;
        width: 100%;
        box-sizing: border-box;
        z-index: 1 !important;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1) !important;
    }
    .fmc-audit-item:last-child { border-bottom: none; }
    .fmc-audit-item-clickable { cursor: pointer; }
    .fmc-audit-item-clickable:hover { background: var(--mud-palette-action-default-hover); transform: translateX(2px); z-index: 10 !important; }
    .fmc-audit-item-clickable:active { opacity: 0.85; transform: translateX(0); }

    .fmc-audit-item .fmc-row-tooltip {
        position: absolute !important;
        bottom: 115% !important;
        left: 50% !important;
        width: 320px !important;
        background: #12121a !important; /* Solid Premium Dark Background in Dark Mode */
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.25) !important;
        border-radius: 12px !important;
        padding: 14px !important;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5), 0 0 25px rgba(var(--mud-palette-primary-rgb), 0.15) !important;
        backdrop-filter: blur(25px) saturate(120%) !important;
        color: var(--mud-palette-text-primary) !important;
        z-index: 100 !important;
        opacity: 0 !important;
        visibility: hidden !important;
        transform: translateX(-50%) translateY(8px) scale(0.97) !important;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
        pointer-events: none !important; /* Breaks hover trap */
        text-align: left !important;
    }

    /* Opaque Background for Light Mode - Checked strictly against html class */
    html:not(.dark) .fmc-audit-item .fmc-row-tooltip {
        background: #ffffff !important;
        color: #1e293b !important;
        border: 1px solid rgba(0, 0, 0, 0.08) !important;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08), 0 0 25px rgba(var(--mud-palette-primary-rgb), 0.05) !important;
    }
    html:not(.dark) .fmc-audit-item .tooltip-val {
        color: #0f172a !important;
    }
    html:not(.dark) .fmc-audit-item .tooltip-lbl {
        color: #64748b !important;
    }

    .fmc-audit-item:hover .fmc-row-tooltip {
        opacity: 1 !important;
        visibility: visible !important;
        transform: translateX(-50%) translateY(0) scale(1) !important;
    }

    /* Downward positioning override for first rows to prevent layout clipping at the top of the feed */
    .fmc-audit-item:nth-of-type(-n+2) .fmc-row-tooltip {
        bottom: auto !important;
        top: 115% !important;
        transform: translateX(-50%) translateY(-8px) scale(0.97) !important;
    }
    .fmc-audit-item:nth-of-type(-n+2):hover .fmc-row-tooltip {
        opacity: 1 !important;
        visibility: visible !important;
        transform: translateX(-50%) translateY(0) scale(1) !important;
    }

    /* Tooltip Internal Structure */
    .fmc-row-tooltip .tooltip-header {
        font-size: 0.58rem !important;
        font-weight: 950 !important;
        letter-spacing: 0.08em !important;
        display: flex !important;
        align-items: center !important;
        margin-bottom: 8px !important;
        opacity: 0.8 !important;
    }
    .fmc-row-tooltip .tooltip-header.credit { color: #10b981 !important; }
    .fmc-row-tooltip .tooltip-header.debit { color: #f43f5e !important; }
    .fmc-row-tooltip .tooltip-header.info { color: #3b82f6 !important; }
    .fmc-row-tooltip .tooltip-header.warning { color: #f59e0b !important; }

    .fmc-row-tooltip .tooltip-body {
        display: flex !important;
        flex-direction: column !important;
        gap: 5px !important;
    }
    .fmc-row-tooltip .tooltip-row {
        display: flex !important;
        justify-content: space-between !important;
        align-items: center !important;
        font-size: 0.72rem !important;
    }
    .fmc-row-tooltip .tooltip-lbl {
        font-weight: 550 !important;
        color: rgba(255, 255, 255, 0.38) !important;
        font-size: 0.68rem !important;
        letter-spacing: 0.02em !important;
    }
    html:not(.dark) .fmc-row-tooltip .tooltip-lbl {
        color: #64748b !important;
        font-weight: 550 !important;
    }
    .fmc-row-tooltip .tooltip-val {
        font-weight: 750 !important;
        color: rgba(255, 255, 255, 0.9) !important;
        text-align: right !important;
    }
    .fmc-row-tooltip .tooltip-val.mono {
        font-family: 'JetBrains Mono', monospace !important;
        font-size: 0.68rem !important;
    }
    .fmc-row-tooltip .tooltip-val.highlighted-val {
        font-weight: 950 !important;
        font-family: 'JetBrains Mono', monospace !important;
        font-size: 0.76rem !important;
        color: #ffffff !important;
        text-shadow: 0 0 8px rgba(255, 255, 255, 0.12) !important;
    }
    html:not(.dark) .fmc-row-tooltip .tooltip-val.highlighted-val {
        color: #000000 !important;
        text-shadow: none !important;
    }
    .fmc-row-tooltip .tooltip-val.credit { color: #10b981 !important; }
    .fmc-row-tooltip .tooltip-val.debit { color: #f43f5e !important; }
    .fmc-row-tooltip .tooltip-val.info { color: #3b82f6 !important; }
    .fmc-row-tooltip .tooltip-val.warning { color: #f59e0b !important; }

    .fmc-row-tooltip .tooltip-footer {
        margin-top: 8px !important;
        padding-top: 8px !important;
        border-top: 1px solid rgba(255, 255, 255, 0.08) !important;
        font-size: 0.58rem !important;
        font-weight: 900 !important;
        letter-spacing: 0.05em !important;
        color: rgba(255, 255, 255, 0.35) !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        text-transform: uppercase !important;
    }
    html:not(.dark) .fmc-row-tooltip .tooltip-footer {
        border-top-color: rgba(0, 0, 0, 0.06) !important;
        color: rgba(0, 0, 0, 0.4) !important;
    }

    .fmc-audit-indicator { width: 4px; border-radius: 2px; position: absolute; left: 0; top: 12px; bottom: 12px; }
    .fmc-audit-item.credit .fmc-audit-indicator { background: var(--mud-palette-success); }
    .fmc-audit-item.debit .fmc-audit-indicator { background: var(--mud-palette-error); }
    .fmc-audit-item.info .fmc-audit-indicator { background: var(--mud-palette-info); }
    .fmc-audit-item.warning .fmc-audit-indicator { background: var(--mud-palette-warning); }
    .fmc-audit-body-content { flex: 1; }
    .fmc-audit-amt { font-family: 'JetBrains Mono', monospace; font-weight: 900; font-size: 0.9rem; }
    .fmc-audit-amt.credit { color: var(--mud-palette-success); }
    .fmc-audit-amt.debit { color: var(--mud-palette-error); }
    .fmc-audit-badge { font-size: 0.55rem; font-weight: 900; padding: 2px 6px; border-radius: 4px; text-transform: uppercase; }
    .fmc-audit-badge.credit { background: rgba(var(--mud-palette-success-rgb), 0.1); color: var(--mud-palette-success); }
    .fmc-audit-badge.debit { background: rgba(var(--mud-palette-error-rgb), 0.1); color: var(--mud-palette-error); }
    .fmc-audit-badge.info { background: rgba(var(--mud-palette-info-rgb), 0.1); color: var(--mud-palette-info); }
    .fmc-audit-badge.warning { background: rgba(var(--mud-palette-warning-rgb), 0.1); color: var(--mud-palette-warning); }
    .fmc-audit-entity-compact { font-weight: 800; color: var(--mud-palette-text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px; }
    .fmc-audit-footer { border-top: 1px solid var(--mud-palette-divider); margin-top: auto; }

    /* ── Audit Log Skeleton Loader ── */
    @@keyframes audit-shimmer {
        0%   { background-position: -500px 0; }
        100% { background-position: 500px 0; }
    }
    .fmc-audit-skel-list { display: flex; flex-direction: column; }
    .fmc-audit-skel-item { padding: 16px 24px; border-bottom: 1px solid var(--mud-palette-divider); display: flex; gap: 16px; position: relative; }
    .fmc-audit-skel-item:last-child { border-bottom: none; }
    .fmc-audit-skel-indicator { width: 4px; border-radius: 2px; position: absolute; left: 0; top: 12px; bottom: 12px; background: var(--mud-palette-divider); }
    .fmc-audit-skel-body { flex: 1; padding-left: 8px; }
    .fmc-audit-skel {
        border-radius: 5px;
        background: linear-gradient(90deg, var(--mud-palette-divider) 25%, rgba(var(--mud-palette-primary-rgb), 0.06) 50%, var(--mud-palette-divider) 75%);
        background-size: 500px 100%;
        animation: audit-shimmer 1.6s ease-in-out infinite;
    }
    .fmc-audit-skel-amt   { height: 13px; width: 72px; }
    .fmc-audit-skel-badge { height: 16px; width: 80px; border-radius: 4px; }
    .fmc-audit-skel-entity { height: 12px; width: 60%; }
    .fmc-audit-skel-meta  { height: 9px; border-radius: 4px; }

    /* Pagination Styles */
    .fmc-pagination-bar {
        border-top: 1px solid var(--mud-palette-divider);
        background: rgba(var(--mud-palette-primary-rgb), 0.01);
    }
    .fmc-pagination-lbl {
        font-size: 0.7rem;
        font-weight: 700;
        opacity: 0.6;
    }
    .fmc-pagination-select {
        background: var(--mud-palette-background-grey);
        color: var(--mud-palette-text-primary);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 6px;
        padding: 2px 6px;
        font-size: 0.7rem;
        font-weight: 700;
        outline: none;
        cursor: pointer;
    }
    .fmc-pagination-select option {
        background-color: var(--mud-palette-surface) !important;
        color: var(--mud-palette-text-primary) !important;
    }
    .fmc-pager-btn {
        background: var(--mud-palette-background-grey);
        color: var(--mud-palette-text-primary);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 6px;
        width: 26px;
        height: 26px;
        display: flex;
        align-center: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
    }
    .fmc-pager-btn:hover:not(:disabled) {
        background: var(--mud-palette-action-default-hover);
    }
    .fmc-pager-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }
    .fmc-pagination-info {
        font-size: 0.7rem;
        font-weight: 700;
        font-family: 'JetBrains Mono', monospace;
    }
</style>

@code {
    [Parameter] public List<AuditLogDto> Logs { get; set; } = new();
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }

    private int _currentPage = 1;
    private int _pageSize = 10;

    protected override void OnParametersSet()
    {
        var maxPage = (int)Math.Ceiling((double)Logs.Count / _pageSize);
        if (_currentPage > maxPage)
        {
            _currentPage = Math.Max(1, maxPage);
        }
    }

    private void OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
        {
            _pageSize = size;
            _currentPage = 1;
        }
    }

    private void FirstPage()
    {
        _currentPage = 1;
    }

    private void PrevPage()
    {
        if (_currentPage > 1) _currentPage--;
    }

    private void NextPage()
    {
        var maxPage = Math.Ceiling((double)Logs.Count / _pageSize);
        if (_currentPage < maxPage) _currentPage++;
    }

    private void LastPage()
    {
        _currentPage = Math.Max(1, (int)Math.Ceiling((double)Logs.Count / _pageSize));
    }

    private async Task OpenDetail(AuditLogDto log)
    {
        var parameters = new DialogParameters { ["Log"] = log };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };
        await DialogService.ShowAsync<AuditDetailDialog>("Forensic Event Trace", parameters, options);
    }

    private string FormatAction(string? action)
    {
        if (string.IsNullOrEmpty(action)) return string.Empty;
        var upper = action.ToUpperInvariant();
        return upper switch
        {
            "TRANSACTION_APPROVED" => "Transaction Approved",
            "BATCH_SUBMITTED" => "Batch Submitted",
            "BATCH_CANCELLED" => "Batch Cancelled",
            "BATCH_REJECTED" => "Batch Rejected",
            "TRANSACTION_REJECTED" => "Transaction Rejected",
            "SYNC_LIMIT" => "Sync Limit",
            "WALLET_ADJUSTED" => "Wallet Adjusted",
            "EXHAUSTION_WARNING" => "Exhaustion Warning",
            "APPROVAL_SUCCESS" => "Approval Success",
            _ => System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(action.Replace("_", " ").ToLower())
        };
    }
}
