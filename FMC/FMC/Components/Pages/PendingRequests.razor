    #region Export Helpers

    /// <summary>
    /// Generates an Excel report of the currently filtered ledger and triggers a browser download.
    /// </summary>
    private async Task ExportToExcelAsync()
    {
        var filtered = _allTransactions.Where(FilterFunc).ToList();
        var bytes = ReportGen.GenerateExcel($"FMC_Ledger_{_orgId}", filtered);
        await DownloadFileAsync(bytes, $"FMC_Report_{DateTime.Now:yyyyMMdd}.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    /// <summary>
    /// Generates a PDF report of the currently filtered ledger and triggers a browser download.
    /// </summary>
    private async Task ExportToPdfAsync()
    {
        var filtered = _allTransactions.Where(FilterFunc).ToList();
        var bytes = ReportGen.GeneratePdf($"Structural Settlement Report — {DateTime.Now:MMM dd, yyyy}", filtered);
        await DownloadFileAsync(bytes, $"FMC_Settlement_{DateTime.Now:yyyyMMdd}.pdf", "application/pdf");
    }

    private async Task DownloadFileAsync(byte[] bytes, string fileName, string contentType)
    {
        using var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
        await JS.InvokeVoidAsync("fmc_downloadFile", fileName, contentType, streamRef);
    }

    #endregion

    #region Models

    /// <summary>
    /// A UI-only DTO used to visually group multiple pending transactions that belong to the same BatchId.
    /// </summary>
    public class TransactionGroup
    {
        public Guid? BatchId { get; set; }
        public List<TransactionDto> Transactions { get; set; } = new();
        
        public decimal TotalAmount => Transactions.Sum(t => t.Amount);
        public string? Label => Transactions.FirstOrDefault()?.Label;
        public string? MakerName => Transactions.FirstOrDefault()?.MakerName;
        public string? ApproverName => Transactions.FirstOrDefault()?.ApproverName;
        public string Status => Transactions.All(t => t.Status == Transactions.First().Status) ? Transactions.First().Status : "Mixed";
        public DateTime Date => Transactions.FirstOrDefault()?.Date ?? DateTime.UtcNow;
        public string? AccountNumber => BatchId.HasValue ? null : Transactions.FirstOrDefault()?.AccountNumber;
        
        /// <summary>
        /// Used by the UI to toggle the accordion visibility of child transactions.
        /// </summary>
        public bool ShowDetails { get; set; }
    }

    #endregion
