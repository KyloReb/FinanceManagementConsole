@page "/accounts"
@using FMC.Shared.DTOs
@using FMC.Shared.Auth
@using FMC.Shared.DTOs.Organization
@using MudBlazor.Services
@implements IAsyncDisposable
@implements IBrowserViewportObserver
@attribute [Authorize(Roles = Roles.SuperAdmin + "," + Roles.CEO + "," + Roles.Maker + "," + Roles.Approver)]
@inject FMC.Services.Api.AdminService AdminService
@inject FMC.Services.Api.OrganizationApiService OrganizationService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IBrowserViewportService BrowserViewportService
@inject IDialogService DialogService
@inject ThemeService ThemeService

<PageTitle>Financial Account Inventory | FMC</PageTitle>

<div class="fmc-acc-root @(ThemeService.IsDarkMode ? "fmc-dark-mode" : "fmc-light-mode")">
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mt-md-8 mb-12 fmc-acc-table-container">
    @* PLATINUM HEADER AREA *@
    <div class="fmc-acc-header mb-8 flex-wrap gap-4">
        <div class="d-flex align-center">
            <div class="fmc-acc-bar mr-4"></div>
            <div>
                <MudText Typo="Typo.h4" Class="fmc-acc-hero-text">Capital Account Inventory</MudText>
                <MudText Typo="Typo.body1" Class="fmc-acc-subtitle d-none d-sm-block">Comprehensive institutional oversight of all liquidity endpoints.</MudText>
            </div>
        </div>
        @if (_isCEOOrAdmin)
        {
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" 
                       Size="Size.Large" Class="fmc-acc-action-btn" OnClick="OpenCreateUserDialog">CREATE NEW ACCOUNT</MudButton>
        }
    </div>

    <div class="mb-4">
    </div>

    @if (_loading)
    {
        @* ── ADMINISTRATIVE ACCESS MATRIX SKELETON ── *@
        <div class="fmc-acc-surface mb-10">
            <div class="pa-6 d-flex align-center justify-space-between fmc-staff-surface" style="border-bottom: 1px solid var(--mud-palette-divider);">
                <div class="d-flex align-center gap-3">
                    <div class="fmc-page-skel" style="width:28px;height:28px;border-radius:6px;"></div>
                    <div class="fmc-page-skel" style="width:220px;height:18px;"></div>
                </div>
                <div class="fmc-page-skel" style="width:220px;height:38px;border-radius:10px;"></div>
            </div>
            @* Table Header *@
            <div class="d-flex pa-4 px-6" style="border-bottom:1px solid var(--mud-palette-divider); gap:16px;">
                <div class="fmc-page-skel" style="flex:4;height:11px;"></div>
                <div class="fmc-page-skel" style="flex:3;height:11px;"></div>
                <div class="fmc-page-skel" style="flex:2;height:11px;"></div>
                <div class="fmc-page-skel" style="flex:1;height:11px;"></div>
            </div>
            @* Skeleton org group header *@
            <div class="px-6 py-3" style="background:var(--mud-palette-background-grey); border-bottom:1px solid var(--mud-palette-divider);">
                <div class="fmc-page-skel" style="width:160px;height:13px;"></div>
            </div>
            @* Skeleton rows *@
            @for (int i = 0; i < 4; i++)
            {
                <div class="d-flex align-center pa-4 px-6" style="border-bottom:1px solid var(--mud-palette-divider); gap:16px;">
                    <div class="d-flex align-center gap-3" style="flex:4;">
                        <div class="fmc-page-skel" style="width:40px;height:40px;border-radius:50%;flex-shrink:0;"></div>
                        <div style="flex:1;">
                            <div class="fmc-page-skel" style="width:60%;height:13px;margin-bottom:6px;"></div>
                            <div class="fmc-page-skel" style="width:45%;height:10px;"></div>
                        </div>
                    </div>
                    <div style="flex:3;">
                        <div class="fmc-page-skel" style="width:55%;height:13px;margin-bottom:6px;"></div>
                        <div class="fmc-page-skel" style="width:35%;height:10px;"></div>
                    </div>
                    <div style="flex:2;">
                        <div class="fmc-page-skel" style="width:80px;height:24px;border-radius:20px;"></div>
                    </div>
                    <div class="d-flex gap-2 justify-end" style="flex:1;">
                        <div class="fmc-page-skel" style="width:30px;height:30px;border-radius:8px;"></div>
                        <div class="fmc-page-skel" style="width:30px;height:30px;border-radius:8px;"></div>
                    </div>
                </div>
            }
        </div>

        @* ── CARDHOLDER REGISTRY SKELETON ── *@
        <div class="fmc-acc-surface">
            <div class="pa-6 d-flex align-center justify-space-between fmc-cardholder-surface" style="border-bottom: 1px solid var(--mud-palette-divider);">
                <div class="d-flex align-center gap-3">
                    <div class="fmc-page-skel" style="width:28px;height:28px;border-radius:6px;"></div>
                    <div class="fmc-page-skel" style="width:240px;height:18px;"></div>
                </div>
                <div class="fmc-page-skel" style="width:220px;height:38px;border-radius:10px;"></div>
            </div>
            @* Table Header *@
            <div class="d-flex pa-4 px-6" style="border-bottom:1px solid var(--mud-palette-divider); gap:16px;">
                <div class="fmc-page-skel" style="flex:4;height:11px;"></div>
                <div class="fmc-page-skel" style="flex:3;height:11px;"></div>
                <div class="fmc-page-skel" style="flex:2;height:11px;"></div>
                <div class="fmc-page-skel" style="flex:1;height:11px;"></div>
            </div>
            @* Skeleton rows *@
            @for (int i = 0; i < 6; i++)
            {
                <div class="d-flex align-center pa-5 px-6" style="border-bottom:1px solid var(--mud-palette-divider); gap:16px;">
                    <div class="d-flex align-center gap-3" style="flex:4;">
                        <div class="fmc-page-skel" style="width:40px;height:40px;border-radius:50%;flex-shrink:0;"></div>
                        <div style="flex:1;">
                            <div class="fmc-page-skel" style="width:55%;height:13px;margin-bottom:6px;"></div>
                            <div class="fmc-page-skel" style="width:70%;height:10px;"></div>
                        </div>
                    </div>
                    <div style="flex:3;">
                        <div class="fmc-page-skel" style="width:60%;height:13px;margin-bottom:6px;"></div>
                        <div class="fmc-page-skel" style="width:40%;height:10px;"></div>
                    </div>
                    <div class="text-right" style="flex:2;">
                        <div class="fmc-page-skel" style="width:90px;height:16px;margin-left:auto;"></div>
                    </div>
                    <div class="d-flex gap-2 justify-end" style="flex:1;">
                        <div class="fmc-page-skel" style="width:30px;height:30px;border-radius:8px;"></div>
                        <div class="fmc-page-skel" style="width:30px;height:30px;border-radius:8px;"></div>
                    </div>
                </div>
            }
            @* Pager skeleton *@
            <div class="d-flex justify-end align-center pa-4 gap-3" style="border-top:1px solid var(--mud-palette-divider);">
                <div class="fmc-page-skel" style="width:100px;height:11px;"></div>
                <div class="fmc-page-skel" style="width:80px;height:32px;border-radius:8px;"></div>
                <div class="fmc-page-skel" style="width:80px;height:32px;border-radius:8px;"></div>
            </div>
        </div>
    }
    else
    {
        @if (!_isMobile)
        {
        <div class="fmc-acc-surface mb-10">
            <div class="pa-6 border-b border-divider d-flex align-center justify-space-between flex-wrap gap-4 fmc-staff-surface">
                <div class="d-flex align-center gap-3">
                    <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Style="color: var(--fmc-accent-staff);" />
                    <MudText Typo="Typo.h6" Style="font-family: 'Outfit', sans-serif; font-weight: 900; letter-spacing: -0.01em;">ADMINISTRATIVE ACCESS MATRIX</MudText>
                </div>
                <div style="width: 320px;">
                    <MudTextField @bind-Value="_staffSearchString" Placeholder="Filter staff accounts..." 
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.FilterList" 
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="fmc-acc-input"
                                  Clearable="true" Immediate="true" />
                </div>
            </div>
            <MudTable @ref="_staffTable" Items="@FilteredStaff" Hover="true" Elevation="0" Class="fmc-acc-table"
                      GroupBy="@(_isSuperAdmin ? _staffGroupDefinition : null)"
                      RowClassFunc="@((item, index) => $"cursor-pointer {(IsOrgExpanded(item.Organization) ? "" : "fmc-row-hidden")}")"
                      OnRowClick="@((TableRowClickEventArgs<UserDto> e) => Navigation.NavigateTo($"/profile/{e.Item!.Id}"))">
                <ColGroup>
                    @if (_isCEOOrAdmin)
                    {
                        <col style="width: 40%;" />
                        <col style="width: 30%;" />
                        <col style="width: 20%;" />
                        <col style="width: 10%;" />
                    }
                    else
                    {
                        <col style="width: 40%;" />
                        <col style="width: 35%;" />
                        <col style="width: 25%;" />
                    }
                </ColGroup>
                <HeaderContent>
                    <MudTh Class="fmc-th"><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.DisplayName)">STAFF IDENTITY</MudTableSortLabel></MudTh>
                    <MudTh Class="fmc-th"><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Organization ?? string.Empty)">ORGANIZATION</MudTableSortLabel></MudTh>
                    <MudTh Class="fmc-th"><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Role)">SYSTEM ROLE</MudTableSortLabel></MudTh>
                    @if (_isCEOOrAdmin)
                    {
                        <MudTh Class="fmc-th" Style="text-align:right">ACTIONS</MudTh>
                    }
                </HeaderContent>
                <GroupHeaderTemplate>
                    <MudTh Class="fmc-group-header fmc-group-override" colspan="10" @onclick="@(() => ToggleGroup(context))" style="cursor: pointer;">
                        <div class="d-flex align-center gap-3 py-1 justify-start" style="width: 100%;">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Medium" Style="color: var(--fmc-accent-premium); opacity: 0.8;" />
                            <div class="d-flex flex-column">
                                <div class="d-flex align-center gap-2">
                                    <MudText Typo="Typo.subtitle2" Style="font-family: 'Outfit', sans-serif; font-weight: 900; letter-spacing: 0.02em; color: var(--mud-palette-text-primary);">
                                        @((context.Key ?? "SYSTEM CORE").ToString()?.ToUpper())
                                    </MudText>
                                    <MudIcon Icon="@(IsOrgExpanded(context.Key?.ToString()) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" 
                                             Size="Size.Small" Class="mud-text-secondary" />
                                </div>
                                <MudText Typo="Typo.caption" Style="font-weight: 800; opacity: 0.5; text-transform: uppercase; letter-spacing: 0.05em;">
                                    @context.Items.Count() Authorized Staff Members
                                </MudText>
                            </div>
                        </div>
                    </MudTh>
                </GroupHeaderTemplate>
                <RowTemplate Context="staff">
                    <MudTd Style="@(!staff.IsActive ? "opacity: 0.55;" : "")">
                        <div class="d-flex align-center">
                            <div style="position: relative;">
                                <MudAvatar Color="Color.Default" Class="@($"mr-4 staff staff-avatar fmc-avatar-{GetAvatarIndex(staff.DisplayName)}")" Style="@($"color: white; font-weight: 950; font-size: 0.85rem; width: 40px; height: 40px; {(!staff.IsActive ? "filter: grayscale(80%);" : "")}")">@(GetInitials(staff))</MudAvatar>
                                @if (!staff.IsActive)
                                {
                                    <div style="position: absolute; bottom: 0; right: 12px; width: 11px; height: 11px; background: var(--mud-palette-error); border-radius: 50%; border: 2px solid var(--mud-palette-surface);" title="Account Suspended"></div>
                                }
                                else
                                {
                                    <div style="position: absolute; bottom: 0; right: 12px; width: 11px; height: 11px; background: var(--mud-palette-success); border-radius: 50%; border: 2px solid var(--mud-palette-surface);" title="Account Active"></div>
                                }
                            </div>
                            <div class="d-flex flex-column">
                                <div class="d-flex align-center gap-2">
                                    <MudText Typo="Typo.body2" Class="fmc-staff-name">@staff.DisplayName</MudText>
                                    @if (!staff.IsActive)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled"
                                                 Style="height: 16px; font-size: 0.55rem; font-weight: 900; letter-spacing: 0.05em; padding: 0 6px; margin: 0; text-transform: uppercase;">SUSPENDED</MudChip>
                                    }
                                </div>
                                <MudText Typo="Typo.caption" Class="fmc-staff-email">@staff.Email</MudText>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd Style="@(!staff.IsActive ? "opacity: 0.55;" : "")">
                        <MudText Typo="Typo.body2" Class="fmc-org-name">@(staff.Organization ?? "SYSTEM CORE")</MudText>
                        <MudText Typo="Typo.caption" Class="fmc-org-sub">Institutional Entity</MudText>
                    </MudTd>
                    <MudTd Style="@(!staff.IsActive ? "opacity: 0.55;" : "")">
                        <span class="fmc-role-tag @(staff.Role == Roles.SuperAdmin ? "admin" : (staff.Role == Roles.CEO ? "ceo" : (staff.Role == Roles.Maker ? "maker" : "approver")))">@staff.Role</span>
                    </MudTd>
                    @if (_isCEOOrAdmin)
                    {
                        <MudTd Style="text-align:right" @onclick:stopPropagation="true">
                            <div class="d-flex justify-end gap-2">
                                 <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" 
                                                OnClick="@(() => OpenEditUserDialog(staff))" Class="fmc-adj-btn staff-edit" />
                                 <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" 
                                                Disabled="@(staff.Role == Roles.SuperAdmin)"
                                                OnClick="@(() => ConfirmDeleteUser(staff))" Class="fmc-adj-btn staff-delete" />
                            </div>
                        </MudTd>
                    }
                </RowTemplate>
            </MudTable>
        </div>

        @if (!_isSuperAdmin)
        {
            @* BANKING STATUS LEGEND *@
            <div class="d-flex align-center justify-center gap-6 mb-10 pa-4 fmc-legend-panel flex-wrap">
                <div class="d-flex align-center gap-2">
                    <div class="fmc-status-dot active"></div>
                    <MudText Typo="Typo.caption" Style="font-weight: 800; opacity: 0.8;">REGISTERED / ACTIVE</MudText>
                </div>
                <div class="d-flex align-center gap-2">
                    <div class="fmc-status-dot dormant"></div>
                    <MudText Typo="Typo.caption" Style="font-weight: 800; opacity: 0.8;">INACTIVE / DORMANT</MudText>
                </div>
                <div class="d-flex align-center gap-2">
                    <div class="fmc-status-dot suspended"></div>
                    <MudText Typo="Typo.caption" Style="font-weight: 800; opacity: 0.8;">BLOCKED / SUSPENDED</MudText>
                </div>
                <div class="d-flex align-center gap-2">
                    <div class="fmc-status-dot uninitialized"></div>
                    <MudText Typo="Typo.caption" Style="font-weight: 800; opacity: 0.8;">NEW ACCOUNT PENDING</MudText>
                </div>
            </div>

            <div class="fmc-acc-surface">
                <div class="pa-6 border-b border-divider d-flex align-center justify-space-between flex-wrap gap-4 fmc-cardholder-surface">
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.Groups" Style="color: var(--fmc-accent-premium);" />
                        <MudText Typo="Typo.h6" Style="font-weight: 900; letter-spacing: -0.01em;">REGISTERED CARDHOLDER REGISTRY</MudText>
                    </div>
                    <div style="width: 320px;">
                        <MudTextField @bind-Value="_searchString" Placeholder="Search cardholders..." 
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="fmc-acc-input"
                                      Clearable="true" Immediate="true" />
                    </div>
                </div>
                <MudTable Items="@FilteredCardholders" Hover="true" Elevation="0" Class="fmc-acc-table" HorizontalScrollbar="true"
                          OnRowClick="@((TableRowClickEventArgs<UserDto> e) => Navigation.NavigateTo($"/profile/{e.Item!.Id}"))" RowClass="cursor-pointer">
                    <HeaderContent>
                        <MudTh Class="fmc-th"><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.DisplayName)">CARDHOLDER IDENTITY</MudTableSortLabel></MudTh>
                        <MudTh Class="fmc-th"><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Organization ?? string.Empty)">SUBSCRIBER</MudTableSortLabel></MudTh>
                        <MudTh Class="fmc-th" Style="text-align:right"><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Balance)">AVAILABLE LIQUIDITY</MudTableSortLabel></MudTh>
                        @if (_canAdjust)
                        {
                            <MudTh Class="fmc-th" Style="text-align:right">ACTIONS</MudTh>
                        }
                    </HeaderContent>
                    <RowTemplate Context="cardholder">
                        <MudTd Class="py-5">
                            <div class="d-flex align-center">
                                <MudAvatar Color="Color.Default" Class="mr-3" Style="@($"background-color: {GetAvatarColor(cardholder.DisplayName)} !important; color: white; font-weight: 950; font-size: 0.8rem;")">@(GetInitials(cardholder))</MudAvatar>
                                <div>
                                    <div class="d-flex align-center gap-2">
                                        <MudText Typo="Typo.body1" Style="font-weight:900; letter-spacing:-0.02em;">@cardholder.DisplayName</MudText>
                                        <MudTooltip Text="@GetStatusText(cardholder)">
                                            <div class="fmc-status-dot @GetStatusClass(cardholder)"></div>
                                        </MudTooltip>
                                    </div>
                                    <MudText Typo="Typo.caption" Class="fmc-card-mono">@MaskCard(cardholder.AccountNumber)</MudText>
                                </div>
                            </div>
                        </MudTd>
                        <MudTd>
                            <MudText Typo="Typo.body2" Style="font-weight:800;">@(cardholder.Organization ?? "EXTERNAL")</MudText>
                            <MudText Typo="Typo.caption" Style="opacity: 0.6;">Subscriber Unit</MudText>
                        </MudTd>
                        <MudTd Style="text-align:right">
                            <MudText Typo="Typo.body1" Class="fmc-money fmc-table-balance">
                                ₱@cardholder.Balance.ToString("N2")
                            </MudText>
                        </MudTd>
                        <MudTd Style="text-align:right" @onclick:stopPropagation="true">
                            @if (_canAdjust)
                            {
                                <div class="d-flex justify-end gap-2">
                                    <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" 
                                                   OnClick="@(() => OpenUserAdjustmentDialog(cardholder, true))" 
                                                   Class="fmc-adj-btn credit" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" 
                                                   OnClick="@(() => OpenUserAdjustmentDialog(cardholder, false))" 
                                                   Class="fmc-adj-btn debit" />
                                </div>
                            }
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            </div>
        }
    }
    else
    {
            @* MOBILE CARDHOLDER VIEW (Staff views are usually desktop-focused for admins) *@
            @if (!_isSuperAdmin)
            {
                <div class="d-flex flex-column gap-3">
                    <MudText Typo="Typo.subtitle2" Class="fmc-acc-card-label ml-2">CARDHOLDER REGISTRY</MudText>
                    @foreach (var user in FilteredCardholders)
                    {
                        <div class="fmc-acc-mobile-card cursor-pointer" @onclick="@(() => Navigation.NavigateTo($"/profile/{user.Id}"))">
                            <div class="fmc-mobile-header pa-4">
                                <div class="d-flex justify-space-between align-start">
                                    <div class="d-flex gap-3">
                                        <MudAvatar Color="Color.Default" Class="@($"fmc-avatar-{GetAvatarIndex(user.DisplayName)}")" Style="color: white; font-weight: 950;">@(GetInitials(user))</MudAvatar>
                                        <div class="d-flex flex-column">
                                            <div class="fmc-mobile-name-row">
                                                <MudText Typo="Typo.body1" Inline="true" Style="font-weight:950; letter-spacing:-0.02em;">@user.DisplayName</MudText>
                                                <div class="fmc-status-dot @GetStatusClass(user) s-mobile"></div>
                                            </div>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary fmc-mobile-acc-number">@(MaskCard(user.AccountNumber))</MudText>
                                        </div>
                                    </div>
                                    <div class="text-right d-flex flex-column align-end">
                                        <MudText Typo="Typo.body1" Class="fmc-money" Style="color: var(--mud-palette-info); font-size:1rem;">₱@user.Balance.ToString("N0")</MudText>
                                        <MudText Typo="Typo.caption" Style="font-size:0.55rem; font-weight:950; opacity:0.5; letter-spacing:0.05em;">BALANCE</MudText>
                                    </div>
                                </div>
                            </div>
                            <div class="fmc-mobile-body px-4 py-3">
                                <div class="d-flex justify-space-between align-center mb-2">
                                    <MudText Typo="Typo.caption" Style="font-weight:900; opacity:0.5; letter-spacing:0.05em;">ORGANIZATION</MudText>
                                    <MudText Typo="Typo.caption" Style="font-weight:900; color: var(--mud-palette-text-primary);">@(user.Organization ?? "INDIVIDUAL")</MudText>
                                </div>
                                <div class="d-flex justify-space-between align-center">
                                    <MudText Typo="Typo.caption" Style="font-weight:900; opacity:0.5; letter-spacing:0.05em;">IDENTITY ROLE</MudText>
                                    <span class="fmc-role-tag s-small @(user.Role == Roles.SuperAdmin ? "admin" : (user.Role == Roles.CEO ? "ceo" : "user"))">@user.Role</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    }
</MudContainer>
</div>

@code {
    private List<UserDto>? _users;
    private OrganizationDto? _organization;
    private bool _loading = true;
    private string _searchString = "";
    private string _staffSearchString = "";
    private bool _isOrgScoped = false;
    private bool _isCEOOrAdmin = false;
    private bool _canAdjust = false;
    private bool _isMobile = false;
    private bool _isSuperAdmin = false;
    
    private TableGroupDefinition<UserDto> _staffGroupDefinition = new()
    {
        Selector = (e) => e.Organization ?? "SYSTEM CORE",
        Expandable = false
    };
    private MudTable<UserDto> _staffTable = default!;
    private HashSet<string> _expandedGroups = new();

    private bool IsOrgExpanded(string? org) => 
        _expandedGroups.Contains(org ?? "SYSTEM CORE");

    private async Task ToggleGroup(TableGroupData<object, UserDto> context)
    {
        var key = (context.Key ?? "SYSTEM CORE").ToString() ?? "SYSTEM CORE";
        
        if (_expandedGroups.Contains(key)) _expandedGroups.Remove(key);
        else _expandedGroups.Add(key);
        
        await InvokeAsync(StateHasChanged);
    }
    public Guid Id { get; } = Guid.NewGuid();
    public ResizeOptions ResizeOptions { get; } = new() { ReportRate = 100, NotifyOnBreakpointOnly = true };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _isSuperAdmin = user.IsInRole(Roles.SuperAdmin);
        _isCEOOrAdmin = user.IsInRole(Roles.CEO) || _isSuperAdmin;
        _isOrgScoped = !_isSuperAdmin;
        
        // Strict Enforcement: Only the MAKER role has direct balance adjustment authority 
        // to maintain the 4-eyes principle. SuperAdmins and CEOs are oversight only.
        _canAdjust = user.IsInRole(Roles.Maker);
        
        await LoadData(user);
    }

    private async Task LoadData(System.Security.Claims.ClaimsPrincipal user)
    {
        try
        {
            _loading = true;
            await LoadUsers();

            if (_isOrgScoped)
            {
                var orgIdStr = user.FindFirst("OrganizationId")?.Value;
                if (Guid.TryParse(orgIdStr, out var orgId))
                {
                    _organization = await OrganizationService.GetByIdAsync(orgId);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to generate account inventory trace: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isMobile = await BrowserViewportService.GetCurrentBreakpointAsync() < Breakpoint.Sm;
            await BrowserViewportService.SubscribeAsync(this);
            StateHasChanged();
        }
    }

    public async Task NotifyBrowserViewportChangeAsync(BrowserViewportEventArgs e)
    {
        var mobile = e.Breakpoint < Breakpoint.Sm;
        if (_isMobile != mobile)
        {
            _isMobile = mobile;
            await InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        await BrowserViewportService.UnsubscribeAsync(this);
    }

    private async Task LoadUsers()
    {
        _users = await AdminService.GetUsersAsync();
        
        // Initialize all organizations as expanded by default
        if (_users != null)
        {
            foreach (var org in _users.Select(u => u.Organization ?? "SYSTEM CORE").Distinct())
            {
                if (!_expandedGroups.Contains(org))
                {
                    _expandedGroups.Add(org);
                }
            }
        }
    }

    private IEnumerable<UserDto> FilteredCardholders => 
        _users?.Where(u => u.Role == Roles.User && 
                          (string.IsNullOrWhiteSpace(_searchString) || 
                           u.DisplayName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                           (u.Email ?? "").Contains(_searchString, StringComparison.OrdinalIgnoreCase))) ?? Enumerable.Empty<UserDto>();

    private IEnumerable<UserDto> FilteredStaff => 
        _users?.Where(u => u.Role != Roles.User && 
                          (string.IsNullOrWhiteSpace(_staffSearchString) || 
                           u.DisplayName.Contains(_staffSearchString, StringComparison.OrdinalIgnoreCase) ||
                           (u.Email ?? "").Contains(_staffSearchString, StringComparison.OrdinalIgnoreCase))) ?? Enumerable.Empty<UserDto>();

    private string MaskCard(string? number)
    {
        if (string.IsNullOrWhiteSpace(number) || number.Length < 10) return "UNAVAILABLE";
        // Display 6-XXXXX-4 format
        return $"{number.Substring(0, 6)} • • • {number.Substring(number.Length - 4)}";
    }

    private string GetStatusClass(UserDto user)
    {
        if (!user.IsActive) return "suspended";
        if (user.LastLoginAt == null) return "uninitialized";
        if (user.LastLoginAt < DateTime.UtcNow.AddMonths(-3)) return "dormant";
        return "active";
    }

    private string GetStatusText(UserDto user)
    {
        if (!user.IsActive) return "Blocked/Suspended";
        if (user.LastLoginAt == null) return "Pending Initial Login";
        if (user.LastLoginAt < DateTime.UtcNow.AddMonths(-3)) return "Dormant (90+ Days Inactive)";
        return "Active & Operational";
    }

    private string GetAvatarColor(string seed)
    {
        // Theme-aware palette using semi-transparent colors that work in both light and dark modes.
        // These are HSL-tuned to remain legible against white text regardless of background.
        string[] colors =
        {
            "#6366f1", // Indigo
            "#8b5cf6", // Violet
            "#0891b2", // Cyan
            "#0d9488", // Teal
            "#059669", // Emerald
            "#d97706", // Amber
            "#dc2626", // Red
            "#7c3aed", // Purple
        };
        var index = Math.Abs(seed.GetHashCode()) % colors.Length;
        return colors[index];
    }

    private int GetAvatarIndex(string seed)
    {
        return Math.Abs(seed.GetHashCode()) % 8;
    }

    private string GetInitials(UserDto user)
    {
        if (string.IsNullOrWhiteSpace(user.DisplayName)) return "U";
        var parts = user.DisplayName.Split(' ');
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper();
    }

