@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public Guid OrgId { get; set; }

    private int _step = 1;
    private bool _isLoading;
    private bool _isCredit = true;
    private List<BulkTransactionRowDto> _rows = new();
    private BulkUploadResultDto? _result;

    private string GetTemplateUrl()
    {
        var baseUrl = Config["ApiSettings:BaseUrl"]?.TrimEnd('/');
        return $"{baseUrl}/api/excel/download-template";
    }

    /// <summary>
    /// Utility to mask 16-digit card numbers for security while maintaining auditability.
    /// Shows first 6 and last 4 digits.
    /// </summary>
    private string MaskCard(string? card)
    {
        if (string.IsNullOrEmpty(card)) return "N/A";
        if (card.Length < 10) return card;
        return $"{card[..6]}••••{card[^4..]}";
    }

    /// <summary>
    /// Orchestrates the initial file ingestion and analysis.
    /// Converts the browser file to a stream and invokes the parsing service.
    /// </summary>
    private async Task HandleFileUpload(IBrowserFile file)
    {
        if (file == null) return;
        
        _isLoading = true;
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;
            
            _rows = await OrgService.ParseExcelCardholderFileAsync(OrgId, ms);
            await Task.Delay(1200); // Enhanced visual duration
            _step = 2;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Analysis Failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Transitions the user from the quick-view dialog to the comprehensive 
    /// full-page Batch Allocation Manager, persisting the current session state.
    /// </summary>
    private async Task OpenFullManager()
    {
        // Populate state service before navigation
        StateService.OrgId = OrgId;
        StateService.IsCredit = _isCredit;
        StateService.PendingRows = _rows.ToList();
        
        // Fetch Org Name for the manager header
        var org = await OrgService.GetByIdAsync(OrgId);
        StateService.OrganizationName = org?.Name;

        MudDialog.Close();
        Navigation.NavigateTo("/admin/bulk-upload-manager");
    }

    /// <summary>
    /// Submits the valid portion of the current batch directly from the dialog.
    /// Transitions to the results view upon completion.
    /// </summary>
    private async Task SubmitBatch()
    {
        _isLoading = true;
        try
        {
            var validRows = _rows.Where(r => r.ValidationError == null).ToList();
            
            // Generate unique batch idempotency key
            string batchKey = $"BATCH-{OrgId}-{DateTime.UtcNow.Ticks}";
            
            var payload = new BulkTransactionRequestDto 
            { 
                IsCredit = _isCredit, 
                Rows = validRows,
                BatchIdempotencyKey = batchKey
            };
            
            _result = await OrgService.SubmitBulkTransactionAsync(OrgId, payload);
            _step = 3;
            OrgService.NotifyDataChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Submission Failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void Done() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}
