@page "/forgot-password"
@layout Layout.BlankLayout
@attribute [AllowAnonymous]
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@using FMC.Shared.DTOs.Auth
@using FMC.Services.Api
@implements IDisposable

<PageTitle>Forgot Password</PageTitle>

<div class="d-flex justify-center align-center py-8" style="min-height: 100vh; background-color: var(--mud-palette-background);">
    <MudCard Elevation="4" Class="pa-8 d-flex flex-column align-center mx-4" Style="width: 100%; max-width: 500px; border-radius: 12px;">
        <MudImage Src="nlklogo.png" Height="36" ObjectFit="ObjectFit.Contain" Class="mb-4" />
        <MudText Typo="Typo.h5" Class="mb-2 fw-bold">Reset Password</MudText>
        
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="w-100 mb-4">@_errorMessage</MudAlert>
        }

        @if (!_isCodeSent)
        {
            // STEP 1: Request Password Reset
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-6 text-center">
                Enter your username or email address and we will send you a verification code to securely reset your password.
            </MudText>

            <EditForm Model="@_requestModel" OnValidSubmit="HandleRequestOtpAsync" class="w-100">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="_requestModel.Identifier" For="@(() => _requestModel.Identifier)" Label="Username or Email" Variant="Variant.Outlined" FullWidth="true" Class="mb-6" Disabled="@_isLoading" />

                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" Disabled="@_isLoading" Style="border-radius: 8px; height: 50px;">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">Sending Code...</MudText>
                    }
                    else
                    {
                        <MudText>Send Recovery Code</MudText>
                    }
                </MudButton>
            </EditForm>
        }
        else
        {
            // STEP 2: Verify OTP and set New Password
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-6 text-center">
                An OTP has been sent to your registered email: <strong>@_maskedEmail</strong>
            </MudText>

            <EditForm Model="@_resetModel" OnValidSubmit="HandleResetPasswordAsync" class="w-100">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="_resetModel.Otp" For="@(() => _resetModel.Otp)" Label="6-Digit Code" Variant="Variant.Outlined" FullWidth="true" MaxLength="6" Class="mb-4" Disabled="@_isLoading" 
                              Adornment="Adornment.End" AdornmentText="@_resendText" AdornmentColor="@(_canResend ? Color.Primary : Color.Default)" OnAdornmentClick="HandleResendOtpAsync" />

                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_resetModel.NewPassword" For="@(() => _resetModel.NewPassword)" Label="New Password" Variant="Variant.Outlined" FullWidth="true" 
                                      InputType="@_passwordInput" Adornment="Adornment.End" AdornmentIcon="@_passwordIcon" OnAdornmentClick="TogglePasswordVisibility" Disabled="@_isLoading" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_resetModel.ConfirmNewPassword" For="@(() => _resetModel.ConfirmNewPassword)" Label="Confirm New Password" Variant="Variant.Outlined" FullWidth="true" 
                                      InputType="@_confirmPasswordInput" Class="mb-2" Adornment="Adornment.End" AdornmentIcon="@_confirmPasswordIcon" OnAdornmentClick="ToggleConfirmPasswordVisibility" Disabled="@_isLoading" />
                    </MudItem>
                </MudGrid>

                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" Disabled="@_isLoading" Class="mt-6" Style="border-radius: 8px; height: 50px;">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">Updating Password...</MudText>
                    }
                    else
                    {
                        <MudText>Reset Password</MudText>
                    }
                </MudButton>
            </EditForm>
        }

        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => NavigationManager.NavigateTo("/login"))" Class="mt-4" Disabled="@_isLoading">Back to Login</MudButton>
    </MudCard>
</div>

@code {
    [Inject] private AuthService AuthService { get; set; } = default!;

    private ForgotPasswordRequestDto _requestModel = new();
    private ResetPasswordRequestDto _resetModel = new();
    
    private bool _isLoading = false;
    private bool _isCodeSent = false;
    private string _errorMessage = "";
    private string _maskedEmail = "";

    private bool _passwordVisibility;
    private InputType _passwordInput = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;

    private bool _confirmPasswordVisibility;
    private InputType _confirmPasswordInput = InputType.Password;
    private string _confirmPasswordIcon = Icons.Material.Filled.VisibilityOff;

    // Resend Timer logic
    private System.Threading.Timer? _timer;
    private int _resendCooldown = 60;
    private bool _canResend = false;
    private string _resendText = "01:00";

    private void StartResendTimer()
    {
        _resendCooldown = 60;
        _canResend = false;
        _resendText = "01:00";
        InvokeAsync(StateHasChanged);

        _timer?.Dispose();
        _timer = new System.Threading.Timer(TimerCallback, null, 1000, 1000);
    }

    private void TimerCallback(object? state)
    {
        _resendCooldown--;
        if (_resendCooldown <= 0)
        {
            _canResend = true;
            _resendText = "Resend Code";
            _timer?.Dispose();
        }
        else
        {
            _resendText = $"00:{_resendCooldown:D2}";
        }
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleRequestOtpAsync()
    {
        if (_isLoading) return;
        _isLoading = true;
        _errorMessage = "";

        try
        {
            var response = await AuthService.ForgotPassword(_requestModel);
            if (response != null && !string.IsNullOrEmpty(response.UserId))
            {
                _maskedEmail = response.MaskedEmail;
                _resetModel.UserId = response.UserId;
                _isCodeSent = true;
                Snackbar.Add("Security code sent successfully.", Severity.Info);
                StartResendTimer();
            }
            else
            {
                // Generic error for enumeration protection
                _errorMessage = "If an account exists for this identifier, a recovery code has been sent.";
            }
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleResendOtpAsync()
    {
        if (!_canResend || _isLoading) return;

        _isLoading = true;

        try
        {
            var response = await AuthService.ForgotPassword(_requestModel);
            if (response != null && !string.IsNullOrEmpty(response.UserId))
            {
                Snackbar.Add("New security code sent successfully.", Severity.Info);
                StartResendTimer();
            }
            else
            {
                Snackbar.Add("Failed to resend secure code. Please try again later.", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("An error occurred while attempting to resend the code.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleResetPasswordAsync()
    {
        if (_isLoading) return;
        _isLoading = true;
        _errorMessage = "";

        try
        {
            var success = await AuthService.ResetPassword(_resetModel);
            if (success)
            {
                Snackbar.Add("Password reset successfully! You can now log in.", Severity.Success);
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                _errorMessage = "Invalid verification code or password does not meet requirements.";
            }
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void TogglePasswordVisibility()
    {
        if (_passwordVisibility)
        {
            _passwordVisibility = false;
            _passwordIcon = Icons.Material.Filled.VisibilityOff;
            _passwordInput = InputType.Password;
        }
        else
        {
            _passwordVisibility = true;
            _passwordIcon = Icons.Material.Filled.Visibility;
            _passwordInput = InputType.Text;
        }
    }

    private void ToggleConfirmPasswordVisibility()
    {
        if (_confirmPasswordVisibility)
        {
            _confirmPasswordVisibility = false;
            _confirmPasswordIcon = Icons.Material.Filled.VisibilityOff;
            _confirmPasswordInput = InputType.Password;
        }
        else
        {
            _confirmPasswordVisibility = true;
            _confirmPasswordIcon = Icons.Material.Filled.Visibility;
            _confirmPasswordInput = InputType.Text;
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
