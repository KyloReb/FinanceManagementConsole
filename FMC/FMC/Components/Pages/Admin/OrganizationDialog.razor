@using FMC.Shared.Auth
@using FMC.Shared.DTOs.Organization
@using FMC.Shared.DTOs.User
@using FMC.Services.Api
@using MudBlazor
@inject OrganizationApiService OrganizationService
@inject AdminService AdminService
@inject ISnackbar Snackbar

<MudDialog Class="fmc-theme-dialog">
    <DialogContent>
        <MudForm @ref="_form" IsValid="@_isValid" IsValidChanged="OnValidChanged">
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" Color="Color.Primary" 
                     SliderColor="Color.Primary" TabHeaderClass="fmc-custom-tabs">
                
                <MudTabPanel Text="General Settings" Icon="@Icons.Material.Filled.Settings" Style="text-transform:none">
                    <div class="py-6 px-2">
                        <MudText Typo="Typo.subtitle2" Class="fmc-section-header mb-6">ORGANIZATION PROFILE</MudText>
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_model.Name" Label="Organization Name" 
                                              Required="true" RequiredError="Name is required" 
                                              Variant="Variant.Outlined" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_model.Description" Label="Business Description" 
                                              Lines="3" Variant="Variant.Outlined" FullWidth="true" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudNumericField @bind-Value="_model.WalletLimit" Label="Assigned Balance (Liquidity Ceiling)" 
                                                 Variant="Variant.Outlined" FullWidth="true" 
                                                 Format="N0" Adornment="Adornment.Start" 
                                                 AdornmentFontFamily="'JetBrains Mono',monospace"
                                                 AdornmentText="₱" HelperText="The maximum operational float before depletion alerts trigger." />
                            </MudItem>
                            @if (!IsCreate)
                            {
                                <MudItem xs="12" Class="d-flex align-center justify-space-between mt-4 pa-4" 
                                         Style="background-color: var(--mud-palette-background-grey); border-radius: 12px;">
                                    <div class="d-flex flex-column">
                                        <MudText Typo="Typo.body1" Style="font-weight: 700;">Active Entity Status</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Toggle operational accessibility</MudText>
                                    </div>
                                    <MudSwitch @bind-Value="_model.IsActive" Color="Color.Success" UnCheckedColor="Color.Error" />
                                </MudItem>
                            }
                        </MudGrid>
                    </div>
                </MudTabPanel>

                @if (!IsCreate)
                {
                    <MudTabPanel Text="Personnel & Roles" Icon="@Icons.Material.Filled.People" BadgeData='_affiliatedUsers.Count.ToString()' BadgeColor="Color.Primary">
                        <div class="py-6 px-2">
                            <div class="d-flex align-center justify-space-between mb-4">
                                <MudText Typo="Typo.subtitle2" Class="fmc-section-header">SECURITY ACCESS CONTROL</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@_affiliatedUsers.Count Total Users</MudText>
                            </div>
                            
                            <div class="fmc-scroll-area">
                                @foreach (var user in _affiliatedUsers)
                                {
                                    <div class="fmc-user-row mb-3">
                                        <div class="d-flex align-center flex-grow-1">
                                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                                @user.FirstName?[0]
                                            </MudAvatar>
                                            <div class="d-flex flex-column">
                                                <MudText Typo="Typo.body2" Style="font-weight: 700;">@user.DisplayName</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@user.Email</MudText>
                                            </div>
                                        </div>
                                        <div style="width: 160px;">
                                            <MudSelect T="string" Value="@GetPrimaryRole(user)" 
                                                       ValueChanged="@(async r => await SyncUserRole(user, r))"
                                                       Label="System Role" Dense="true" Variant="Variant.Outlined" 
                                                       AnchorOrigin="Origin.BottomCenter" Margin="Margin.Dense">
                                                <MudSelectItem Value="@Roles.CEO">CEO</MudSelectItem>
                                                <MudSelectItem Value="@Roles.Manager">Manager</MudSelectItem>
                                                <MudSelectItem Value="@Roles.User">User</MudSelectItem>
                                            </MudSelect>
                                        </div>
                                    </div>
                                }

                                @if (!_affiliatedUsers.Any())
                                {
                                    <div class="pa-10 d-flex flex-column align-center mud-text-secondary">
                                        <MudIcon Icon="@Icons.Material.Filled.PeopleOutline" Size="Size.Large" Class="mb-2" />
                                        <MudText Typo="Typo.body2">No affiliated personnel found.</MudText>
                                    </div>
                                }
                            </div>
                        </div>
                    </MudTabPanel>
                }
            </MudTabs>
        </MudForm>

        <style>
            /* Dynamic Theme Adaptation */
            .fmc-theme-dialog { 
                background-color: var(--mud-palette-surface) !important; 
                border-radius: 16px !important; 
            }
            
            .fmc-custom-tabs { 
                border-bottom: 2px solid var(--mud-palette-divider); 
                background-color: var(--mud-palette-background-grey) !important;
            }
            .fmc-custom-tabs .mud-tab { 
                text-transform: none !important; 
                font-weight: 600; 
                color: var(--mud-palette-text-secondary) !important;
                padding: 14px 28px;
            }
            .fmc-custom-tabs .mud-tab.mud-tab-active { 
                color: var(--mud-palette-primary) !important; 
                background-color: var(--mud-palette-surface);
            }
            
            .fmc-section-header { 
                color: var(--mud-palette-primary); 
                font-weight: 800; 
                letter-spacing: 0.1em; 
                font-size: 0.75rem; 
                padding-left: 4px; border-left: 4px solid var(--mud-palette-primary);
            }
            
            .fmc-scroll-area { max-height: 400px; overflow-y: auto; padding-right: 4px; }
            .fmc-scroll-area::-webkit-scrollbar { width: 6px; }
            .fmc-scroll-area::-webkit-scrollbar-thumb { background: var(--mud-palette-divider); border-radius: 10px; }
            
            .fmc-user-row { 
                padding: 12px 16px;
                border: 1px solid var(--mud-palette-divider);
                border-radius: 12px;
                display: flex;
                align-items: center;
                background-color: var(--mud-palette-surface);
                transition: background-color 0.2s;
            }
            .fmc-user-row:hover { background-color: var(--mud-palette-background-grey); }
        </style>
    </DialogContent>
    <DialogActions>
        <div class="px-8 py-4 d-flex align-center w-100 mud-background-grey" style="border-top: 1px solid var(--mud-palette-divider);">
            <MudButton OnClick="Cancel" Variant="Variant.Text" Style="text-transform: none; font-weight: 600;">Dismiss</MudButton>
            <MudSpacer />
            <MudButton Color="Color.Primary" Variant="Variant.Filled" 
                       Style="text-transform: none; border-radius: 8px; padding: 10px 24px; font-weight: 700;" 
                       Disabled="@(!_isValid || _isSaving)" OnClick="SubmitAsync">
                @if (_isSaving)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Processing...</MudText>
                }
                else
                {
                    <MudText>@(IsCreate ? "Create Organization" : "Commit Changes")</MudText>
                }
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public OrganizationDto? OrganizationToEdit { get; set; }

    private MudForm _form = default!;
    private OrganizationModel _model = new();
    private List<FMC.Shared.DTOs.User.UserDto> _affiliatedUsers = new();
    private bool _isValid;
    private bool _isSaving;

    private bool IsCreate => OrganizationToEdit == null;

    protected override async Task OnInitializedAsync()
    {
        if (OrganizationToEdit != null)
        {
            _model.Id = OrganizationToEdit.Id;
            _model.Name = OrganizationToEdit.Name;
            _model.Description = OrganizationToEdit.Description;
            _model.IsActive = OrganizationToEdit.IsActive;
            _model.ChiefExecutiveId = OrganizationToEdit.ChiefExecutiveId;
            _model.WalletLimit = OrganizationToEdit.WalletLimit;

            // Load users affiliated with this organization
            try
            {
                _affiliatedUsers = await OrganizationService.GetUsersAsync(OrganizationToEdit.Id);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Warning: Could not load organization personnel. {ex.Message}", Severity.Warning);
            }
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void OnValidChanged(bool isValid) => _isValid = isValid;

    private string GetPrimaryRole(UserDto user) => user.Roles.FirstOrDefault() ?? Roles.User;

    private async Task SyncUserRole(UserDto user, string newRole)
    {
        try
        {
            var updateDto = new UpdateUserDto
            {
                Id = user.Id,
                FirstName = user.FirstName!,
                LastName = user.LastName!,
                Email = user.Email!,
                Organization = OrganizationToEdit?.Name,
                Roles = new List<string> { newRole },
                IsActive = user.IsActive
            };

            var success = await AdminService.UpdateUserAsync(updateDto);
            if (success)
            {
                user.Roles = new List<string> { newRole }; // Update UI locally
                
                // If the role became CEO, also update the Organization model's CEO link for persistence
                if (newRole == Roles.CEO)
                {
                    _model.ChiefExecutiveId = user.Id;
                }
                else if (user.Id == _model.ChiefExecutiveId)
                {
                    // If they WERE the CEO but now are demoted, clear the ID
                    _model.ChiefExecutiveId = null;
                }

                Snackbar.Add($"{user.DisplayName} successfully promoted to {newRole}.", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Failed to update role for {user.DisplayName}.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private async Task SubmitAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _isSaving = true;
        
        try
        {
            bool success;

            if (IsCreate)
            {
                var dto = new CreateOrganizationDto
                {
                    Name = _model.Name,
                    Description = _model.Description,
                    WalletLimit = _model.WalletLimit
                };
                success = await OrganizationService.CreateAsync(dto);
            }
            else
            {
                var dto = new UpdateOrganizationDto
                {
                    Id = _model.Id!.Value,
                    Name = _model.Name,
                    Description = _model.Description,
                    IsActive = _model.IsActive,
                    ChiefExecutiveId = _model.ChiefExecutiveId,
                    WalletLimit = _model.WalletLimit
                };
                success = await OrganizationService.UpdateAsync(dto);
            }

            if (success)
            {
                Snackbar.Add($"Organization {(IsCreate ? "created" : "updated")} successfully.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("An error occurred or the name is already taken.", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("An error occurred. The organization name might already be in use.", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private class OrganizationModel
    {
        public Guid? Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool IsActive { get; set; } = true;
        public string? ChiefExecutiveId { get; set; }
        public decimal WalletLimit { get; set; } = 1_000_000m;
    }
}
