@inherits LayoutComponentBase
@implements IDisposable
@using FMC.Shared.DTOs.Organization
@using FMC.Shared.Auth
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject OrganizationApiService OrgService
@inject IJSRuntime JSRuntime

@*
    The main layout for the Finance Management Console.

    Provides the top AppBar with navigation controls, theme toggling, and the side Drawer.
*@
<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Color="Color.Inherit" Fixed="true" Style="border-bottom: 1px solid var(--mud-palette-divider);">
        @* Sidebar Toggle Control *@
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />

        @* Desktop View Logo and Title (Clickable) *@
        <MudHidden Breakpoint="Breakpoint.Xs">
            <div class="d-flex align-center ml-2 mr-4 cursor-pointer brand-link" @onclick='() => NavigationManager.NavigateTo("/", true)' 
                 style="user-select: none; transition: opacity 0.2s;">
                <MudImage Src="favicon.png" Width="30" Height="30" Class="mr-2" />
                <MudText Typo="Typo.h6">Finance Management Console</MudText>
            </div>
        </MudHidden>

        @* Mobile View Logo and Title (Clickable) *@
        <MudHidden Breakpoint="Breakpoint.SmAndUp">
             <div class="d-flex align-center ml-2 cursor-pointer brand-link" @onclick='() => NavigationManager.NavigateTo("/", true)'>
                <MudImage Src="favicon.png" Width="24" Height="24" Class="mr-2" />
                <MudText Typo="Typo.h6">FMC</MudText>
            </div>
        </MudHidden>
        
        <MudSpacer />

        @* ── NOTIFICATION BELL ── *@
        <AuthorizeView Roles="@($"{Roles.SuperAdmin},{Roles.CEO},{Roles.Maker},{Roles.Approver}")" Context="notifState">
            <Authorized>
                <MudMenu @bind-Open="_notifOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                         Dense="true" PopoverClass="fmc-notif-popover mud-elevation-25">
                    <ActivatorContent>
                        <div class="fmc-bell-wrap @(_notifOpen ? "fmc-bell-active" : "")" @onclick="ToggleNotif" @onclick:stopPropagation="true">
                            <MudIcon Icon="@Icons.Material.Filled.NotificationsNone" Class="fmc-bell-icon" />
                            @if (_alertCount > 0)
                            {
                                <span class="fmc-notif-badge">@(_alertCount > 9 ? "9+" : _alertCount.ToString())</span>
                            }
                        </div>
                    </ActivatorContent>
                    <ChildContent>
                        <div class="fmc-notif-panel">
                            <div class="fmc-notif-header">
                                <MudText Typo="Typo.h6" Style="font-weight: 700;">Notification</MudText>
                            </div>
                            
                            <div class="fmc-notif-tabs">
                                <div class="fmc-notif-tab @(_selectedTab == "All" ? "active" : "")" @onclick="@(() => _selectedTab = "All")">All</div>
                                <div class="fmc-notif-tab @(_selectedTab == "Activity" ? "active" : "")" @onclick="@(() => _selectedTab = "Activity")">Activity</div>
                                <div class="fmc-notif-tab @(_selectedTab == "Thresholds" ? "active" : "")" @onclick="@(() => _selectedTab = "Thresholds")">Thresholds</div>
                                <div class="fmc-notif-tab @(_selectedTab == "System" ? "active" : "")" @onclick="@(() => _selectedTab = "System")">System</div>
                            </div>

                            <div class="fmc-notif-body">
                                @if (_alertCount == 0)
                                {
                                    <div class="fmc-notif-empty">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color: var(--mud-palette-success); font-size: 2rem;" />
                                        <MudText Typo="Typo.body2" Style="font-weight:600; margin-top:8px;">No Issues Found</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">All tenants are healthy</MudText>
                                    </div>
                                }
                                else
                                {
                                    @foreach (var notif in FilteredNotifications)
                                    {
                                        var isActivity = notif.EntityId != null && (notif.EntityId.StartsWith("Pending") || notif.EntityId.StartsWith("Processed") || notif.EntityId.StartsWith("Status"));
                                        var isThreshold = notif.Title.Contains("Threshold") || notif.Title.Contains("Capacity") || notif.Title.Contains("Liquidity") || notif.Title.Contains("Payroll");
                                        var actionText = isActivity ? "Resolve ↗" : "Review ↗";
                                        var itemType = isActivity ? "Activity" : isThreshold ? "Oversight" : "System";

                                        <div class="fmc-notif-item">
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="margin-bottom: 8px; display: block;">@itemType · @notif.CreatedAt.ToString("MM/dd/yyyy")</MudText>
                                            <MudText Typo="Typo.body1" Style="font-weight: 700; margin-bottom: 6px;">@notif.Title</MudText>
                                            <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="line-height:1.4; margin-bottom: 16px;">
                                                @if(string.IsNullOrEmpty(notif.EntityId) || !notif.EntityId.StartsWith("Pending"))
                                                {
                                                    <span style="font-size: 1.1em;">🔔</span>
                                                }
                                                @notif.Description
                                            </MudText>
                                            
                                            <div class="fmc-notif-action" @onclick="@(() => HandleAlertClick(notif))">
                                                <span style="font-weight: 600; font-size: 0.85rem; cursor: pointer;">@actionText</span>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </ChildContent>
                </MudMenu>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Context="authState">
            <Authorized>
                @* ACCOUNT DROPDOWN (Avatar & Name as Trigger) *@
                @* ACCOUNT DROPDOWN (Avatar & Name as Trigger) *@
                <MudMenu @bind-Open="_userMenuOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" 
                         Dense="true" Class="ml-1" PopoverClass="fmc-user-popover mud-elevation-25">
                    <ActivatorContent>
                        <div class="fmc-user-trigger @(_userMenuOpen ? "active" : "")" @onclick="ToggleUserMenu" @onclick:stopPropagation="true">
                            <div class="fmc-user-info-text mr-3 ml-1">
                                <MudText Typo="Typo.body2" Class="fmc-user-name">@GetDisplayName(authState.User)</MudText>
                            </div>
                            <div class="fmc-user-avatar-wrap">
                                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="fmc-avatar-glow">
                                    @GetInitials(authState.User)
                                </MudAvatar>
                            </div>
                        </div>
                    </ActivatorContent>
                    <ChildContent>
                        <div class="fmc-user-dropdown-panel">
                            <div class="fmc-user-header">
                                <div class="d-flex align-center justify-space-between mb-2">
                                    <MudText Typo="Typo.h6" Class="fmc-executive-name">@GetDisplayName(authState.User)</MudText>
                                    @if (!string.IsNullOrEmpty(GetOrganization(authState.User)))
                                    {
                                        <div class="fmc-org-tag">@GetOrganization(authState.User)</div>
                                    }
                                </div>
                                <div class="fmc-role-indicator">
                                    <div class="fmc-role-dot"></div>
                                    <MudText Typo="Typo.caption" Class="fmc-role-text">@GetRoleName(authState.User).ToUpper()</MudText>
                                </div>
                            </div>
                            
                            <div class="fmc-user-actions">
                                <MudMenuItem Class="fmc-user-item" Icon="@Icons.Material.Filled.Person" OnClick="@(() => NavigationManager.NavigateTo("/profile"))">
                                    <div class="d-flex align-center justify-space-between w-100">
                                        <span>Edit Profile</span>
                                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Class="fmc-item-chevron" />
                                    </div>
                                </MudMenuItem>
                                <MudMenuItem Class="fmc-user-item" Icon="@Icons.Material.Filled.Settings" OnClick="@(() => NavigationManager.NavigateTo("/settings"))">
                                    <div class="d-flex align-center justify-space-between w-100">
                                        <span>Settings</span>
                                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Class="fmc-item-chevron" />
                                    </div>
                                </MudMenuItem>
                                
                                <AuthorizeView Roles="@FMC.Shared.Auth.Roles.SuperAdmin" Context="adminContext">
                                    <Authorized>
                                        <div class="fmc-user-divider"></div>
                                        <MudMenuItem Class="fmc-user-item tenant-manager" Icon="@Icons.Material.Filled.CorporateFare" OnClick="@(() => NavigationManager.NavigateTo("/admin/organizations"))">
                                            <div class="d-flex align-center justify-space-between w-100">
                                                <span>Manage System Tenants</span>
                                                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Class="fmc-item-chevron" />
                                            </div>
                                        </MudMenuItem>
                                    </Authorized>
                                </AuthorizeView>

                                <div class="fmc-user-divider"></div>
                                <MudMenuItem Class="fmc-user-item logout-action" Icon="@Icons.Material.Filled.Logout" OnClick="LogoutAsync">
                                    <span class="fmc-logout-text">Terminate Session</span>
                                </MudMenuItem>
                            </div>
                        </div>
                    </ChildContent>
                </MudMenu>
                </Authorized>
            <NotAuthorized>
                <MudButton Href="/login" Variant="Variant.Text" Color="Color.Inherit" Class="mr-2">Log In</MudButton>
                <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Primary" Class="mr-3">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    @* Navigation Sidebar - Wrapped in AuthorizeView to prevent guest visibility *@
    <AuthorizeView>
        <Authorized>
            <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Anchor="Anchor.Left" Style="border-right: 1px solid var(--mud-palette-divider);">
                <NavMenu />
            </MudDrawer>
        </Authorized>
    </AuthorizeView>

    @* Main Page Content *@
    <MudMainContent Class="pa-0 pt-16">
        <FMC.Components.Admin.GlobalAlertBanner />
        <div class="pa-4">
            @Body
        </div>
    </MudMainContent>
</MudLayout>

<style>
    :root { --fmc-calendar-filter: none; }
    .dark { --fmc-calendar-filter: invert(1); }
    
    .brand-link:hover { opacity: 0.8; }
    
    /* ── Notification Bell ── */
    .fmc-bell-wrap {
        position: relative;
        width: 38px; height: 38px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 10px;
        cursor: pointer;
        margin-right: 6px;
        transition: background-color 0.15s;
    }
    .fmc-bell-wrap:hover, .fmc-bell-active {
        background-color: var(--mud-palette-action-default-hover);
    }
    .fmc-bell-icon {
        font-size: 1.3rem !important;
        color: var(--mud-palette-text-secondary);
        transition: color 0.15s;
    }
    .fmc-bell-wrap:hover .fmc-bell-icon { color: var(--mud-palette-text-primary); }
    .fmc-notif-badge {
        position: absolute;
        top: 4px; right: 4px;
        min-width: 16px; height: 16px;
        background: var(--mud-palette-error);
        color: #fff;
        border-radius: 50px;
        font-size: 0.55rem;
        font-weight: 900;
        display: flex; align-items: center; justify-content: center;
        padding: 0 4px;
        border: 2px solid var(--mud-palette-appbar-background);
        letter-spacing: 0;
    }

    /* ── Notification Popover Panel ── */
    .fmc-notif-popover .mud-popover { padding: 0 !important; }
    .fmc-notif-panel {
        width: 360px;
        background-color: var(--mud-palette-surface);
        border-radius: 12px;
        overflow: hidden;
    }
    .fmc-notif-header {
        padding: 20px 20px 8px;
    }
    .fmc-notif-tabs {
        display: flex;
        padding: 0 12px;
        border-bottom: 1px solid var(--mud-palette-divider);
    }
    .fmc-notif-tab {
        padding: 8px 12px;
        font-size: 0.8rem;
        color: var(--mud-palette-text-secondary);
        font-weight: 500;
        cursor: pointer;
        position: relative;
    }
    .fmc-notif-tab.active {
        color: var(--mud-palette-primary);
        font-weight: 600;
    }
    .fmc-notif-tab.active::after {
        content: "";
        position: absolute;
        bottom: -1px;
        left: 12px;
        right: 12px;
        height: 2px;
        background-color: var(--mud-palette-primary);
    }
    
    .fmc-notif-body { 
        padding: 12px;
        max-height: 400px;
        overflow-y: auto;
    }
    .fmc-notif-empty {
        padding: 36px 20px;
        display: flex; flex-direction: column; align-items: center;
        text-align: center;
    }
    
    .fmc-notif-item {
        background-color: var(--mud-palette-background);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 12px;
        display: flex;
        flex-direction: column;
    }
    .fmc-notif-item:last-child { margin-bottom: 0; }
    
    .fmc-notif-action {
        border-top: 1px solid var(--mud-palette-divider);
        padding-top: 12px;
        text-align: center;
        transition: opacity 0.2s;
    }
    .fmc-notif-action:hover { opacity: 0.7; }

    /* ── Executive User Menu ── */
    .fmc-user-trigger {
        display: flex; align-items: center; padding: 4px 8px; border-radius: 14px;
        cursor: pointer; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid transparent;
    }
    .fmc-user-trigger:hover, .fmc-user-trigger.active {
        background: rgba(var(--mud-palette-primary-rgb), 0.05);
        border-color: rgba(var(--mud-palette-primary-rgb), 0.1);
    }
    .fmc-user-name { font-weight: 800 !important; letter-spacing: -0.02em; color: var(--mud-palette-text-primary); }
    .fmc-avatar-glow { box-shadow: 0 0 15px rgba(var(--mud-palette-primary-rgb), 0.3); font-weight: 800 !important; }

    .fmc-user-popover .mud-popover { 
        padding: 0 !important; 
        background: transparent !important;
        box-shadow: none !important;
        margin-top: 8px !important;
    }
    .fmc-user-dropdown-panel {
        width: 320px;
        background: rgba(var(--mud-palette-surface-rgb), 0.9) !important;
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.15) !important;
    }

    .fmc-user-header {
        padding: 24px;
        background: linear-gradient(to bottom right, rgba(var(--mud-palette-primary-rgb), 0.05), transparent);
        border-bottom: 1px solid var(--mud-palette-divider);
    }
    .fmc-executive-name { font-weight: 950 !important; letter-spacing: -0.04em; color: var(--mud-palette-text-primary); }
    .fmc-org-tag { 
        padding: 4px 10px; border-radius: 8px; background: rgba(var(--mud-palette-primary-rgb), 0.1);
        color: var(--mud-palette-primary); font-size: 0.65rem; font-weight: 950; letter-spacing: 0.05em;
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.2);
    }
    .fmc-role-indicator { display: flex; align-items: center; gap: 8px; margin-top: 4px; }
    .fmc-role-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--mud-palette-primary); box-shadow: 0 0 8px var(--mud-palette-primary); }
    .fmc-role-text { font-weight: 800 !important; letter-spacing: 0.1em; color: var(--mud-palette-text-secondary); opacity: 0.8; }

    .fmc-user-actions { padding: 12px; }
    .fmc-user-item { 
        border-radius: 12px !important; margin-bottom: 4px; padding: 12px 16px !important;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }
    .fmc-user-item:hover { 
        background: rgba(var(--mud-palette-primary-rgb), 0.05) !important;
        transform: translateX(4px);
    }
    .fmc-user-item ::deep .mud-list-item-icon { color: var(--mud-palette-primary) !important; min-width: 36px !important; }
    .fmc-item-chevron { opacity: 0; transition: all 0.2s ease; transform: translateX(-10px); }
    .fmc-user-item:hover .fmc-item-chevron { opacity: 0.5; transform: translateX(0); }

    .fmc-user-divider { height: 1px; background: var(--mud-palette-divider); margin: 8px 12px; opacity: 0.5; }

    .fmc-user-item.logout-action { margin-top: 8px; }
    .fmc-user-item.logout-action:hover { background: rgba(var(--mud-palette-error-rgb), 0.05) !important; }
    .fmc-user-item.logout-action ::deep .mud-list-item-icon { color: var(--mud-palette-error) !important; }
    .fmc-logout-text { font-weight: 950 !important; color: var(--mud-palette-error); letter-spacing: 0.02em; }
</style>

@code {
    private bool _drawerOpen = true;
    private bool _userMenuOpen = false;
    private bool _notifOpen = false;

    // Notification state
    private string _selectedTab = "All";
    private int _alertCount;
    private record NotifItem(long Id, string Title, string Description, string Href, string Severity, int Count, string? EntityId, DateTime CreatedAt);
    private List<NotifItem> _notifications = new();
    private HashSet<string> _dismissedNotifications = new();

    private IEnumerable<NotifItem> FilteredNotifications => _selectedTab switch
    {
        "Activity" => _notifications.Where(n => n.EntityId != null && (n.EntityId.StartsWith("Pending") || n.EntityId.StartsWith("Processed") || n.EntityId.StartsWith("Status"))),
        "Thresholds" => _notifications.Where(n => n.Title.Contains("Capacity") || n.Title.Contains("Liquidity") || n.Title.Contains("Threshold") || n.Title.Contains("Payroll")),
        "System" => _notifications.Where(n => n.Id > 0 && !n.Title.Contains("Capacity") && !n.Title.Contains("Liquidity") && !n.Title.Contains("Threshold") && !n.Title.Contains("Payroll")),
        _ => _notifications
    };

    private async Task HandleAlertClick(NotifItem notif)
    {
        _notifOpen = false;

        // Optimistic UI updates
        _notifications.RemoveAll(n => n.Id == notif.Id && n.Title == notif.Title);
        _alertCount = _notifications.Count;
        
        if (notif.Id > 0)
        {
            // Background enterprise resolution for persistent system alerts
            await OrgService.ResolveAlertAsync(notif.Id);
        }
        else if (notif.EntityId != null)
        {
            // Transient workflow alert dismissals from navbar
            _dismissedNotifications.Add(notif.EntityId);
            try { await JSRuntime.InvokeVoidAsync("localStorage.setItem", "fmc_wf_dismissed", System.Text.Json.JsonSerializer.Serialize(_dismissedNotifications)); } catch { }
        }
        
        OrgService.NotifyDataChanged(); // Let other components know an indicator was dismissed
        StateHasChanged();

        if (!string.IsNullOrEmpty(notif.Href))
            NavigationManager.NavigateTo(notif.Href);
    }

    private void ToggleNotif() => _notifOpen = !_notifOpen;
    private void ToggleUserMenu() => _userMenuOpen = !_userMenuOpen;

    protected override async Task OnInitializedAsync()
    {
        OrgService.OnDataChanged += HandleDataChanged;
        await LoadAlerts();
    }

    private async void HandleDataChanged()
    {
        await LoadAlerts();
        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Dismiss the institutional splash screen once the app is interactive
            try { await JSRuntime.InvokeVoidAsync("fmcPreloader.hide"); } catch { }

            try
            {
                var dictStr = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "fmc_wf_dismissed");
                if (!string.IsNullOrEmpty(dictStr))
                {
                    _dismissedNotifications = System.Text.Json.JsonSerializer.Deserialize<HashSet<string>>(dictStr) ?? new();
                }

                // Pending_* and Threshold_* are action-required alerts — strip them from the
                // dismissed set every session so the bell count always reflects unresolved items.
                var actionRequiredPrefixes = new[] { "Pending_", "Threshold_" };
                var toRestore = _dismissedNotifications
                    .Where(id => actionRequiredPrefixes.Any(prefix => id.StartsWith(prefix)))
                    .ToList();

                bool restoredAny = false;
                foreach (var id in toRestore)
                {
                    _dismissedNotifications.Remove(id);
                    restoredAny = true;
                }

                if (restoredAny)
                {
                    // Persist the cleaned dismissed set back to localStorage
                    try { await JSRuntime.InvokeVoidAsync("localStorage.setItem", "fmc_wf_dismissed", System.Text.Json.JsonSerializer.Serialize(_dismissedNotifications)); } catch { }
                }

                // Reload alerts with the correct dismissed set and update badge
                await LoadAlerts();
                StateHasChanged();
            }
            catch { }
        }
    }


    private bool _isUpdatingAlerts;
    private async Task LoadAlerts()
    {
        if (_isUpdatingAlerts) return;
        try
        {
            _isUpdatingAlerts = true;
            _notifications.Clear();
            var seenKeys = new HashSet<string>(); 
            
            var authState = await AuthService.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user?.Identity?.IsAuthenticated != true) return;

            // 1. Fetch Persistent Alerts (System Alerts / Organization Alerts)
            // Now available to all roles due to Phase 3 API refactor
            try
            {
                var dbAlerts = await OrgService.GetActiveAlertsAsync();
                foreach (var alert in dbAlerts)
                {
                    var businessKey = $"{alert.EntityId}_{alert.Title}";
                    if (seenKeys.Contains(businessKey)) continue;

                    _notifications.Add(new NotifItem(
                        alert.Id,
                        alert.Title, 
                        alert.Message, 
                        alert.EntityType == "Organization" ? $"/admin/organizations/{alert.EntityId}" : "/admin/audit",
                        alert.Severity.ToString().ToLower(),
                        1,
                        alert.EntityId,
                        alert.CreatedAt
                    ));
                    seenKeys.Add(businessKey);
                }
            }
            catch { /* Managed by silent fail */ }

            // 2. Fetch Workflow Alerts (Pending requests, etc.)
            try
            {
                var wfAlerts = await OrgService.GetWorkflowAlertsAsync();
                foreach (var alert in wfAlerts)
                {
                    if (_dismissedNotifications.Contains(alert.EntityId ?? "")) continue;

                    var businessKey = $"{alert.EntityId}_{alert.Title}";
                    if (seenKeys.Contains(businessKey)) continue;

                    // Routing Logic
                    var href = "/transactions";
                    if (alert.EntityId != null)
                    {
                        if (alert.EntityId.StartsWith("Pending")) href = "/pending-requests";
                        else if (alert.EntityId.StartsWith("Threshold_"))
                        {
                            var parts = alert.EntityId.Split('_');
                            if (parts.Length > 1) href = $"/admin/organizations/{parts[1]}";
                        }
                    }

                    _notifications.Add(new NotifItem(
                        0, // Synthetic ID for transient workflow alerts
                        alert.Title,
                        alert.Message,
                        href,
                        alert.Severity.ToString().ToLower(),
                        1,
                        alert.EntityId,
                        DateTime.UtcNow
                    ));
                    seenKeys.Add(businessKey);
                }
            }
            catch { /* Managed by silent fail */ }

            _alertCount = _notifications.Count;
        }
        catch { /* Fallback for pre-rendering */ }
        finally { _isUpdatingAlerts = false; }
    }

    private async Task LogoutAsync()
    {
        await AuthService.Logout("current");
        NavigationManager.NavigateTo("/login", true);
    }

    void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private string GetDisplayName(System.Security.Claims.ClaimsPrincipal user)
    {
        var firstName = user.FindFirst("firstName")?.Value;
        var lastName  = user.FindFirst("lastName")?.Value;
        if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
            return $"{firstName} {lastName}".Trim();
        return user.Identity?.Name ?? "User";
    }

    private string GetInitials(System.Security.Claims.ClaimsPrincipal user)
    {
        var firstName = user.FindFirst("firstName")?.Value;
        var lastName  = user.FindFirst("lastName")?.Value;
        if (!string.IsNullOrWhiteSpace(firstName) && !string.IsNullOrWhiteSpace(lastName))
            if (firstName.Length > 0 && lastName.Length > 0)
                return $"{firstName[0]}{lastName[0]}".ToUpper();
        var name = user.Identity?.Name ?? "U";
        return name.Length > 0 ? name[0].ToString().ToUpper() : "U";
    }

    private string GetRoleName(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
            ?? user.FindFirst("role")?.Value
            ?? "User";
    }

    private string GetOrganization(System.Security.Claims.ClaimsPrincipal user)
        => user.FindFirst("organization")?.Value ?? string.Empty;

    public void Dispose() 
    { 
        OrgService.OnDataChanged -= HandleDataChanged;
    }
}
