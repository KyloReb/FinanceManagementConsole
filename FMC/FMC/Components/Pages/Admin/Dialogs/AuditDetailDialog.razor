@using MudBlazor
@using FMC.Shared.DTOs.Admin
@using FMC.Services.Api
@inject ISnackbar Snackbar
@inject OrganizationApiService OrgService
@inject AdminService AdminService

<MudDialog Class="fmc-audit-dialog">
    <TitleContent>
        <div class="d-flex align-center gap-3">
            <MudIcon Icon="@GetEventIcon(Log.Action)" Color="@GetEventColor(Log.Action)" Size="Size.Large" />
            <div class="d-flex flex-column">
                <MudText Typo="Typo.h6" Style="font-weight:900;">Forensic Event Trace</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Internal Sequence ID: #@Log.Id.ToString().PadLeft(6, '0')</MudText>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="fmc-detail-container px-2">
            @* CORE IDENTITY *@
            <div class="detail-section mb-6">
                <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6;">Event Identity</MudText>
                <div class="d-flex justify-space-between align-center mt-2 pa-4 fmc-highlight-box">
                    <div>
                        <MudText Style="font-weight:900; font-size:1.1rem; color: var(--mud-palette-primary);">@Log.Action</MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">@Log.CreatedAt.ToLocalTime().ToString("MMMM dd, yyyy 'at' HH:mm:ss.fff")</MudText>
                    </div>
                    @if (Log.Amount.HasValue)
                    {
                        <div class="text-right">
                            @{
                                var actUpper = Log.Action?.ToUpper() ?? "";
                                var isCreditToUser = actUpper.Contains("CREDIT") || actUpper.Contains("DEPOSIT") || actUpper.Contains("ALLOT");
                                var sign = isCreditToUser ? "+" : "-";
                                var color = isCreditToUser ? Color.Success : Color.Error;
                            }
                            <MudText Style="font-weight:900; font-size:1.2rem; font-family:'JetBrains Mono',monospace;" Color="@color">
                                @sign@Math.Abs(Log.Amount.Value).ToString("N2")
                            </MudText>
                            <MudText Typo="Typo.caption">Currency Magnitude</MudText>
                        </div>
                    }
                </div>
            </div>

            <MudDivider Class="mb-6 opacity-50" />

            @* ACTOR & CONTEXT *@
            <MudGrid Class="mb-6">
                <MudItem xs="6">
                    <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6;">Operator / Actor</MudText>
                    <div class="d-flex align-center gap-3 mt-2">
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                            @(GetInitial(GetFriendlyName()))
                        </MudAvatar>
                        <div>
                            <MudText Style="font-weight:800; font-size:0.9rem;">@GetFriendlyName()</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Authenticated User</MudText>
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6;">Target Context</MudText>
                    <div class="mt-2">
                        <MudText Style="font-weight:800; font-size:0.9rem;">@(Log.EntityName ?? Log.Organization ?? "Global Infrastructure")</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Tenant / Entity</MudText>
                    </div>
                </MudItem>
            </MudGrid>

            @* ── LIQUIDITY FLOW DIAGRAM ── *@
            @if (Log.Amount.HasValue && !Log.Action.Contains("BATCH") && (!Log.EntityName?.Contains("Bulk") ?? true))
            {
                var actUpper = Log.Action?.ToUpper() ?? "";
                var isCorporateToUser = actUpper.Contains("CREDIT") || actUpper.Contains("APPROV") || actUpper.Contains("ALLOT") || actUpper.Contains("DEPOSIT");
                var absAmount = Math.Abs(Log.Amount.Value);
                var orgIdentity = GetOrgIdentity();
                var cardholderIdentity = GetCardNumber();
                
                var sourceName = isCorporateToUser ? _orgName : (Log.EntityName?.Replace("Wallet: ", "") ?? "Cardholder");
                var destName = isCorporateToUser ? (Log.EntityName?.Replace("Wallet: ", "") ?? "Cardholder") : _orgName;
                var sourceIcon = isCorporateToUser ? Icons.Material.Filled.AccountBalance : Icons.Material.Filled.Wallet;
                var destIcon = isCorporateToUser ? Icons.Material.Filled.Wallet : Icons.Material.Filled.AccountBalance;

                <div class="detail-section mb-6">
                    <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6;">Liquidity Flow</MudText>
                    <div class="mt-2 pa-4 fmc-surface-box d-flex align-center justify-space-between" style="position:relative; overflow: hidden;">
                        
                        <!-- Source Node -->
                        <div class="d-flex flex-column align-center" style="width: 140px; z-index: 2;">
                            <div class="fmc-flow-node source">
                                <MudIcon Icon="@sourceIcon" Style="font-size: 1.5rem; color: var(--mud-palette-info);" />
                            </div>
                            <div class="mt-2 text-center" style="line-height: 1.1;">
                                <MudText Style="font-weight: 800; font-size: 0.7rem; display: block;">@sourceName</MudText>
                                @if (isCorporateToUser && !string.IsNullOrEmpty(_orgAccountNumber))
                                {
                                    <MudText Style="font-size: 0.55rem; font-family: 'Roboto Mono', monospace; opacity: 0.5;">@MaskAccount(_orgAccountNumber)</MudText>
                                }
                                else if (!isCorporateToUser)
                                {
                                    var sub = MaskAccount(_userAccountNumber);
                                    if (sub != sourceName)
                                    {
                                        <MudText Style="font-size: 0.55rem; font-family: 'Roboto Mono', monospace; opacity: 0.5;">@sub</MudText>
                                    }
                                }
                            </div>
                        </div>

                        <!-- Animated Connector -->
                        <div class="fmc-flow-connector flex-grow-1 mx-2" style="position: relative; z-index: 1; height: 2px; background: rgba(var(--mud-palette-info-rgb), 0.2); margin-top: -24px;">
                            <div class="fmc-flow-particle"></div>
                            <div class="fmc-flow-badge">
                                <MudText Style="font-family:'JetBrains Mono',monospace; font-weight:900; font-size:0.75rem; color: var(--mud-palette-info);">
                                    @absAmount.ToString("N2")
                                </MudText>
                            </div>
                        </div>

                        <!-- Destination Node -->
                        <div class="d-flex flex-column align-center" style="width: 140px; z-index: 2;">
                            <div class="fmc-flow-node dest">
                                <MudIcon Icon="@destIcon" Style="font-size: 1.5rem; color: var(--mud-palette-success);" />
                            </div>
                            <div class="mt-2 text-center" style="line-height: 1.1;">
                                <MudText Style="font-weight: 800; font-size: 0.7rem; display: block;">@destName</MudText>
                                @if (!isCorporateToUser && !string.IsNullOrEmpty(_orgAccountNumber))
                                {
                                    <MudText Style="font-size: 0.55rem; font-family: 'Roboto Mono', monospace; opacity: 0.5;">@MaskAccount(_orgAccountNumber)</MudText>
                                }
                                else if (isCorporateToUser)
                                {
                                    var sub = MaskAccount(_userAccountNumber);
                                    if (sub != destName)
                                    {
                                        <MudText Style="font-size: 0.55rem; font-family: 'Roboto Mono', monospace; opacity: 0.5;">@sub</MudText>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* ── BATCH BREAKDOWN (Forensic Detail) ── *@
            @if (Log.Action == "BATCH_SUBMITTED" || (Log.Amount.HasValue && Log.EntityName.Contains("Bulk")))
            {
                <div class="detail-section mb-6">
                    <div class="d-flex align-center gap-2 mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle2" Style="font-weight: 900; letter-spacing: 0.02em;">BATCH BREAKDOWN</MudText>
                    </div>
                    
                    <div class="fmc-breakdown-surface">
                        @if (TryGetBatchData(out var batchData))
                        {
                            <MudTable Items="@batchData.Items" Dense="true" Hover="true" Elevation="0" Style="background: transparent;">
                                <HeaderContent>
                                    <MudTh Style="font-size: 0.65rem; font-weight: 900; opacity: 0.6;">CARDHOLDER</MudTh>
                                    <MudTh Style="font-size: 0.65rem; font-weight: 900; opacity: 0.6; text-align: right;">AMOUNT</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="item">
                                    <MudTd>
                                        <div class="d-flex flex-column">
                                            <MudText Typo="Typo.body2" Style="font-weight: 700; font-size: 0.8rem;">@item.Subscriber</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.65rem;">@MaskAccount(item.CardNumber)</MudText>
                                        </div>
                                    </MudTd>
                                    <MudTd Style="text-align: right;">
                                        <MudText Typo="Typo.body2" Style="font-family:'JetBrains Mono',monospace; font-weight: 800; font-size: 0.85rem;" 
                                                 Color="@(batchData.IsCredit ? Color.Success : Color.Error)">
                                            @(batchData.IsCredit ? "+" : "-")₱@item.Amount.ToString("N2")
                                        </MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="pa-4">
                                <div class="d-flex justify-space-between align-center mb-3">
                                    <div>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:800;">TOTAL MAGNITUDE</MudText>
                                        <MudText Style="font-weight:900; font-family:'JetBrains Mono',monospace;">@Log.Amount?.ToString("C")</MudText>
                                    </div>
                                    <div class="text-right">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:800;">OPERATION TYPE</MudText>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Style="font-weight:900; margin:0;">BULK_ALLOTMENT</MudChip>
                                    </div>
                                </div>
                                <MudDivider Class="mb-3 opacity-20" />
                                <MudText Typo="Typo.caption" Style="font-style:italic; opacity:0.7;">
                                    Forensic Note: Detailed itemization is available in the primary transactional ledger.
                                </MudText>
                            </div>
                        }
                    </div>
                </div>
            }

            @* TELEMETRY *@
            <div class="detail-section mb-6">
                <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6;">Network Telemetry</MudText>
                <div class="mt-2 pa-4 fmc-surface-box">
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Source IP</MudText>
                        <MudText Typo="Typo.body2" Style="font-family:monospace; font-weight:700;">@Log.IpAddress</MudText>
                    </div>
                    <div class="d-flex justify-space-between align-start">
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Digital Fingerprint</MudText>
                        <MudText Typo="Typo.caption" Style="max-width:200px; text-align:right;">@Log.Device</MudText>
                    </div>
                </div>
            </div>

            @* METADATA / MEMO *@
            <div class="detail-section">
                <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6;">Forensic Metadata</MudText>
                <MudPaper Elevation="0" Class="mt-2 pa-4 fmc-memo-box">
                    <MudText Typo="Typo.body2" Style="font-style:italic;">@GetMemo()</MudText>
                </MudPaper>
            </div>
            <div style="height: 32px;"></div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Default" Style="text-transform:none; font-weight:700; border-radius:10px;">Dismiss</MudButton>
        <MudButton OnClick="CopyRef" Variant="Variant.Filled" Color="Color.Primary" 
                   Style="text-transform:none; font-weight:700; border-radius:10px;">Copy Event ID</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .fmc-audit-dialog { border-radius: 20px !important; }
    .fmc-highlight-box { background: rgba(var(--mud-palette-primary-rgb), 0.05); border-radius: 12px; border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.1); }
    .fmc-surface-box { background: var(--mud-palette-background-grey); border-radius: 12px; border: 1px dashed var(--mud-palette-divider); }
    .fmc-memo-box { background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-divider); border-radius: 12px; color: var(--mud-palette-text-secondary); }
    .fmc-breakdown-surface { background: rgba(var(--mud-palette-info-rgb), 0.02); border-radius: 12px; border: 1px solid var(--mud-palette-divider); max-height: 240px; overflow-y: auto; }
    .opacity-50 { opacity: 0.5; }
    .opacity-20 { opacity: 0.2; }

    /* Flow Diagram Styles */
    .fmc-flow-node { width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: var(--mud-palette-surface); border: 2px solid var(--mud-palette-divider); box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
    .fmc-flow-node.source { border-color: rgba(var(--mud-palette-info-rgb), 0.5); }
    .fmc-flow-node.dest { border-color: rgba(var(--mud-palette-success-rgb), 0.5); }
    
    .fmc-flow-particle {
        position: absolute;
        top: -3px;
        left: 0;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--mud-palette-info);
        box-shadow: 0 0 8px var(--mud-palette-info);
        animation: flow-move 2s infinite cubic-bezier(0.4, 0, 0.2, 1);
    }
    @@keyframes flow-move {
        0% { left: 0; opacity: 0; }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { left: 100%; opacity: 0; }
    }
    .fmc-flow-badge {
        position: absolute;
        top: -12px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--mud-palette-surface);
        padding: 2px 10px;
        border-radius: 12px;
        border: 1px solid var(--mud-palette-divider);
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public AuditLogDto Log { get; set; } = default!;

    private string _orgName = "";
    private string _orgAccountNumber = "";
    private string _userAccountNumber = "";

    protected override async Task OnInitializedAsync()
    {
        _orgName = !string.IsNullOrWhiteSpace(Log.Organization) ? Log.Organization : "Corporate Liquidity";
        _userAccountNumber = GetCardNumber();
        
        // Deep resolution: If we have an EntityName (e.g. "Wallet: Ava Gonzalez"), try to find the user's full identity
        if (!string.IsNullOrWhiteSpace(Log.EntityName) && Log.EntityName.Contains(":"))
        {
            try {
                var targetName = Log.EntityName.Split(':').Last().Trim();
                var users = await AdminService.GetUsersAsync();
                var user = users.FirstOrDefault(u => u.DisplayName.Equals(targetName, StringComparison.OrdinalIgnoreCase) 
                                                  || u.UserName?.Equals(targetName, StringComparison.OrdinalIgnoreCase) == true);
                
                if (user != null)
                {
                    if (string.IsNullOrEmpty(_orgName) || _orgName == "Corporate Liquidity")
                        _orgName = user.Organization ?? _orgName;
                        
                    if (string.IsNullOrEmpty(_orgAccountNumber))
                        _orgAccountNumber = user.OrganizationAccountNumber;
                        
                    if (string.IsNullOrEmpty(_userAccountNumber) || _userAccountNumber == targetName)
                        _userAccountNumber = user.AccountNumber;
                }
            } catch { }
        }

        // Fallback for Org lookup by name if not already found
        if (!string.IsNullOrWhiteSpace(_orgName) && _orgName != "Corporate Liquidity" && string.IsNullOrEmpty(_orgAccountNumber))
        {
            try {
                var orgs = await OrgService.GetOrganizationsAsync();
                var org = orgs.FirstOrDefault(o => o.Name.Equals(_orgName, StringComparison.OrdinalIgnoreCase));
                if (org != null) _orgAccountNumber = org.AccountNumber;
            } catch { }
        }
    }

    private void Close() => MudDialog.Cancel();

    private string GetFriendlyName()
    {
        // Prioritize actual UserName from the system, fallback to PerformedBy if it's not a Guid
        if (!string.IsNullOrWhiteSpace(Log.UserName) && Log.UserName != "Unknown") return Log.UserName;
        
        var name = Log.PerformedBy ?? "System";
        if (Guid.TryParse(name, out _))
        {
            return "Administrative Operator";
        }
        return name;
    }

    private string GetMemo()
    {
        var memo = Log.Label ?? "No forensic metadata recorded.";
        if (!string.IsNullOrWhiteSpace(Log.Details) && !Log.Details.Trim().StartsWith("{") && !Log.Details.Contains("@"))
        {
            memo += $" | Additional: {Log.Details}";
        }
        return memo;
    }

    private bool TryGetBatchData(out BatchDetail? data)
    {
        data = null;
        if (string.IsNullOrWhiteSpace(Log.Details) || !Log.Details.Trim().StartsWith("{")) return false;
        
        try {
            data = System.Text.Json.JsonSerializer.Deserialize<BatchDetail>(Log.Details, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            return data != null;
        } catch { return false; }
    }

    private string MaskAccount(string? account)
    {
        if (string.IsNullOrEmpty(account)) return "N/A";
        if (account.Length <= 10) return account;
        return $"{account[..6]}{new string('*', account.Length - 10)}{account[^4..]}";
    }

    private string GetCardNumber()
    {
        if (TryGetBatchData(out var batchData) && batchData.Items.Any())
        {
            return MaskAccount(batchData.Items.First().CardNumber);
        }
        
        // Try to parse JSON from Details for single transactions
        if (!string.IsNullOrWhiteSpace(Log.Details) && Log.Details.Trim().StartsWith("{"))
        {
            try {
                using var doc = System.Text.Json.JsonDocument.Parse(Log.Details);
                if (doc.RootElement.TryGetProperty("cardNumber", out var prop))
                    return MaskAccount(prop.GetString());
                if (doc.RootElement.TryGetProperty("accountNumber", out var propAcc))
                    return MaskAccount(propAcc.GetString());
            } catch { }
        }

        // Fallback to Label if it looks like a card number
        if (!string.IsNullOrWhiteSpace(Log.Label) && Log.Label.Length > 10)
        {
            var label = Log.Label.Replace(" ", "");
            if (label.All(c => char.IsDigit(c) || c == '*' || c == '-'))
                return MaskAccount(Log.Label);
        }
            
        return Log.EntityName?.Replace("Wallet: ", "") ?? "Cardholder"; 
    }

    private string GetOrgIdentity()
    {
        // Try to parse JSON from Details for org account number
        if (!string.IsNullOrWhiteSpace(Log.Details) && Log.Details.Trim().StartsWith("{"))
        {
            try {
                using var doc = System.Text.Json.JsonDocument.Parse(Log.Details);
                if (doc.RootElement.TryGetProperty("orgAccountNumber", out var prop))
                    return MaskAccount(prop.GetString());
                if (doc.RootElement.TryGetProperty("sourceAccountNumber", out var propSrc))
                    return MaskAccount(propSrc.GetString());
            } catch { }
        }
        
        return !string.IsNullOrWhiteSpace(Log.Organization) ? Log.Organization : "Corporate Liquidity";
    }

    private char GetInitial(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return 'S';
        var trimmed = name.Trim();
        return trimmed.Length > 0 ? trimmed.ToUpper()[0] : 'S';
    }

    private void CopyRef()
    {
        Snackbar.Add("Event reference copied to clipboard", Severity.Info);
    }

    private string GetEventIcon(string action)
    {
        return action switch {
            "CREDIT" or "BATCH_SUBMITTED" => Icons.Material.Filled.AddModerator,
            "DEBIT" => Icons.Material.Filled.RemoveModerator,
            "LOGIN" or "LOGIN_SUCCESS" => Icons.Material.Filled.VpnKey,
            _ => Icons.Material.Filled.Hub
        };
    }

    private Color GetEventColor(string action)
    {
        return action switch {
            "CREDIT" or "BATCH_SUBMITTED" => Color.Success,
            "DEBIT" => Color.Error,
            "LOGIN" or "LOGIN_SUCCESS" => Color.Info,
            _ => Color.Primary
        };
    }

    public class BatchDetail {
        public bool IsCredit { get; set; }
        public List<BatchItem> Items { get; set; } = new();
    }
    public class BatchItem {
        public string? CardNumber { get; set; }
        public decimal Amount { get; set; }
        public string? Subscriber { get; set; }
    }
}
