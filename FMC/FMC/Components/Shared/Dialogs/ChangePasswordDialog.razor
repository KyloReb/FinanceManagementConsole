@using MudBlazor
@using FMC.Shared.DTOs.Auth
@using FMC.Services.Api
@inject AuthService AuthService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Primary" Class="mr-3" />
            <MudText Typo="Typo.h6">Change Password</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="4">
            @if (_currentStep == 1)
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.body2" Class="mb-4">Enter your current and new passwords to initiate the change. A security code will be sent to your email.</MudText>
                    <EditForm Model="@_changeRequest" OnValidSubmit="HandleInitiateAsync" Context="step1Context">
                        <DataAnnotationsValidator />
                        <MudGrid>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_changeRequest.OldPassword" Label="Current Password" 
                                              InputType="@_oldPasswordInput" Variant="Variant.Outlined" 
                                              Adornment="Adornment.End" AdornmentIcon="@_oldPasswordIcon" 
                                              OnAdornmentClick="ToggleOldPassword" Required="true" Disabled="@_loading" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_changeRequest.NewPassword" Label="New Password" 
                                              InputType="@_newPasswordInput" Variant="Variant.Outlined" 
                                              Adornment="Adornment.End" AdornmentIcon="@_newPasswordIcon" 
                                              OnAdornmentClick="ToggleNewPassword" Required="true" Disabled="@_loading" />
                            </MudItem>
                             <MudItem xs="12">
                                 <MudTextField @bind-Value="_changeRequest.ConfirmNewPassword" Label="Confirm New Password" 
                                               InputType="@_newPasswordInput" Variant="Variant.Outlined" 
                                               Adornment="Adornment.End" AdornmentIcon="@_newPasswordIcon" 
                                               OnAdornmentClick="ToggleNewPassword" Required="true" 
                                               Immediate="true" Disabled="@_loading" />
                                 @if (!string.IsNullOrEmpty(_changeRequest.ConfirmNewPassword))
                                 {
                                     @if (_changeRequest.NewPassword == _changeRequest.ConfirmNewPassword)
                                     {
                                         <MudText Typo="Typo.caption" Color="Color.Success" Class="ml-1 mt-1">
                                             <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1" /> Passwords match
                                         </MudText>
                                     }
                                     else
                                     {
                                         <MudText Typo="Typo.caption" Color="Color.Error" Class="ml-1 mt-1">
                                             <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Small" Class="mr-1" /> Passwords do not match
                                         </MudText>
                                     }
                                 }
                             </MudItem>
                         </MudGrid>
                     </EditForm>
                 </MudItem>
            }
            else
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Class="mb-4" Variant="Variant.Outlined">
                        A security code has been sent to your email. Please enter it below to confirm.
                    </MudAlert>
                    <EditForm Model="@_verifyRequest" OnValidSubmit="HandleCompleteAsync" Context="step2Context">
                        <MudGrid>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_verifyRequest.Otp" Label="6-Digit Security Code" 
                                              Variant="Variant.Outlined" Placeholder="123456" 
                                              MaxLength="6" HelperText="Check your registered email address" Disabled="@_loading" />
                            </MudItem>
                        </MudGrid>
                    </EditForm>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="@_loading">Cancel</MudButton>
        @if (_currentStep == 1)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="HandleInitiateAsync" Disabled="@_loading">
                @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Send Security Code
            </MudButton>
        }
        else
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="HandleCompleteAsync" Disabled="@_loading">
                @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Confirm Update
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private ChangePasswordRequestDto _changeRequest = new();
    private VerifyPasswordChangeDto _verifyRequest = new();
    private int _currentStep = 1;
    private bool _loading = false;

    private InputType _oldPasswordInput = InputType.Password;
    private string _oldPasswordIcon = Icons.Material.Filled.VisibilityOff;
    private InputType _newPasswordInput = InputType.Password;
    private string _newPasswordIcon = Icons.Material.Filled.VisibilityOff;

    private void ToggleOldPassword() => (_oldPasswordInput, _oldPasswordIcon) = _oldPasswordInput == InputType.Password ? (InputType.Text, Icons.Material.Filled.Visibility) : (InputType.Password, Icons.Material.Filled.VisibilityOff);
    private void ToggleNewPassword() => (_newPasswordInput, _newPasswordIcon) = _newPasswordInput == InputType.Password ? (InputType.Text, Icons.Material.Filled.Visibility) : (InputType.Password, Icons.Material.Filled.VisibilityOff);

    private void Cancel() => MudDialog.Cancel();

    private async Task HandleInitiateAsync()
    {
        if (_changeRequest.NewPassword != _changeRequest.ConfirmNewPassword)
        {
            Snackbar.Add("New passwords do not match.", Severity.Error);
            return;
        }

        _loading = true;
        try
        {
            var success = await AuthService.InitiatePasswordChange(_changeRequest);
            if (success)
            {
                _verifyRequest.NewPassword = _changeRequest.NewPassword;
                _currentStep = 2;
                Snackbar.Add("Security code sent successfully.", Severity.Info);
            }
            else
            {
                Snackbar.Add("Failed to initiate password change. Please verify your current password.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"An error occurred: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleCompleteAsync()
    {
        if (string.IsNullOrWhiteSpace(_verifyRequest.Otp))
        {
            Snackbar.Add("Please enter the security code.", Severity.Warning);
            return;
        }

        _loading = true;
        try
        {
            var success = await AuthService.CompletePasswordChange(_verifyRequest);
            if (success)
            {
                Snackbar.Add("Password updated successfully.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Invalid security code or password update failed.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"An error occurred: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
