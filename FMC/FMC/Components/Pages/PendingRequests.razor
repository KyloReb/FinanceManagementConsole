@page "/pending-requests"
@using FMC.Shared.DTOs
@using FMC.Shared.Auth
@using FMC.Services.Api
@using FMC.Services
@using FMC.Components.Pages.Admin
@using FMC.Components.Pages.Admin.Dialogs
@inject OrganizationApiService OrgService
@inject IReportService ReportGen
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@attribute [Authorize(Roles = "SuperAdmin,CEO,Maker,Approver")]

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-12">
    <!-- Header Section -->
    <div class="d-flex align-center justify-space-between mb-8">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 950; letter-spacing: -0.04em; text-transform: uppercase;" Color="Color.Primary">Operations Center</MudText>
            <MudText Typo="Typo.subtitle1" Style="font-weight: 500; opacity: 0.5;">Comprehensive financial settlement and authorization queue.</MudText>
        </div>
        
        <!-- Action Buttons for Makers -->
        <div class="d-flex gap-3">
            @if (_isMaker)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => OpenUserSelectionAsync(isCredit: true))"
                           Class="fmc-enterprise-btn">New Credit</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Surface" StartIcon="@Icons.Material.Filled.Remove" OnClick="@(() => OpenUserSelectionAsync(isCredit: false))"
                           Class="fmc-enterprise-btn secondary">New Debit</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.FileUpload" OnClick="OpenBulkUploadAsync"
                           Class="fmc-enterprise-btn info">Bulk Upload</MudButton>
            }
        </div>
    </div>

    <!-- Integrated Ledger & Queue -->
    <div class="fmc-integrated-ledger">
        <!-- Navigation Tabs -->
        <div class="fmc-custom-tab-bar">
            <button class="fmc-tab-btn @(GetActiveTabClass(0))" @onclick="@(() => SetTabAsync(0))" aria-label="View all transactions">
                <MudIcon Icon="@Icons.Material.Filled.List" Size="Size.Small" Class="mr-2" /> ALL
            </button>
            <button class="fmc-tab-btn @(GetActiveTabClass(1))" @onclick="@(() => SetTabAsync(1))" aria-label="View pending actions">
                <MudIcon Icon="@Icons.Material.Filled.PendingActions" Size="Size.Small" Class="mr-2" /> ACTION REQUIRED
            </button>
            <button class="fmc-tab-btn @(GetActiveTabClass(2))" @onclick="@(() => SetTabAsync(2))" aria-label="View authorized transactions">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-2" /> AUTHORIZED
            </button>
            <button class="fmc-tab-btn @(GetActiveTabClass(3))" @onclick="@(() => SetTabAsync(3))" aria-label="View denied transactions">
                <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Class="mr-2" /> DENIED
            </button>
        </div>

        <!-- Tab Content Area -->
        <div class="fmc-tab-content pa-4">
            @if (_activeIndex == 0)
            {
                @RenderTable(_allTransactions, "Global")
            }
            else if (_activeIndex == 1)
            {
                @RenderPendingTable()
            }
            else if (_activeIndex == 2)
            {
                @RenderTable(_approvedTransactions, "Authorized")
            }
            else if (_activeIndex == 3)
            {
                @RenderTable(_rejectedTransactions, "Denied")
            }
        </div>
    </div>
</MudContainer>

@code {
    #region Render Fragments (UI Components)

    /// <summary>
    /// Renders the standard transaction table used for All, Authorized, and Denied tabs.
    /// </summary>
    private RenderFragment RenderTable(List<TransactionDto> items, string status) => __builder => 
    {
        if (_loading)
        {
            <div class="d-flex justify-center pa-12">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            </div>
        }
        else if (!items.Any())
        {
            <!-- Empty State Display -->
            <MudPaper Class="pa-16 d-flex flex-column align-center justify-center text-center fmc-empty-state" Elevation="0">
                <MudIcon Icon="@(status == "Pending" ? Icons.Material.Filled.AssignmentTurnedIn : Icons.Material.Filled.History)" 
                         Size="Size.Large" Style="font-size: 6rem; opacity: 0.05;" />
                <MudText Typo="Typo.h5" Class="mt-6" Style="font-weight: 900; opacity: 0.4;">Queue is Empty</MudText>
                <MudText Typo="Typo.body1" Class="mud-text-secondary" Style="max-width:300px;">
                    @(status == "Pending" ? "There are no records requiring immediate authorization." : $"No {status.ToLower()} records found in recent history.")
                </MudText>
            </MudPaper>
        }
        else
        {
            <!-- Data Table -->
            <MudTable Items="@items" Hover="true" Elevation="0" Class="fmc-premium-table" Striped="false" 
                      Filter="new Func<TransactionDto,bool>(FilterFunc)"
                      OnRowClick="@((TableRowClickEventArgs<TransactionDto> e) => OpenDetailAsync(e.Item!))" RowClass="cursor-pointer">
                
                <!-- Table Toolbar: Title, Exports, Filters -->
                <ToolBarContent>
                    <MudText Typo="Typo.h6" Style="font-weight: 900; font-size: 0.95rem; letter-spacing: 0.05em; opacity:0.8;">@status.ToUpper() RECORDS</MudText>
                    <MudSpacer />
                    
                    <div class="d-flex align-center gap-4 py-2">
                        @if (_isCeo)
                        {
                            <!-- CEO Reporting Exports -->
                            <div class="d-flex gap-2 mr-4">
                                <MudTooltip Text="Export to Excel">
                                    <MudIconButton Icon="@Icons.Custom.FileFormats.FileExcel" Color="Color.Success" Variant="Variant.Outlined" 
                                                   OnClick="ExportToExcelAsync" Style="border-radius: 8px;" aria-label="Export to Excel" />
                                </MudTooltip>
                                <MudTooltip Text="Export to PDF">
                                    <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Error" Variant="Variant.Outlined" 
                                                   OnClick="ExportToPdfAsync" Style="border-radius: 8px;" aria-label="Export to PDF" />
                                </MudTooltip>
                            </div>
                        }

                        <!-- Date Range Picker -->
                        <div class="fmc-date-filter-container" style="position: relative;">
                            <MudOverlay Visible="@_datePickerOpen" OnClick="@(() => _datePickerOpen = false)" ZIndex="9998" AutoClose="true" />
                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.CalendarMonth" 
                                       EndIcon="@Icons.Material.Filled.ArrowDropDown" OnClick="@(() => _datePickerOpen = !_datePickerOpen)"
                                       Style="border-radius: 12px; min-width: 240px; height: 40px; font-weight: 800; text-transform: none; color: var(--mud-palette-text-primary); border-color: var(--mud-palette-divider); position: relative; z-index: 10000;">
                                @(_filterDateRange?.Start?.ToString("MMM dd") ?? "Start") — @(_filterDateRange?.End?.ToString("MMM dd") ?? "End")
                            </MudButton>
                            
                            <MudPopover Open="@_datePickerOpen" AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft" 
                                        Class="fmc-datepicker-popover" Fixed="true" Style="z-index: 9999;">
                                <div class="pa-2" style="background-color: #121212; width: 330px; overflow: hidden;">
                                     <MudDateRangePicker DateRange="_filterDateRange" PickerVariant="PickerVariant.Static" 
                                                         Elevation="0" Color="Color.Primary" Rounded="true" 
                                                         Style="width: 100%;"
                                                         DateRangeChanged="@(async dr => { _filterDateRange = dr; _datePickerOpen = false; StateHasChanged(); })" />
                                </div>
                            </MudPopover>
                        </div>
                                       
                        <!-- Global Search Filter -->
                        <MudTextField @bind-Value="_searchString" Placeholder="Filter ledger..." 
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" 
                                      Class="mt-0" Immediate="true" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 300px; border-radius: 12px; font-weight: 700;"></MudTextField>
                    </div>
                </ToolBarContent>
                
                <!-- Table Headers -->
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x => x.Date))">TIMESTAMP</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x => x.Subscriber))">IDENTIFIER</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x => x.AccountNumber ?? string.Empty))">CARD NUMBER</MudTableSortLabel></MudTh>
                    
                    @if (status == "Pending")
                    {
                        <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x => x.MakerName ?? string.Empty))">INITIATOR</MudTableSortLabel></MudTh>
                    }
                    else if (status == "Global")
                    {
                        <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x => x.Status))">STATUS</MudTableSortLabel></MudTh>
                    }
                    else
                    {
                        <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x => x.ApproverName ?? string.Empty))">SETTLED BY</MudTableSortLabel></MudTh>
                    }
                    
                    <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x => x.Amount))">SETTLEMENT</MudTableSortLabel></MudTh>
                    <MudTh>ACTION</MudTh>
                </HeaderContent>
                
                <!-- Row Layout -->
                <RowTemplate>
                    <MudTd DataLabel="Timestamp">
                         <div class="d-flex flex-column">
                             <MudText Style="font-weight: 800; font-size: 0.85rem;">@context.Date.ToString("MMM dd")</MudText>
                             <MudText Typo="Typo.caption" Style="opacity: 0.5;">@context.Date.ToString("HH:mm:ss")</MudText>
                         </div>
                    </MudTd>
                    <MudTd DataLabel="Identifier">
                        <MudText Style="font-weight: 900; color: var(--mud-palette-primary); letter-spacing: -0.01em;">@context.Subscriber</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.5; display: block; max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@context.Label</MudText>
                    </MudTd>
                    <MudTd DataLabel="Card Number">
                        <code class="fmc-card-mono">@GetMaskedAccount(context.AccountNumber)</code>
                    </MudTd>
                    <MudTd DataLabel="Authority">
                        <div class="d-flex align-center">
                            @if (status == "Global")
                            {
                                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Filled" Style="font-weight: 900; font-size: 0.6rem;">@context.Status.ToUpper()</MudChip>
                            }
                            else
                            {
                                <MudAvatar Size="Size.Small" Color="Color.Surface" Class="mr-2" Style="width: 24px; height: 24px; font-size: 0.6rem; border:1px solid var(--mud-palette-divider);">
                                    @((context.ApproverName ?? context.MakerName ?? "S")[0])
                                </MudAvatar>
                                <MudText Typo="Typo.caption" Style="font-weight: 800; opacity: 0.8;">@(context.Status == "Pending" ? context.MakerName : context.ApproverName ?? "System")</MudText>
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Settlement">
                        <MudText Color="@(context.Amount < 0 ? Color.Error : Color.Success)" Class="fmc-financial-mono" Style="font-weight: 950; font-size: 1.05rem; letter-spacing: -0.02em;">
                            @context.Amount.ToString("C")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Action" @onclick:stopPropagation="true">
                        @if (context.Status == "Pending")
                        {
                            @if (_isApprover && context.MakerId != _currentUserId)
                            {
                                <div class="d-flex gap-2">
                                    <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" OnClick="@(() => HandleApprovalAsync(context, approve: true))" Size="Size.Small" Variant="Variant.Filled" Style="border-radius: 8px;" aria-label="Approve" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" OnClick="@(() => HandleApprovalAsync(context, approve: false))" Size="Size.Small" Variant="Variant.Outlined" Style="border-radius: 8px;" aria-label="Reject" />
                                </div>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text" Style="font-weight: 950; font-size: 0.65rem; border: 1px solid rgba(var(--mud-palette-warning-rgb), 0.3);">AWAITING</MudChip>
                            }
                        }
                        else
                        {
                             <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Text" Style="font-weight: 950; font-size: 0.65rem;">
                                 @context.Status.ToUpper()
                             </MudChip>
                        }
                    </MudTd>
                </RowTemplate>
                
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[]{10, 20, 50, 100}" />
                </PagerContent>
            </MudTable>
        }
    };

    /// <summary>
    /// Renders the specialized Action Required table, which natively supports Batch Grouping for bulk approvals.
    /// </summary>
    private RenderFragment RenderPendingTable() => __builder => 
    {
        if (_loading)
        {
            <div class="d-flex justify-center pa-12">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            </div>
        }
        else if (!_pendingGroups.Any())
        {
            <MudPaper Class="pa-16 d-flex flex-column align-center justify-center text-center fmc-empty-state" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Size="Size.Large" Style="font-size: 6rem; opacity: 0.05;" />
                <MudText Typo="Typo.h5" Class="mt-6" Style="font-weight: 900; opacity: 0.4;">Queue is Empty</MudText>
                <MudText Typo="Typo.body1" Class="mud-text-secondary" Style="max-width:300px;">There are no records requiring immediate authorization.</MudText>
            </MudPaper>
        }
        else
        {
            <MudTable Items="@_pendingGroups" Hover="true" Elevation="0" Class="fmc-premium-table" 
                      OnRowClick="@((TableRowClickEventArgs<TransactionGroup> e) => { if(e.Item != null && !e.Item.BatchId.HasValue && e.Item.Transactions.Any()) OpenDetailAsync(e.Item.Transactions.First()); })" 
                      RowClassFunc="@((group, idx) => group != null && !group.BatchId.HasValue ? "cursor-pointer" : "")">
                
                <ToolBarContent>
                    <MudText Typo="Typo.h6" Style="font-weight: 900; font-size: 0.95rem; letter-spacing: 0.05em; opacity:0.8;">PENDING AUTHORIZATIONS</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchString" Placeholder="Filter pending..." 
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" 
                                  Class="mt-0" Immediate="true" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 300px; border-radius: 12px; font-weight: 700;"></MudTextField>
                </ToolBarContent>
                
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<TransactionGroup, object>(x => x.Date)">TIMESTAMP</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TransactionGroup, object>(x => x.Label ?? string.Empty)">IDENTIFIER / BATCH</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TransactionGroup, object>(x => x.MakerName ?? string.Empty)">SOURCE / MAKER</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<TransactionGroup, object>(x => x.TotalAmount)">TOTAL SETTLEMENT</MudTableSortLabel></MudTh>
                    <MudTh>ACTIONS</MudTh>
                </HeaderContent>
                
                <RowTemplate>
                    <MudTd DataLabel="Timestamp">
                         <div class="d-flex flex-column">
                             <MudText Style="font-weight: 800; font-size: 0.85rem;">@context.Date.ToString("MMM dd")</MudText>
                             <MudText Typo="Typo.caption" Style="opacity: 0.5;">@context.Date.ToString("HH:mm")</MudText>
                         </div>
                    </MudTd>
                    <MudTd DataLabel="Identifier">
                        @if (context.BatchId.HasValue)
                        {
                            <!-- Batch Group Display -->
                            <div class="d-flex align-center">
                                <MudIconButton Icon="@(context.ShowDetails ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" 
                                               OnClick="@(() => context.ShowDetails = !context.ShowDetails)" Size="Size.Small" Class="mr-2" aria-label="Toggle batch details" />
                                <div>
                                    <div class="d-flex align-center gap-2">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled" Style="font-weight: 800; font-size: 0.6rem;">BATCH</MudChip>
                                        <MudText Style="font-weight: 900; color: var(--mud-palette-text-primary); letter-spacing: -0.01em;">@context.Label</MudText>
                                    </div>
                                    <MudText Typo="Typo.caption" Style="opacity: 0.7;">ID: @context.BatchId.Value.ToString().Substring(0, 8)... &bull; @context.Transactions.Count items</MudText>
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- Single Transaction Display -->
                            <MudText Style="font-weight: 900; color: var(--mud-palette-primary); letter-spacing: -0.01em;">@context.Transactions.First().Subscriber</MudText>
                            <MudText Typo="Typo.caption" Style="opacity: 0.5;">@context.Transactions.First().Label</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Maker">
                        <div class="d-flex align-center">
                            <MudAvatar Size="Size.Small" Color="Color.Surface" Class="mr-2" Style="width: 24px; height: 24px; font-size: 0.6rem; border:1px solid var(--mud-palette-divider);">
                                @((context.MakerName ?? "S")[0])
                            </MudAvatar>
                            <MudText Typo="Typo.caption" Style="font-weight: 800; opacity: 0.8;">@context.MakerName</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Settlement">
                        <MudText Color="@(context.TotalAmount < 0 ? Color.Error : Color.Success)" Class="fmc-financial-mono" Style="font-weight: 950; font-size: 1.05rem; letter-spacing: -0.02em;">
                            @context.TotalAmount.ToString("C")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Action" @onclick:stopPropagation="true">
                        @if (_isApprover && context.Transactions.Any(t => t.MakerId != _currentUserId))
                        {
                            <div class="d-flex gap-2">
                                <MudButton Variant="Variant.Filled" Size="Size.Small" 
                                           StartIcon="@Icons.Material.Filled.Check"
                                           OnClick="@(() => HandleGroupApprovalAsync(context, approve: true))" 
                                           Style="background-color: #2e7d32; color: #ffffff; border-radius: 8px; font-weight: 800; text-transform: none; opacity: 0.9;">
                                    @(context.BatchId.HasValue ? "Approve Batch" : "Approve")
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" 
                                           StartIcon="@Icons.Material.Filled.Close"
                                           OnClick="@(() => HandleGroupApprovalAsync(context, approve: false))" 
                                           Style="border-radius: 8px; font-weight: 800; text-transform: none;">
                                    @(context.BatchId.HasValue ? "Reject Batch" : "Reject")
                                </MudButton>
                            </div>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text" Style="font-weight: 950; font-size: 0.65rem; border: 1px solid rgba(var(--mud-palette-warning-rgb), 0.3);">AWAITING</MudChip>
                        }
                    </MudTd>
                </RowTemplate>
                
                <ChildRowContent>
                    <!-- Expandable Batch Details -->
                    @if (context.ShowDetails && context.BatchId.HasValue)
                    {
                        <MudTr>
                            <td colspan="5" class="pa-0">
                                <div class="pa-4" style="background: rgba(var(--mud-palette-primary-rgb), 0.02); border-bottom: 1px solid var(--mud-palette-divider);">
                                    <MudTable Items="@context.Transactions" Dense="true" Hover="true" Elevation="0" Context="tx">
                                        <HeaderContent>
                                            <MudTh Style="font-size: 0.6rem;">SUBSCRIBER</MudTh>
                                            <MudTh Style="font-size: 0.6rem;">CARD NUMBER</MudTh>
                                            <MudTh Style="font-size: 0.6rem; text-align: right;">AMOUNT</MudTh>
                                            <MudTh></MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>@tx.Subscriber</MudTd>
                                            <MudTd><code class="fmc-card-mono" style="font-size: 0.7rem;">@GetMaskedAccount(tx.AccountNumber)</code></MudTd>
                                            <MudTd Style="text-align: right;">
                                                <MudText Typo="Typo.body2" Color="@(tx.Amount < 0 ? Color.Error : Color.Success)" Style="font-weight: 800;">@tx.Amount.ToString("C")</MudText>
                                            </MudTd>
                                            <MudTd Style="text-align: right;">
                                                <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" OnClick="@(() => OpenDetailAsync(tx))" aria-label="View transaction detail" />
                                            </MudTd>
                                        </RowTemplate>
                                        <PagerContent>
                                            <MudTablePager PageSizeOptions="new int[]{10, 20, 50}" />
                                        </PagerContent>
                                    </MudTable>
                                </div>
                            </td>
                        </MudTr>
                    }
                </ChildRowContent>
                
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[]{10, 25, 50, 100}" />
                </PagerContent>
            </MudTable>
        }
    };
    #endregion
}

<style>
    /* Styling Definitions */
    :root { --fmc-font-premium: 'Inter', -apple-system, sans-serif; }
    .fmc-integrated-ledger { border-radius: 20px; border: 1px solid var(--mud-palette-divider); overflow: hidden; background-color: var(--mud-palette-surface); box-shadow: 0 4px 20px rgba(0,0,0,0.15); }
    .fmc-custom-tab-bar { display: flex; width: 100%; background: rgba(var(--mud-palette-primary-rgb), 0.04); height: 64px; border-bottom: 2px solid var(--mud-palette-divider); }
    .fmc-tab-btn { flex: 1; border: none; background: transparent; color: var(--mud-palette-text-secondary); font-weight: 900; font-size: 0.75rem; letter-spacing: 0.1em; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; border-right: 1px solid rgba(var(--mud-palette-divider-rgb), 0.1); outline: none; }
    .fmc-tab-btn:last-child { border-right: none; }
    .fmc-tab-btn:hover { background: rgba(255,255,255,0.02); color: var(--mud-palette-text-primary); }
    .fmc-tab-btn.active { color: var(--mud-palette-primary); background: rgba(var(--mud-palette-primary-rgb), 0.06); position: relative; }
    .fmc-tab-btn.active::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 4px; background: var(--mud-palette-primary); }
    .fmc-tab-content { min-height: 400px; }
    
    .fmc-datepicker-popover .mud-picker-static-header { display: none !important; }
    .fmc-datepicker-popover .mud-picker-header { background-color: #1a1a1c !important; color: var(--mud-palette-primary) !important; }
    .fmc-datepicker-popover .mud-picker-header-label { color: var(--mud-palette-primary) !important; font-weight: 900 !important; }
    .fmc-datepicker-popover .mud-picker-calendar-header { color: white !important; }
    .fmc-datepicker-popover .mud-day { color: #ccc !important; }
    .fmc-premium-table { padding-bottom: 8px; }
    .fmc-premium-table .mud-table-head { background-color: transparent; }
    .fmc-premium-table .mud-th { font-weight: 950 !important; color: var(--mud-palette-text-secondary); font-size: 0.65rem !important; letter-spacing: 0.12em; text-transform: uppercase; padding: 22px 24px !important; border-bottom: 2px solid var(--mud-palette-divider); }
    .fmc-premium-table .mud-td { padding: 18px 24px !important; border-bottom: 1px solid rgba(var(--mud-palette-divider-rgb), 0.2); }
