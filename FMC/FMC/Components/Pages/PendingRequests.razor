@code {
    #region Injections & State
    
    [CascadingParameter] 
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    
    [Inject] 
    private IJSRuntime JS { get; set; } = default!;

    private Guid _orgId;
    private string? _currentUserId;
    private string _currentUserName = "Approver";
    private bool _isApprover;
    private bool _isMaker;
    private bool _isCeo;
    private bool _isSuperAdmin;
    private bool _isSuperAdminApprover;

    // Data Collections
    private List<TransactionDto> _allTransactions = new();
    private List<TransactionGroup> _allGroups = new();
    private List<TransactionGroup> _pendingGroups = new();
    private List<TransactionGroup> _approvedGroups = new();
    private List<TransactionGroup> _rejectedGroups = new();

    // UI State
    private bool _loading = true;
    private string? _processingGroupId = null;
    private string? _rejectionReason;
    private bool _processingIsApprove = false;
    private bool _showErrorOverlay = false;
    private string _errorTitle = "";
    private string _errorSubtext = "";
    private bool _showSuccessOverlay = false;
    private string _successTitle = "";
    private string _successSubtext = "";
    private int _activeIndex = 0;
    private string _searchString = "";
    private DateRange? _filterDateRange = new DateRange(DateTime.Today.AddDays(-7), DateTime.Today);
    private string _activeDateRange = "7d";
    private int _mobilePageSize = 10;
    private int _mobileCurrentPage = 0;
    private MudTable<TransactionGroup>? _table;

    #endregion

    #region Lifecycle Methods

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var user = authState.User;
        
        // Resolve RBAC permissions
        _isApprover = user.IsInRole(Roles.Approver) || user.IsInRole(Roles.SuperAdminApprover);
        _isMaker = user.IsInRole(Roles.Maker);
        _isCeo = user.IsInRole(Roles.CEO);
        _isSuperAdmin = user.IsInRole(Roles.SuperAdmin);
        _isSuperAdminApprover = user.IsInRole(Roles.SuperAdminApprover);
        _currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        _currentUserName = user.Identity?.Name ?? "Approver";
        try { var me = await AuthService.GetCurrentUserAsync(); if (me != null) _currentUserName = me.DisplayName; } catch { }
        
        if (_isSuperAdmin || _isSuperAdminApprover)
        {
            var orgs = await OrgService.GetOrganizationsAsync();
            if (orgs.Any())
            {
                await LoadAllOrgsQueueDataAsync(orgs);
            }
            else
            {
                ShowApprovalErrorAsync("No organizations found.", false);
                _loading = false;
            }
        }
        else
        {
            var orgIdClaim = user.FindFirst("OrganizationId")?.Value;
            if (Guid.TryParse(orgIdClaim, out var id))
            {
                _orgId = id;
                await LoadQueueDataAsync();
            }
            else
            {
                ShowApprovalErrorAsync("Organizational context unresolved.", false);
                _loading = false;
            }
        }
    }

    #endregion

    #region Data Loading & Structuring

    /// <summary>
    /// Fetches the latest transaction history from all orgs and consolidates (SuperAdmin path).
    /// </summary>
    private async Task LoadAllOrgsQueueDataAsync(List<FMC.Shared.DTOs.Organization.OrganizationDto> orgs)
    {
        _loading = true;
        try
        {
            var fetchCount = _isSuperAdmin || _isSuperAdminApprover ? 200 : 2000;
            var tasks = orgs.Select(o => OrgService.GetOrganizationTransactionsAsync(o.Id, count: fetchCount));
            var results = await Task.WhenAll(tasks);
            _allTransactions = results.SelectMany(r => r).ToList();
            if (_isSuperAdmin || _isSuperAdminApprover)
                _allTransactions = _allTransactions.Where(t => t.Category is "Org Adjustment Pending" or "System Adjustment").ToList();
            
            _allGroups = GroupTransactions(_allTransactions);
            _pendingGroups = GroupTransactions(_allTransactions.Where(t => t.Status == "Pending").ToList());
            _approvedGroups = GroupTransactions(_allTransactions.Where(t => t.Status == "Approved" || t.Status == "Successful").ToList());
            _rejectedGroups = GroupTransactions(_allTransactions.Where(t => t.Status == "Rejected").ToList());
        }
        catch (Exception ex)
        {
            ShowApprovalErrorAsync($"Load Failed: {ex.Message}", false);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Fetches the latest transaction history from a single org and segregates it into tab queues.
    /// </summary>
    private async Task LoadQueueDataAsync()
    {
        _loading = true;
        try
        {
            var allHistory = await OrgService.GetOrganizationTransactionsAsync(_orgId, count: 2000); 
            _allTransactions = allHistory.ToList();
            
            _allGroups = GroupTransactions(_allTransactions);
            var pendingTxs = _allTransactions.Where(t => t.Status == "Pending");
            if (_isSuperAdmin || _isSuperAdminApprover)
                pendingTxs = pendingTxs.Where(t => t.Category == "Org Adjustment Pending");
            else
                pendingTxs = pendingTxs.Where(t => t.Category != "Org Adjustment Pending");
            _pendingGroups = GroupTransactions(pendingTxs.ToList());
            _approvedGroups = GroupTransactions(_allTransactions.Where(t => t.Status == "Approved" || t.Status == "Successful").ToList());
            _rejectedGroups = GroupTransactions(_allTransactions.Where(t => t.Status == "Rejected").ToList());
        }
        catch (Exception ex)
        {
            ShowApprovalErrorAsync($"Load Failed: {ex.Message}", false);
        }
        finally
        {
            _loading = false;
        }
    }

    private List<TransactionGroup> GroupTransactions(List<TransactionDto> txs)
    {
        var result = new List<TransactionGroup>();

        // Batch transactions: group by shared BatchId
        var batchGroups = txs
            .Where(t => t.BatchId.HasValue)
            .GroupBy(t => t.BatchId!.Value)
            .Select(g => new TransactionGroup { BatchId = g.Key, Transactions = g.ToList() });

        // Individual transactions: each gets its own group
        var individualGroups = txs
            .Where(t => !t.BatchId.HasValue)
            .Select(t => new TransactionGroup { BatchId = null, Transactions = new List<TransactionDto> { t } });

        result.AddRange(batchGroups);
        result.AddRange(individualGroups);

        return result.OrderByDescending(g => g.Date).ToList();
    }

    #endregion

    #region UI & Tab Helpers

    /// <summary>
    /// Retrieves the active CSS class for tab highlights.
    /// </summary>
    private string GetActiveTabClass(int idx) => _activeIndex == idx ? "active" : string.Empty;
    
    /// <summary>
    /// Switches the active view tab.
    /// </summary>
    private async Task SetTabAsync(int idx)
    {
        _activeIndex = idx;
    }

    /// <summary>
    /// Maps transaction status to a standard MudBlazor color code.
    /// </summary>
    private Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Warning,
        "Approved" or "Successful" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Surface
    };

    /// <summary>
    /// Obfuscates account numbers leaving only the first 6 and last 4 visible.
    /// </summary>
    private string GetMaskedAccount(string? account)
    {
        if (string.IsNullOrEmpty(account)) return "ID.NULL";
        if (account.Length <= 10) return account;
        return $"{account[..6]}••••{account[^4..]}";
    }

    private void SetQuickDate(string range)
    {
        _activeDateRange = range;
        var today = DateTime.Today;
        switch (range)
        {
            case "all": _filterDateRange = new DateRange(null, null); break;
            case "7d":  _filterDateRange = new DateRange(today.AddDays(-7), today); break;
            case "1m":  _filterDateRange = new DateRange(today.AddMonths(-1), today); break;
            case "3m":  _filterDateRange = new DateRange(today.AddMonths(-3), today); break;
            case "1y":  _filterDateRange = new DateRange(today.AddYears(-1), today); break;
        }
        StateHasChanged();
    }

    /// <summary>
    /// Filters the transaction groups based on the search string and date range constraints.
    /// </summary>
    private bool GroupFilterFunc(TransactionGroup group)
    {
        // Check date bounds
        if (_filterDateRange?.Start.HasValue == true && _filterDateRange?.End.HasValue == true)
        {
            if (group.Date.Date < _filterDateRange.Start.Value.Date || group.Date.Date > _filterDateRange.End.Value.Date)
                return false;
        }

        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        
        return group.Transactions.Any(tx => 
            (tx.Subscriber?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (tx.AccountNumber?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (tx.Label?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (tx.MakerName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (tx.ApproverName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
        );
    }

    /// <summary>
    /// Individual record filter for report generation.
    /// </summary>
    private bool FilterFunc(TransactionDto tx)
    {
        if (_filterDateRange?.Start.HasValue == true && _filterDateRange?.End.HasValue == true)
        {
            if (tx.Date.Date < _filterDateRange.Start.Value.Date || tx.Date.Date > _filterDateRange.End.Value.Date)
                return false;
        }
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        return (tx.Subscriber?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
               (tx.AccountNumber?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) ||
               (tx.Label?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false);
    }

    #endregion

    #region Interaction Handlers (Modals & Approvals)

    /// <summary>
    /// Opens the new transaction modal for manual debits/credits.
    /// </summary>
    private async Task OpenUserSelectionAsync(bool isCredit)
    {
        var parameters = new DialogParameters { ["OrgId"] = _orgId };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<UserSelectionDialog>("Identity Resolution", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is UserDto selectedUser)
        {
            var adjustParams = new DialogParameters { ["User"] = selectedUser, ["IsCredit"] = isCredit };
            var adjustDialog = await DialogService.ShowAsync<UserBalanceDialog>("Initiate Settlement", adjustParams, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
            var adjustResult = await adjustDialog.Result;
            
            if (adjustResult is not null && !adjustResult.Canceled)
            {
                await LoadQueueDataAsync();
            }
        }
    }

