@page "/login"
@layout Layout.BlankLayout
@attribute [AllowAnonymous]
@implements IDisposable
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject FMC.Services.ThemeService ThemeService
@inject AuthenticationStateProvider AuthStateProvider
@using FMC.Shared.DTOs.Admin
@using System.Net

<PageTitle>FMC — Sign In</PageTitle>

<div class="d-flex justify-center align-center py-8" style="min-height: 100vh; background-color: var(--mud-palette-background);">

    @if (_showMaintenance)
    {
        <div class="sc-maintenance-root @(ThemeService.IsDarkMode ? "dark" : "light")">
            <div class="sc-maintenance-card">
                <div class="sc-maintenance-logo-wrap">
                    <img src="/nlkLogo.png" alt="NLK Logo" style="height:32px; object-fit:contain;" />
                </div>
                <div class="sc-maintenance-icon">&#9881;</div>
                <h1 class="sc-maintenance-title">Under Maintenance</h1>
                <p class="sc-maintenance-desc">@_maintenanceMsg</p>
                <p class="sc-maintenance-accent">&#9679; We&rsquo;ll be back shortly</p>
                <div class="sc-maintenance-contact">
                    &#128231; For questions or inquiries, please contact<br/>
                    <a href="mailto:nl.admin@nationlink.ph">nl.admin@nationlink.ph</a>
                </div>
                <div class="sc-maintenance-footer">
                    <span class="sc-pulse-dot-sm"></span>
                    FMC &middot; @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss") UTC
                </div>
                <button class="sc-maintenance-logout-btn" @onclick="Logout">Sign Out</button>
            </div>
        </div>
    }
    else
    {
    <MudCard Elevation="4" Class="pa-8 d-flex flex-column align-center mx-4" Style="width: 100%; max-width: 450px; border-radius: 12px;">
        <img src="/nlkLogo.png" alt="NLK Logo" style="height:36px; object-fit:contain; margin-bottom:24px;" />
        <MudText Typo="Typo.h5" Class="mb-5 fw-bold">Sign In</MudText>
        @if (_showMaintenanceWarning)
        {
            <div class="fmc-maint-warning w-100 mb-4">&#9888; <strong>Maintenance in progress.</strong> Even if you log in, you will not be able to access the dashboard until maintenance is resolved.</div>
        }
        @if (_isAuthenticated && !string.IsNullOrEmpty(_authenticatedUserName))
        {
            <div class="fmc-logged-in-banner w-100 mb-4">
                <span>Signed in as <strong>@_authenticatedUserName</strong></span>
                <button class="fmc-signout-btn" @onclick="Logout">Sign Out</button>
            </div>
        }

        @if (_isRateLimited)
        {
            <div class="fmc-rate-limit-alert w-100 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" height="18" width="18" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0;"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                <div class="fmc-rate-limit-body">
                    <div class="fmc-rate-limit-title">Too many attempts</div>
                    <div class="fmc-rate-limit-desc">Try again in <strong>@_rateLimitRemaining</strong> second@(_rateLimitRemaining != 1 ? "s" : "")</div>
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="fmc-login-error w-100 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" height="16" width="16" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0;"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                <span>@_errorMessage</span>
            </div>
        }

        <EditForm Model="@_model" OnValidSubmit="HandleLoginAsync" Context="EditFormContext" FormName="LoginForm" class="w-100">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="_model!.Identifier" For="@(() => _model!.Identifier)" 
                          Label="Username or Email" Variant="Variant.Outlined" FullWidth="true" 
                          Class="mb-3" autocomplete="username" Disabled="@_isLoading" />

            <MudTextField @bind-Value="_model!.Password" For="@(() => _model.Password)" 
                          Label="Password" Variant="Variant.Outlined" FullWidth="true" 
                          InputType="@_passwordInput" Class="mb-1" Disabled="@_isLoading"
                          Adornment="Adornment.End" AdornmentIcon="@_passwordIcon" 
                          OnAdornmentClick="TogglePasswordVisibility" AdornmentAriaLabel="Show Password" 
                          autocomplete="current-password" />

            <div class="d-flex justify-space-between align-center w-100 mb-4">
                <MudCheckBox @bind-Value="_model!.RememberMe" Label="Remember me" 
                             Color="Color.Primary" Dense="true" Disabled="@_isLoading" />
                
                @if (!_isLoading)
                {
                    <MudLink href="/forgot-password" Underline="Underline.None" Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary);font-weight:600;">Forgot password?</MudLink>
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Forgot password?</MudText>
                }
            </div>

            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Dark" 
                       FullWidth="true" Size="Size.Large" Disabled="@_isLoading" 
                       Style="border-radius: 8px; height: 50px; font-weight: 700; letter-spacing: 0.03em; text-transform: uppercase;">
                @if (_isLoading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Signing in...</MudText>
                }
                else
                {
                    <MudText>Log In</MudText>
                }
            </MudButton>

            <div class="d-flex justify-center mt-6">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Contact your organization administrator for account creation.</MudText>
            </div>
        </EditForm>
    </MudCard>
    }
</div>

@code {
    [SupplyParameterFromForm]
    private LoginRequestDto? _model { get; set; }
    
    private bool _isLoading = false;
    private string _errorMessage = "";
    private bool _isRateLimited = false;
    private DateTime _rateLimitExpiresAt;
    private int _rateLimitRemaining => Math.Max(0, (int)(_rateLimitExpiresAt - DateTime.UtcNow).TotalSeconds);
    private Timer? _countdownTimer;

    private bool _showMaintenance;
    private string _maintenanceMsg = "";
    private bool _passwordVisibility;
    private InputType _passwordInput = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;
    private bool _isAuthenticated;
    private string _authenticatedUserName = "";
    private bool _showMaintenanceWarning;
    [Inject] private HttpClient HttpClient { get; set; } = default!;

    [SupplyParameterFromQuery]
    public string? maint { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _model ??= new();
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
            _authenticatedUserName = _isAuthenticated ? authState.User.Identity?.Name ?? "" : "";

            // Check maintenance state
            string? maintMsg = null;
            try
            {
                var resp = await HttpClient.GetAsync($"api/system/maintenance?_t={DateTime.UtcNow.Ticks}");
                if (resp.IsSuccessStatusCode)
                {
                    var json = await resp.Content.ReadAsStringAsync();
                    var status = System.Text.Json.JsonSerializer.Deserialize<MaintenanceStatusDto>(json,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    if (status is { IsActive: true }) maintMsg = status.Message;
                }
            }
            catch { }

            if (maint == "1" || maintMsg != null)
            {
                _maintenanceMsg = maintMsg ?? "System is undergoing scheduled maintenance.";
                _showMaintenance = true;
                return;
            }

            // Already authenticated non-admin with active maintenance → show maintenance page
            if (_isAuthenticated && maintMsg != null)
            {
                _maintenanceMsg = maintMsg;
                _showMaintenance = true;
                return;
            }

            // Already authenticated SuperAdmin → redirect to dashboard
            if (_isAuthenticated && authState.User.IsInRole("SuperAdmin"))
            {
                NavigationManager.NavigateTo("/", forceLoad: true);
                return;
            }

            _showMaintenanceWarning = maintMsg != null;
        }
        catch { }
    }

    private void TogglePasswordVisibility()
    {
        if (_passwordVisibility)
        {
            _passwordVisibility = false;
            _passwordIcon = Icons.Material.Filled.VisibilityOff;
            _passwordInput = InputType.Password;
        }
        else
        {
            _passwordVisibility = true;
            _passwordIcon = Icons.Material.Filled.Visibility;
            _passwordInput = InputType.Text;
        }
    }
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private async Task HandleLoginAsync()
    {
        if (_isLoading) return;
        _isLoading = true;
        _errorMessage = "";
        _isRateLimited = false;

        try
        {
            var (result, statusCode, retryAfter, remainingAttempts) = await AuthService.Login(_model!);
            if (result != null)
            {
                // Check if maintenance is active — if so, reload /login to show maintenance page
                try
                {
                    var resp = await HttpClient.GetAsync($"api/system/maintenance?_t={DateTime.UtcNow.Ticks}");
                    if (resp.IsSuccessStatusCode)
                    {
                        var json = await resp.Content.ReadAsStringAsync();
                        var status = System.Text.Json.JsonSerializer.Deserialize<MaintenanceStatusDto>(json,
                            new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                        if (status is { IsActive: true })
                        {
                            NavigationManager.NavigateTo("/login?maint=1", forceLoad: true);
                            return;
                        }
                    }
                }
                catch { }
                NavigationManager.NavigateTo(string.IsNullOrEmpty(ReturnUrl) ? "/" : ReturnUrl, forceLoad: true);
            }
            else if (statusCode == HttpStatusCode.TooManyRequests)
            {
                _isRateLimited = true;
                _rateLimitExpiresAt = DateTime.UtcNow.AddSeconds(retryAfter > 0 ? retryAfter : 60);
                StartCountdown();
            }
            else
            {
                _errorMessage = remainingAttempts > 0
                    ? $"Invalid email or password. {remainingAttempts} attempt{(remainingAttempts != 1 ? "s" : "")} remaining."
                    : "Invalid email or password.";
            }
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void StartCountdown()
    {
        _countdownTimer?.Dispose();
        _countdownTimer = new Timer(async _ =>
        {
            if (_rateLimitRemaining <= 0)
            {
                _isRateLimited = false;
                _countdownTimer?.Dispose();
            }
            await InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    private async Task Logout()
    {
        await AuthService.Logout("current");
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        _countdownTimer?.Dispose();
    }
}
