@using FMC.Shared.Auth
<div class="fmc-nav-container">
    <div class="fmc-nav-list">
        @* ── CORE SUITE ── *@
        <div class="fmc-nav-group-label">CORE SUITE</div>
        <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard" Class="fmc-nav-link" title="Dashboard">Dashboard</MudNavLink>
        <MudNavLink Href="transactions" Icon="@Icons.Material.Filled.AccountBalanceWallet" Class="fmc-nav-link" title="View All Transactions">Transactions</MudNavLink>
        <MudNavLink Href="accounts" Icon="@Icons.Material.Filled.CreditCard" Class="fmc-nav-link" title="Manage Accounts">Accounts</MudNavLink>
        <MudNavLink Href="reports" Icon="@Icons.Material.Filled.Insights" Class="fmc-nav-link" title="Financial Reports">Reports</MudNavLink>

        <AuthorizeView Roles="@($"{Roles.SuperAdmin},{Roles.CEO},{Roles.Maker},{Roles.Approver},{Roles.SuperAdminApprover}")">
            <Authorized>
                <MudNavLink Href="admin/audit" Icon="@Icons.Material.Filled.Shield" Class="fmc-nav-link" title="Audit Intelligence">Audit Intelligence</MudNavLink>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="@($"{Roles.CEO},{Roles.Approver},{Roles.SuperAdminApprover},{Roles.Maker},{Roles.SuperAdmin}")">
            <Authorized>
                <MudNavLink Href="/pending-requests" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PendingActions" Class="fmc-nav-link" title="Pending Requests">Pending Requests</MudNavLink>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="@Roles.SuperAdmin">
            <Authorized>
                <div class="fmc-nav-group-divider"></div>
                <div class="fmc-nav-group-label">ADMINISTRATION</div>

                <MudNavLink Href="admin/docs" Icon="@Icons.Material.Filled.LibraryBooks" Class="fmc-nav-link" title="Documentation">Documentation</MudNavLink>
                <MudNavLink Href="admin/system" Icon="@Icons.Material.Filled.Tune" Class="fmc-nav-link" title="System Controls">System Controls</MudNavLink>
            </Authorized>
        </AuthorizeView>

    </div>
</div>

<style>
    .fmc-nav-container { 
        height: 100%; display: flex; flex-direction: column; 
        background-color: var(--mud-palette-surface);
        padding: 8px 0 0 0;
        overflow: hidden;
    }

    .fmc-nav-list {
        display: flex;
        flex-direction: column;
        justify-content: space-evenly;
        min-height: 100%;
        overflow: hidden;
        padding: 4px 0;
    }

    .fmc-nav-group-label { 
        padding: 4px 24px 2px 24px; font-size: 0.55rem; font-weight: 900; 
        color: var(--mud-palette-text-secondary); opacity: 0.4; letter-spacing: 0.15em;
        text-transform: uppercase;
        flex-shrink: 0;
    }

    .fmc-nav-group-divider { margin: 2px 24px; height: 1px; background: var(--mud-palette-divider); opacity: 0.3; flex-shrink: 0; }

    .fmc-nav-link { 
        margin: 0 10px; border-radius: 8px !important; 
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1) !important;
        flex: 1 1 0 !important;
        display: flex !important; align-items: center !important;
        color: var(--mud-palette-text-secondary) !important;
        font-weight: 600 !important; font-size: 0.78rem !important;
    }

    .fmc-nav-link:hover { 
        background: rgba(184, 134, 11, 0.08) !important;
        color: #b8860b !important;
    }

    .mud-nav-link.active { 
        background: linear-gradient(90deg, rgba(184, 134, 11, 0.1) 0%, rgba(184, 134, 11, 0) 100%) !important;
        color: #b8860b !important;
        font-weight: 800 !important;
        position: relative;
    }

    .mud-nav-link.active::before {
        content: ""; position: absolute; left: 0; top: 6px; bottom: 6px; width: 3px;
        background: #b8860b; border-radius: 0 3px 3px 0;
        box-shadow: 2px 0 6px rgba(184, 134, 11, 0.4);
    }

    .fmc-nav-link .mud-nav-link-icon-default { 
        margin-right: 12px !important; transition: transform 0.2s;
        color: inherit !important;
    }

    .fmc-nav-link:hover .mud-nav-link-icon-default { transform: translateX(2px); }

</style>
