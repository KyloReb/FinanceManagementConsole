@page "/settings"
@attribute [Authorize]
@using MudBlazor
@inject ThemeService ThemeService
@inject IDialogService DialogService
@using FMC.Components.Shared.Dialogs

<PageTitle>Settings</PageTitle>

<div class="fmc-settings-root @(ThemeService.IsDarkMode ? "fmc-dark-mode" : "fmc-light-mode")">
<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <div class="d-flex align-center mb-8">
        <div class="fmc-settings-bar mr-4"></div>
        <MudText Typo="Typo.h4" Class="fmc-settings-title">Account Settings</MudText>
    </div>

    <MudGrid Spacing="6">
        @* Display Preferences Section *@
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6 d-flex flex-column fmc-settings-card" Elevation="0" Style="height: 100%;">
                <div class="d-flex align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Palette" Color="Color.Primary" Class="mr-2" />
                    <MudText Typo="Typo.h6" Class="fmc-settings-section-title">Display Preferences</MudText>
                </div>
                <MudDivider Class="mb-6" />
                
                <MudText Typo="Typo.subtitle2" Class="mb-1">Interface Theme</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">Customize the visual appearance of your dashboard.</MudText>
                
                <MudSpacer />
                
                <div class="d-flex align-center justify-space-between mt-auto pa-3 rounded-lg" style="background-color: var(--mud-palette-background-grey);">
                    <div class="d-flex align-center">
                        <MudIcon Icon="@(ThemeService.IsDarkMode ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)" 
                                 Color="@(ThemeService.IsDarkMode ? Color.Primary : Color.Warning)" 
                                 Class="mr-3" />
                        <MudText Typo="Typo.body2">@(ThemeService.IsDarkMode ? "Dark Mode Active" : "Light Mode Active")</MudText>
                    </div>
                    <MudSwitch @bind-Value="@ThemeService.IsDarkMode" 
                               Color="Color.Primary" 
                               UnCheckedColor="Color.Default" />
                </div>
            </MudPaper>
        </MudItem>

        @* User Profile Section *@
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-6 d-flex flex-column fmc-settings-card" Elevation="0" Style="height: 100%;">
                <div class="d-flex align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Class="mr-2" />
                    <MudText Typo="Typo.h6" Class="fmc-settings-section-title">User Profile</MudText>
                </div>
                <MudDivider Class="mb-6" />
                
                <MudText Typo="Typo.subtitle2" Class="mb-1">Personal Details</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">Manage your legal name, email address, and contact information for your financial entity.</MudText>
                
                <MudSpacer />
                
                <MudButton Variant="Variant.Filled" FullWidth="true" Href="/profile" 
                           StartIcon="@Icons.Material.Filled.Edit" Class="fmc-btn-premium">
                    Edit Profile Information
                </MudButton>
            </MudPaper>
        </MudItem>

        @* Security & Privacy Section *@
        <MudItem xs="12">
            <MudPaper Class="pa-6 fmc-settings-card" Elevation="0">
                <div class="d-flex align-center mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Primary" Class="mr-2" />
                    <MudText Typo="Typo.h6" Class="fmc-settings-section-title">Security & Privacy</MudText>
                </div>
                <MudDivider Class="mb-6" />
                
                <MudGrid>
                    <MudItem xs="12" md="8">
                        <MudText Typo="Typo.subtitle2" Class="mb-1">Authentication Security</MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Configure your password, multi-factor authentication (OTP), and track your active login sessions for enhanced security.</MudText>
                    </MudItem>
                    <MudItem xs="12" md="4" Class="d-flex align-center justify-md-end">
                        <MudButton Variant="Variant.Filled" Class="fmc-btn-premium" 
                                   StartIcon="@Icons.Material.Filled.Lock" OnClick="OpenChangePasswordDialog">Change Password</MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>
</div>

@code {
    private void OpenChangePasswordDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true, BackdropClick = false };
        DialogService.ShowAsync<ChangePasswordDialog>("Change Password", options);
    }
}
