    #region Batch Breakdown

    /// <summary>
    /// Attempts to deserialize the audit details JSON into a <see cref="BatchDetail"/>
    /// object for individual item rendering.
    /// </summary>
    private bool TryGetBatchData(out BatchDetail? data)
    {
        data = null;
        if (string.IsNullOrWhiteSpace(Log.Details) || !Log.Details.Trim().StartsWith("{")) return false;
        
        try {
            data = System.Text.Json.JsonSerializer.Deserialize<BatchDetail>(Log.Details,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            return data != null;
        } catch { return false; }
    }

    #endregion

    #region Account Resolution

    /// <summary>
    /// Masks an account number by showing the first 6 and last 4 digits,
    /// padding the middle with asterisks. Short values pass through unchanged.
    /// </summary>
    private static string MaskAccount(string? account)
    {
        if (string.IsNullOrEmpty(account)) return "N/A";
        if (account.Length <= 10) return account;
        return $"{account[..6]}{new string('*', account.Length - 10)}{account[^4..]}";
    }

    /// <summary>
    /// Resolves a card number from the audit entry, checking batch data,
    /// JSON details, label text, and entity name in order of priority.
    /// </summary>
    private string GetCardNumber()
    {
        // Priority 1: batch payload contains explicit card numbers
        if (TryGetBatchData(out var batchData) && batchData?.Items != null && batchData.Items.Any())
            return MaskAccount(batchData.Items.First().CardNumber);
        
        // Priority 2: single-transaction JSON details
        if (!string.IsNullOrWhiteSpace(Log.Details) && Log.Details.Trim().StartsWith("{"))
        {
            try {
                using var doc = System.Text.Json.JsonDocument.Parse(Log.Details);
                if (doc.RootElement.TryGetProperty("cardNumber", out var prop))
                    return MaskAccount(prop.GetString());
                if (doc.RootElement.TryGetProperty("accountNumber", out var propAcc))
                    return MaskAccount(propAcc.GetString());
            } catch { }
        }

        // Priority 3: label that looks like a numeric account identifier
        if (!string.IsNullOrWhiteSpace(Log.Label) && Log.Label.Length > 10)
        {
            var label = Log.Label.Replace(" ", "");
            if (label.All(c => char.IsDigit(c) || c == '*' || c == '-'))
                return MaskAccount(Log.Label);
        }
            
        // Priority 4: fall back to entity name or generic placeholder
        var name = Log.EntityName?.Replace("Wallet: ", "");
        return string.IsNullOrWhiteSpace(name) || name == "N/A" ? "Cardholder" : name; 
    }

    /// <summary>
    /// Resolves the organization identity, preferring JSON-embedded account data
    /// over the raw Organization field.
    /// </summary>
    private string GetOrgIdentity()
    {
        if (!string.IsNullOrWhiteSpace(Log.Details) && Log.Details.Trim().StartsWith("{"))
        {
            try {
                using var doc = System.Text.Json.JsonDocument.Parse(Log.Details);
                if (doc.RootElement.TryGetProperty("orgAccountNumber", out var prop))
                    return MaskAccount(prop.GetString());
                if (doc.RootElement.TryGetProperty("sourceAccountNumber", out var propSrc))
                    return MaskAccount(propSrc.GetString());
            } catch { }
        }
        
        return !string.IsNullOrWhiteSpace(Log.Organization) ? Log.Organization : "Corporate Liquidity";
    }

    /// <summary>
    /// Returns a deterministic, stable account number derived from the given
    /// identifier. If a valid account string already exists, it is preserved;
    /// otherwise a synthetic one is generated for consistent masking across sessions.
    /// </summary>
    private static string GetStableAccountNumber(string id, string? currentAcct)
    {
        if (!string.IsNullOrWhiteSpace(currentAcct) && currentAcct != "N/A" && currentAcct.Length > 10)
            return currentAcct;
        var rnd = new Random(id.GetHashCode());
        long r1 = rnd.Next(10000, 99999);
        long r2 = rnd.Next(100000, 999999);
        return "63641" + r1.ToString("D5") + r2.ToString("D6");
    }

    #endregion

    #region Models

    /// <summary>
    /// Deserialized representation of a batch allotment payload stored in the
    /// audit log's Details JSON field.
    /// </summary>
    public class BatchDetail
    {
        /// <summary>Whether the batch is a credit (true) or debit (false) operation.</summary>
        public bool IsCredit { get; set; }

        /// <summary>Individual cardholder items within the batch.</summary>
        public List<BatchItem> Items { get; set; } = new();
    }

    /// <summary>Individual line item within a <see cref="BatchDetail"/>.</summary>
    public class BatchItem
    {
        /// <summary>The masked card/account number of the cardholder.</summary>
        public string? CardNumber { get; set; }

        /// <summary>The monetary amount for this line item.</summary>
        public decimal Amount { get; set; }

        /// <summary>The display name of the subscriber.</summary>
        public string? Subscriber { get; set; }
    }

    #endregion
