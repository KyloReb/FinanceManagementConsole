@page "/verify-email"
@layout Layout.BlankLayout
@attribute [AllowAnonymous]
@inject NavigationManager NavigationManager

<PageTitle>Verify Email</PageTitle>

<div class="d-flex justify-center align-center py-8" style="min-height: 100vh; background-color: var(--mud-palette-background);">
    <MudCard Elevation="4" Class="pa-8 d-flex flex-column align-center mx-4" Style="width: 100%; max-width: 450px; border-radius: 12px;">
        <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
        <MudText Typo="Typo.h5" Class="mb-2 fw-bold">Verify Your Email</MudText>
        <MudAlert Severity="Severity.Info">Verification is disabled during architecture migration.</MudAlert>
        <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => NavigationManager.NavigateTo("/login"))" Class="mt-4">Back to Login</MudButton>
    </MudCard>
</div>
