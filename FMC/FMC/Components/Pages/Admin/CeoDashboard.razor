@page "/ceo/dashboard"
@using FMC.Shared.Auth
@using FMC.Shared.DTOs.User
@using FMC.Shared.DTOs.Organization
@using FMC.Services.Api
@attribute [Authorize(Roles = Roles.CEO)]
@inject OrganizationApiService OrgService
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>CEO Command Center - FMC</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mt-md-8 mb-12">
    @* PLATINUM CEO HEADER *@
    <div class="fmc-ceo-header mb-6 mb-md-10">
        <div class="d-flex align-center">
            <div class="fmc-ceo-accent mr-3 mr-md-5"></div>
            <div class="d-flex flex-column">
                <MudText Typo="Typo.h4" Class="fmc-ceo-hero-text d-none d-md-block">Corporate Oversight</MudText>
                <MudText Typo="Typo.h5" Class="fmc-ceo-hero-text d-block d-md-none">Corporate Oversight</MudText>
                <MudText Typo="Typo.subtitle1" Class="fmc-ceo-subtitle d-none d-md-block">Financial Velocity & Workforce Liquidity</MudText>
                <MudText Typo="Typo.caption" Class="fmc-ceo-subtitle d-block d-md-none" Style="font-weight:700;">Financial Velocity & Workforce Liquidity</MudText>
            </div>
        </div>
        <div class="d-none d-sm-flex gap-3">
            <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Assessment" 
                       Style="border-radius: 12px; font-weight: 600; text-transform:none;">
                Company Report
            </MudButton>
        </div>
    </div>

    @* KPI POWER CARDS *@
    <MudGrid Spacing="3" Class="mb-8">
        <MudItem xs="12" sm="6" md="4">
            <div class="fmc-ceo-card accent-primary">
                <MudText Typo="Typo.subtitle2" Class="fmc-ceo-card-label">CORPORATE LIQUIDITY</MudText>
                <MudText Typo="Typo.h3" Class="fmc-ceo-kpi-val d-none d-sm-block">@(_orgMetrics?.TotalBalance.ToString("C") ?? "---")</MudText>
                <MudText Typo="Typo.h4" Class="fmc-ceo-kpi-val d-block d-sm-none">@(_orgMetrics?.TotalBalance.ToString("C") ?? "---")</MudText>
                <div class="fmc-ceo-card-icon"><MudIcon Icon="@Icons.Material.Filled.AccountBalance" /></div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <div class="fmc-ceo-card accent-info">
                <MudText Typo="Typo.subtitle2" Class="fmc-ceo-card-label">TOTAL WORKFORCE</MudText>
                <MudText Typo="Typo.h3" Class="fmc-ceo-kpi-val d-none d-sm-block">@(_orgMetrics?.UserCount ?? 0)</MudText>
                <MudText Typo="Typo.h4" Class="fmc-ceo-kpi-val d-block d-sm-none">@(_orgMetrics?.UserCount ?? 0)</MudText>
                <div class="fmc-ceo-card-icon"><MudIcon Icon="@Icons.Material.Filled.Groups" /></div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="12" md="4">
            <div class="fmc-ceo-card accent-success">
                <MudText Typo="Typo.subtitle2" Class="fmc-ceo-card-label">24H SETTLEMENT VOLUME</MudText>
                <MudText Typo="Typo.h3" Class="fmc-ceo-kpi-val d-none d-sm-block">@(_orgMetrics?.DailyVolume.ToString("C") ?? "---")</MudText>
                <MudText Typo="Typo.h4" Class="fmc-ceo-kpi-val d-block d-sm-none">@(_orgMetrics?.DailyVolume.ToString("C") ?? "---")</MudText>
                <div class="fmc-ceo-card-icon"><MudIcon Icon="@Icons.Material.Filled.Insights" /></div>
            </div>
        </MudItem>
    </MudGrid>

    @* CORPORATE VELOCITY CHART *@
    <MudGrid Class="mb-8">
        <MudItem xs="12" lg="8">
            <MudPaper Elevation="0" Class="fmc-ceo-surface pa-4 pa-md-8 h-100">
                <div class="d-flex align-center justify-space-between mb-8 flex-wrap gap-4">
                    <div class="d-flex align-center">
                        <div class="fmc-ceo-table-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Info" /></div>
                        <div>
                            <MudText Typo="Typo.h6" Style="font-weight: 800;">Corporate Cashflow Trend</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Historical liquidity overview for the network</MudText>
                        </div>
                    </div>
                    <div class="fmc-ceo-timeframe-selector">
                        <MudButton OnClick="@(() => SetTimeframe("Daily"))" Class="@("fmc-time-btn " + (_selectedTimeframe == "Daily" ? "active" : ""))">2W</MudButton>
                        <MudButton OnClick="@(() => SetTimeframe("Monthly"))" Class="@("fmc-time-btn " + (_selectedTimeframe == "Monthly" ? "active" : ""))">1Y</MudButton>
                        <MudButton OnClick="@(() => SetTimeframe("Quarterly"))" Class="@("fmc-time-btn " + (_selectedTimeframe == "Quarterly" ? "active" : ""))">ALL</MudButton>
                    </div>
                </div>
                
                @if (_chartLoading)
                {
                    <div class="d-flex flex-column align-center justify-center" style="height:350px;">
                        <MudProgressCircular Color="Color.Info" Indeterminate="true" Class="mb-4" />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Synthesizing corporate metrics...</MudText>
                    </div>
                }
                else
                {
                    <div class="fmc-ceo-chart-wrap" style="height:350px; width:100%;">
                        <MudChart T="double" ChartType="ChartType.Line" ChartSeries="@_lineChartSeries" 
                                  @attributes="@(new Dictionary<string, object> { { "XAxisLabels", _lineChartLabels } })" 
                                  Width="100%" Height="350px" 
                                  ChartOptions="@_chartOptions" />
                    </div>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="4">
            <MudPaper Elevation="0" Class="fmc-ceo-surface pa-4 pa-md-8 h-100">
                <div class="d-flex align-center mb-6">
                    <div class="fmc-ceo-table-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Info" /></div>
                    <MudText Typo="Typo.h6" Style="font-weight: 800;">Recent Velocity</MudText>
                </div>
                <div class="fmc-ceo-activity-feed">
                    @if (!_recentAuditLogs.Any())
                    {
                        <div class="pa-10 text-center mud-text-secondary">
                            <MudIcon Icon="@Icons.Material.Filled.EventNote" Style="opacity:0.2;" Size="Size.Large" />
                            <MudText Typo="Typo.caption" Class="d-block mt-2">No recent corporate movements</MudText>
                        </div>
                    }
                    else
                    {
                        @foreach (var log in _recentAuditLogs.Take(8))
                        {
                            <div class="fmc-feed-item">
                                <div class="feed-indicator @(log.Action == "CREDIT" ? "success" : "error")"></div>
                                <div class="d-flex justify-space-between align-start w-100">
                                    <div class="d-flex flex-column">
                                        <MudText Typo="Typo.body2" Style="font-weight:700; line-height:1.2;">@log.EntityName</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size:0.65rem;">@log.CreatedAt.ToString("MMM dd, HH:mm")</MudText>
                                    </div>
                                    <MudText Typo="Typo.body2" Style="font-weight:900; font-family:'JetBrains Mono';"
                                             Color="@(log.Action == "CREDIT" ? Color.Success : Color.Error)">
                                        @(log.Action == "CREDIT" ? "+" : "-")@log.Amount?.ToString("C0")
                                    </MudText>
                                </div>
                            </div>
                        }
                    }
                </div>
                <MudButton Variant="Variant.Text" Color="Color.Info" FullWidth="true" 
                           Style="text-transform:none; font-weight:700; margin-top:16px;">View Forensic Ledger</MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* AFFILIATED USER REPOSITORY *@
    <MudPaper Elevation="0" Class="fmc-ceo-surface">
        <div class="fmc-ceo-table-header flex-wrap gap-4">
            <div class="d-flex align-center">
                <div class="fmc-ceo-table-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.ContactPage" Color="Color.Info" /></div>
                <div>
                    <MudText Typo="Typo.h6" Style="font-weight: 800;">Affiliated User Directory</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-none d-sm-block">Execute financial adjustments for your organization's staff</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block d-sm-none" Style="font-size:0.65rem;">Manage staff financial adjustments</MudText>
                </div>
            </div>
            <div class="fmc-ceo-search-container">
                <MudTextField @bind-Value="_searchString" Placeholder="Filter directory..." 
                               Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                               Variant="Variant.Outlined" Margin="Margin.Dense" Class="fmc-ceo-search" />
            </div>
        </div>

        @* DESKTOP TABLE *@
        <div class="d-none d-md-block">
            <MudTable Items="@_affiliatedUsers" Loading="@_loading" Hover="true" Elevation="0" Class="fmc-ceo-table" Filter="@UserFilter">
                <HeaderContent>
                    <MudTh>PERSONNEL</MudTh>
                    <MudTh>EMAIL</MudTh>
                    <MudTh>USER WALLET</MudTh>
                    <MudTh Style="text-align:right;">FINANCIAL ACTIONS</MudTh>
                </HeaderContent>
                <RowTemplate Context="user">
                    <MudTd>
                        <div class="d-flex align-center gap-3">
                            <MudAvatar Color="Color.Info" Size="Size.Medium" Style="font-weight:800;">
                                @(user.FirstName?[0])@(user.LastName?[0])
                            </MudAvatar>
                            <div>
                                <MudText Style="font-weight:800;">@user.DisplayName</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@user.Roles.FirstOrDefault()</MudText>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd>@user.Email</MudTd>
                    <MudTd>
                        <MudText Style="font-weight:900; font-family:'JetBrains Mono', monospace;" 
                                 Color="@(user.Balance < 0 ? Color.Error : Color.Info)">
                            @user.Balance.ToString("C")
                        </MudText>
                    </MudTd>
                    <MudTd Style="text-align:right;">
                        <div class="d-flex justify-end gap-2">
                            <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="@(() => OpenAdjustmentDialog(user, true))"
                                       Style="border-radius:8px; text-transform:none; font-weight:700;">Credit</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Remove"
                                       OnClick="@(() => OpenAdjustmentDialog(user, false))"
                                       Style="border-radius:8px; text-transform:none; font-weight:700;">Debit</MudButton>
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>

        @* MOBILE LIST *@
        <div class="d-block d-md-none pa-2">
            @if (_loading)
            {
                <div class="d-flex justify-center pa-10">
                    <MudProgressCircular Color="Color.Info" Indeterminate="true" />
                </div>
            }
            else
            {
                @foreach (var user in _affiliatedUsers.Where(u => UserFilter(u)))
                {
                    <div class="fmc-ceo-mobile-user-card mb-2 pa-4">
                        <div class="d-flex justify-space-between align-center mb-3">
                            <div class="d-flex align-center gap-3">
                                <MudAvatar Color="Color.Info" Size="Size.Small" Style="font-weight:800;">
                                    @(user.FirstName?[0])@(user.LastName?[0])
                                </MudAvatar>
                                <div class="d-flex flex-column">
                                    <MudText Typo="Typo.body2" Style="font-weight:800; line-height:1.1;">@user.DisplayName</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size:0.6rem;">@user.Email</MudText>
                                </div>
                            </div>
                            <div class="text-right">
                                <MudText Typo="Typo.body2" Style="font-weight:900; font-family:'JetBrains Mono', monospace;" 
                                         Color="@(user.Balance < 0 ? Color.Error : Color.Info)">
                                    @user.Balance.ToString("C")
                                </MudText>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="@(() => OpenAdjustmentDialog(user, true))"
                                       Style="border-radius:8px; text-transform:none; font-weight:700; height:36px;">Credit</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.Remove"
                                       OnClick="@(() => OpenAdjustmentDialog(user, false))"
                                       Style="border-radius:8px; text-transform:none; font-weight:700; height:36px;">Debit</MudButton>
                        </div>
                    </div>
                }
            }
        </div>
    </MudPaper>
</MudContainer>

<style>
    .fmc-ceo-header { display: flex; align-items: center; justify-content: space-between; }
    .fmc-ceo-accent { width: 6px; height: 48px; background: var(--mud-palette-info); border-radius: 4px; }
    .fmc-ceo-hero-text { font-weight: 900; letter-spacing: -0.04em; color: var(--mud-palette-text-primary); }
    .fmc-ceo-subtitle { color: var(--mud-palette-text-secondary); opacity: 0.8; font-weight: 500; }

    .fmc-ceo-card {
        padding: 32px; border-radius: 24px; background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider); position: relative; overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }
    .fmc-ceo-card-label { letter-spacing: 0.1em; opacity: 0.6; font-weight: 800; font-size: 0.7rem; }
    .fmc-ceo-kpi-val { font-weight: 900; margin-top: 8px; font-family: 'JetBrains Mono', monospace; }
    .fmc-ceo-card-icon { position: absolute; right: -8px; top: -8px; opacity: 0.05; font-size: 6rem !important; }
    
    .fmc-ceo-card.accent-primary { border-left: 6px solid var(--mud-palette-primary); }
    .fmc-ceo-card.accent-info { border-left: 6px solid var(--mud-palette-info); }
    .fmc-ceo-card.accent-success { border-left: 6px solid var(--mud-palette-success); }

    .fmc-ceo-surface { border-radius: 20px; border: 1px solid var(--mud-palette-divider); background: var(--mud-palette-surface); overflow: hidden; }
    .fmc-ceo-table-header { padding: 24px 32px; display: flex; align-items: center; justify-content: space-between; background: var(--mud-palette-background-grey); border-bottom: 1px solid var(--mud-palette-divider); }
    .fmc-ceo-table-icon { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; background: rgba(var(--mud-palette-info-rgb), 0.1); border-radius: 12px; }
    .fmc-ceo-search { border-radius: 10px !important; background: var(--mud-palette-surface) !important; }

    .fmc-ceo-timeframe-selector { display: flex; gap: 4px; background: var(--mud-palette-background-grey); padding: 4px; border-radius: 12px; }
    .fmc-time-btn { border-radius: 10px !important; font-weight: 800 !important; font-size: 0.65rem !important; min-width: 50px !important; color: var(--mud-palette-text-secondary) !important; }
    .fmc-time-btn.active { background: var(--mud-palette-surface) !important; color: var(--mud-palette-info) !important; box-shadow: var(--mud-elevation-2); }
    
    .fmc-ceo-activity-feed { display: flex; flex-direction: column; gap: 12px; }
    .fmc-feed-item { display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 12px; background: var(--mud-palette-background-grey); position: relative; overflow: hidden; }
    .feed-indicator { position: absolute; left: 0; top: 0; bottom: 0; width: 4px; }
    .feed-indicator.success { background: var(--mud-palette-success); }
    .feed-indicator.error { background: var(--mud-palette-error); }

    .fmc-ceo-table .mud-th { font-weight: 800; color: var(--mud-palette-text-secondary); font-size: 0.65rem; letter-spacing: 0.08em; padding: 20px 24px; }
    .fmc-ceo-table .mud-td { padding: 20px 24px; border-bottom: 1px solid var(--mud-palette-divider); }

    .fmc-ceo-search-container { max-width: 300px; width: 100%; }
    .fmc-ceo-mobile-user-card { background: var(--mud-palette-background-grey); border-radius: 16px; border: 1px solid var(--mud-palette-divider); }

    @@media (max-width: 600px) {
        .fmc-ceo-card { padding: 20px; }
        .fmc-ceo-kpi-val { font-size: 1.5rem !important; }
        .fmc-ceo-search-container { max-width: 100%; }
        .fmc-ceo-table-header { padding: 16px; }
    }
</style>

@code {
    private List<UserDto> _affiliatedUsers = new();
    private List<FMC.Shared.DTOs.Admin.AuditLogDto> _recentAuditLogs = new();
    private OrganizationDashboardMetricsDto? _orgMetrics;
    private bool _loading = true;
    private bool _chartLoading = true;
    private string _searchString = "";
    private Guid _orgId;

    // Charting State
    private List<ChartSeries<double>> _lineChartSeries = new();
    private string[] _lineChartLabels = Array.Empty<string>();
    private string _selectedTimeframe = "Daily";
    private ChartOptions _chartOptions = new() { ChartPalette = new[] { "#3b82f6", "#10b981", "#8b5cf6" } };

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try 
        {
            _loading = true;
            _chartLoading = true;
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var orgIdClaim = authState.User.FindFirst("OrganizationId")?.Value;
            
            if (Guid.TryParse(orgIdClaim, out _orgId))
            {
                var metricsTask = OrgService.GetOrganizationMetricsAsync(_orgId);
                var usersTask = OrgService.GetUsersAsync(_orgId);
                var auditTask = OrgService.GetRecentAuditLogsAsync(20, "financial"); // Filtered by Org on Server

                await Task.WhenAll(metricsTask, usersTask, auditTask);

                _orgMetrics = await metricsTask;
                _affiliatedUsers = await usersTask;
                _recentAuditLogs = (await auditTask).ToList();

                PrepareLineChartData();
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to synchronize corporate data.", Severity.Error);
        }
        finally
        {
            _loading = false;
            _chartLoading = false;
        }
    }

    private void SetTimeframe(string timeframe)
    {
        _selectedTimeframe = timeframe;
        _chartLoading = true;
        PrepareLineChartData();
        _chartLoading = false;
        StateHasChanged();
    }

    private void PrepareLineChartData()
    {
        _lineChartSeries.Clear();
        int count = _selectedTimeframe switch { "Daily" => 14, "Monthly" => 12, "Quarterly" => 8, _ => 14 };
        DateTime now = DateTime.Today;
        
        var labels = new List<string>();
        var dataPoints = new double[count];
        
        double runningBalance = (double)(_orgMetrics?.TotalBalance ?? 0);

        for (int i = count - 1; i >= 0; i--)
        {
            DateTime start, end;
            string label;

            if (_selectedTimeframe == "Daily")
            {
                start = now.AddDays(-(count - 1 - i));
                end = start.AddDays(1);
                label = start.ToString("dd MMM");
            }
            else if (_selectedTimeframe == "Monthly")
            {
                start = new DateTime(now.Year, now.Month, 1).AddMonths(-(count - 1 - i));
                end = start.AddMonths(1);
                label = start.ToString("MMM");
            }
            else
            {
                start = new DateTime(now.Year, ((now.Month - 1) / 3) * 3 + 1, 1).AddMonths(-(count - 1 - i) * 3);
                end = start.AddMonths(3);
                label = $"Q{((start.Month - 1) / 3) + 1}'{start.ToString("yy")}";
            }

            labels.Insert(0, label);
            dataPoints[i] = runningBalance;

            // Trace movement backward
            var sliceLogs = _recentAuditLogs.Where(l => l.CreatedAt >= start && l.CreatedAt < end);
            double movement = (double)sliceLogs.Sum(l => l.Action == "DEBIT" ? -(l.Amount ?? 0) : (l.Amount ?? 0));
            runningBalance -= movement;
        }

        _lineChartLabels = labels.ToArray();
        _lineChartSeries.Add(new ChartSeries<double> { Name = "Liquidity", Data = dataPoints });
    }

    private bool UserFilter(UserDto user)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        if (user.DisplayName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (user.Email?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false) return true;
        return false;
    }

    private async Task OpenAdjustmentDialog(UserDto user, bool isCredit)
    {
        var parameters = new DialogParameters { ["User"] = user, ["IsCredit"] = isCredit };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<UserBalanceDialog>("Adjust Personal Ledger", parameters, options);
        var result = await dialog.Result;

        if (!result!.Canceled)
        {
            await LoadDataAsync();
        }
    }
}
