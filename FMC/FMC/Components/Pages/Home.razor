@page "/"
@using FMC.Shared.Auth
@using FMC.Shared.DTOs.Organization
@using FMC.Shared.DTOs.User
@inject AuthenticationStateProvider AuthProvider
@inject OrganizationApiService OrgService 
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <AuthorizeView Roles="@(Roles.SuperAdmin + "," + Roles.CEO)">
        <Authorized>
            @* ENTERPRISE COMMAND CENTER HEADER *@
            <MudItem xs="12" sm="8" Class="pb-2">
                <div class="d-flex align-center">
                    <div class="fmc-header-accent mr-5"></div>
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.h3" Class="fmc-hero-text">@(context.User.IsInRole(Roles.CEO) ? "Corporate Dashboard" : "Control Center")</MudText>
                        <MudText Typo="Typo.subtitle1" Class="fmc-subtitle">@(context.User.IsInRole(Roles.CEO) ? "Organization Capital & Workforce Oversight" : "System Health & Multi-Tenant Capital Oversight")</MudText>
                    </div>
                </div>
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-center justify-sm-end pb-2">
                <div class="d-flex gap-3 w-100 justify-sm-end">
                    @if (context.User.IsInRole(Roles.SuperAdmin))
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.CloudSync" 
                                   Class="fmc-header-btn secondary d-none d-md-flex">
                            Logs
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Href="/admin/organizations" 
                                   Class="fmc-header-btn primary w-100 w-sm-auto">
                            Provision Tenant
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Business" Href="/ceo/dashboard" 
                                   Class="fmc-header-btn primary w-100 w-sm-auto">
                            Global Overview
                        </MudButton>
                    }
                </div>
            </MudItem>

            <MudGrid Spacing="2" Class="mb-8">
                @* HIGH-LEVEL PERFORMANCE CARDS *@
                @if (context.User.IsInRole(Roles.SuperAdmin))
                {
                    <MudItem xs="6" sm="6" md="3">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">ACTIVE SUBSCRIBERS</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h3" Class="fmc-kpi-val" Style="font-weight: 900; line-height: 1;">@_organizations.Count</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Success" Style="font-weight: 700; margin-bottom: 2px;">+18% WoW</MudText>
                                </div>
                            </div>
                            <div class="fmc-card-icon-bg"><MudIcon Icon="@Icons.Material.Filled.CorporateFare" /></div>
                            <div class="fmc-card-progress primary"></div>
                        </div>
                    </MudItem>
                }
                else
                {
                    <MudItem xs="6" sm="6" md="3">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">AFFILIATED USERS</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h3" Class="fmc-kpi-val" Style="font-weight: 900; line-height: 1;">@(_organizations.FirstOrDefault()?.UserCount ?? 0)</MudText>
                                </div>
                            </div>
                            <div class="fmc-card-icon-bg"><MudIcon Icon="@Icons.Material.Filled.Groups" /></div>
                            <div class="fmc-card-progress primary"></div>
                        </div>
                    </MudItem>
                }
                <MudItem xs="6" sm="6" md="3">
                    <div class="fmc-glass-card">
                        <div class="fmc-card-content">
                            <MudText Typo="Typo.subtitle2" Class="fmc-card-label">AVAILABLE CAPITAL</MudText>
                            <div class="d-flex align-end gap-2 mt-1">
                                <MudText Typo="Typo.h4" Class="fmc-kpi-val fmc-responsive-val">@_organizations.Sum(o => o.TotalBalance).ToString("C0")</MudText>
                            </div>
                        </div>
                        <div class="fmc-card-icon-bg success"><MudIcon Icon="@Icons.Material.Filled.AccountBalance" /></div>
                        <div class="fmc-card-progress success"></div>
                    </div>
                </MudItem>
                <MudItem xs="6" sm="6" md="3">
                    <div class="fmc-glass-card">
                        <div class="fmc-card-content">
                            <MudText Typo="Typo.subtitle2" Class="fmc-card-label">NETWORK UPTIME</MudText>
                            <div class="d-flex align-end gap-2 mt-1">
                                <MudText Typo="Typo.h3" Class="fmc-kpi-val" Style="font-weight: 900; line-height: 1;">99.9%</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700; margin-bottom: 2px;">SECURE</MudText>
                            </div>
                        </div>
                        <div class="fmc-card-icon-bg info"><MudIcon Icon="@Icons.Material.Filled.FlashOn" /></div>
                        <div class="fmc-card-progress info"></div>
                    </div>
                </MudItem>
                <MudItem xs="6" sm="6" md="3">
                    <div class="fmc-glass-card">
                        <div class="fmc-card-content">
                            <MudText Typo="Typo.subtitle2" Class="fmc-card-label">LAST RECONCILIATION</MudText>
                            <div class="d-flex align-end gap-2 mt-1">
                                <MudText Typo="Typo.h3" Class="fmc-kpi-val" Style="font-weight: 900; line-height: 1;">@DateTime.Now.ToString("HH:mm")</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700; margin-bottom: 2px;">LIVE</MudText>
                            </div>
                        </div>
                        <div class="fmc-card-icon-bg warning"><MudIcon Icon="@Icons.Material.Filled.ManageHistory" /></div>
                        <div class="fmc-card-progress warning"></div>
                    </div>
                </MudItem>

                @* ── SYSTEM ALERT PANEL (only renders when issues exist) ── *@
                @if (!_alertsDismissed && _hasAlerts && !_loading)
                {
                    <MudItem xs="12">
                        <div class="fmc-alert-panel">
                            <div class="fmc-alert-header">
                                <div class="d-flex align-center gap-3">
                                    <div class="fmc-alert-icon-wrap">
                                        <MudIcon Icon="@Icons.Material.Filled.NotificationImportant" Color="Color.Warning" Size="Size.Small" />
                                    </div>
                                    <div>
                                        <MudText Typo="Typo.body1" Style="font-weight: 800; color: var(--mud-palette-warning);">System Alerts</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@_totalAlerts item@(_totalAlerts == 1 ? "" : "s") require your attention</MudText>
                                    </div>
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Default"
                                               OnClick="@(() => _alertsDismissed = true)"
                                               Style="margin: -4px -4px -4px 0;" />
                            </div>

                            <div class="fmc-alert-body">
                                @if (_zeroBalanceTenants.Any())
                                {
                                    <div class="fmc-alert-row fmc-alert-critical">
                                        <div class="fmc-alert-severity-bar"></div>
                                        <div class="fmc-alert-row-icon">
                                            <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Style="font-size: 1.1rem; color: var(--mud-palette-error);" />
                                        </div>
                                        <div class="fmc-alert-row-content">
                                            <div class="d-flex align-center flex-wrap gap-2">
                                                <span class="fmc-alert-badge fmc-badge-error">ZERO BALANCE</span>
                                                @foreach (var t in _zeroBalanceTenants.Take(3))
                                                {
                                                    <MudLink Href="@($"/admin/organizations/{t.Id}")" Class="fmc-alert-tenant-link">@t.Name</MudLink>
                                                }
                                                @if (_zeroBalanceTenants.Count > 3)
                                                {
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">+@(_zeroBalanceTenants.Count - 3) more</MudText>
                                                }
                                            </div>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                                @_zeroBalanceTenants.Count active tenant@(_zeroBalanceTenants.Count == 1 ? "" : "s") with depleted wallets — service may be impacted
                                            </MudText>
                                        </div>
                                        <MudTooltip Text="Credit wallet now">
                                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                                                       Style="text-transform:none; font-weight:700; border-radius:8px; white-space:nowrap;"
                                                       OnClick="@(() => OpenAdjustmentDialog(_zeroBalanceTenants.First(), true))">
                                                Resolve
                                            </MudButton>
                                        </MudTooltip>
                                    </div>
                                }

                                @if (_suspendedTenants.Any())
                                {
                                    <div class="fmc-alert-row fmc-alert-warning">
                                        <div class="fmc-alert-severity-bar fmc-bar-warning"></div>
                                        <div class="fmc-alert-row-icon">
                                            <MudIcon Icon="@Icons.Material.Filled.PauseCircle" Style="font-size: 1.1rem; color: var(--mud-palette-warning);" />
                                        </div>
                                        <div class="fmc-alert-row-content">
                                            <div class="d-flex align-center flex-wrap gap-2">
                                                <span class="fmc-alert-badge fmc-badge-warning">SUSPENDED</span>
                                                @foreach (var t in _suspendedTenants.Take(3))
                                                {
                                                    <MudLink Href="@($"/admin/organizations/{t.Id}")" Class="fmc-alert-tenant-link">@t.Name</MudLink>
                                                }
                                                @if (_suspendedTenants.Count > 3)
                                                {
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">+@(_suspendedTenants.Count - 3) more</MudText>
                                                }
                                            </div>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                                @_suspendedTenants.Count tenant@(_suspendedTenants.Count == 1 ? "" : "s") currently offline — access restricted
                                            </MudText>
                                        </div>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                                                   Style="text-transform:none; font-weight:700; border-radius:8px; white-space:nowrap;"
                                                   Href="/admin/organizations">
                                            Review
                                        </MudButton>
                                    </div>
                                }

                                @if (_noCeoTenants.Any())
                                {
                                    <div class="fmc-alert-row fmc-alert-info">
                                        <div class="fmc-alert-severity-bar fmc-bar-info"></div>
                                        <div class="fmc-alert-row-icon">
                                            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Style="font-size: 1.1rem; color: var(--mud-palette-info);" />
                                        </div>
                                        <div class="fmc-alert-row-content">
                                            <div class="d-flex align-center flex-wrap gap-2">
                                                <span class="fmc-alert-badge fmc-badge-info">NO CEO</span>
                                                @foreach (var t in _noCeoTenants.Take(3))
                                                {
                                                    <MudLink Href="@($"/admin/organizations/{t.Id}")" Class="fmc-alert-tenant-link">@t.Name</MudLink>
                                                }
                                                @if (_noCeoTenants.Count > 3)
                                                {
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">+@(_noCeoTenants.Count - 3) more</MudText>
                                                }
                                            </div>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                                @_noCeoTenants.Count tenant@(_noCeoTenants.Count == 1 ? "" : "s") without a designated executive
                                            </MudText>
                                        </div>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                                   Style="text-transform:none; font-weight:700; border-radius:8px; white-space:nowrap;"
                                                   Href="/admin/organizations">
                                            Assign
                                        </MudButton>
                                    </div>
                                }
                            </div>
                        </div>
                    </MudItem>
                }



                @* MAIN REPOSITORY TABLE *@
                <MudItem xs="12">
                    <MudPaper Elevation="0" Class="fmc-main-surface">
                        <div class="fmc-header-area">
                            <div class="d-flex align-center">
                                <div class="fmc-header-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Primary" /></div>
                                <div>
                                    <MudText Typo="Typo.h6" Style="font-weight: 800; letter-spacing: -0.01em;">Subscriber Wallet Repository</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Real-time ledger balances across all tenants</MudText>
                                </div>
                            </div>
                            <div style="width: 360px;">
                                <MudTextField @bind-Value="_searchString" Placeholder="Search by tenant or CEO..." 
                                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.FilterList" 
                                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="fmc-enterprise-search" />
                            </div>
                        </div>

                        @* ── DESKTOP TABLE (hidden on mobile) ── *@
                        <div class="fmc-desktop-table">
                            <MudTable Items="@_filteredOrgs" Hover="true" Elevation="0" Loading="@_loading" Class="fmc-premium-table">
                                <HeaderContent>
                                    <MudTh>TENANT ORGANIZATION</MudTh>
                                    <MudTh>STATUS</MudTh>
                                    <MudTh>LEDGER BALANCE</MudTh>
                                    <MudTh>USERS</MudTh>
                                    <MudTh Style="text-align:right;">ACTIONS</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="orgItem">
                                    <MudTd>
                                        <div class="d-flex align-center gap-3">
                                            <MudAvatar Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Medium" Style="background-color:var(--mud-palette-background-grey); font-weight:800;">
                                                @orgItem.Name?[0]
                                            </MudAvatar>
                                            <div>
                                                <MudText Style="font-weight:800;">@orgItem.Name</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">CEO: @(orgItem.CeoName ?? "Unassigned")</MudText>
                                            </div>
                                        </div>
                                    </MudTd>
                                    <MudTd>
                                        <div class="fmc-status-pill @(orgItem.IsActive ? "active" : "suspended")">
                                            <div class="fmc-pulse"></div>
                                            <span>@(orgItem.IsActive ? "OPERATIONAL" : "SUSPENDED")</span>
                                        </div>
                                    </MudTd>
                                    <MudTd>
                                        <MudText Style="font-weight:900; font-family:'JetBrains Mono',monospace;"
                                                 Color="@(orgItem.TotalBalance < 0 ? Color.Error : Color.Default)">
                                            @orgItem.TotalBalance.ToString("C")
                                        </MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">NET LIQUIDITY</MudText>
                                    </MudTd>
                                    <MudTd>
                                        <div class="d-flex align-center gap-1">
                                            <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" Class="mud-text-secondary" />
                                            <MudText Typo="Typo.body2" Style="font-weight:700;">@orgItem.UserCount</MudText>
                                        </div>
                                    </MudTd>
                                    <MudTd Style="text-align:right;">
                                        <div class="d-flex align-center justify-end gap-2">
                                            <MudTooltip Text="Credit Wallet">
                                                <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                                               Variant="Variant.Outlined" Size="Size.Small"
                                                               OnClick="@(() => OpenAdjustmentDialog(orgItem, true))"
                                                               Style="border-radius:8px;" />
                                            </MudTooltip>
                                            <MudTooltip Text="Debit Wallet">
                                                <MudIconButton Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error"
                                                               Variant="Variant.Outlined" Size="Size.Small"
                                                               OnClick="@(() => OpenAdjustmentDialog(orgItem, false))"
                                                               Style="border-radius:8px;" />
                                            </MudTooltip>
                                            <MudDivider Vertical="true" FlexItem="true" Style="height:22px; margin:0 2px;" />
                                            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default"
                                                           Size="Size.Small" Href="@($"/admin/organizations/{orgItem.Id}")"
                                                           Style="border-radius:8px;" />
                                        </div>
                                    </MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <div class="pa-10 d-flex flex-column align-center mud-text-secondary">
                                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Class="mb-2" />
                                        <MudText>No tenants match your search.</MudText>
                                    </div>
                                </NoRecordsContent>
                            </MudTable>
                        </div>

                        @* ── MOBILE CARDS (hidden on desktop) ── *@
                        <div class="fmc-mobile-cards">
                            @if (_loading)
                            {
                                @for (int i = 0; i < 3; i++)
                                {
                                    <div class="fmc-mobile-card">
                                        <MudSkeleton Width="60%" Height="20px" Class="mb-2" />
                                        <MudSkeleton Width="40%" Height="16px" Class="mb-3" />
                                        <MudSkeleton Width="80%" Height="16px" />
                                    </div>
                                }
                            }
                            else if (!_filteredOrgs.Any())
                            {
                                <div class="pa-8 d-flex flex-column align-center mud-text-secondary">
                                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Class="mb-2" />
                                    <MudText>No tenants match your search.</MudText>
                                </div>
                            }
                            else
                            {
                                @foreach (var org in _filteredOrgs)
                                {
                                    <div class="fmc-mobile-card">
                                        @* Row 1: Avatar + Name LEFT | Balance RIGHT *@
                                        <div class="fmc-mobile-row-main">
                                            <div class="d-flex align-center gap-3">
                                                <MudAvatar Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small"
                                                           Style="background-color:var(--mud-palette-background-grey); font-weight:800; font-size:0.75rem;">
                                                    @org.Name?[0]
                                                </MudAvatar>
                                                <div>
                                                    <MudText Typo="Typo.body2" Style="font-weight:800; line-height:1.2;">@org.Name</MudText>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size:0.65rem;">@(org.CeoName ?? "No CEO")</MudText>
                                                </div>
                                            </div>
                                            <div class="text-right">
                                                <MudText Typo="Typo.body2" Style="font-weight:900; font-family:'JetBrains Mono',monospace;"
                                                         Color="@(org.TotalBalance < 0 ? Color.Error : Color.Default)">
                                                    @org.TotalBalance.ToString("C")
                                                </MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size:0.6rem;">NET LIQUIDITY</MudText>
                                            </div>
                                        </div>
                                        @* Row 2: Status + Personnel LEFT | Action Buttons RIGHT *@
                                        <div class="fmc-mobile-row-sub">
                                            <div class="d-flex align-center gap-2">
                                                <div class="fmc-status-pill @(org.IsActive ? "active" : "suspended")" style="padding:4px 10px; font-size:0.6rem;">
                                                    <div class="fmc-pulse"></div>
                                                    <span>@(org.IsActive ? "ACTIVE" : "SUSPENDED")</span>
                                                </div>
                                                <div class="d-flex align-center gap-1">
                                                    <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" Class="mud-text-secondary" Style="font-size:0.9rem;" />
                                                    <MudText Typo="Typo.caption" Style="font-weight:700;">@org.UserCount</MudText>
                                                </div>
                                            </div>
                                            <div class="d-flex align-center gap-1">
                                                <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                                               Variant="Variant.Outlined" Size="Size.Small"
                                                               OnClick="@(() => OpenAdjustmentDialog(org, true))"
                                                               Style="border-radius:8px; width:34px; height:34px;" />
                                                <MudIconButton Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error"
                                                               Variant="Variant.Outlined" Size="Size.Small"
                                                               OnClick="@(() => OpenAdjustmentDialog(org, false))"
                                                               Style="border-radius:8px; width:34px; height:34px;" />
                                                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default"
                                                               Size="Size.Small" Href="@($"/admin/organizations/{org.Id}")"
                                                               Style="border-radius:8px; width:34px; height:34px;" />
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </MudPaper>
                </MudItem>

                @* ── ENTERPRISE FINANCIAL VELOCITY (Line Chart) ── *@
                <MudItem xs="12">
                    <MudPaper Elevation="0" Class="fmc-main-surface pa-8 mb-6">
                        <div class="fmc-chart-header mb-6">
                            <div class="fmc-chart-title">
                                <div class="fmc-header-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Primary" /></div>
                                <div>
                                    <MudText Typo="Typo.h6" Style="font-weight: 800; letter-spacing: -0.01em;">Cumulative Liquidity Trend</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Track the historical balance progression of active network wallets</MudText>
                                </div>
                            </div>
                            <div class="fmc-chart-controls">
                                <div class="fmc-timeframe-selector">
                                    <MudButton OnClick="@(() => SetTimeframe("Daily"))" Class="@("fmc-timeframe-btn " + (_selectedTimeframe == "Daily" ? "fmc-btn-active" : ""))">DAILY</MudButton>
                                    <MudButton OnClick="@(() => SetTimeframe("Monthly"))" Class="@("fmc-timeframe-btn " + (_selectedTimeframe == "Monthly" ? "fmc-btn-active" : ""))">MONTHLY</MudButton>
                                    <MudButton OnClick="@(() => SetTimeframe("Quarterly"))" Class="@("fmc-timeframe-btn " + (_selectedTimeframe == "Quarterly" ? "fmc-btn-active" : ""))">QUARTERLY</MudButton>
                                    <MudButton OnClick="@(() => SetTimeframe("Yearly"))" Class="@("fmc-timeframe-btn " + (_selectedTimeframe == "Yearly" ? "fmc-btn-active" : ""))">YEARLY</MudButton>
                                </div>
                            </div>
                        </div>
                        
                        @if (_auditLoading)
                        {
                            <div class="d-flex flex-column justify-center align-center" style="height:350px;">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mb-4" />
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Synthesizing network metrics...</MudText>
                            </div>
                        }
                        else
                        {
                            <div class="fmc-chart-container" style="min-height:420px; width: 100%; overflow: visible;">
                                @* MUD0002 suppressed: XAxisLabels is functional in this MudBlazor version *@
                                <MudChart T="double" ChartType="ChartType.Line" ChartSeries="@_lineChartSeries" XAxisLabels="@_lineChartLabels" 
                                          Width="100%" Height="380px" ChartOptions="@_lineChartOptions" />
                            </div>
                        }
                    </MudPaper>
                </MudItem>

                @* ── LEDGER ADJUSTMENT LOG (Audit Feed) ── *@
                <MudItem xs="12">
                    <div class="fmc-audit-surface">
                        <div class="fmc-audit-header">
                            <div class="fmc-audit-header-inner">
                                <div class="fmc-audit-title">
                                    <div class="fmc-audit-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.HistoryEdu" Color="Color.Info" /></div>
                                    <div class="fmc-alert-title-text">
                                        <MudText Typo="Typo.h6" Style="font-weight: 800;">Portfolio Health Warnings</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700; color: var(--mud-palette-warning);">Persistent issues that cannot be cleared until the wallet balance is restored.</MudText>
                                    </div>
                                </div>
                                <div class="fmc-audit-controls">
                                    <div class="d-flex align-center gap-2">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary fmc-audit-showing-txt" Style="font-weight:700;">SHOWING LAST</MudText>
                                        <MudSelect T="int" Value="@_auditLogLimit" ValueChanged="@OnAuditLogLimitChanged" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Style="background-color:var(--mud-palette-surface); font-weight:700; width:85px; height:32px;">
                                            <MudSelectItem Value="10">10</MudSelectItem>
                                            <MudSelectItem Value="20">20</MudSelectItem>
                                            <MudSelectItem Value="50">50</MudSelectItem>
                                            <MudSelectItem Value="100">100</MudSelectItem>
                                        </MudSelect>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary fmc-audit-showing-txt" Style="font-weight:700;">ENTRIES</MudText>
                                    </div>
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.FileDownload" 
                                               Style="text-transform:none; border-radius:8px; font-weight:700;">Export CSV</MudButton>
                                </div>
                            </div>
                        </div>

                        <div class="fmc-audit-body">
                            @if (_auditLoading)
                            {
                                <div class="pa-10 d-flex justify-center">
                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Medium" />
                                </div>
                            }
                            else if (!_auditLogs.Any())
                            {
                                <div class="pa-12 d-flex flex-column align-center mud-text-secondary">
                                    <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Large" Style="opacity:0.3;" />
                                    <MudText Class="mt-2">No adjustment history found.</MudText>
                                </div>
                            }
                            else
                            {
                                <div class="fmc-audit-list">
                                    @foreach (var log in _auditLogs)
                                    {
                                        bool isCredit = log.Action == "CREDIT";
                                        var localTime = log.CreatedAt.ToLocalTime();
                                        <div class="fmc-audit-item @(isCredit ? "credit" : "debit")">
                                            <div class="fmc-audit-indicator"></div>
                                            <div class="fmc-audit-type-icon">
                                                <MudIcon Icon="@(isCredit ? Icons.Material.Filled.ArrowUpward : Icons.Material.Filled.ArrowDownward)"
                                                         Color="@(isCredit ? Color.Success : Color.Error)" Size="Size.Small" />
                                            </div>
                                            <div class="fmc-audit-body-content">
                                                @* Row 1: Name + Badge *@
                                                <div class="fmc-audit-row1">
                                                    <MudText Typo="Typo.body2" Class="fmc-audit-entity">@log.EntityName</MudText>
                                                    <span class="fmc-audit-badge @(isCredit ? "credit" : "debit")">@log.Action</span>
                                                </div>
                                                @* Row 2: Actor · date on left, amount on right *@
                                                <div class="fmc-audit-row2">
                                                    <span class="fmc-audit-actor mud-text-secondary">
                                                        @log.PerformedBy&nbsp;<span class="fmc-audit-dot">·</span>&nbsp;@localTime.ToString("MMM dd · HH:mm")
                                                    </span>
                                                    <span class="fmc-audit-amt @(isCredit ? "credit" : "debit")">
                                                        @(isCredit ? "+" : "-")@log.Amount?.ToString("N2")
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="fmc-audit-footer">
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Style="text-transform:none; font-weight:700;">Load Historical Archives</MudButton>
                                </div>
                            }
                        </div>
                    </div>
                </MudItem>
            </MudGrid>
        </Authorized>
        <NotAuthorized>
            @* STANDARD USER DASHBOARD (KEEP CLEAN BUT MATCH STYLE) *@
            <div class="d-flex align-center justify-space-between mb-8">
                <MudText Typo="Typo.h4" Style="font-weight: 800; letter-spacing: -0.01em;">Financial Overview</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Href="/transactions/add"
                           Style="border-radius: 12px; padding: 10px 24px;">
                    Log Settlement
                </MudButton>
            </div>

            <MudGrid Spacing="4">
                @if (_loading)
                {
                    @for (int i = 0; i < 3; i++)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudSkeleton Width="100%" Height="180px" SkeletonType="SkeletonType.Rectangle" Style="border-radius: 16px;" />
                        </MudItem>
                    }
                }
                else
                {
                    <MudItem xs="12" sm="6" md="4">
                        <div class="fmc-glass-card static">
                            <MudText Typo="Typo.subtitle2" Class="fmc-card-label">AVAILABLE CAPITAL</MudText>
                            <MudText Typo="Typo.h3" Style="font-weight: 900; margin: 8px 0;">@_totalBalance.ToString("C")</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Primary" Size="Size.Large" Class="fmc-static-icon" />
                            <div class="fmc-card-progress primary"></div>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <div class="fmc-glass-card static">
                            <MudText Typo="Typo.subtitle2" Class="fmc-card-label">MONTHLY DISBURSEMENTS</MudText>
                            <MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 900; margin: 8px 0;">@_monthlyExpenses.ToString("C")</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Color="Color.Error" Size="Size.Large" Class="fmc-static-icon" />
                            <div class="fmc-card-progress error"></div>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <div class="fmc-glass-card static">
                            <MudText Typo="Typo.subtitle2" Class="fmc-card-label">ACTIVE ALLOCATIONS</MudText>
                            <MudText Typo="Typo.h3" Color="Color.Info" Style="font-weight: 900; margin: 8px 0;">@_activeBudgetsCount</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.PivotTableChart" Color="Color.Info" Size="Size.Large" Class="fmc-static-icon" />
                            <div class="fmc-card-progress info"></div>
                        </div>
                    </MudItem>

                    <MudItem xs="12" md="8">
                        <MudPaper Class="pa-8 fmc-main-surface" Elevation="0">
                            <div class="d-flex align-center justify-space-between mb-8">
                                <div class="d-flex align-center">
                                    <div class="fmc-header-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Primary" /></div>
                                    <MudText Typo="Typo.h5" Style="font-weight: 700;">Recent Settlements</MudText>
                                </div>
                                <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward" Href="/transactions">Open Ledger</MudButton>
                            </div>
                            <MudTable Items="@_recentTransactions" Hover="true" Dense="true" Elevation="0" Class="fmc-table-transparent">
                                <HeaderContent>
                                    <MudTh>SETTLEMENT DATE</MudTh>
                                    <MudTh>MEMO</MudTh>
                                    <MudTh>CATEGORY</MudTh>
                                    <MudTh Style="text-align: right;">AMOUNT</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="txItem">
                                    <MudTd DataLabel="Date">@(((TransactionDto)txItem).Date.ToShortDateString())</MudTd>
                                    <MudTd DataLabel="Label"><b>@(((TransactionDto)txItem).Label)</b></MudTd>
                                    <MudTd DataLabel="Category">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info" Style="font-weight: 700;">@(((TransactionDto)txItem).Category)</MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Amount" Style="text-align: right;">
                                        <MudText Color="@(((TransactionDto)txItem).Amount < 0 ? Color.Error : Color.Success)" Style="font-weight: 800; font-family: 'JetBrains Mono', monospace;">
                                            @(((TransactionDto)txItem).Amount.ToString("C"))
                                        </MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-8 fmc-main-surface" Elevation="0">
                            <div class="d-flex align-center mb-8">
                                <div class="fmc-header-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.QueryStats" Color="Color.Primary" /></div>
                                <MudText Typo="Typo.h5" Style="font-weight: 700;">Capital Allocation</MudText>
                            </div>
                            <div class="d-flex flex-column align-center">
                                <MudChart T="double" ChartType="ChartType.Donut" inputdata="@_chartData" inputlabels="@_chartLabels" Width="100%" Height="280px" />
                            </div>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        </NotAuthorized>
    </AuthorizeView>
</MudContainer>

<style>
    /* Dynamic Enterprise Theme Adaptation */
    .fmc-dashboard-header { display: flex; align-items: center; justify-content: space-between; }
    .fmc-header-accent { width: 6px; height: 48px; background: var(--mud-palette-primary); border-radius: 4px; }
    .fmc-hero-text { font-weight: 900; letter-spacing: -0.04em; color: var(--mud-palette-text-primary); font-size: clamp(1.5rem, 4vw, 3rem) !important; }
    .fmc-subtitle { color: var(--mud-palette-text-secondary); opacity: 0.8; font-weight: 500; font-size: clamp(0.75rem, 1.5vw, 1rem); }
    
    .fmc-header-btn { border-radius: 12px !important; text-transform: none !important; font-weight: 700 !important; }
    .fmc-header-btn.primary { padding: 12px 28px !important; box-shadow: var(--mud-elevation-4) !important; }
    .fmc-header-btn.secondary { border: 1px solid var(--mud-palette-divider) !important; }

    .fmc-responsive-val {
        font-weight: 900 !important; 
        line-height: 1 !important; 
        font-family: 'JetBrains Mono', monospace !important;
        font-size: clamp(1rem, 3.5vw, 2.2rem) !important;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Performance Panels - Adaptive Glass */
    .fmc-glass-card {
        position: relative; overflow: hidden; padding: 24px;
        background-color: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider); border-radius: 20px;
        height: 100%; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }
    .fmc-glass-card:hover { transform: translateY(-4px); box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08); border-color: var(--mud-palette-primary); }
    .fmc-glass-card.static { cursor: default; }
    .fmc-glass-card.static:hover { transform: none; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05); }
    
    .fmc-card-label { font-weight: 800; letter-spacing: 0.12em; color: var(--mud-palette-text-secondary); opacity: 0.7; font-size: 0.7rem; }
    .fmc-card-icon-bg { position: absolute; right: -8px; top: -8px; opacity: 0.04; font-size: 6rem !important; }
    .fmc-static-icon { position: absolute; right: 24px; bottom: 24px; opacity: 0.3; }
    
    .fmc-card-progress { position: absolute; bottom: 0; left: 0; height: 4px; width: 35%; border-radius: 0 10px 10px 0; }
    .fmc-card-progress.primary { background: var(--mud-palette-primary); }
    .fmc-card-progress.success { background: var(--mud-palette-success); }
    .fmc-card-progress.info { background: var(--mud-palette-info); }
    .fmc-card-progress.warning { background: var(--mud-palette-warning); }
    .fmc-card-progress.error { background: var(--mud-palette-error); }

    /* Main Repository Surface */
    .fmc-main-surface { 
        border-radius: 24px; border: 1px solid var(--mud-palette-divider); 
        background-color: var(--mud-palette-surface); overflow: hidden;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
    }
    .fmc-header-area { 
        padding: 32px; display: flex; align-items: center; justify-content: space-between; 
        background-color: var(--mud-palette-background-grey);
        border-bottom: 1px solid var(--mud-palette-divider);
    }
    .fmc-header-icon { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; background: rgba(var(--mud-palette-primary-rgb), 0.1); border-radius: 12px; }
    
    .fmc-premium-table .mud-table-head { background-color: rgba(var(--mud-palette-surface-rgb), 1) !important; }
    .fmc-premium-table .mud-th { 
        font-weight: 800; color: var(--mud-palette-text-secondary); 
        font-size: 0.65rem; letter-spacing: 0.08em; padding: 22px 18px; 
        background-color: var(--mud-palette-surface) !important;
        border-bottom: 2px solid var(--mud-palette-divider);
    }
    .fmc-premium-table .mud-table-row { transition: background-color 0.15s; cursor: pointer; }
    .fmc-premium-table .mud-table-row:hover { background-color: var(--mud-palette-action-default-hover) !important; }
    .fmc-premium-table .mud-td { padding: 18px; border-bottom: 1px solid var(--mud-palette-divider); }

    .fmc-enterprise-search { border-radius: 12px !important; background-color: var(--mud-palette-surface) !important; }
    .fmc-enterprise-search .mud-input-slot { font-size: 0.85rem; padding: 10px 16px !important; }

    /* Custom Status Indicators */
    .fmc-status-pill { display: inline-flex; align-items: center; padding: 6px 14px; border-radius: 50px; font-size: 0.7rem; font-weight: 800; gap: 8px; border: 1px solid transparent; }
    .fmc-status-pill.active { background: rgba(var(--mud-palette-success-rgb), 0.1); color: var(--mud-palette-success); border-color: rgba(var(--mud-palette-success-rgb), 0.2); }
    .fmc-status-pill.suspended { background: rgba(var(--mud-palette-error-rgb), 0.1); color: var(--mud-palette-error); border-color: rgba(var(--mud-palette-error-rgb), 0.2); }
    
    .fmc-pulse { width: 6px; height: 6px; border-radius: 50%; background: currentColor; animation: fmc-breathing 2s infinite ease-in-out; }
    @@keyframes fmc-breathing { 0% { transform: scale(0.9); opacity: 0.6; } 50% { transform: scale(1.4); opacity: 1; } 100% { transform: scale(0.9); opacity: 0.6; } }

    .fmc-table-transparent { background-color: transparent !important; }

    /* Responsive Layout: Desktop Table / Mobile Cards */
    .fmc-desktop-table { display: block; }
    .fmc-mobile-cards  { display: none; }

    .fmc-chart-header { display: flex; align-items: center; justify-content: space-between; }
    .fmc-chart-title { display: flex; align-items: center; }
    .fmc-chart-controls { display: flex; align-items: center; gap: 24px; }
    .fmc-chart-legend { display: flex; gap: 8px; }

    @@media (max-width: 768px) {
        .fmc-desktop-table { display: none; }
        .fmc-mobile-cards  { display: block; }
        .fmc-header-area   { flex-direction: column; align-items: flex-start; gap: 12px; }
        .fmc-header-area > div:last-child { width: 100%; }

        /* Dashboard Header compaction */
        .fmc-hero-text { font-size: 2.2rem !important; line-height: 1.1; }
        .fmc-dashboard-header { flex-direction: column; align-items: flex-start; gap: 16px; margin-bottom: 24px !important; }
        .fmc-dashboard-header .d-flex.gap-3 { width: 100%; justify-content: space-between; }
        .fmc-dashboard-header .d-flex.gap-3 button { flex: 1; padding-left: 8px !important; padding-right: 8px !important; font-size: 0.8rem; }

        /* Mobile 2x2 Grid Adjustments for KPIs */
        .fmc-glass-card { padding: 16px 12px; }
        .fmc-card-label { font-size: 0.55rem; letter-spacing: 0.05em; }
        .fmc-kpi-val { font-size: 1.35rem !important; }
        .fmc-card-icon-bg { font-size: 5rem !important; right: -12px; top: -12px; }

        .fmc-chart-header { flex-direction: column; align-items: flex-start; gap: 20px; }
        .fmc-chart-title { flex-direction: row; align-items: center; gap: 0; }
        .fmc-chart-controls { flex-direction: column; align-items: flex-start; gap: 16px; width: 100%; }
        .fmc-timeframe-selector { width: 100%; overflow-x: auto; padding-bottom: 4px; justify-content: flex-start; }

        .fmc-audit-header-inner { flex-direction: column; align-items: flex-start !important; gap: 16px; width: 100%; }
        .fmc-audit-title { flex-direction: row; align-items: center; justify-content: flex-start !important; width: 100%; gap: 0; }
        .fmc-audit-controls { width: 100%; flex-wrap: wrap; justify-content: flex-start; gap: 8px; }
        .fmc-audit-showing-txt { font-size: 0.65rem !important; }
    }

    /* Mobile Card Styles */
    .fmc-mobile-card {
        padding: 14px 16px;
        border-bottom: 1px solid var(--mud-palette-divider);
        transition: background-color 0.15s;
    }
    .fmc-mobile-card:last-child { border-bottom: none; }
    .fmc-mobile-card:hover { background-color: var(--mud-palette-action-default-hover); }

    .fmc-mobile-row-main {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 10px;
    }
    .fmc-mobile-row-sub {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .text-right { text-align: right; }

    /* ── ALERT PANEL ──────────────────────────────────────────── */
    .fmc-alert-panel {
        border-radius: 16px;
        border: 1px solid var(--mud-palette-divider);
        border-left: 4px solid var(--mud-palette-warning);
        background-color: var(--mud-palette-surface);
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    }
    .fmc-alert-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        background-color: var(--mud-palette-background-grey);
        border-bottom: 1px solid var(--mud-palette-divider);
    }
    .fmc-alert-icon-wrap {
        width: 34px; height: 34px;
        display: flex; align-items: center; justify-content: center;
        background: rgba(var(--mud-palette-warning-rgb), 0.12);
        border-radius: 8px;
    }
    .fmc-alert-body { padding: 4px 0; }
    .fmc-alert-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 20px;
        border-bottom: 1px solid var(--mud-palette-divider);
        position: relative;
        transition: background-color 0.15s;
    }
    .fmc-alert-row:last-child { border-bottom: none; }
    .fmc-alert-row:hover { background-color: var(--mud-palette-action-default-hover); }
    .fmc-alert-severity-bar {
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 3px;
        background: var(--mud-palette-error);
    }
    .fmc-bar-warning { background: var(--mud-palette-warning) !important; }
    .fmc-bar-info    { background: var(--mud-palette-info) !important; }
    .fmc-alert-row-icon {
        width: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .fmc-alert-row-content { flex: 1; min-width: 0; }
    .fmc-alert-badge {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 50px;
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 0.08em;
    }
    .fmc-badge-error   { background: rgba(var(--mud-palette-error-rgb), 0.1);   color: var(--mud-palette-error);   border: 1px solid rgba(var(--mud-palette-error-rgb), 0.2); }
    .fmc-badge-warning { background: rgba(var(--mud-palette-warning-rgb), 0.1); color: var(--mud-palette-warning); border: 1px solid rgba(var(--mud-palette-warning-rgb), 0.2); }
    .fmc-badge-info    { background: rgba(var(--mud-palette-info-rgb), 0.1);    color: var(--mud-palette-info);    border: 1px solid rgba(var(--mud-palette-info-rgb), 0.2); }
    .fmc-alert-tenant-link {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--mud-palette-text-primary) !important;
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: var(--mud-palette-divider);
    }
    .fmc-alert-tenant-link:hover { text-decoration-color: var(--mud-palette-primary); color: var(--mud-palette-primary) !important; }

    /* ── AUDIT FEED PANEL ───────────────────────────────────────── */
    .fmc-audit-surface {
        border-radius: 20px;
        border: 1px solid var(--mud-palette-divider);
        background-color: var(--mud-palette-surface);
        overflow: hidden;
        margin-top: 24px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }
    .fmc-audit-header {
        padding: 24px 28px;
        background-color: var(--mud-palette-background-grey);
        border-bottom: 1px solid var(--mud-palette-divider);
    }
    .fmc-audit-header-inner { display: flex; align-items: center; justify-content: space-between; width: 100%; gap: 16px; }
    .fmc-audit-title { display: flex; align-items: center; justify-content: flex-start; }
    .fmc-audit-title-text { display: flex; flex-direction: column; align-items: flex-start; text-align: left; }
    .fmc-audit-controls { display: flex; align-items: center; gap: 16px; }

    .fmc-audit-icon {
        width: 40px; height: 40px;
        display: flex; align-items: center; justify-content: center;
        background: rgba(var(--mud-palette-info-rgb), 0.1);
        border-radius: 10px;
    }
    .fmc-audit-body { padding: 0; }
    .fmc-audit-list { display: flex; flex-direction: column; }

    /* ── Audit Row ── */
    .fmc-audit-item {
        display: flex;
        align-items: center;
        padding: 14px 20px 14px 24px;
        border-bottom: 1px solid var(--mud-palette-divider);
        position: relative;
        gap: 12px;
    }
    .fmc-audit-item:last-child { border-bottom: none; }
    .fmc-audit-indicator {
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 4px;
    }
    .fmc-audit-item.credit .fmc-audit-indicator { background: var(--mud-palette-success); }
    .fmc-audit-item.debit  .fmc-audit-indicator { background: var(--mud-palette-error); }

    /* ── Direction Icon ── */
    .fmc-audit-type-icon { width: 22px; flex-shrink: 0; display: flex; justify-content: center; }

    /* ── Two-Row Body ── */
    .fmc-audit-body-content { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 5px; }

    .fmc-audit-row1 { display: flex; align-items: center; gap: 8px; flex-wrap: nowrap; }
    .fmc-audit-entity {
        font-weight: 800 !important;
