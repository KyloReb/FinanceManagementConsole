@page "/register"
@using Microsoft.EntityFrameworkCore
@layout Layout.BlankLayout
@attribute [AllowAnonymous]
@inject UserManager<ApplicationUser> UserManager
@inject IOtpService OtpService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Register</PageTitle>

<div class="d-flex justify-center align-center py-8" style="min-height: 100vh; background-color: var(--mud-palette-background);">
    <MudCard Elevation="4" Class="pa-8 d-flex flex-column align-center mx-4" Style="width: 100%; max-width: 450px; border-radius: 12px;">
        <MudImage Src="nlklogo.png" Height="36" ObjectFit="ObjectFit.Contain" Class="mb-4" />
        <MudText Typo="Typo.h5" Class="mb-5 fw-bold">Create Account</MudText>

        @if (_isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4 w-100" />
        }

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="w-100 mb-4">@_errorMessage</MudAlert>
        }

        <ErrorBoundary>
            <EditForm Model="@_model" OnValidSubmit="HandleRegisterAsync" class="w-100">
                <DataAnnotationsValidator />

                <div class="d-flex gap-4 mb-3">
                    <MudTextField @bind-Value="_model.FirstName" For="@(() => _model.FirstName)" Label="First Name" Variant="Variant.Outlined" FullWidth="true" />
                    <MudTextField @bind-Value="_model.LastName" For="@(() => _model.LastName)" Label="Last Name" Variant="Variant.Outlined" FullWidth="true" />
                </div>

                <MudTextField @bind-Value="_model.Email" For="@(() => _model.Email)" Label="Email Address" Variant="Variant.Outlined" FullWidth="true" Class="mb-3" />
                
                <MudTextField @bind-Value="_model.Username" For="@(() => _model.Username)" Label="Username" Variant="Variant.Outlined" FullWidth="true" Class="mb-3" />

                <MudTextField @bind-Value="_model.Password" For="@(() => _model.Password)" Label="Password" Variant="Variant.Outlined" FullWidth="true" InputType="@_passwordInput" Class="mb-3"
                              Adornment="Adornment.End" AdornmentIcon="@_passwordIcon" OnAdornmentClick="TogglePasswordVisibility" AdornmentAriaLabel="Show Password"
                              @onkeydown="CheckCapsLock" @onkeypress="CheckCapsLock" />

                <MudTextField @bind-Value="_model.ConfirmPassword" For="@(() => _model.ConfirmPassword)" Label="Confirm Password" Variant="Variant.Outlined" FullWidth="true" InputType="@_passwordInput" Class="mb-2"
                              @onkeydown="CheckCapsLock" @onkeypress="CheckCapsLock" />
                
                @if (_capsLockOn)
                {
                    <MudText Typo="Typo.caption" Color="Color.Warning" Class="d-flex align-center mb-4 mt-n1 w-100">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-1" />
                        Caps Lock is ON
                    </MudText>
                }

                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" Disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                        <MudText Class="ms-2">Creating Account...</MudText>
                    }
                    else
                    {
                        <MudText>Register</MudText>
                    }
                </MudButton>
            </EditForm>
        </ErrorBoundary>

        <MudText Typo="Typo.body2" Class="mt-5 text-center">
            Already have an account? <MudLink Href="/login" Color="Color.Primary">Log in</MudLink>
        </MudText>
    </MudCard>
</div>

@code {
    private RegisterModel _model = new();
    private bool _isLoading = false;
    private string _errorMessage = "";
    private bool _capsLockOn = false;

    /// <summary>
    /// Parses the physical character casing against the active state of the user's hardware Shift modifier to probabilistically determine if Caps Lock is engaged.
    /// </summary>
    private void CheckCapsLock(KeyboardEventArgs e)
    {
        if (!string.IsNullOrEmpty(e.Key) && e.Key.Length == 1)
        {
            char c = e.Key[0];
            if (char.IsLetter(c))
            {
                _capsLockOn = (char.IsUpper(c) && !e.ShiftKey) || (char.IsLower(c) && e.ShiftKey);
            }
        }
    }

    private bool _passwordVisibility;
    private InputType _passwordInput = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;

    /// <summary>
    /// Swaps the HTML InputType of the password fields between 'Password' and 'Text', dynamically exchanging the visibility icon.
    /// </summary>
    private void TogglePasswordVisibility()
    {
        @if (_passwordVisibility)
        {
            _passwordVisibility = false;
            _passwordIcon = Icons.Material.Filled.VisibilityOff;
            _passwordInput = InputType.Password;
        }
        else
        {
            _passwordVisibility = true;
            _passwordIcon = Icons.Material.Filled.Visibility;
            _passwordInput = InputType.Text;
        }
    }

    /// <summary>
    /// Executes the core registration workflow: validates unverified ghost accounts, secures the new user identity, and queues an email verification OTP block.
    /// </summary>
    private async Task HandleRegisterAsync()
    {
        if (_isLoading) return; // Prevent DbContext thread concurrency issue on double-submit
        _isLoading = true;
        _errorMessage = "";

        try
        {
            var existingByEmail = await UserManager.Users.FirstOrDefaultAsync(u => u.Email == _model.Email);
            if (existingByEmail != null)
            {
                if (!existingByEmail.EmailConfirmed)
                {
                    await UserManager.DeleteAsync(existingByEmail); // Clean up unverified ghost account
                }
                else
                {
                    _errorMessage = "This email is already registered and verified.";
                    return;
                }
            }

            var existingByUsername = await UserManager.FindByNameAsync(_model.Username);
            if (existingByUsername != null)
            {
                if (!existingByUsername.EmailConfirmed)
                {
                    await UserManager.DeleteAsync(existingByUsername); // Clean up unverified ghost account
                }
                else
                {
                    _errorMessage = "This username is already taken.";
                    return;
                }
            }

            var user = new ApplicationUser
            {
                UserName = _model.Username,
                Email = _model.Email,
                FirstName = _model.FirstName ?? "",
                LastName = _model.LastName ?? "",
                IsActive = true
            };

            var result = await UserManager.CreateAsync(user, _model.Password);

            if (result.Succeeded)
            {
                // Assign default role
                await UserManager.AddToRoleAsync(user, "User");

                // Generate and email OTP
                await OtpService.GenerateAndSendOtpAsync(user.Id, user.Email, "EmailVerification");

                Snackbar.Add("Registration successful. Please check your email for the verification code.", Severity.Success);
                NavigationManager.NavigateTo($"/verify-email?userId={user.Id}&email={Uri.EscapeDataString(user.Email)}");
            }
            else
            {
                _errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            }
        }
        catch (Exception)
        {
            _errorMessage = "An unexpected error occurred. Please try again later.";
            // In a real app, log exception here.
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Strongly-typed DataAnnotation model bound directly to the registration form inputs.
    /// </summary>
    public class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.StringLength(50)]
        public string? FirstName { get; set; }

        [System.ComponentModel.DataAnnotations.StringLength(50)]
        public string? LastName { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.StringLength(20, MinimumLength = 3)]
        public string Username { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.DataType(System.ComponentModel.DataAnnotations.DataType.Password)]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^\da-zA-Z]).{8,}$", ErrorMessage = "Password must be at least 8 characters and contain at least one uppercase letter, one lowercase letter, one number and one special character.")]
        public string Password { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.Compare(nameof(Password), ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = "";
    }
}
