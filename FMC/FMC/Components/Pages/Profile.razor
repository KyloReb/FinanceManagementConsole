@page "/profile"
@page "/profile/{UserId}"
@using Microsoft.AspNetCore.Authorization
@using FMC.Shared.DTOs.User
@using FMC.Shared.Auth
@attribute [Authorize]

<PageTitle>Identity Profile</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-16 fmc-profile-container">
    @if (_user == null)
    {
        <MudGrid Spacing="4">
            <MudItem xs="12" sm="8" Class="pb-2">
                <MudSkeleton Width="250px" Height="40px" SkeletonType="SkeletonType.Rectangle" Class="rounded-lg mb-2" />
                <MudSkeleton Width="350px" Height="20px" SkeletonType="SkeletonType.Rectangle" Class="rounded" />
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-center justify-sm-end pb-2">
                <MudSkeleton Width="150px" Height="48px" SkeletonType="SkeletonType.Rectangle" Class="rounded-xl" />
            </MudItem>

            <MudItem xs="12" lg="4">
                <MudPaper Elevation="0" Class="pa-6 d-flex flex-column align-center fmc-sidebar-card">
                    <MudSkeleton SkeletonType="SkeletonType.Circle" Width="110px" Height="110px" Class="mb-4" />
                    <MudSkeleton Width="180px" Height="30px" Class="mb-1" />
                    <MudSkeleton Width="220px" Height="18px" Class="mb-3" />
                    <MudSkeleton Width="100px" Height="24px" Class="mb-4 rounded" />
                    <MudDivider Class="mb-4 w-100" Style="opacity:0.2;" />
                    <div class="w-100 d-flex flex-column gap-2">
                        <MudSkeleton Width="100%" Height="44px" Class="rounded-lg" />
                        <MudSkeleton Width="100%" Height="44px" Class="rounded-lg" />
                        <MudSkeleton Width="100%" Height="44px" Class="rounded-lg" />
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="8">
                <MudGrid Spacing="3">
                    <MudItem xs="6">
                        <MudSkeleton Width="100%" Height="140px" SkeletonType="SkeletonType.Rectangle" Class="rounded-xl" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudSkeleton Width="100%" Height="140px" SkeletonType="SkeletonType.Rectangle" Class="rounded-xl" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudPaper Elevation="0" Class="fmc-profile-tabs" Style="height: 400px;">
                            <div class="px-8 pt-8">
                                <MudSkeleton Width="200px" Height="15px" Class="mb-2" />
                                <MudSkeleton Width="250px" Height="30px" Class="mb-6" />
                                <MudGrid Spacing="3">
                                    <MudItem xs="6">
                                        <MudSkeleton Width="100%" Height="80px" Class="rounded-lg" />
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudSkeleton Width="100%" Height="80px" Class="rounded-lg" />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudSkeleton Width="100%" Height="80px" Class="rounded-lg" />
                                    </MudItem>
                                </MudGrid>
                            </div>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudItem>
        </MudGrid>
    }
    else
    {
        <MudGrid Spacing="4">
            @* HEADER / QUICK STATS *@
            <MudItem xs="12" sm="8" Class="pb-2">
                <MudText Typo="Typo.h4" Style="font-weight:800; letter-spacing:-0.5px;">@(_isForeignProfile ? "User Audit Profile" : "Identity Profile")</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">@(_isForeignProfile ? $"Administrative forensic view for account ID: {UserId}" : "Security, Identity & Financial Sovereignty")</MudText>
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-center justify-sm-end pb-2 gap-2">
                @if (!_isForeignProfile && !_isEditing)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" 
                               OnClick="@StartEdit" Class="fmc-action-btn-compact">
                        Edit Profile
                    </MudButton>
                }
                else if (_isEditing)
                {
                    <MudButton Variant="Variant.Text" OnClick="@CancelEdit" Class="fmc-btn-cancel mr-2">
                        CANCEL
                    </MudButton>
                    <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" 
                               OnClick="@SaveProfile" Class="fmc-btn-save" Disabled="@_saving">
                        @(_saving ? "SYNCHRONIZING..." : "SAVE CHANGES")
                    </MudButton>
                }
                
                @if (IsAdminOrCeo && !_isEditing)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Dashboard" 
                               OnClick="@(() => Navigation.NavigateTo("/"))" Class="fmc-action-btn">
                        Control Center
                    </MudButton>
                }
            </MudItem>

            <MudItem xs="12" lg="4">
                <MudPaper Elevation="0" Class="pa-6 d-flex flex-column align-center fmc-sidebar-card">
                    <div class="avatar-wrapper mb-4">
                        <MudAvatar Style="@($"height:110px; width:110px; font-size:2.5rem; font-weight:700; background: {GetAvatarGradient(_user.Id)}; color: white; box-shadow: 0 8px 20px rgba(0,0,0,0.15);")">
                            @(GetInitials(_user))
                        </MudAvatar>
                    </div>
                    
                    <MudText Typo="Typo.h5" Align="Align.Center" Style="font-weight:800; letter-spacing:-0.5px; line-height:1.2;">@_user.DisplayName</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary" Align="Align.Center">@_user.Email</MudText>
                    <div class="mt-1 mb-3 fmc-util-pill normal d-inline-block px-3 py-1 mx-auto" style="font-size:0.75rem; font-family:'JetBrains Mono', monospace; font-weight:800;">
                        ACCT: @MaskAccountNumber(GetStableAccountNumber(_user.Id.ToString(), _user.AccountNumber))
                    </div>
                    
                    <div class="d-flex gap-2 flex-wrap justify-center mb-4">
                        @{
                            var colorClass = _user.Role == Roles.SuperAdmin ? "admin" : _user.Role == Roles.CEO ? "ceo" : "user";
                        }
                        <span class="fmc-profile-badge @colorClass">@_user.Role</span>
                    </div>

                    <MudDivider Class="mb-4 w-100" Style="opacity:0.2;" />
                    
                    <div class="w-100 d-flex flex-column gap-1 mt-1">
                        <div class="d-flex align-center pa-3 fmc-mini-stat clickable @(_activeTab == 0 ? "active" : "")" @onclick="@(() => _activeTab = 0)">
                            <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Size="Size.Small" Color="Color.Primary" Class="mr-3" />
                            <MudText Typo="Typo.body2" Style="font-weight:700;">Personal Details</MudText>
                        </div>
                        <div class="d-flex align-center pa-3 fmc-mini-stat clickable" @onclick="@StartEdit">
                            <MudIcon Icon="@Icons.Material.Filled.Security" Size="Size.Small" Color="Color.Info" Class="mr-3" />
                            <MudText Typo="Typo.body2" Style="font-weight:700;">Security & Credentials</MudText>
                        </div>
                        <div class="d-flex align-center pa-3 fmc-mini-stat clickable @(_activeTab == 1 ? "active" : "")" @onclick="@(() => _activeTab = 1)">
                            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Color="Color.Default" Class="mr-3" />
                            <MudText Typo="Typo.body2" Style="font-weight:700;">Activity Session</MudText>
                        </div>
                    </div>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="8">
                <MudGrid Spacing="3">
                    @* Financial Cards - Only show wallet for Cardholders (Roles.User) *@
                    @if (_user.Role == Roles.User)
                    {
                        <MudItem xs="6" lg="6">
                            <MudPaper Elevation="0" Class="pa-6 fmc-balance-card h-100">
                                <div class="d-flex align-center justify-space-between w-100">
                                    <MudText Typo="Typo.overline" Style="color: rgba(255,255,255,0.7); font-weight:800; letter-spacing: 1px; font-size:0.65rem;">AVAILABLE BALANCE</MudText>
                                    <MudIconButton Icon="@(_showBalance ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)" 
                                                Color="Color.Inherit" Size="Size.Small" 
                                                OnClick="@(() => _showBalance = !_showBalance)" 
                                                Style="padding:0; opacity: 0.7;" />
                                </div>
                                <div class="fmc-balance-container">
                                    @if (_showBalance)
                                    {
                                        <MudText Typo="Typo.h2" Class="fmc-balance-amount">@(_walletBalance.ToString("C2"))</MudText>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.h2" Class="fmc-balance-amount">₱ ••••••</MudText>
                                    }
                                </div>
                                <div class="d-flex align-center mt-2">
                                    <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Small" Style="color: rgba(255,255,255,0.5); font-size: 0.8rem;" Class="mr-1" />
                                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.6); font-weight:600; font-size:0.6rem;">Secured Ledger</MudText>
                                </div>
                            </MudPaper>
                        </MudItem>
                    }

                    <MudItem xs="@(_user.Role == Roles.User ? 6 : 12)" lg="@(_user.Role == Roles.User ? 6 : 12)">
                        <MudPaper Elevation="0" Class="pa-6 d-flex flex-column justify-center fmc-org-card h-100 fmc-hover-card" 
                                  Style="@(_user.OrganizationId.HasValue ? "cursor: pointer;" : "")"
                                  @onclick="@(() => { if(_user.OrganizationId.HasValue) Navigation.NavigateTo($"/admin/organizations/{_user.OrganizationId.Value}"); })">
                            <MudText Typo="Typo.overline" Style="color: var(--mud-palette-text-secondary); font-weight:800; letter-spacing: 1px; font-size:0.65rem;">
                                @(_user.Role == Roles.SuperAdmin ? "SYSTEM AUTHORITY" : "TENANT")
                            </MudText>
                            <div class="fmc-org-compact mt-2">
                                <MudIcon Icon="@(_user.Role == Roles.SuperAdmin ? Icons.Material.Filled.AdminPanelSettings : Icons.Material.Filled.Business)" 
                                         Color="Color.Primary" Size="Size.Medium" Class="mr-2" />
                                <div class="fmc-org-details w-100" style="overflow:hidden;">
                                    <MudText Typo="Typo.body1" Class="fmc-org-name-compact" Style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@(_user.Organization ?? "Global Core")</MudText>
                                    <div class="d-flex align-center justify-space-between mt-1 w-100">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size:0.65rem;">ID: @(_user.OrganizationId?.ToString().Substring(0, 8) ?? "System")</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:700; font-size:0.65rem;">ACCT: @GetStableAccountNumber(_user.OrganizationId?.ToString() ?? "", _user.OrganizationAccountNumber)</MudText>
                                    </div>
                                </div>
                            </div>
                        </MudPaper>
                    </MudItem>

                    @* Institutional Liquidity Card for CEOs/Admins *@
                    @if (_user.Role == Roles.CEO || _user.Role == Roles.SuperAdmin)
                    {
                        <MudItem xs="12">
                            <MudPaper Elevation="0" Class="pa-6 fmc-institutional-card">
                                <div class="d-flex align-center justify-space-between mb-4">
                                    <div>
                                        <MudText Typo="Typo.overline" Style="color: rgba(255,255,255,0.7); font-weight:800; letter-spacing: 1px;">INSTITUTIONAL LIQUIDITY</MudText>
                                        <MudText Typo="Typo.h3" Style="font-weight:900; font-family: 'JetBrains Mono', monospace; line-height:1;">@(_orgBalance.ToString("C2"))</MudText>
                                    </div>
                                    <MudIcon Icon="@Icons.Material.Filled.BusinessCenter" Size="Size.Large" Style="color: rgba(255,255,255,0.2); font-size: 4rem;" />
                                </div>
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Style="color: rgba(255,255,255,0.5);" Class="mr-2" />
                                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.6); font-weight:600;">Authorized Corporate Float available for subscriber allocation.</MudText>
                                </div>
                            </MudPaper>
                        </MudItem>
                    }

                    @if (_walletBalance == 0 && !IsAdminOrCeo)
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="fmc-zero-alert" Icon="@Icons.Material.Filled.AccountBalanceWallet">
                                Your wallet is currently at zero liquidity. Please contact your organization's <strong>Chief Executive</strong> to request a fund allotment for this cycle.
                            </MudAlert>
                        </MudItem>
                    }

                    <MudItem xs="12">
                        <MudTabs @bind-ActivePanelIndex="_activeTab" Elevation="0" Rounded="true" ApplyEffectsToContainer="true" Class="fmc-profile-tabs">
                            <MudTabPanel Text="Identity Mapping" Icon="@Icons.Material.Filled.Fingerprint">
                                <div class="fmc-tab-content-premium">
                                    <div class="px-8 pt-8 pb-4 d-flex align-center justify-space-between">
                                        <div>
                                            <MudText Typo="Typo.overline" Class="fmc-premium-overline">INSTITUTIONAL IDENTITY RECORDS</MudText>
                                            <MudText Typo="Typo.h5" Class="fmc-premium-title">Secure Identity Mapping</MudText>
                                        </div>
                                        <div class="fmc-security-badge-premium">
                                            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Class="mr-2" />
                                            <span>ENCRYPTED LEDGER</span>
                                        </div>
                                    </div>
                                    
                                    <MudGrid Spacing="2" Class="px-8 pb-8">
                                        <MudItem xs="12" sm="6">
                                            <div class="fmc-id-card @(_isEditing ? "editing" : "")">
                                                <div class="fmc-id-accent primary"></div>
                                                <div class="fmc-id-content">
                                                    <div class="d-flex align-center mb-1">
                                                        <div class="fmc-id-icon-bg primary mr-2">
                                                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Style="font-size:0.9rem;" />
                                                        </div>
                                                        <MudText Typo="Typo.caption" Class="fmc-id-label">GIVEN NAME</MudText>
                                                    </div>
                                                    @if (_isEditing)
                                                    {
                                                        <MudTextField @bind-Value="_editModel.FirstName" Variant="Variant.Outlined" Margin="Margin.Dense" Class="fmc-edit-input-compact" Placeholder="Enter name" />
                                                    }
                                                    else
                                                    {
                                                        <MudText Typo="Typo.body1" Class="fmc-id-value">@_user.FirstName</MudText>
                                                    }
                                                </div>
                                            </div>
                                        </MudItem>

                                        <MudItem xs="12" sm="6">
                                            <div class="fmc-id-card @(_isEditing ? "editing" : "")">
                                                <div class="fmc-id-accent secondary"></div>
                                                <div class="fmc-id-content">
                                                    <div class="d-flex align-center mb-1">
                                                        <div class="fmc-id-icon-bg secondary mr-2">
                                                            <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Small" Style="font-size:0.9rem;" />
                                                        </div>
                                                        <MudText Typo="Typo.caption" Class="fmc-id-label">SURNAME</MudText>
                                                    </div>
                                                    @if (_isEditing)
                                                    {
                                                        <MudTextField @bind-Value="_editModel.LastName" Variant="Variant.Outlined" Margin="Margin.Dense" Class="fmc-edit-input-compact" Placeholder="Enter surname" />
                                                    }
                                                    else
                                                    {
                                                        <MudText Typo="Typo.body1" Class="fmc-id-value">@_user.LastName</MudText>
                                                    }
                                                </div>
                                            </div>
                                        </MudItem>

                                        <MudItem xs="12">
                                            <div class="fmc-id-card">
                                                <div class="fmc-id-accent info"></div>
                                                <div class="fmc-id-content">
                                                    <div class="d-flex align-center justify-space-between mb-1">
                                                        <div class="d-flex align-center">
                                                            <div class="fmc-id-icon-bg info mr-2">
                                                                <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Style="font-size:0.9rem;" />
                                                            </div>
                                                            <MudText Typo="Typo.caption" Class="fmc-id-label">REGISTERED INSTITUTIONAL EMAIL</MudText>
                                                        </div>
                                                        <div class="d-flex align-center fmc-verified-chip">
                                                            <div class="status-dot sm mr-2"></div>
                                                            <span>VERIFIED CHANNEL</span>
                                                        </div>
                                                    </div>
                                                    <MudText Typo="Typo.h6" Style="font-weight:800; letter-spacing:-0.2px;">@_user.Email</MudText>
                                                </div>
                                            </div>
                                        </MudItem>
                                    </MudGrid>
                                </div>
                            </MudTabPanel>
                            
                            @if (_user.Role == Roles.User)
                            {
                                <MudTabPanel Text="Financial Forensic" Icon="@Icons.Material.Filled.QueryStats">
                                    @if (_loadingHistory)
                                    {
                                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="rounded" />
                                    }
                                    else if (!_transactions.Any())
                                    {
                                        <div class="d-flex flex-column align-center justify-center py-16">
                                            <div class="fmc-empty-icon-container mb-6">
                                                <MudIcon Icon="@Icons.Material.Filled.HistoryToggleOff" Style="font-size: 3rem; color: var(--mud-palette-primary);" />
                                            </div>
                                            <MudText Typo="Typo.h6" Style="font-weight:900; letter-spacing:-0.5px;">No Transactions Found</MudText>
                                            <MudText Typo="Typo.body2" Class="mud-text-secondary text-center px-12 mt-2" Style="max-width: 450px; line-height: 1.6;">
                                                The digital ledger for this account is currently empty. Any future adjustments or credits will be logged here for forensic auditing.
                                            </MudText>
                                            <MudButton Variant="Variant.Text" Color="Color.Primary" Class="mt-6" Style="text-transform:none; font-weight:700;">Refresh Ledger</MudButton>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="px-8 pt-8 pb-2 d-flex align-center justify-space-between">
                                            <MudText Typo="Typo.h6" Style="font-weight:900; letter-spacing:-0.5px;">Digital Ledger Trace</MudText>
                                            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Download" Color="Color.Primary" Size="Size.Small" Style="text-transform:none; font-weight:700;">Export History</MudButton>
                                        </div>
                                        <MudTable Items="@_transactions" Dense="true" Hover="true" Bordered="false" Striped="false" Elevation="0" Class="fmc-trace-table mb-4">
                                            <HeaderContent>
                                                <MudTh Class="fmc-th pl-8">DATE</MudTh>
                                                <MudTh Class="fmc-th">EVENT LABEL</MudTh>
                                                <MudTh Class="fmc-th pr-8" Style="text-align:right">ADJUSTMENT</MudTh>
                                            </HeaderContent>
                                            <RowTemplate Context="tx">
                                                <MudTd DataLabel="Date" Class="pl-8 py-4">@tx.Date.ToString("MMM dd, yyyy")</MudTd>
                                                <MudTd DataLabel="Label">
                                                    <div class="d-flex align-center">
                                                        <MudIcon Icon="@(tx.Amount >= 0 ? Icons.Material.Filled.AddCircleOutline : Icons.Material.Filled.RemoveCircleOutline)" 
                                                                Size="Size.Small" Class="mr-2" 
                                                                Color="@(tx.Amount >= 0 ? Color.Success : Color.Error)" 
                                                                Style="opacity: 0.7;" />
                                                        <MudText Typo="Typo.body2" Style="font-weight:600; color: var(--mud-palette-text-primary);">@tx.Label</MudText>
                                                    </div>
                                                </MudTd>
                                                <MudTd DataLabel="Amount" Class="pr-8" Style="text-align:right">
                                                    <MudText Color="@(tx.Amount < 0 ? Color.Error : Color.Success)" Style="font-weight:800; font-family: 'JetBrains Mono', 'Roboto Mono', monospace; font-size:1.1rem; letter-spacing:-0.5px;">
                                                        @(tx.Amount > 0 ? "+" : "")@tx.Amount.ToString("N2")
                                                    </MudText>
                                                </MudTd>
                                            </RowTemplate>
                                        </MudTable>
                                        <div class="d-flex justify-center pb-8">
                                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="fmc-action-btn" EndIcon="@Icons.Material.Filled.ArrowForward" OnClick="@(() => Navigation.NavigateTo("/transactions"))">Access Full Transaction Logs</MudButton>
                                        </div>
                                    }
                                </MudTabPanel>
                            }
                        </MudTabs>
                    </MudItem>
                </MudGrid>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Inject] private FMC.Services.Api.AuthService AuthService { get; set; } = default!;
    [Inject] private FMC.Services.Api.ApiFinanceService FinanceService { get; set; } = default!;
    [Inject] private FMC.Services.Api.AdminService AdminService { get; set; } = default!;
    [Inject] private FMC.Services.Api.OrganizationApiService OrgService { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    [Parameter] public string? UserId { get; set; }

    private UserDto? _user;
    private decimal _walletBalance = 0;
    private decimal _orgBalance = 0;
    private bool _showBalance = true;
    private List<FMC.Shared.DTOs.TransactionDto> _transactions = new();
    private bool _loadingHistory = true;
    private bool _isForeignProfile = false;
    private bool _isEditing = false;
    private bool _saving = false;
    private int _activeTab = 0;
    private UpdateUserDto _editModel = new();

    private bool IsAdminOrCeo => _user?.Role == Roles.SuperAdmin || _user?.Role == Roles.CEO;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            if (string.IsNullOrEmpty(UserId))
            {
                _user = await AuthService.GetCurrentUserAsync();
                if (_user != null)
                {
                    _walletBalance = await FinanceService.GetTotalBalanceAsync();
                    _transactions = await FinanceService.GetRecentTransactionsAsync(8);

                    // Fetch Org Balance if CEO/Admin
                    if (IsAdminOrCeo && _user.OrganizationId.HasValue)
                    {
                        var org = await OrgService.GetByIdAsync(_user.OrganizationId.Value);
                        if (org != null) _orgBalance = org.TotalBalance;
                    }
                }
            }
            else
            {
                _isForeignProfile = true;
                _user = await AdminService.GetUserAsync(UserId);
                if (_user != null)
                {
                    // Check permissions: SuperAdmin can see all, CEO only their own org
                    var currentUser = await AuthService.GetCurrentUserAsync();
                    if (currentUser == null) { Navigation.NavigateTo("/login"); return; }
                    
                    bool isSuperAdmin = currentUser.Role == Roles.SuperAdmin;
                    bool isOrgStaff = (currentUser.Role == Roles.CEO || currentUser.Role == Roles.Maker || currentUser.Role == Roles.Approver) 
                                      && currentUser.OrganizationId == _user.OrganizationId;
                    
                    if (!isSuperAdmin && !isOrgStaff)
                    {
                        Snackbar.Add("Access Denied: You do not have permission to view this forensic identity profile.", Severity.Error);
                        Navigation.NavigateTo("/profile");
                        return;
                    }

                    _walletBalance = _user.Balance;
                    _transactions = await AdminService.GetUserTransactionsAsync(UserId, 8);

                    // Fetch Org Balance for target user if they are CEO/Admin
                    if (IsAdminOrCeo && _user.OrganizationId.HasValue)
                    {
                        var org = await OrgService.GetByIdAsync(_user.OrganizationId.Value);
                        if (org != null) _orgBalance = org.TotalBalance;
                    }
                }
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Identity synchronization failure. Please refresh the browser.", Severity.Error);
        }
        finally
        {
            _loadingHistory = false;
        }
    }

    private void StartEdit()
    {
        if (_user == null) return;
        _editModel = new UpdateUserDto
        {
            Id = _user.Id,
            FirstName = _user.FirstName ?? "",
            LastName = _user.LastName ?? "",
            Email = _user.Email ?? "",
            Role = _user.Role,
            IsActive = _user.IsActive,
            Organization = _user.Organization
        };
        _isEditing = true;
    }

    private void CancelEdit() => _isEditing = false;

    private async Task SaveProfile()
    {
        if (_user == null || _saving) return;
        
        _saving = true;
        try 
        {
            var result = await AdminService.UpdateUserAsync(_editModel);
            if (result.Succeeded)
            {
                _user.FirstName = _editModel.FirstName;
                _user.LastName = _editModel.LastName;
                _isEditing = false;
                Snackbar.Add("Identity profile successfully updated on the secure ledger.", Severity.Success);
                StateHasChanged();
            }
            else
            {
                Snackbar.Add(result.Error ?? "Failed to update profile identity.", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Ledger write failure. Profile remains unchanged.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private string GetAvatarGradient(string userId)
    {
        if (string.IsNullOrEmpty(userId)) return "linear-gradient(135deg, #3b82f6 0%, #1e3a8a 100%)";
        
        // Premium color palettes
        string[][] palettes = new[] {
            new[] { "#FF6B6B", "#EE0979" }, // Sunset
            new[] { "#4158D0", "#C850C0" }, // Royal
            new[] { "#0093E9", "#80D0C7" }, // Ocean
            new[] { "#00DBDE", "#FC00FF" }, // Neon
            new[] { "#8EC5FC", "#E0C3FC" }, // Cloud
            new[] { "#FAD961", "#F76B1C" }, // Fire
            new[] { "#614385", "#516395" }  // Deep Space
        };
        
        int index = Math.Abs(userId.GetHashCode()) % palettes.Length;
        var colors = palettes[index];
        return $"linear-gradient(135deg, {colors[0]} 0%, {colors[1]} 100%)";
    }

    private string GetInitials(UserDto? user)
    {
        if (user == null) return "";
        var first = user.FirstName?.Trim().ToUpper() ?? "";
        var last = user.LastName?.Trim().ToUpper() ?? "";
        
        string initial = "";
        if (first.Length > 0) initial += first[0];
        if (last.Length > 0) initial += last[0];
        
        return initial;
    }

    private string MaskAccountNumber(string acct)
    {
        if (string.IsNullOrEmpty(acct) || acct.Length < 10) return acct;
        return $"{acct.Substring(0, 6)} {new string('*', acct.Length - 10)} {acct.Substring(acct.Length - 4)}";
    }

    private string GetStableAccountNumber(string id, string? currentAcct)
    {
        if (!string.IsNullOrWhiteSpace(currentAcct) && currentAcct != "N/A" && currentAcct.Length > 10) return currentAcct;
        if (string.IsNullOrEmpty(id)) return "N/A";
        var rnd = new Random(id.GetHashCode());
        long r1 = rnd.Next(10000, 99999);
        long r2 = rnd.Next(100000, 999999);
        return "63641" + r1.ToString("D5") + r2.ToString("D6");
    }
}
