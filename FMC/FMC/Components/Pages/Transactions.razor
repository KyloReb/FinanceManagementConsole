@page "/transactions"
@using FMC.Application.Interfaces
@using FMC.Components.Pages.Admin.Dialogs
@attribute [Authorize]

<style>
    /* EXECUTIVE THEME TOKENS */
    .fmc-header-accent { width: 6px; height: 54px; background: linear-gradient(to bottom, var(--mud-palette-primary), var(--mud-palette-info)); border-radius: 4px; }
    .fmc-hero-text { font-weight: 950; letter-spacing: -0.05em; color: var(--mud-palette-text-primary); margin-bottom: -4px; }
    .fmc-subtitle { color: var(--mud-palette-text-secondary); opacity: 0.7; font-weight: 500; }
    
    /* FISCAL TELEMETRY GLASS CARDS */
    .fmc-glass-card {
        padding: 24px; border-radius: 20px; background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider); position: relative; overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease; box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    }
    .fmc-glass-card:hover { transform: translateY(-4px); box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
    .fmc-glass-card.success { border-top: 4px solid var(--mud-palette-success); }
    .fmc-glass-card.error { border-top: 4px solid var(--mud-palette-error); }
    .fmc-glass-card.info { border-top: 4px solid var(--mud-palette-info); }
    
    .fmc-card-label { letter-spacing: 0.12em; opacity: 0.5; font-weight: 950; font-size: 0.65rem; }
    .fmc-card-icon-bg { position: absolute; right: -12px; bottom: -12px; opacity: 0.05; font-size: 5rem !important; transform: rotate(-10deg); }

    /* REPOSITORY SURFACE */
    .fmc-main-surface { border-radius: 24px; border: 1px solid var(--mud-palette-divider); overflow: hidden; box-shadow: 0 4px 25px rgba(0,0,0,0.02); }
    .fmc-header-area { padding: 24px 32px; background: var(--mud-palette-background-grey); border-bottom: 1px solid var(--mud-palette-divider); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
    .fmc-header-icon { width: 42px; height: 42px; background: rgba(var(--mud-palette-primary-rgb), 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; }

    .fmc-premium-table .mud-th { font-weight: 950; color: var(--mud-palette-text-secondary); font-size: 0.65rem; letter-spacing: 0.1em; padding: 20px 24px; text-transform: uppercase; border-bottom: 2px solid var(--mud-palette-divider); }
    .fmc-premium-table .mud-td { padding: 18px 24px; border-bottom: 1px solid var(--mud-palette-divider); }
    
    .fmc-control-orchestrator { display: flex; align-items: center; gap: 12px; }
    .fmc-search-box .mud-input-outlined { border-radius: 12px; background: var(--mud-palette-surface); }
    
    /* STATUS BADGES */
    .fmc-status-badge {
        display: inline-flex; align-items: center; padding: 4px 10px; border-radius: 8px;
        font-weight: 850; font-size: 0.65rem; letter-spacing: 0.05em; text-transform: uppercase;
    }
    .fmc-status-badge.successful { background: rgba(var(--mud-palette-success-rgb), 0.1); color: var(--mud-palette-success); border: 1px solid rgba(var(--mud-palette-success-rgb), 0.2); }
    .fmc-status-badge.approved { background: rgba(var(--mud-palette-success-rgb), 0.1); color: var(--mud-palette-success); border: 1px solid rgba(var(--mud-palette-success-rgb), 0.2); }
    .fmc-status-badge.pending { background: rgba(var(--mud-palette-warning-rgb), 0.1); color: var(--mud-palette-warning); border: 1px solid rgba(var(--mud-palette-warning-rgb), 0.2); }
    .fmc-status-badge.error { background: rgba(var(--mud-palette-error-rgb), 0.1); color: var(--mud-palette-error); border: 1px solid rgba(var(--mud-palette-error-rgb), 0.2); }
    .fmc-status-badge.failed { background: rgba(var(--mud-palette-error-rgb), 0.1); color: var(--mud-palette-error); border: 1px solid rgba(var(--mud-palette-error-rgb), 0.2); }
    .fmc-status-badge.rejected { background: rgba(var(--mud-palette-error-rgb), 0.1); color: var(--mud-palette-error); border: 1px solid rgba(var(--mud-palette-error-rgb), 0.2); }
    .fmc-status-badge.mixed { background: rgba(var(--mud-palette-info-rgb), 0.1); color: var(--mud-palette-info); border: 1px solid rgba(var(--mud-palette-info-rgb), 0.2); }
    
    /* FIN typography */
    .fmc-money { font-family: 'JetBrains Mono', monospace !important; font-variant-numeric: tabular-nums !important; letter-spacing: -0.05em !important; font-weight: 950 !important; }

    @@media (max-width: 600px) {
        .fmc-hero-text { font-size: 1.8rem !important; }
        .fmc-header-area { flex-direction: column; align-items: stretch; }
        .fmc-control-orchestrator { flex-direction: column-reverse; align-items: stretch; }
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    @* EXECUTIVE HERO HEADER *@
    <div class="d-flex align-center justify-space-between mb-8">
        <div class="d-flex align-center">
            <div class="fmc-header-accent mr-5"></div>
            <div class="d-flex flex-column">
                <MudText Typo="Typo.h3" Class="fmc-hero-text">Fiscal Transaction Ledger</MudText>
                <MudText Typo="Typo.subtitle1" Class="fmc-subtitle">Comprehensive forensic history of institutional liquidity movements.</MudText>
            </div>
        </div>
    </div>

    @* HIGH-FIDELITY LEDGER TABLE *@
    <MudPaper Elevation="0" Class="fmc-main-surface">
        <div class="fmc-header-area">
             <div class="d-flex align-center">
                <div class="fmc-header-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.HistoryEdu" Color="Color.Primary" /></div>
                <div>
                    <MudText Typo="Typo.h6" Style="font-weight: 800; letter-spacing: -0.01em;">Forensic Settlement History</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Authorized audit stream of financial adjustments</MudText>
                </div>
            </div>
            <div class="fmc-control-orchestrator">
                <div class="fmc-suite-element ml-auto mr-4 d-none d-md-flex gap-2">
                    <MudTooltip Text="Export to Microsoft Excel">
                        <MudIconButton Icon="@Icons.Custom.FileFormats.FileExcel" Color="Color.Success" Variant="Variant.Outlined" OnClick="ExportExcel" Style="border-radius:10px;" />
                    </MudTooltip>
                    <MudTooltip Text="Generate PDF Ledger">
                        <MudIconButton Icon="@Icons.Custom.FileFormats.FilePdf" Color="Color.Error" Variant="Variant.Outlined" OnClick="ExportPdf" Style="border-radius:10px;" />
                    </MudTooltip>
                </div>
                <div class="fmc-suite-element fmc-search-box" style="flex: 1;">
                    <MudTextField @bind-Value="_searchString" 
                                  Placeholder="Filter settlement records..." 
                                  Adornment="Adornment.Start" 
                                  AdornmentIcon="@Icons.Material.Filled.Search" 
                                  Variant="Variant.Outlined" 
                                  Margin="Margin.None" />
                </div>
            </div>
        </div>

        <MudTable Items="@_transactions" Hover="true" Elevation="0" Loading="@_loading" 
                 OnRowClick="OnRowClick" T="TransactionDto"
                 Filter="new Func<TransactionDto,bool>(FilterFunc1)" Class="fmc-premium-table">
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Date)">TIMESTAMP</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Subscriber)">SUBSCRIBER</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Category)">CATEGORY</MudTableSortLabel></MudTh>
                <MudTh Style="text-align:center;"><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Status)">STATUS</MudTableSortLabel></MudTh>
                <MudTh Style="text-align:right;"><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Amount)">AMOUNT</MudTableSortLabel></MudTh>
                <MudTh Style="text-align:right;">ACTION</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.body2" Style="font-weight:800;">@context!.Date.ToString("MMM dd, yyyy")</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@context!.Date.ToString("HH:mm:ss")</MudText>
                    </div>
                </MudTd>
                <MudTd>
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.body2" Style="font-weight:700;">@context!.Subscriber</MudText>
                        @if (!string.IsNullOrEmpty(context.AccountNumber))
                        {
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@GetMaskedAccount(context.AccountNumber)</MudText>
                        }
                    </div>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Style="font-weight: 800; font-size: 0.65rem;">
                        @context!.Category.ToUpper()
                    </MudChip>
                </MudTd>
                <MudTd>
                    <div class="d-flex justify-center">
                        <div class="fmc-status-badge @(context!.Status.ToLower())">
                            <MudIcon Icon="@GetStatusIcon(context!.Status)" Size="Size.Small" Class="mr-1" Style="font-size: 0.9rem;" />
                            <span>@context.Status.ToUpper()</span>
                        </div>
                    </div>
                </MudTd>
                <MudTd Style="text-align:right">
                    <MudText Color="@(context!.Amount < 0 ? Color.Error : Color.Success)" 
                             Class="fmc-money" Style="font-size: 1.1rem;">
                        @(context!.Amount > 0 ? "+" : "")@context!.Amount.ToString("C2")
                    </MudText>
                </MudTd>
                <MudTd Style="text-align:right">
                    <MudIconButton Icon="@Icons.Material.Filled.History" Color="Color.Default" Size="Size.Small" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudContainer>

@code {
    private List<TransactionDto> _transactions = new();
    private string _searchString = "";
    private TransactionDto? _selectedItem;

    [Inject] private ApiFinanceService FinanceService { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private ICurrentUserService CurrentUserService { get; set; } = default!;

    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!RendererInfo.IsInteractive) return;
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        try
        {
            _loading = true;
            var raw = await FinanceService.GetRecentTransactionsAsync(200);
            
            // ── AGGREGATION LOGIC ──
            // If BatchId exists and has multiple items, group them as a single "Bulk" entry
            var processed = new List<TransactionDto>();
            var batches = raw.Where(t => t.BatchId.HasValue && t.BatchId != Guid.Empty)
                            .GroupBy(t => t.BatchId!.Value);
            
            var individuals = raw.Where(t => !t.BatchId.HasValue || t.BatchId == Guid.Empty);
            
            foreach (var batch in batches)
            {
                if (batch.Count() > 1)
                {
                    var rep = batch.First();
                    processed.Add(new TransactionDto
                    {
                        Id = Guid.Empty, // Synthetic ID for UI
                        BatchId = rep.BatchId,
                        Date = batch.Max(x => x.Date),
                        Amount = batch.Sum(x => x.Amount),
                        Category = "BULK ALLOTMENT",
                        Subscriber = $"Multiple Subscribers ({batch.Count()} items)",
                        Label = rep.Label,
                        Status = batch.All(b => b.Status == "Approved") ? "Approved" : 
                                 batch.All(b => b.Status == "Rejected") ? "Rejected" : "Mixed",
                        OrganizationId = rep.OrganizationId,
                        AccountNumber = "BATCH_SUMMARY"
                    });
                }
                else
                {
                    processed.Add(batch.First());
                }
            }
            
            processed.AddRange(individuals);
            _transactions = processed.OrderByDescending(t => t.Date).ToList();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading transactions: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnSelectedItemChanged(TransactionDto? item)
    {
        _selectedItem = item;
    }

    private bool FilterFunc1(TransactionDto? transaction) => transaction != null && FilterFunc(transaction, _searchString);

    private bool FilterFunc(TransactionDto transaction, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (transaction.Subscriber.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (transaction.Category.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (transaction.Status.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private async Task OpenAddDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<AddTransactionDialog>("Add Transaction", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is TransactionDto newTransaction)
        {
            await FinanceService.AddTransactionAsync(newTransaction);
            await LoadTransactions();
            Snackbar.Add("Transaction added successfully", Severity.Success);
        }
    }

    private async Task ExportExcel()
    {
        var bytes = ReportService.GenerateExcel("Fiscal Transaction Ledger", _transactions);
        await DownloadFile("Transactions.xlsx", bytes, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private async Task ExportPdf()
    {
        var bytes = ReportService.GeneratePdf("Forensic Settlement History", _transactions);
        await DownloadFile("Transactions.pdf", bytes, "application/pdf");
    }

    private async Task DownloadFile(string fileName, byte[] content, string contentType)
    {
        using var streamRef = new DotNetStreamReference(new MemoryStream(content));
        await JS.InvokeVoidAsync("fmc_downloadFile", fileName, contentType, streamRef);
    }

    private string GetStatusIcon(string status) => status?.ToLower() switch
    {
        "successful" or "approved" => Icons.Material.Filled.CheckCircle,
        "pending" => Icons.Material.Filled.AccessTimeFilled,
        "error" or "failed" or "rejected" => Icons.Material.Filled.Error,
        _ => Icons.Material.Filled.Help
    };

    private string GetMaskedAccount(string? acc)
    {
        if (string.IsNullOrEmpty(acc) || acc == "BATCH_SUMMARY") return acc == "BATCH_SUMMARY" ? "BATCH SUMMARY" : "N/A";
        if (acc.Length < 10) return acc;
        return $"{acc.Substring(0, 6)}******{acc.Substring(acc.Length - 4)}";
    }

    private async Task OnRowClick(TableRowClickEventArgs<TransactionDto> args)
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var parameters = new DialogParameters<PendingDetailDialog>
        {
            { x => x.Transaction, args.Item! },
            { x => x.IsOwnTransaction, args.Item!.MakerId == CurrentUserService.UserId }
        };

        var dialog = await DialogService.ShowAsync<PendingDetailDialog>("Forensic Audit Investigation", parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
        {
            await LoadTransactions();
        }
    }

    [Inject] private IReportService ReportService { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
}
