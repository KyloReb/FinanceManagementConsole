@page "/login"
@using Microsoft.EntityFrameworkCore
@layout Layout.BlankLayout
@attribute [AllowAnonymous]
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<PageTitle>Log in</PageTitle>

<div class="d-flex justify-center align-center py-8" style="min-height: 100vh; background-color: var(--mud-palette-background);">
    <MudCard Elevation="4" Class="pa-8 d-flex flex-column align-center mx-4" Style="width: 100%; max-width: 450px; border-radius: 12px;">
        <MudImage Src="nlklogo.png" Height="36" ObjectFit="ObjectFit.Contain" Class="mb-4" />
        <MudText Typo="Typo.h5" Class="mb-5 fw-bold">Sign In</MudText>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="w-100 mb-4">@_errorMessage</MudAlert>
        }

        <EditForm Model="@_model" OnValidSubmit="HandleLoginAsync" class="w-100">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="_model.UsernameOrEmail" For="@(() => _model.UsernameOrEmail)" Label="Username or Email" Variant="Variant.Outlined" FullWidth="true" Class="mb-3" autocomplete="username" />

            <MudTextField @bind-Value="_model.Password" For="@(() => _model.Password)" Label="Password" Variant="Variant.Outlined" FullWidth="true" InputType="@_passwordInput" Class="mb-1"
                          Adornment="Adornment.End" AdornmentIcon="@_passwordIcon" OnAdornmentClick="TogglePasswordVisibility" AdornmentAriaLabel="Show Password" autocomplete="current-password"
                          @onkeydown="CheckCapsLock" @onkeypress="CheckCapsLock" />
            @if (_capsLockOn)
            {
                <MudText Typo="Typo.caption" Color="Color.Warning" Class="d-flex align-center mb-2 mt-1">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-1" />
                    Caps Lock is ON
                </MudText>
            }

            <div class="d-flex justify-space-between align-center mb-4 w-100">
                <MudCheckBox @bind-Value="_model.RememberMe" For="@(() => _model.RememberMe)" Label="Remember me" Color="Color.Primary" Size="Size.Small" Class="mt-0" />
                <MudLink Href="/forgot-password" Color="Color.Primary" Typo="Typo.caption">Forgot password?</MudLink>
            </div>

            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" Disabled="@_isLoading">
                @if (_isLoading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Signing in...</MudText>
                }
                else
                {
                    <MudText>Log In</MudText>
                }
            </MudButton>
        </EditForm>

        <form action="/api/auth/login" method="post" id="loginForm" class="d-none">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />
            <input type="hidden" name="username" value="@_model.UsernameOrEmail" />
            <input type="hidden" name="password" value="@_model.Password" />
            <input type="hidden" name="rememberMe" value="@_model.RememberMe.ToString().ToLower()" />
        </form>

        <MudText Typo="Typo.body2" Class="mt-5 text-center">
            Don't have an account? <MudLink Href="/register" Color="Color.Primary">Register</MudLink>
        </MudText>
    </MudCard>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private LoginModel _model = new();
    private bool _isLoading = false;
    private string _errorMessage = "";
    private bool _capsLockOn = false;

    /// <summary>
    /// Parses the physical character casing against the active state of the user's hardware Shift modifier to probabilistically determine if Caps Lock is engaged.
    /// </summary>
    private void CheckCapsLock(KeyboardEventArgs e)
    {
        if (!string.IsNullOrEmpty(e.Key) && e.Key.Length == 1)
        {
            char c = e.Key[0];
            if (char.IsLetter(c))
            {
                _capsLockOn = (char.IsUpper(c) && !e.ShiftKey) || (char.IsLower(c) && e.ShiftKey);
            }
        }
    }

    private bool _passwordVisibility;
    private InputType _passwordInput = InputType.Password;
    private string _passwordIcon = Icons.Material.Filled.VisibilityOff;

    /// <summary>
    /// Swaps the HTML InputType of the password field between 'Password' and 'Text', dynamically exchanging the visibility icon.
    /// </summary>
    private void TogglePasswordVisibility()
    {
        @if (_passwordVisibility)
        {
            _passwordVisibility = false;
            _passwordIcon = Icons.Material.Filled.VisibilityOff;
            _passwordInput = InputType.Password;
        }
        else
        {
            _passwordVisibility = true;
            _passwordIcon = Icons.Material.Filled.Visibility;
            _passwordInput = InputType.Text;
        }
    }

    /// <summary>
    /// Executes the core credential validation workflow: checks Account Status, resolves Identity Lockouts, and proxies a native HTTP POST to generate secure session cookies.
    /// </summary>
    private async Task HandleLoginAsync()
    {
        if (_isLoading) return; // Prevent double-click DbContext Exception
        _isLoading = true;
        _errorMessage = "";

        try
        {
            // Determine if the user is logging in with an Email or a Username
            var user = _model.UsernameOrEmail.Contains("@") 
                ? await UserManager.Users.FirstOrDefaultAsync(u => u.Email == _model.UsernameOrEmail)
                : await UserManager.FindByNameAsync(_model.UsernameOrEmail);

            if (user == null)
            {
                _errorMessage = "We couldn't find an account matching that username or email address.";
                return;
            }
            
            // Security Policy Check: Must be active
            if (!user.IsActive)
            {
                _errorMessage = "This account has been deactivated by an administrator. Please contact support.";
                return;
            }

            // Security Policy Check: Must confirm email
            if (!user.EmailConfirmed)
            {
                Snackbar.Add("Please verify your email address to continue.", Severity.Warning);
                NavigationManager.NavigateTo($"/verify-email?email={Uri.EscapeDataString(user.Email)}");
                return;
            }

            var isPasswordValid = await UserManager.CheckPasswordAsync(user, _model.Password);
            if (!isPasswordValid)
            {
                await UserManager.AccessFailedAsync(user);
                
                if (await UserManager.IsLockedOutAsync(user))
                {
                    _logger.LogWarning("User account locked out.");
                    _errorMessage = "This account has been temporarily locked due to too many failed login attempts. Please try again later.";
                }
                else
                {
                    var maxAttempts = UserManager.Options.Lockout.MaxFailedAccessAttempts;
                    var failedCount = await UserManager.GetAccessFailedCountAsync(user);
                    var remaining = maxAttempts - failedCount;
                    
                    if (remaining > 0 && remaining <= 3)
                    {
                        _errorMessage = $"The password you entered is incorrect. You have {remaining} attempt(s) remaining before your account is locked.";
                    }
                    else
                    {
                        _errorMessage = "The password you entered is incorrect. Please check your spelling and try again.";
                    }
                }
                return;
            }

            // Password is valid! Submit the native HTTP Form to the API Controller to establish cookie.
            await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('loginForm').submit();");
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Login Failed");
            _errorMessage = "An unexpected error occurred.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    [Inject] private ILogger<Login> _logger { get; set; } = default!;

    /// <summary>
    /// Strongly-typed DataAnnotation model bound directly to the login form inputs.
    /// </summary>
    public class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "The Username or Email field is required.")]
        public string UsernameOrEmail { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.DataType(System.ComponentModel.DataAnnotations.DataType.Password)]
        public string Password { get; set; } = "";

        public bool RememberMe { get; set; }
    }
}
