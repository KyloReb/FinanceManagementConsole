@page "/"
@using FMC.Shared.Auth
@using FMC.Shared.DTOs.Organization
@using FMC.Shared.DTOs.User
@using FMC.Shared.DTOs.Admin
@using FMC.Components.Dashboard
@using FMC.Services.Api
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@inject AuthenticationStateProvider AuthProvider
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject ApiFinanceService FinanceService
@inject OrganizationApiService OrgService
@inject NavigationManager Navigation
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <AuthorizeView Roles="@(Roles.SuperAdmin + "," + Roles.CEO)">
        <Authorized>
            <MudGrid Class="mb-4">
                <MudItem xs="12">
                    <div class="d-flex align-center">
                        <div class="fmc-header-accent mr-5"></div>
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.h3" Class="fmc-hero-text">@(context.User.IsInRole(Roles.CEO) ? "Corporate Dashboard" : "Control Center")</MudText>
                            <MudText Typo="Typo.subtitle1" Class="fmc-subtitle">@(context.User.IsInRole(Roles.CEO) ? "Organization Capital & Workforce Oversight" : "System Health & Multi-Tenant Capital Oversight")</MudText>
                        </div>
                    </div>
                </MudItem>
            </MudGrid>
            
            <MudGrid Spacing="2" Class="mb-8">
                @if (!context.User.IsInRole(Roles.SuperAdmin))
                {
                    var ceoOrg = _organizations.FirstOrDefault();
                    var walletBalance = ceoOrg?.WalletLimit ?? (ceoOrg?.TotalBalance ?? 0); // Using TotalBalance safely fallback
                    walletBalance = ceoOrg?.TotalBalance ?? 0; // Total credited 
                    var balanceUsed   = ceoOrg?.Usage ?? 0;
                    var currentBal    = walletBalance - balanceUsed;
                    var usedPct       = walletBalance > 0 ? (balanceUsed / walletBalance) * 100m : 0m;
                    var remainPct     = 100m - usedPct;
                    var balColor      = usedPct >= 80m ? Color.Error : (usedPct >= 60m ? Color.Warning : Color.Success);

                    @* CEO: Wallet Balance — total credited by SuperAdmin *@
                    <MudItem xs="12" sm="4">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">WALLET BALANCE</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h4" Class="fmc-kpi-val fmc-responsive-val">@walletBalance.ToString("C0")</MudText>
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:700;">Total credited by admin</MudText>
                            </div>
                            <div class="fmc-card-icon-bg primary"><MudIcon Icon="@Icons.Material.Filled.Wallet" /></div>
                            <div class="fmc-card-progress primary"></div>
                        </div>
                    </MudItem>
                    @* CEO: Current Balance — remaining available *@
                    <MudItem xs="12" sm="4">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">CURRENT BALANCE</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h4" Class="fmc-kpi-val fmc-responsive-val" Color="@balColor">
                                        @currentBal.ToString("C0")
                                    </MudText>
                                </div>
                                <div class="d-flex align-center gap-1 mt-1">
                                    <MudProgressLinear Value="@((double)remainPct)" Max="100" Color="@balColor" Rounded="true" Style="height:6px; flex:1;" />
                                    <MudText Typo="Typo.caption" Style="font-weight:900; font-size:0.65rem; white-space:nowrap;">@remainPct.ToString("F0")% left</MudText>
                                </div>
                            </div>
                            <div class="fmc-card-icon-bg success"><MudIcon Icon="@Icons.Material.Filled.AccountBalance" /></div>
                            <div class="fmc-card-progress success"></div>
                        </div>
                    </MudItem>
                    @* CEO: Balance Used — distributed to cardholders *@
                    <MudItem xs="12" sm="4">
                        <div class="fmc-glass-card">
                            <div class="fmc-card-content">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">BALANCE USED</MudText>
                                <div class="d-flex align-end gap-2 mt-1">
                                    <MudText Typo="Typo.h4" Class="fmc-kpi-val fmc-responsive-val" Color="Color.Info">@balanceUsed.ToString("C0")</MudText>
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:700;">@usedPct.ToString("F1")% of wallet allocated</MudText>
                            </div>
                            <div class="fmc-card-icon-bg info"><MudIcon Icon="@Icons.Material.Filled.Payments" /></div>
                            <div class="fmc-card-progress info"></div>
                        </div>
                    </MudItem>
                }
            </MudGrid>

            @* ── SYSTEM ALERT PANEL (Full Width) ── *@
            <MudGrid Class="mb-4">
                <MudItem xs="12">
                    @if (context.User.IsInRole(Roles.SuperAdmin))
                    {
                        <ExecutiveAlertPanel Organizations="_organizations" 
                                             Loading="_loading" 
                                             OnActionCompleted="RefreshDashboard" />
                    }
                    else if (context.User.IsInRole(Roles.CEO))
                    {
                        <ExecutiveAlertPanel Organizations="_organizations" Loading="_loading" OnActionCompleted="RefreshDashboard" />
                    }
                </MudItem>
            </MudGrid>
            @* ── ROW 1: PRIMARY OPERATIONAL CENTER (Repository & Audit) ── *@
            <MudGrid Spacing="4">
                @* ── LEFT: REPOSITORY & ANALYTICS (8/12) ── *@
                <MudItem xs="12" md="8">
                    <div class="d-flex flex-column gap-6">

                        @* ── SUBSCRIBER WALLET HEALTH ── *@
                        <MudPaper Elevation="0" Class="fmc-main-surface pa-8">
                            <div class="d-flex align-center justify-space-between mb-6">
                                <div class="d-flex align-center">
                                    <div class="fmc-header-icon mr-4" style="background: rgba(var(--mud-palette-primary-rgb), 0.1);">
                                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Primary" />
                                    </div>
                                    <div>
                                        <MudText Typo="Typo.h6" Style="font-weight: 950; letter-spacing: -0.02em;">Subscriber Wallet Health</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700;">Real-time utilization & depletion risk per tenant</MudText>
                                    </div>
                                </div>
                                    <div class="d-flex align-center gap-4">
                                        @* Summary Risk Chips *@
                                        @if (!_auditLoading && GetFilteredSubscribers().Any())
                                        {
                                            var criticalCount = GetFilteredSubscribers().Count(o => o.TotalBalance > 0 && (o.Usage / o.TotalBalance) >= 0.9m);
                                            var warnCount     = GetFilteredSubscribers().Count(o => o.TotalBalance > 0 && (o.Usage / o.TotalBalance) >= 0.7m && (o.Usage / o.TotalBalance) < 0.9m);
                                            
                                            @if (criticalCount > 0)
                                            {
                                                <MudChip T="string" Color="Color.Error" Variant="Variant.Filled"
                                                         Icon="@Icons.Material.Filled.ErrorOutline"
                                                         Style="font-size:0.65rem; font-weight:900;">
                                                    @criticalCount CRITICAL
                                                </MudChip>
                                            }
                                            @if (warnCount > 0)
                                            {
                                                <MudChip T="string" Color="Color.Warning" Variant="Variant.Filled"
                                                         Icon="@Icons.Material.Filled.WarningAmber"
                                                         Style="font-size:0.65rem; font-weight:900;">
                                                    @warnCount WARNING
                                                </MudChip>
                                            }
                                        }

                                        @* Search & page-size controls — SuperAdmin only *@
                                        @if (_isSuperAdmin)
                                        {
                                            <MudTextField @bind-Value="_walletSearchQuery" Placeholder="Search tenant..." Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Style="width: 200px; background: var(--mud-palette-background);" />
                                            <MudSelect @bind-Value="_walletPageSize" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Style="width: 80px; background: var(--mud-palette-background);">
                                                <MudSelectItem Value="5">5</MudSelectItem>
                                                <MudSelectItem Value="10">10</MudSelectItem>
                                                <MudSelectItem Value="20">20</MudSelectItem>
                                                <MudSelectItem Value="50">50</MudSelectItem>
                                            </MudSelect>
                                        }
                                    </div>
                                </div>

                            @if (_auditLoading)
                            {
                                <div class="d-flex justify-center pa-10">
                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                                </div>
                            }
                            else if (GetFilteredSubscribers().Any())
                            {
                                @* Sort cards: Critical first, then Warning, then Healthy *@
                                var sorted = GetFilteredSubscribers()
                                    .Select(o => new {
                                        Org       = o,
                                        UsedPct   = o.TotalBalance > 0 ? (double)(o.Usage / o.TotalBalance) * 100 : 0,
                                        Remaining = Math.Max(0, o.TotalBalance - o.Usage)
                                    })
                                    .OrderByDescending(x => x.UsedPct)
                                    .ToList();

                                <div class="fmc-wallet-health-list">
                                    @{ int wi = 0; }
                                    @foreach (var item in sorted)
                                    {
                                        var wIdx       = wi++;
                                        var pct        = item.UsedPct;
                                        var isCritical = pct >= 90;
                                        var isWarning  = pct >= 70 && pct < 90;
                                        var tierColor  = isCritical ? "var(--mud-palette-error)"
                                                       : isWarning  ? "var(--mud-palette-warning)"
                                                                    : "var(--mud-palette-success)";
                                        var tierLabel  = isCritical ? "CRITICAL" : isWarning ? "WARNING" : "HEALTHY";
                                        var capturedId = item.Org.Id; // capture for lambda closures

                                        <div class="fmc-health-card @(isCritical ? "fmc-health-critical" : isWarning ? "fmc-health-warn" : "")">

                                            @* ── Row 1: Avatar + Name + Tier + Cardholder Count + Percentage ── *@
                                            <div class="d-flex justify-space-between align-center mb-3">
                                                <div class="d-flex align-center gap-3" style="flex: 1; min-width: 0;">
                                                    <div class="fmc-health-avatar" style="background: @GetChartColor(wIdx);">
                                                        @item.Org.Name[0]
                                                    </div>
                                                    <div style="min-width: 0;">
                                                        <div class="d-flex align-center gap-2 flex-wrap">
                                                            <MudText Typo="Typo.body2" Style="font-weight: 900; line-height: 1.2;">@item.Org.Name</MudText>
                                                            <span class="fmc-tier-badge" style="color: @tierColor; border-color: @tierColor;">@tierLabel</span>
                                                            @if (HasRecentCredit(item.Org))
                                                            {
                                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Style="font-size:0.6rem;height:18px;margin-left:4px;">Recently Credited</MudChip>
                                                            }
                                                        </div>
                                                        @* Cardholder count if available *@
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.65rem;">
                                                            <MudIcon Icon="@Icons.Material.Filled.Group" Style="font-size: 0.7rem; vertical-align: middle; margin-right: 2px;" />
                                                            @(_organizations.FirstOrDefault(o => o.Id == item.Org.Id)?.UserCount ?? 0) cardholders
                                                        </MudText>
                                                    </div>
                                                </div>
                                                <div class="d-flex align-center gap-1">
                                                    <div class="text-right mr-3">
                                                        <MudText Typo="Typo.h6" Style="@($"font-weight: 900; font-family: 'JetBrains Mono', monospace; color: {tierColor}; line-height:1;")">
                                                            @pct.ToString("F1")%
                                                        </MudText>
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.62rem;">UTILIZED</MudText>
                                                    </div>
                                                    @* ── Manage Wallet (SuperAdmin only for Credit/Debit) ── *@
                                                    @if (_isSuperAdmin)
                                                    {
                                                        <MudTooltip Text="Credit Wallet" Arrow="true" Placement="Placement.Top">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Add"
                                                                           Size="Size.Small"
                                                                           Color="Color.Success"
                                                                           Variant="Variant.Outlined"
                                                                           Style="border-radius: 10px; width: 32px; height: 32px; margin-right: 4px;"
                                                                           OnClick="@(() => OpenAdjustmentDialog(item.Org, true))" />
                                                        </MudTooltip>
                                                        <MudTooltip Text="Debit Wallet" Arrow="true" Placement="Placement.Top">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                                                           Size="Size.Small"
                                                                           Color="Color.Error"
                                                                           Variant="Variant.Outlined"
                                                                           Style="border-radius: 10px; width: 32px; height: 32px; margin-right: 4px;"
                                                                           OnClick="@(() => OpenAdjustmentDialog(item.Org, false))" />
                                                        </MudTooltip>
                                                    }
                                                    <MudTooltip Text="Manage Wallet" Arrow="true" Placement="Placement.Top">
                                                        <MudIconButton Icon="@Icons.Material.Filled.ManageAccounts"
                                                                       Size="Size.Small"
                                                                       Color="@(isCritical ? Color.Error : Color.Default)"
                                                                       Variant="Variant.Outlined"
                                                                       Style="border-radius: 10px; width: 32px; height: 32px;"
                                                                       OnClick="@(() => Navigation.NavigateTo($"/admin/organizations/{capturedId}"))" />
                                                    </MudTooltip>
                                                </div>
                                            </div>

                                            @* ── Row 2: Annotated Fuel Gauge with Draggable Scrubber ── *@
                                            <div class="d-flex justify-space-between mb-1">
                                                <MudText Typo="Typo.caption" Style="font-size: 0.55rem; opacity: 0.4;">₱0</MudText>
                                                <MudText Typo="Typo.caption" Style="font-size: 0.55rem; opacity: 0.5; font-weight: 800;">← drag to explore →</MudText>
                                                <MudText Typo="Typo.caption" Style="font-size: 0.55rem; opacity: 0.4;">₱@item.Org.TotalBalance.ToString("N0")</MudText>
                                            </div>

                                            @* Scrubber wrapper: gauge fill behind, invisible range input on top *@
                                            <div class="fmc-gauge-wrapper">
                                                @* Fill responds to drag: uses scrub position when active, real pct when idle *@
                                                @{
                                                    var isScrubbing = _scrubActive.GetValueOrDefault(capturedId);
                                                    var fillPct     = isScrubbing
                                                        ? _scrubPositions.GetValueOrDefault(capturedId, pct)
                                                        : pct;
                                                    var fillColor   = fillPct >= 90 ? "var(--mud-palette-error)"
                                                                    : fillPct >= 70 ? "var(--mud-palette-warning)"
                                                                                    : "var(--mud-palette-success)";
                                                    // Disable transition while dragging for instant feedback
                                                    var fillTransition = isScrubbing ? "none" : "width 0.6s cubic-bezier(0.4, 0, 0.2, 1)";
                                                }
                                                <div class="fmc-gauge-track">
                                                    <div class="fmc-gauge-fill @(fillPct >= 90 ? "fmc-gauge-pulse" : "")"
                                                         style="width: @(Math.Min(fillPct, 100).ToString("F1"))%; background: @fillColor; transition: @fillTransition;">
                                                    </div>
                                                    @* Threshold markers with tooltips *@
                                                    <MudTooltip Text="⚠ 70% — Caution threshold" Arrow="true" Placement="Placement.Top">
                                                        <div class="fmc-gauge-marker" style="left: 70%;"></div>
                                                    </MudTooltip>
                                                    <MudTooltip Text="🔴 90% — Critical / Exhaustion risk" Arrow="true" Placement="Placement.Top">
                                                        <div class="fmc-gauge-marker fmc-gauge-marker-critical" style="left: 90%;"></div>
                                                    </MudTooltip>
                                                </div>

                                                @* Invisible range input overlaid for drag interaction *@
                                                <input type="range" min="0" max="100" step="0.1"
                                                       value="@(_scrubPositions.GetValueOrDefault(capturedId, pct).ToString("F1"))"
                                                       class="fmc-gauge-scrubber"
                                                       @oninput="@((e) => OnGaugeScrub(e, capturedId, item.Org.TotalBalance))"
                                                       @onmouseenter="@(() => _scrubActive[capturedId] = true)"
                                                       @onmouseleave="@(() => { _scrubActive[capturedId] = false; _scrubPositions[capturedId] = pct; })" />

                                                @* Floating tooltip showing peso amount at scrub position *@
                                                @if (_scrubActive.GetValueOrDefault(capturedId))
                                                {
                                                    var sp = _scrubPositions.GetValueOrDefault(capturedId, pct);
                                                    var sa = _scrubAmounts.GetValueOrDefault(capturedId, (decimal)(pct / 100.0) * item.Org.TotalBalance);
                                                    var tipLeft = Math.Max(8, Math.Min(sp, 88)); // clamp so tip doesn't go off edge
                                                    var isAboveReal = sp > pct;
                                                    <div class="fmc-scrub-tip" style="left: @tipLeft.ToString("F1")%;">
                                                        <div class="fmc-scrub-tip-pct" style="color: @(isAboveReal ? "var(--mud-palette-text-secondary)" : tierColor);">@sp.ToString("F1")%</div>
                                                        <div class="fmc-scrub-tip-amt">₱@sa.ToString("N0")</div>
                                                        <div class="fmc-scrub-tip-arrow"></div>
                                                    </div>
                                                }
                                            </div>

                                            @* ── Row 3: Spent | Remaining | Limit ── *@
                                            <div class="d-flex justify-space-between mt-3">
                                                <div>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;">Spent</MudText>
                                                    <MudText Typo="Typo.body2" Style="font-weight: 900; font-family: 'JetBrains Mono', monospace; color: var(--mud-palette-error);">
                                                        @item.Org.Usage.ToString("N0")
                                                    </MudText>
                                                </div>
                                                <div class="text-center">
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;">Remaining</MudText>
                                                    <MudText Typo="Typo.body2" Style="@($"font-weight: 900; font-family: 'JetBrains Mono', monospace; color: {tierColor};")">
                                                        @item.Remaining.ToString("N0")
                                                    </MudText>
                                                </div>
                                                <div class="text-right">
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em;">Wallet Limit</MudText>
                                                    <MudText Typo="Typo.body2" Style="font-weight: 900; font-family: 'JetBrains Mono', monospace;">
                                                        @item.Org.TotalBalance.ToString("N0")
                                                    </MudText>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="d-flex flex-column align-center pa-12 mud-text-secondary"
                                     style="opacity: 0.5; border: 2px dashed var(--mud-palette-divider); border-radius: 20px;">
                                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Large" />
                                    <MudText Class="mt-2" Style="font-weight: 800;">No subscriber data available.</MudText>
                                </div>
                            }
                        </MudPaper>

                        @* ── REGISTERED CARDHOLDER REGISTRY (CEO/Approver/Maker only) ── *@
                        @{
                            var cardholders = _users.Where(u => !string.IsNullOrWhiteSpace(u.AccountNumber)).ToList();
                        }
                        @if (!_isSuperAdmin && cardholders.Any())
                        {
                            <MudPaper Elevation="0" Class="fmc-main-surface pa-8">
                                <div class="d-flex align-center justify-space-between mb-6">
                                    <div class="d-flex align-center">
                                        <div class="fmc-header-icon mr-4" style="background: rgba(var(--mud-palette-info-rgb), 0.1);">
                                            <MudIcon Icon="@Icons.Material.Filled.ContactPage" Color="Color.Info" />
                                        </div>
                                        <div>
                                            <MudText Typo="Typo.h6" Style="font-weight: 950; letter-spacing: -0.02em;">Registered Cardholder Registry</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700;">Enrolled personnel &amp; individual wallet allocation</MudText>
                                        </div>
                                    </div>
                                    <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small"
                                             Icon="@Icons.Material.Filled.Group"
                                             Style="font-weight: 900; font-size: 0.65rem;">
                                        @cardholders.Count ENROLLED
                                    </MudChip>
                                </div>

                                <MudTextField @bind-Value="_cardholderSearch" Placeholder="Search cardholders..." Adornment="Adornment.Start" 
                                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-4"
                                              Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" />

                                @* Desktop Table *@
                                <div class="d-none d-md-block">
                                    <MudTable Items="@cardholders" Hover="true" Elevation="0" Dense="true" Class="fmc-table-transparent" 
                                              Filter="new Func<UserDto,bool>(FilterCardholders)">
                                        <HeaderContent>
                                            <MudTh Style="font-size:0.65rem; font-weight:900; letter-spacing:0.08em; color:var(--mud-palette-text-secondary);">
                                                <MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.DisplayName)">CARDHOLDER</MudTableSortLabel>
                                            </MudTh>
                                            <MudTh Style="font-size:0.65rem; font-weight:900; letter-spacing:0.08em; color:var(--mud-palette-text-secondary); text-align:right;">
                                                <MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Balance)">WALLET BALANCE</MudTableSortLabel>
                                            </MudTh>
                                        </HeaderContent>
                                        <RowTemplate Context="ch">
                                            <MudTd>
                                                <div class="d-flex align-center gap-3">
                                                    <MudAvatar Color="Color.Info" Size="Size.Small" Style="font-size:0.75rem; font-weight:900;">
                                                        @(ch.FirstName?[0])@(ch.LastName?[0])
                                                    </MudAvatar>
                                                    <div>
                                                        <div class="d-flex align-center gap-2">
                                                            <MudText Style="font-weight:800; font-size:0.85rem;">@ch.DisplayName</MudText>
                                                            <span class="fmc-status-pill @(ch.IsActive ? "active" : "suspended")" style="font-size:0.55rem; padding: 1px 6px;">
                                                                @(ch.IsActive ? "Active" : "Suspended")
                                                            </span>
                                                        </div>
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-family:'JetBrains Mono',monospace; font-size:0.65rem;">
                                                            @MaskAccount(ch.AccountNumber)
                                                        </MudText>
                                                    </div>
                                                </div>
                                            </MudTd>
                                            <MudTd Style="text-align:right;">
                                                <MudText Style="font-family:'JetBrains Mono',monospace; font-weight:900;"
                                                         Color="@(ch.Balance < 0 ? Color.Error : Color.Success)">
                                                    @ch.Balance.ToString("C")
                                                </MudText>
                                            </MudTd>
                                        </RowTemplate>
                                        <PagerContent>
                                            <MudTablePager PageSizeOptions="new int[]{10, 25, 50}" />
                                        </PagerContent>
                                    </MudTable>
                                </div>

                                @* Mobile Cards *@
                                <div class="d-block d-md-none">
                                    @foreach (var ch in cardholders)
                                    {
                                        <div class="fmc-ch-mobile-card">
                                            <div class="d-flex align-center justify-space-between">
                                                <div class="d-flex align-center gap-3">
                                                    <MudAvatar Color="Color.Info" Size="Size.Small" Style="font-size:0.75rem; font-weight:900;">
                                                        @(ch.FirstName?[0])@(ch.LastName?[0])
                                                    </MudAvatar>
                                                    <div>
                                                        <div class="d-flex align-center gap-2">
                                                            <MudText Style="font-weight:800; font-size:0.85rem;">@ch.DisplayName</MudText>
                                                            <span class="fmc-status-pill @(ch.IsActive ? "active" : "suspended")" style="font-size:0.55rem; padding: 1px 4px;">
                                                                @(ch.IsActive ? "Active" : "Susp")
                                                            </span>
                                                        </div>
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-family:'JetBrains Mono',monospace; font-size:0.65rem;">
                                                            @MaskAccount(ch.AccountNumber)
                                                        </MudText>
                                                    </div>
                                                </div>
                                                <div class="text-right">
                                                    <MudText Style="font-family:'JetBrains Mono',monospace; font-weight:900;"
                                                             Color="@(ch.Balance < 0 ? Color.Error : Color.Success)">
                                                        @ch.Balance.ToString("C")
                                                    </MudText>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </MudPaper>
                        }

                    </div>
                </MudItem>

                @* ── RIGHT: SYSTEM ACTIVITY LOG (4/12) ── *@
                <MudItem xs="12" md="4">
                    <div class="fmc-audit-surface">
                        <div class="fmc-audit-header">
                            <div class="d-flex align-center justify-space-between w-100">
                                <div class="fmc-audit-title">
                                    <div class="fmc-audit-icon mr-3"><MudIcon Icon="@Icons.Material.Filled.EventNote" Color="Color.Info" Size="Size.Small" /></div>
                                    <div class="fmc-audit-title-text">
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 950; letter-spacing: -0.01em; line-height: 1.1;">System Activity Log</MudText>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700; line-height: 1.1;">Global audit feed</MudText>
                                    </div>
                                </div>
                                <MudTooltip Text="Export & View All">
                                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Color="Color.Primary" Size="Size.Small" Href="/admin/audit" />
                                </MudTooltip>
                            </div>
                        </div>
                        <div class="fmc-audit-section-label">
                            <MudText Typo="Typo.caption" Style="font-weight:900; opacity: 0.6; letter-spacing: 0.05em;">LATEST ACTIVITY</MudText>
                        </div>

                        <div class="fmc-audit-scroll-area">
                            @if (_auditLoading)
                            {
                                <div class="d-flex justify-center pa-8">
                                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" StrokeWidth="4" />
                                </div>
                            }
                            else if (!_allAuditLogs.Any())
                            {
                                <div class="pa-12 d-flex flex-column align-center mud-text-secondary">
                                    <MudIcon Icon="@Icons.Material.Filled.EventNote" Size="Size.Large" Style="opacity:0.3;" />
                                    <MudText Class="mt-2">No activity history found.</MudText>
                                </div>
                            }
                            else
                            {
                                <div class="fmc-audit-list">
                                    @foreach (var log in _allAuditLogs.Take(15))
                                    {
                                        var act = log.Action?.ToUpper() ?? "UNKNOWN";
                                        var isCredit = act == "CREDIT" || act == "TRANSACTION_APPROVED" || act == "WALLET_ADJUSTED";
                                        var isDebit = act == "DEBIT" || act == "REJECTED";
                                        var isFinancial = isCredit || isDebit || log.Amount > 0;
                                        
                                        var clr = isCredit ? "credit" : isDebit ? "debit" : act.Contains("LOGIN") ? "info" : "warning";
                                        
                                        var localTime = log.CreatedAt.ToLocalTime();
                                        <div class="fmc-audit-item @clr">
                                            <div class="fmc-audit-indicator"></div>
                                            <div class="fmc-audit-body-content">
                                                <div class="d-flex justify-space-between align-center mb-1">
                                                    <span class="fmc-audit-amt @clr">
                                                        @(isFinancial && log.Amount.HasValue ? (isCredit ? "+" : isDebit ? "-" : "") + log.Amount?.ToString("N2") : "SYSTEM")
                                                    </span>
                                                    <span class="fmc-audit-badge @clr">@act.Replace("_", " ")</span>
                                                </div>
                                                <MudText Typo="Typo.body2" Class="fmc-audit-entity-compact">@log.EntityName</MudText>
                                                <div class="d-flex justify-space-between mt-1" style="opacity: 0.6;">
                                                    <span style="font-size: 0.65rem; font-weight: 700;">
                                                        <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size: 0.6rem; margin-right: 2px; vertical-align: middle;" />
                                                        @(string.IsNullOrWhiteSpace(log.PerformedBy) ? "System" : log.PerformedBy)
                                                    </span>
                                                    <span style="font-size: 0.65rem; font-weight: 700;">@localTime.ToString("MMM dd HH:mm")</span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="fmc-audit-footer">
                                    <MudButton Variant="Variant.Text" 
                                               Color="Color.Primary" 
                                               FullWidth="true" 
                                               Style="text-transform:none; font-weight:800; padding: 12px 0;"
                                               Href="/admin/audit">
                                        View Full Audit Trail
                                    </MudButton>
                                </div>
                            }
                        </div>
                    </div>
                </MudItem>
            </MudGrid>

        </Authorized>
        <NotAuthorized>
            @if (context.User.IsInRole(Roles.Maker) || context.User.IsInRole(Roles.Approver))
            {
                <MakerDashboard Organization="@GetMakerOrganization()"
                                Users="_users"
                                Loading="_loading"
                                OnActionCompleted="@RefreshDashboard" />
            }
            else
            {
                @* STANDARD USER DASHBOARD (KEEP CLEAN BUT MATCH STYLE) *@
                <div class="d-flex align-center justify-space-between mb-8">
                    <MudText Typo="Typo.h4" Style="font-weight: 800; letter-spacing: -0.01em;">Financial Overview</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Href="/transactions/add"
                               Style="border-radius: 12px; padding: 10px 24px;">
                        Log Settlement
                    </MudButton>
                </div>

                <MudGrid Spacing="4">
                    @if (_loading)
                    {
                        @for (int i = 0; i < 3; i++)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MudSkeleton Width="100%" Height="180px" SkeletonType="SkeletonType.Rectangle" Style="border-radius: 16px;" />
                            </MudItem>
                        }
                    }
                    else
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <div class="fmc-glass-card static">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">AVAILABLE CAPITAL</MudText>
                                <MudText Typo="Typo.h3" Style="font-weight: 900; margin: 8px 0; font-family: 'JetBrains Mono', monospace;">@_totalBalance.ToString("C")</MudText>
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Primary" Size="Size.Large" Class="fmc-static-icon" />
                                <div class="fmc-card-progress primary"></div>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <div class="fmc-glass-card static">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">MONTHLY DISBURSEMENTS</MudText>
                                <MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 900; margin: 8px 0; font-family: 'JetBrains Mono', monospace;">@_monthlyExpenses.ToString("C")</MudText>
                                <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Color="Color.Error" Size="Size.Large" Class="fmc-static-icon" />
                                <div class="fmc-card-progress error"></div>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="4">
                            <div class="fmc-glass-card static">
                                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">ACTIVE ALLOCATIONS</MudText>
                                <MudText Typo="Typo.h3" Color="Color.Info" Style="font-weight: 900; margin: 8px 0;">@_activeBudgetsCount</MudText>
                                <MudIcon Icon="@Icons.Material.Filled.PivotTableChart" Color="Color.Info" Size="Size.Large" Class="fmc-static-icon" />
                                <div class="fmc-card-progress info"></div>
                            </div>
                        </MudItem>

                        <MudItem xs="12" md="8">
                            <MudPaper Class="pa-8 fmc-main-surface" Elevation="0">
                                <div class="d-flex align-center justify-space-between mb-8">
                                    <div class="d-flex align-center">
                                        <div class="fmc-header-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Primary" /></div>
                                        <MudText Typo="Typo.h5" Style="font-weight: 700;">Recent Settlements</MudText>
                                    </div>
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward" Href="/transactions">Open Ledger</MudButton>
                                </div>
                                <MudTable Items="@_recentTransactions" Hover="true" Dense="true" Elevation="0" Class="fmc-table-transparent">
                                    <HeaderContent>
                                        <MudTh>SETTLEMENT DATE</MudTh>
                                        <MudTh>MEMO</MudTh>
                                        <MudTh>CATEGORY</MudTh>
                                        <MudTh Style="text-align: right;">AMOUNT</MudTh>
                                    </HeaderContent>
                                    <RowTemplate Context="txItem">
                                        <MudTd DataLabel="Date">@(((TransactionDto)txItem).Date.ToShortDateString())</MudTd>
                                        <MudTd DataLabel="Label"><b>@(((TransactionDto)txItem).Label)</b></MudTd>
                                        <MudTd DataLabel="Category">
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info" Style="font-weight: 700;">@(((TransactionDto)txItem).Category)</MudChip>
                                        </MudTd>
                                        <MudTd DataLabel="Amount" Style="text-align: right;">
                                            <MudText Color="@(((TransactionDto)txItem).Amount < 0 ? Color.Error : Color.Success)" Style="font-weight: 800; font-family: 'JetBrains Mono', monospace;">
                                                @(((TransactionDto)txItem).Amount.ToString("C"))
                                            </MudText>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </MudPaper>
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudPaper Class="pa-8 fmc-main-surface" Elevation="0">
                                <div class="d-flex align-center mb-8">
                                    <div class="fmc-header-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.QueryStats" Color="Color.Primary" /></div>
                                    <MudText Typo="Typo.h5" Style="font-weight: 700;">Capital Allocation</MudText>
                                </div>
                                <div class="d-flex flex-column align-center">
                                    <MudChart T="double" ChartType="ChartType.Donut" ChartSeries="@_donutSeries" ChartLabels="@_chartLabels" Width="100%" Height="280px" />
                                </div>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
        </NotAuthorized>

    </AuthorizeView>
</MudContainer>

@code {
    #region ── UI State & Data ──
    private bool _loading = true;
    private bool _auditLoading = true;
    private bool _isCeo;
    private bool _isSuperAdmin;
    private List<OrganizationDto> _organizations = new();
    private List<UserDto> _users = new();
    private List<AuditLogDto> _auditLogs = new();
    private List<AuditLogDto> _allAuditLogs = new();
    private int _auditLogLimit = 10;
    private string _walletSearchQuery = "";
    private int _walletPageSize = 5;

    // Charting & Analytics
    private double[] _pieData = Array.Empty<double>();
    private string[] _pieLabels = Array.Empty<string>();
    private List<OrganizationDto> _topSubscribers = new();
    private decimal _totalBalance = 0;
    private decimal _monthlyExpenses = 0;
    private int _activeBudgetsCount = 0;
    private List<TransactionDto> _recentTransactions = new();
    private double[] _chartData = Array.Empty<double>();
    private string[] _chartLabels = Array.Empty<string>();
    private List<ChartSeries<double>> _donutSeries = new();
    private List<ChartSeries<double>> _lineChartSeries = new();
    private string[] _lineChartLabels = Array.Empty<string>();
    private ChartOptions _lineChartOptions = new() { ChartPalette = new[] { "#2ecc71", "#e74c3c" } };
    private string _selectedTimeframe = "Daily";
    private List<ChartSeries<double>> _utilizationSeries = new();
    private ChartOptions _utilizationOptions = new() { ChartPalette = new[] { "#e74c3c", "#3498db" } };

    // Gauge Scrubber State
    private Dictionary<Guid, double> _scrubPositions = new();
    private Dictionary<Guid, decimal> _scrubAmounts = new();
    private Dictionary<Guid, bool> _scrubActive = new();
    private string _cardholderSearch = "";
    #endregion

    #region ── Lifecycle & Core Logic ──
    protected override async Task OnInitializedAsync()
    {
        if (!RendererInfo.IsInteractive) return;
        try 
        {
            _loading = true;
            
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            _isCeo = user.IsInRole(Roles.CEO);
            _isSuperAdmin = user.IsInRole(Roles.SuperAdmin);
            
            if (_isSuperAdmin || _isCeo || user.IsInRole(Roles.Maker) || user.IsInRole(Roles.Approver))
            {
                if (!user.IsInRole(Roles.SuperAdmin))
                {
                    var orgIdClaim = user.FindFirst("OrganizationId")?.Value;
                    if (Guid.TryParse(orgIdClaim, out var orgId))
                    {
                        var orgTask = OrgService.GetByIdAsync(orgId);
                        var usersTask = OrgService.GetUsersAsync(orgId);
                        var auditTask = OrgService.GetRecentAuditLogsAsync(_auditLogLimit, "financial");
                        var allAuditTask = OrgService.GetRecentAuditLogsAsync(30, null);
                        
                        await Task.WhenAll(orgTask, usersTask, auditTask, allAuditTask);
                        
                        var org = await orgTask;
                        if (org != null) 
                        {
                            _organizations = new List<OrganizationDto> { org };
                            _totalBalance = org.TotalBalance;
                        }
                        
                        _users = (await usersTask).ToList();
                        _auditLogs = (await auditTask).ToList();
                        _allAuditLogs = (await allAuditTask).ToList();
                    }
                }
                else // SuperAdmin
                {
                    var orgsTask = OrgService.GetOrganizationsAsync();
                    var auditTask = OrgService.GetRecentAuditLogsAsync(_auditLogLimit, "financial");
                    var allAuditTask = OrgService.GetRecentAuditLogsAsync(30, null);
                    
                    await Task.WhenAll(orgsTask, auditTask, allAuditTask);
                    
                    _organizations = (await orgsTask).Where(o => o.Name != "Nationlink/Infoserve Inc.").ToList();
                    _auditLogs = (await auditTask).ToList();
                    _allAuditLogs = (await allAuditTask).ToList();
                }
                
                PrepareLineChartData();
                _auditLoading = false;
            }
            else 
            {
                _totalBalance = await FinanceService.GetTotalBalanceAsync();
                _monthlyExpenses = await FinanceService.GetMonthlyExpensesAsync();
                var budgets = await FinanceService.GetAccountsAsync();
                _activeBudgetsCount = budgets.Count;
                _recentTransactions = await FinanceService.GetRecentTransactionsAsync(5);

                var groupedData = _recentTransactions
                    .Where(t => t.Amount < 0)
                    .GroupBy(t => t.Category)
                    .Select(g => new { Category = g.Key, Amount = (double)Math.Abs(g.Sum(t => t.Amount)) })
                    .ToList();

                _chartData = groupedData.Select(d => d.Amount).ToArray();
                _chartLabels = groupedData.Select(d => d.Category).ToArray();
                _donutSeries = new List<ChartSeries<double>> { new ChartSeries<double> { Name = "Allocation", Data = _chartData } };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Dashboard Load Failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshDashboard() => await OnInitializedAsync();
    #endregion

    #region ── UI Handlers & Dialogs ──
    private async Task OpenAdjustmentDialog(OrganizationDto org, bool isCredit)
    {
        var parameters = new DialogParameters { ["Organization"] = org, ["IsCredit"] = isCredit };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        
        var dialog = await DialogService.ShowAsync<FMC.Components.Pages.Admin.OrganizationBalanceDialog>(
            isCredit ? "Credit Wallet" : "Debit Wallet", 
            parameters, 
            options);
            
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await RefreshDashboard();
        }
    }

    private void OnGaugeScrub(ChangeEventArgs e, Guid orgId, decimal totalBalance)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any,
                            System.Globalization.CultureInfo.InvariantCulture, out var scrubPct))
        {
            _scrubPositions[orgId] = scrubPct;
            _scrubAmounts[orgId]   = (decimal)(scrubPct / 100.0) * totalBalance;
            _scrubActive[orgId]    = true;
            StateHasChanged();
        }
    }

    private async Task ChangeTimeframe(string timeframe)
    {
        _selectedTimeframe = timeframe;
        PrepareLineChartData();
        StateHasChanged();
    }

    private async Task OnAuditLogLimitChanged(int newLimit)
    {
        _auditLogLimit = newLimit;
        _auditLoading = true;
        StateHasChanged(); 
        var auditLogs = await OrgService.GetRecentAuditLogsAsync(_auditLogLimit, "financial");
        _auditLogs = auditLogs.ToList();
        PrepareLineChartData();
        _auditLoading = false;
        StateHasChanged();
    }
    #endregion

    #region ── Helpers & Data Preparation ──
    private IEnumerable<OrganizationDto> GetFilteredSubscribers()
    {
        var query = _organizations.Where(o => o.Name != "Nationlink/Infoserve Inc.");
        if (!string.IsNullOrWhiteSpace(_walletSearchQuery))
        {
            query = query.Where(o => o.Name.Contains(_walletSearchQuery, StringComparison.OrdinalIgnoreCase));
        }
        return query.OrderByDescending(o => o.TotalBalance - o.Usage).Take(_walletPageSize);
    }

    private bool HasRecentCredit(OrganizationDto org)
    {
        return _auditLogs.Any(log => log.EntityName == org.Name && log.Action == "CREDIT");
    }

    private bool FilterCardholders(UserDto user)
    {
        if (string.IsNullOrWhiteSpace(_cardholderSearch)) return true;
        if (user.DisplayName.Contains(_cardholderSearch, StringComparison.OrdinalIgnoreCase)) return true;
        if ((user.AccountNumber ?? "").Contains(_cardholderSearch, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    }

    private OrganizationDto GetMakerOrganization() => _organizations.FirstOrDefault() ?? new OrganizationDto();

    private string MaskAccount(string? account)
    {
        if (string.IsNullOrWhiteSpace(account)) return "ACCOUNT N/A";
        if (account.Length <= 10) return account;
        return $"{account[..6]}{new string('*', account.Length - 10)}{account[^4..]}";
    }

    private void PrepareLineChartData()
    {
        _topSubscribers = _organizations
            .Where(o => o.Name != "Nationlink/Infoserve Inc.")
            .OrderByDescending(o => o.TotalBalance - o.Usage)
            .Take(7)
            .ToList();
        
        if (_topSubscribers.Any())
        {
            _pieData = _topSubscribers.Select(o => (double)Math.Max(0, o.TotalBalance - o.Usage)).ToArray();
            _pieLabels = _topSubscribers.Select(o => o.Name.Length > 15 ? o.Name.Substring(0, 13) + ".." : o.Name).ToArray();
            _lineChartSeries = new List<ChartSeries<double>> { new ChartSeries<double> { Name = "Liquidity", Data = _pieData } };

            var usageData = _topSubscribers.Select(o => (double)o.Usage).ToArray();
            var remainingData = _topSubscribers.Select(o => (double)Math.Max(0, o.TotalBalance - o.Usage)).ToArray();
            
            _utilizationSeries = new List<ChartSeries<double>>
            {
                new ChartSeries<double> { Name = "Balance Used", Data = usageData },
                new ChartSeries<double> { Name = "Remaining Liquidity", Data = remainingData }
            };
        }
        else
        {
            _pieData = Array.Empty<double>();
            _pieLabels = Array.Empty<string>();
        }

        _lineChartOptions = new ChartOptions { 
            ChartPalette = new[] { "#3b82f6", "#10b981", "#f59e0b", "#8b5cf6", "#ef4444", "#6366f1", "#06b6d4" }
        };
        StateHasChanged();
    }

    private string GetChartColor(int index)
    {
        var palette = new[] { "#3b82f6", "#10b981", "#f59e0b", "#8b5cf6", "#ef4444", "#6366f1", "#06b6d4" };
        return palette[index % palette.Length];
    }
    #endregion
}
