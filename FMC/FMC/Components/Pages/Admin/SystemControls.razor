    private void SetQuickDate(string range)
    {
        _activeDateRange = range;
        _currentPage = 1;
        var today = DateTime.Today;
        switch (range)
        {
            case "7d": _historyStart = today.AddDays(-7); _historyEnd = today.AddDays(1).AddTicks(-1); break;
            case "30d": _historyStart = today.AddDays(-30); _historyEnd = today.AddDays(1).AddTicks(-1); break;
            case "1y": _historyStart = today.AddYears(-1); _historyEnd = today.AddDays(1).AddTicks(-1); break;
            default: _historyStart = null; _historyEnd = null; break;
        }
    }

    private void UpdateHistoryDate(ChangeEventArgs e, bool isStart)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
        {
            if (isStart) _historyStart = dt;
            else _historyEnd = dt.AddDays(1).AddTicks(-1);
            _activeDateRange = "custom";
            _currentPage = 1;
        }
    }

    private List<MaintenanceHistoryItem> ApplyDateFilter(List<MaintenanceHistoryItem> items)
    {
        if (_historyStart == null && _historyEnd == null) return items;
        return items.Where(e => e.CreatedAt >= (_historyStart ?? DateTime.MinValue) && e.CreatedAt <= (_historyEnd ?? DateTime.MaxValue)).ToList();
    }

    private static string FormatAction(string? action)
    {
        return action switch
        {
            "MAINTENANCE_ENABLED" => "Activated",
            "MAINTENANCE_DISABLED" => "Deactivated",
            "MAINTENANCE_SCHEDULED" => "Scheduled",
            _ => action?.Replace("MAINTENANCE_", "")?.Replace("_", " ") ?? "Unknown"
        };
    }

