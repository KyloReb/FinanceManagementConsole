@implements IDisposable
@using System.Reflection
@inject PersistentComponentState ApplicationState
@inject IHttpContextAccessor HttpContextAccessor
@inject FMC.Services.ThemeService ThemeService

<CascadingAuthenticationState>
    <MudThemeProvider @bind-IsDarkMode="@ThemeService.IsDarkMode" Theme="_theme" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    <FMC.Components.Admin.FmcErrorBoundary>
        <Router AppAssembly="typeof(Program).Assembly" AdditionalAssemblies="new[] { typeof(Client._Imports).Assembly }">
            <Found Context="routeData">
                <AuthorizeView>
                    <Authorized>
                        <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
                    </Authorized>
                    <NotAuthorized>
                        @if (routeData.PageType.GetCustomAttributes(typeof(Microsoft.AspNetCore.Authorization.AllowAnonymousAttribute), true).Any())
                        {
                            <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
                        }
                        else
                        {
                            <LayoutView Layout="typeof(Layout.BlankLayout)">
                                @if (context.User.Identity?.IsAuthenticated != true)
                                {
                                    <RedirectToLogin />
                                }
                                else
                                {
                                    <div style="padding: 20px; text-align: center;">
                                        <h2>Access Denied</h2>
                                        <p>You do not have permission to view this page.</p>
                                    </div>
                                }
                            </LayoutView>
                        }
                    </NotAuthorized>
                    <Authorizing>
                        <LayoutView Layout="typeof(Layout.BlankLayout)">
                            <div style="display:flex; justify-content:center; align-items:center; height:100vh; background-color:var(--mud-palette-background);">
                                <p style="color:var(--mud-palette-text-primary);">Authenticating...</p>
                            </div>
                        </LayoutView>
                    </Authorizing>
                </AuthorizeView>
                <FocusOnNavigate RouteData="routeData" Selector="h1" />
            </Found>
            <NotFound>
                <PageTitle>Not found</PageTitle>
                <LayoutView Layout="typeof(Layout.BlankLayout)">
                    <div style="padding: 2.5rem; text-align: center;">
                        <h1>Sorry, there's nothing at this address.</h1>
                        <MudButton Href="/" Color="Color.Primary" Variant="Variant.Filled" Class="mt-4">Go to Home</MudButton>
                    </div>
                </LayoutView>
            </NotFound>
        </Router>
    </FMC.Components.Admin.FmcErrorBoundary>
</CascadingAuthenticationState>

@code {
    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#3f51b5",
            AppbarBackground = "#ffffff", // Pure white for minimalistic look
            AppbarText = "rgba(0,0,0,0.87)", // High emphasis text
            Background = "#f5f7fa", // Subtle light grey background for content contrast
            Surface = "#ffffff",
            DrawerBackground = "#ffffff",
            DrawerText = "rgba(0,0,0,0.7)",
            DrawerIcon = "rgba(0,0,0,0.54)",
            TextPrimary = "rgba(0,0,0,0.87)",
            TextSecondary = "rgba(0,0,0,0.6)",
            Divider = "rgba(0,0,0,0.08)"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#90CAF9",
            Secondary = "#CE93D8",
            Tertiary = "#A5D6A7",
            Info = "#81D4FA",
            Success = "#A5D6A7",
            Warning = "#FFE082",
            Error = "#EF9A9A",
            
            Background = "#121212",
            Surface = "#1E1E1E",
            AppbarBackground = "#1E1E1E",
            AppbarText = "#E0E0E0",
            DrawerBackground = "#1E1E1E",
            DrawerText = "#E0E0E0",
            DrawerIcon = "#E0E0E0",
            
            TextPrimary = "#E0E0E0",
            TextSecondary = "#9E9E9E",
            
            ActionDefault = "#E0E0E0",
            ActionDisabled = "rgba(224, 224, 224, 0.3)",
            ActionDisabledBackground = "rgba(224, 224, 224, 0.12)",
            
            Divider = "rgba(224, 224, 224, 0.12)",
            DividerLight = "rgba(224, 224, 224, 0.06)",
        }
    };
    private PersistingComponentStateSubscription? _subscription;
    private string? _token;

    protected override void OnInitialized()
    {
        ThemeService.OnChange += StateHasChanged;

        // Capture token from cookie on server
        _token = HttpContextAccessor.HttpContext?.Request.Cookies["authToken"];
        
        if (!string.IsNullOrEmpty(_token))
        {
            Console.WriteLine($"[Routes] Found token in Cookie, registering for persistence");
            _subscription = ApplicationState.RegisterOnPersisting(PersistToken);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.InitializeAsync();
            StateHasChanged();
        }
    }

    private Task PersistToken()
    {
        Console.WriteLine($"[Routes] Persisting token to ApplicationState (Length: {_token?.Length ?? 0})");
        ApplicationState.PersistAsJson("authToken", _token);
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        ThemeService.OnChange -= StateHasChanged;
        _subscription?.Dispose();
    }
}
