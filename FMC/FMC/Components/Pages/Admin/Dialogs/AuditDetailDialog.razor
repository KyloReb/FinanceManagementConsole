@using MudBlazor
@using MudBlazor.Services
@using FMC.Shared.DTOs.Admin
@using FMC.Services.Api
@implements IAsyncDisposable
@implements IBrowserViewportObserver
@inject ISnackbar Snackbar
@inject OrganizationApiService OrgService
@inject AdminService AdminService
@inject IJSRuntime JS
@inject IBrowserViewportService BrowserViewportService
@inject FMC.Services.IReportService ReportService

<MudDialog Class="fmc-audit-dialog">
    <TitleContent>
        <div class="d-flex align-center gap-2 gap-sm-3">
            <MudIcon Icon="@GetEventIcon(Log.Action)" Color="@GetEventColor(Log.Action)" Size="Size.Large" />
            <div class="d-flex flex-column" style="min-width:0;">
                <MudText Typo="Typo.h6" Style="font-weight:900; font-size:clamp(0.85rem, 4vw, 1.25rem); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">Forensic Event Trace</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size:clamp(0.55rem, 2.5vw, 0.75rem);">ID: #@Log.Id.ToString().PadLeft(6, '0')</MudText>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="fmc-detail-container px-2">
            @* CORE IDENTITY *@
            <div class="detail-section mb-4 mb-sm-6">
                <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6; font-size:clamp(0.55rem, 2.5vw, 0.75rem);">Event Identity</MudText>
                <div class="d-flex flex-sm-row flex-column justify-sm-space-between justify-start align-sm-center align-start gap-3 mt-2 pa-3 pa-sm-4 fmc-highlight-box">
                    <div>
                        <MudText Style="font-weight:900; font-size:clamp(0.9rem, 4vw, 1.1rem); color: var(--mud-palette-primary);">@Log.Action</MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="font-size:clamp(0.6rem, 2.5vw, 0.875rem);">@Log.CreatedAt.ToDisplayString("MMMM dd, yyyy 'at' HH:mm:ss.fff")</MudText>
                    </div>
                    @if (Log.Amount.HasValue)
                    {
                        <div class="text-left text-sm-right">
                            @{
                                var actUpper = Log.Action?.ToUpper() ?? "";
                                var isCreditToUser = actUpper.Contains("CREDIT") || actUpper.Contains("DEPOSIT") || actUpper.Contains("ALLOT") || actUpper.Contains("FUNDED") || actUpper.Contains("APPROV") || actUpper.Contains("ADJUSTMENT_REQUESTED");
                                var sign = isCreditToUser ? "+" : "-";
                                var color = isCreditToUser ? Color.Success : Color.Error;
                            }
                            <MudText Style="font-weight:900; font-size:clamp(1rem, 5vw, 1.2rem); font-family:'JetBrains Mono',monospace;" Color="@color">
                                @sign@Math.Abs(Log.Amount.Value).ToString("N2")
                            </MudText>
                            <MudText Typo="Typo.caption" Style="font-size:clamp(0.5rem, 2vw, 0.75rem);">Currency Magnitude</MudText>
                        </div>
                    }
                </div>
            </div>

            <MudDivider Class="mb-6 opacity-50" />

            @* ACTOR & CONTEXT *@
            <MudGrid Class="mb-4 mb-sm-6">
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6; font-size:clamp(0.55rem, 2.5vw, 0.75rem);">Operator / Actor</MudText>
                    <div class="d-flex align-center gap-3 mt-2">
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                            @(GetInitial(GetFriendlyName()))
                        </MudAvatar>
                        <div style="min-width:0;">
                            <MudText Style="font-weight:800; font-size:clamp(0.75rem, 3.5vw, 0.9rem); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@GetFriendlyName()</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size:clamp(0.55rem, 2.5vw, 0.75rem);">Authenticated User</MudText>
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6; font-size:clamp(0.55rem, 2.5vw, 0.75rem);">Target Context</MudText>
                    <div class="mt-2">
                        <MudText Style="font-weight:800; font-size:clamp(0.75rem, 3.5vw, 0.9rem); word-break:break-word;">@(string.IsNullOrWhiteSpace(Log.EntityName) || Log.EntityName == "N/A" ? (Log.Organization ?? "Global Infrastructure") : Log.EntityName)</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size:clamp(0.55rem, 2.5vw, 0.75rem);">Tenant / Entity</MudText>
                    </div>
                </MudItem>
            </MudGrid>

            @* ── LIQUIDITY FLOW DIAGRAM ── *@
            @if (Log.Amount.HasValue)
            {
                var actUpper = Log.Action?.ToUpper() ?? "";
                var isBatch = actUpper.Contains("BATCH") || (Log.EntityName?.Contains("Bulk") ?? false);
                
                bool isCorporateToUser;
                if (Log.Label?.Contains("Credit MULTIPLE") == true)
                {
                    isCorporateToUser = true;
                }
                else if (Log.Label?.Contains("Debit MULTIPLE") == true)
                {
                    isCorporateToUser = false;
                }
                else
                {
                    var hasCreditKeyword = actUpper.Contains("CREDIT") 
                                        || actUpper.Contains("APPROV") 
                                        || actUpper.Contains("ALLOT") 
                                        || actUpper.Contains("DEPOSIT") 
                                        || actUpper.Contains("SUBMITTED")
                                        || actUpper.Contains("FUNDED")
                                        || actUpper.Contains("ADJUSTMENT_REQUESTED")
                                        || (Log.Label?.ToUpper().Contains("CREDIT") ?? false)
                                        || (Log.Label?.ToUpper().Contains("ALLOT") ?? false);
                                        
                    var hasDebitKeyword = actUpper.Contains("DEBIT")
                                       || actUpper.Contains("DEBITED")
                                       || actUpper.Contains("DEBIT_REQUESTED")
                                       || (Log.Label?.ToUpper().Contains("DEBIT") ?? false) 
                                       || (Log.Label?.ToUpper().Contains("CHARGE") ?? false);
                                       
                    isCorporateToUser = hasCreditKeyword || (isBatch && !hasDebitKeyword);
                }

                var absAmount = Math.Abs(Log.Amount.Value);
                var orgIdentity = GetOrgIdentity();
                var cardholderIdentity = GetCardNumber();
                
                var targetName = string.IsNullOrWhiteSpace(Log.EntityName) || Log.EntityName == "N/A"
                    ? "Cardholder"
                    : Log.EntityName.Replace("Wallet: ", "");
                
                var sourceName = isCorporateToUser 
                    ? _orgName 
                    : (isBatch ? "Multiple Cardholders" : targetName);
                    
                var destName = isCorporateToUser 
                    ? (isBatch ? "Multiple Cardholders" : targetName)
                    : _orgName;
                    
                var sourceIcon = isCorporateToUser 
                    ? Icons.Material.Filled.AccountBalance 
                    : (isBatch ? Icons.Material.Filled.People : Icons.Material.Filled.Wallet);
                    
                var destIcon = isCorporateToUser 
                    ? (isBatch ? Icons.Material.Filled.People : Icons.Material.Filled.Wallet) 
                    : Icons.Material.Filled.AccountBalance;

                // Edge case: org-level adjustment where source==dest (e.g. EntityName is the org name)
                var hideSourceAcct = false;
                if (sourceName == destName)
                {
                    if (isCorporateToUser)
                    {
                        sourceName = "Corporate Treasury";
                        sourceIcon = Icons.Material.Filled.AccountBalance;
                        hideSourceAcct = true;
                    }
                    else
                    {
                        destName = "Corporate Treasury";
                        destIcon = Icons.Material.Filled.AccountBalance;
                        _orgAccountNumber = null; // treasury has no card number, and dest-side would show it
                    }
                }

                <div class="detail-section mb-4 mb-sm-6">
                    <div class="mb-2 mb-sm-3">
                        <MudText Typo="Typo.overline" Style="letter-spacing:0.12em; font-weight:800; opacity:0.55; font-size:clamp(0.55rem, 2.5vw, 0.75rem);">Liquidity Flow</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-none d-sm-block" Style="font-style:italic;">Directional movement of funds between the corporate float and subscriber wallet(s).</MudText>
                    </div>

                    @* Desktop: horizontal flow *@
                    <div class="d-none d-sm-flex fmc-flow-surface pa-4" style="position:relative; overflow:hidden;">
                        <div class="fmc-flow-node-wrapper">
                            <div class="fmc-flow-glass-node source">
                                <div class="fmc-flow-node-ring"></div>
                                <MudIcon Icon="@sourceIcon" Class="fmc-flow-node-icon" />
                            </div>
                            <div class="fmc-flow-label">
                                <span class="fmc-flow-name">@sourceName</span>
                                    @if (isCorporateToUser && !hideSourceAcct && !string.IsNullOrEmpty(_orgAccountNumber))
                                {
                                    <span class="fmc-flow-acct">@MaskAccount(_orgAccountNumber)</span>
                                }
                                else if (!isCorporateToUser && !isBatch && !string.IsNullOrEmpty(_userAccountNumber) && _userAccountNumber != sourceName && _userAccountNumber != destName && _userAccountNumber != Log.EntityName?.Replace("Wallet: ", ""))
                                {
                                    <span class="fmc-flow-acct">@MaskAccount(_userAccountNumber)</span>
                                }
                                else if (!isCorporateToUser && isBatch)
                                {
                                    <span class="fmc-flow-acct" style="opacity:0.5;">Consolidated Batch Wallets</span>
                                }
                            </div>
                        </div>

                        <div class="fmc-flow-connector">
                            <div class="fmc-flow-particles">
                                <div class="fmc-flow-particle p1"></div>
                                <div class="fmc-flow-particle p2"></div>
                                <div class="fmc-flow-particle p3"></div>
                            </div>
                            <div class="fmc-flow-badge">
                                <span class="fmc-flow-amount">₱@absAmount.ToString("N2")</span>
                            </div>
                            <svg class="fmc-flow-arrow" viewBox="0 0 24 24" fill="none">
                                <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>

                        <div class="fmc-flow-node-wrapper">
                            <div class="fmc-flow-glass-node dest">
                                <div class="fmc-flow-node-ring"></div>
                                <MudIcon Icon="@destIcon" Class="fmc-flow-node-icon" />
                            </div>
                            <div class="fmc-flow-label">
                                <span class="fmc-flow-name">@destName</span>
                                @if (!isCorporateToUser && !string.IsNullOrEmpty(_orgAccountNumber))
                                {
                                    <span class="fmc-flow-acct">@MaskAccount(_orgAccountNumber)</span>
                                }
                                else if (isCorporateToUser && !isBatch && !string.IsNullOrEmpty(_userAccountNumber) && _userAccountNumber != sourceName && _userAccountNumber != destName && _userAccountNumber != Log.EntityName?.Replace("Wallet: ", ""))
                                {
                                    <span class="fmc-flow-acct">@MaskAccount(_userAccountNumber)</span>
                                }
                                else if (isCorporateToUser && isBatch)
                                {
                                    <span class="fmc-flow-acct" style="opacity:0.5;">Consolidated Batch Wallets</span>
                                }
                            </div>
                        </div>
                    </div>

                    @* Mobile: vertical flow *@
                    <div class="d-sm-none fmc-flow-surface-mobile">
                        <div class="fmc-flow-node-wrapper" style="width:100%;">
                            <div class="fmc-flow-glass-node source">
                                <div class="fmc-flow-node-ring"></div>
                                <MudIcon Icon="@sourceIcon" Class="fmc-flow-node-icon" />
                            </div>
                            <div class="fmc-flow-label">
                                <span class="fmc-flow-name">@sourceName</span>
                                @if (isCorporateToUser && !hideSourceAcct && !string.IsNullOrEmpty(_orgAccountNumber))
                                {
                                    <span class="fmc-flow-acct">@MaskAccount(_orgAccountNumber)</span>
                                }
                                else if (!isCorporateToUser && isBatch)
                                {
                                    <span class="fmc-flow-acct" style="opacity:0.5;">Consolidated Batch Wallets</span>
                                }
                            </div>
                        </div>
                        <div class="fmc-flow-connector-v">
                            <div class="fmc-flow-particles-v">
                                <div class="fmc-flow-particle-v p1"></div>
                                <div class="fmc-flow-particle-v p2"></div>
                                <div class="fmc-flow-particle-v p3"></div>
                            </div>
                            <div class="fmc-flow-badge-v">
                                <span class="fmc-flow-amount">₱@absAmount.ToString("N2")</span>
                            </div>
                        </div>
                        <div class="fmc-flow-node-wrapper" style="width:100%;">
                            <div class="fmc-flow-glass-node dest">
                                <div class="fmc-flow-node-ring"></div>
                                <MudIcon Icon="@destIcon" Class="fmc-flow-node-icon" />
                            </div>
                            <div class="fmc-flow-label">
                                <span class="fmc-flow-name">@destName</span>
                                @if (!isCorporateToUser && !string.IsNullOrEmpty(_orgAccountNumber))
                                {
                                    <span class="fmc-flow-acct">@MaskAccount(_orgAccountNumber)</span>
                                }
                                else if (isCorporateToUser && isBatch)
                                {
                                    <span class="fmc-flow-acct" style="opacity:0.5;">Consolidated Batch Wallets</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* ── BATCH BREAKDOWN (Forensic Detail) ── *@
            @if (Log.Action == "BATCH_SUBMITTED" || (Log.Amount.HasValue && Log.EntityName?.Contains("Bulk") == true))
            {
                <div class="detail-section mb-4 mb-sm-6">
                    <div class="d-flex align-center gap-2 mb-2 mb-sm-3">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle2" Style="font-weight: 900; letter-spacing: 0.02em; font-size:clamp(0.7rem, 3vw, 0.875rem);">BATCH BREAKDOWN</MudText>
                    </div>
                    
                    <div class="fmc-breakdown-surface">
                        @if (TryGetBatchData(out var batchData) && batchData?.Items != null)
                        {
                            @* Desktop table *@
                            <MudTable Items="@batchData.Items" Dense="true" Hover="true" Elevation="0" Style="background: transparent;" Class="d-none d-sm-table">
                                <HeaderContent>
                                    <MudTh Style="font-size: 0.65rem; font-weight: 900; opacity: 0.6;">CARDHOLDER</MudTh>
                                    <MudTh Style="font-size: 0.65rem; font-weight: 900; opacity: 0.6; text-align: right;">AMOUNT</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="item">
                                    <MudTd>
                                        <div class="d-flex flex-column">
                                            <MudText Typo="Typo.body2" Style="font-weight: 700; font-size: 0.8rem;">@item.Subscriber</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.65rem;">@MaskAccount(item.CardNumber)</MudText>
                                        </div>
                                    </MudTd>
                                    <MudTd Style="text-align: right;">
                                        <MudText Typo="Typo.body2" Style="font-family:'JetBrains Mono',monospace; font-weight: 800; font-size: 0.85rem;" 
                                                 Color="@(batchData.IsCredit ? Color.Success : Color.Error)">
                                            @(batchData.IsCredit ? "+" : "-")₱@item.Amount.ToString("N2")
                                        </MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                            @* Mobile cards *@
                            <div class="d-sm-none pa-2">
                                @{
                                    var total = batchData.Items.Sum(i => i.Amount);
                                }
                                @foreach (var item in batchData.Items)
                                {
                                    <div class="d-flex align-center justify-space-between pa-3 mb-2" style="background:var(--mud-palette-surface); border-radius:10px; border:1px solid var(--mud-palette-divider);">
                                        <div class="d-flex flex-column" style="min-width:0; flex:1;">
                                            <MudText Style="font-weight:800; font-size:0.7rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@item.Subscriber</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size:0.55rem;">@MaskAccount(item.CardNumber)</MudText>
                                        </div>
                                        <MudText Style="font-family:'JetBrains Mono',monospace; font-weight:900; font-size:0.75rem;" Color="@(batchData.IsCredit ? Color.Success : Color.Error)">
                                            @(batchData.IsCredit ? "+" : "-")₱@item.Amount.ToString("N2")
                                        </MudText>
                                    </div>
                                }
                                @* Total row *@
                                <div class="d-flex align-center justify-space-between pa-3" style="border-top:1px solid var(--mud-palette-divider);">
                                    <MudText Style="font-weight:900; font-size:0.65rem; opacity:0.7; letter-spacing:0.05em;">TOTAL</MudText>
                                    <MudText Style="font-family:'JetBrains Mono',monospace; font-weight:900; font-size:0.8rem;" Color="@(batchData.IsCredit ? Color.Success : Color.Error)">
                                        @(batchData.IsCredit ? "+" : "-")₱@total.ToString("N2")
                                    </MudText>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="pa-3 pa-sm-4">
                                <div class="d-flex flex-sm-row flex-column justify-sm-space-between align-sm-center gap-3 mb-3">
                                    <div>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:800; font-size:clamp(0.55rem, 2.5vw, 0.75rem);">TOTAL MAGNITUDE</MudText>
                                        <MudText Style="font-weight:900; font-family:'JetBrains Mono',monospace; font-size:clamp(0.85rem, 4vw, 1rem);">@Log.Amount?.ToString("C")</MudText>
                                    </div>
                                    <div class="text-left text-sm-right">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:800; font-size:clamp(0.55rem, 2.5vw, 0.75rem);">OPERATION TYPE</MudText>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Style="font-weight:900; margin:0;">BULK_ALLOTMENT</MudChip>
                                    </div>
                                </div>
                                <MudDivider Class="mb-3 opacity-20" />
                                <MudText Typo="Typo.caption" Style="font-style:italic; opacity:0.7; font-size:clamp(0.55rem, 2.5vw, 0.75rem);">
                                    Forensic Note: Detailed itemization is available in the primary transactional ledger.
                                </MudText>
                            </div>
                        }
                    </div>
                </div>
            }

            @* TELEMETRY *@
            <div class="detail-section mb-4 mb-sm-6">
                <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6; font-size:clamp(0.55rem, 2.5vw, 0.75rem);">Network Telemetry</MudText>
                <div class="mt-2 pa-3 pa-sm-4 fmc-surface-box">
                    <div class="d-flex flex-sm-row flex-column justify-sm-space-between justify-start gap-1 mb-2">
                        <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="font-size:clamp(0.65rem, 3vw, 0.875rem);">Source IP</MudText>
                        <MudText Typo="Typo.body2" Style="font-family:monospace; font-weight:700; font-size:clamp(0.65rem, 3vw, 0.875rem); word-break:break-all;">@Log.IpAddress</MudText>
                    </div>
                    <div class="d-flex flex-sm-row flex-column justify-sm-space-between justify-start gap-1">
                        <MudText Typo="Typo.body2" Class="mud-text-secondary" Style="font-size:clamp(0.65rem, 3vw, 0.875rem);">Digital Fingerprint</MudText>
                        <MudText Typo="Typo.caption" Style="font-size:clamp(0.6rem, 2.5vw, 0.75rem); max-width:100%; text-align: left; word-break:break-word;">@Log.Device</MudText>
                    </div>
                </div>
            </div>

            @* METADATA / MEMO *@
            <div class="detail-section">
                <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6; font-size:clamp(0.55rem, 2.5vw, 0.75rem);">Forensic Metadata</MudText>
                <MudPaper Elevation="0" Class="mt-2 pa-3 pa-sm-4 fmc-memo-box">
                    <MudText Typo="Typo.body2" Style="font-style:italic; font-size:clamp(0.7rem, 3vw, 0.875rem); word-break:break-word;">@GetMemo()</MudText>
                </MudPaper>
            </div>
            <div style="height: 24px;"></div>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="d-flex flex-sm-row flex-column-reverse w-100 gap-2">
            <MudButton OnClick="Close" Color="Color.Default" Variant="Variant.Outlined"
                       Class="flex-grow-1" Style="text-transform:none; font-weight:700; border-radius:10px;">Dismiss</MudButton>
            <MudButton OnClick="ExportDialogToPdf" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isDownloadingPdf" 
                       Class="flex-grow-1" Style="text-transform:none; font-weight:700; border-radius:10px;">
                    @if (_isDownloadingPdf)
                    {
                        <MudProgressCircular Class="ms-n1 mr-2" Size="Size.Small" Indeterminate="true" Color="Color.Surface" />
                        <span>Generating...</span>
                    }
                    else
                    {
                        <span>Download Report</span>
                    }
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    // =========================================================================
    // AuditDetailDialog — Code Behind
    // =========================================================================
    // Provides forensic detail on a single audit-log event, including actor
    // resolution, entity/organization lookup, liquidity flow direction detection,
    // batch item breakdown, and PDF report export.
    // =========================================================================

    #region Dependencies & State

    /// <summary>Reference to the owning MudDialog instance for close/cancel.</summary>
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>The audit-log entry to render in forensic detail.</summary>
    [Parameter] public AuditLogDto Log { get; set; } = default!;

    /// <summary>Resolved display name of the parent organization.</summary>
    private string _orgName = "";

    /// <summary>Resolved account number of the parent organization.</summary>
    private string _orgAccountNumber = "";

    /// <summary>Resolved account number of the individual user / subscriber.</summary>
    private string _userAccountNumber = "";

    /// <summary>Human-readable name of the authenticated actor.</summary>
    private string _resolvedActorName = "";

    /// <summary>Whether the viewport is below the SM breakpoint (mobile).</summary>
    private bool _isMobile = false;

    /// <summary>Flag guarding against duplicate PDF download requests.</summary>
    private bool _isDownloadingPdf = false;

    #endregion

    #region BrowserViewportObserver Support

    /// <summary>Unique identifier required by <see cref="IBrowserViewportService"/>.</summary>
    public Guid Id { get; } = Guid.NewGuid();

    /// <summary>Resize reporting configuration for viewport breakpoint detection.</summary>
    public ResizeOptions ResizeOptions { get; } = new() { ReportRate = 100, NotifyOnBreakpointOnly = true };

    #endregion

    #region Lifecycle

    /// <summary>
    /// Initializes the component by resolving the organization identity,
    /// cardholder identity, and the actor who performed the action.
    /// Falls back through multiple resolution strategies for robustness.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        _orgName = !string.IsNullOrWhiteSpace(Log.Organization) ? Log.Organization : "Corporate Liquidity";
        _userAccountNumber = GetCardNumber();
        
        List<FMC.Shared.DTOs.User.UserDto>? users = null;
        try { users = await AdminService.GetUsersAsync(); } catch { }

        // ── Resolve actor display name from the PerformedBy GUID ──
        if (users != null && !string.IsNullOrWhiteSpace(Log.PerformedBy) && Guid.TryParse(Log.PerformedBy, out _))
        {
            var actor = users.FirstOrDefault(u => u.Id.Equals(Log.PerformedBy, StringComparison.OrdinalIgnoreCase));
            if (actor != null) _resolvedActorName = actor.DisplayName;
        }
        
        // ── Deep-resolution: look up the target entity by display name ──
        if (users != null && !string.IsNullOrWhiteSpace(Log.EntityName))
        {
            try {
                var targetName = Log.EntityName.Contains(":") 
                    ? Log.EntityName.Split(':').Last().Trim() 
                    : Log.EntityName.Trim();
                    
                var user = users.FirstOrDefault(u =>
                    u.DisplayName.Equals(targetName, StringComparison.OrdinalIgnoreCase) ||
                    u.UserName?.Equals(targetName, StringComparison.OrdinalIgnoreCase) == true);
                
                if (user != null)
                {
                    // Hydrate org name from user identity if not yet resolved
                    if (string.IsNullOrEmpty(_orgName) || _orgName == "Corporate Liquidity")
                        _orgName = user.Organization ?? _orgName;
                        
                    // Resolve the org's stable account number
                    if (string.IsNullOrEmpty(_orgAccountNumber))
                    {
                        var orgs = await OrgService.GetOrganizationsAsync();
                        var org = orgs.FirstOrDefault(o => o.Name.Equals(_orgName, StringComparison.OrdinalIgnoreCase));
                        var orgIdStr = org?.Id.ToString() ?? user.OrganizationId?.ToString() ?? Guid.Empty.ToString();
                        _orgAccountNumber = GetStableAccountNumber(orgIdStr, user.OrganizationAccountNumber);
                    }
                        
                    // Resolve the user's stable account number
                    if (string.IsNullOrEmpty(_userAccountNumber) || _userAccountNumber == targetName)
                        _userAccountNumber = GetStableAccountNumber(user.Id, user.AccountNumber);
                }
            } catch { }
        }

        // ── Fallback: resolve org by name if not found via user ──
        if (!string.IsNullOrWhiteSpace(_orgName) && _orgName != "Corporate Liquidity" && string.IsNullOrEmpty(_orgAccountNumber))
        {
            try {
                var orgs = await OrgService.GetOrganizationsAsync();
                var org = orgs.FirstOrDefault(o => o.Name.Equals(_orgName, StringComparison.OrdinalIgnoreCase));
                if (org != null) _orgAccountNumber = GetStableAccountNumber(org.Id.ToString(), org.AccountNumber);
            } catch { }
        }
    }

    /// <summary>
    /// Subscribes to viewport resize events on first render so the mobile layout
    /// can adapt when the user rotates or resizes the browser.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isMobile = await BrowserViewportService.GetCurrentBreakpointAsync() < Breakpoint.Sm;
            await BrowserViewportService.SubscribeAsync(this);
            StateHasChanged();
        }
    }

    #endregion

    #region BrowserViewportObserver Implementation

    /// <inheritdoc />
    public async Task NotifyBrowserViewportChangeAsync(BrowserViewportEventArgs e)
    {
        var mobile = e.Breakpoint < Breakpoint.Sm;
        if (_isMobile != mobile) { _isMobile = mobile; await InvokeAsync(StateHasChanged); }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        await BrowserViewportService.UnsubscribeAsync(this);
        GC.SuppressFinalize(this);
    }

    #endregion

    #region Action Handlers

    /// <summary>Closes the dialog without saving.</summary>
    private void Close() => MudDialog.Cancel();

    /// <summary>
    /// Generates a forensic PDF report for the current audit event and
    /// triggers a browser download via JavaScript interop.
    /// </summary>
    private async Task ExportDialogToPdf()
    {
        if (_isDownloadingPdf) return;
        _isDownloadingPdf = true;
        StateHasChanged();
        
        try
        {
            var title = "Forensic Event Trace Report";
            var timestamp = DateTime.Now.ToString("yyyyMMdd_HHmmss");
            var fileName = $"FMC_EventTrace_{Log.Id.ToString().PadLeft(6, '0')}_{timestamp}.pdf";
                
            var bytes = await Task.Run(() =>
                ReportService.GenerateAuditPdf(title, new List<AuditLogDto> { Log }));
            using var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
            await JS.InvokeVoidAsync("fmc_downloadFile", fileName, "application/pdf", streamRef);
            
            Snackbar.Add("Forensic trace report downloaded successfully.", Severity.Success);
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to generate PDF report.", Severity.Error);
        }
        finally
        {
            _isDownloadingPdf = false;
            StateHasChanged();
        }
    }

    #endregion

    #region Display Helpers

    /// <summary>
    /// Returns the best human-readable name for the actor, preferring the
    /// resolved identity over the raw PerformedBy GUID string.
    /// </summary>
    private string GetFriendlyName()
    {
        if (!string.IsNullOrWhiteSpace(_resolvedActorName)) return _resolvedActorName;
        if (!string.IsNullOrWhiteSpace(Log.UserName) && Log.UserName != "Unknown") return Log.UserName;
        
        var name = Log.PerformedBy ?? "System";
        return Guid.TryParse(name, out _) ? "Administrative Operator" : name;
    }

    /// <summary>
    /// Builds the forensic metadata memo by combining the audit Label and
    /// optional Details text (excluding JSON payloads and email addresses).
    /// </summary>
    private string GetMemo()
    {
        var memo = Log.Label ?? "No forensic metadata recorded.";
        if (!string.IsNullOrWhiteSpace(Log.Details) && !Log.Details.Trim().StartsWith("{") && !Log.Details.Contains("@"))
            memo += $" | Additional: {Log.Details}";
        return memo;
    }

    /// <summary>
    /// Returns the uppercased first character of a name, defaulting to 'S' for System.
    /// </summary>
    private static char GetInitial(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return 'S';
        var trimmed = name.Trim();
        return trimmed.Length > 0 ? char.ToUpper(trimmed[0]) : 'S';
    }

    #endregion

    #region Icon & Color Selectors

    /// <summary>Maps an audit action string to its representative Material icon.</summary>
    private static string GetEventIcon(string action) => action switch
    {
        "CREDIT" or "BATCH_SUBMITTED" => Icons.Material.Filled.AddModerator,
        "DEBIT"                     => Icons.Material.Filled.RemoveModerator,
        "LOGIN" or "LOGIN_SUCCESS"  => Icons.Material.Filled.VpnKey,
        _                            => Icons.Material.Filled.Hub
    };

    /// <summary>Maps an audit action string to its MudBlazor color for visual distinction.</summary>
    private static Color GetEventColor(string action) => action switch
    {
        "CREDIT" or "BATCH_SUBMITTED" => Color.Success,
        "DEBIT"                     => Color.Error,
        "LOGIN" or "LOGIN_SUCCESS"  => Color.Info,
        _                            => Color.Primary
    };

