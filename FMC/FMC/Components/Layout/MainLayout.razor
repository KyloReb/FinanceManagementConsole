@inherits LayoutComponentBase
@implements IDisposable
@using FMC.Shared.DTOs.Organization
@using FMC.Shared.Auth
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject OrganizationApiService OrgService

@*
    The main layout for the Finance Management Console.

    Provides the top AppBar with navigation controls, theme toggling, and the side Drawer.
*@
<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Color="Color.Inherit" Fixed="true" Style="border-bottom: 1px solid var(--mud-palette-divider);">
        @* Sidebar Toggle Control *@
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />

        @* Desktop View Logo and Title (Clickable) *@
        <MudHidden Breakpoint="Breakpoint.Xs">
            <div class="d-flex align-center ml-2 mr-4 cursor-pointer brand-link" @onclick='() => NavigationManager.NavigateTo("/", true)' 
                 style="user-select: none; transition: opacity 0.2s;">
                <MudImage Src="favicon.png" Width="30" Height="30" Class="mr-2" />
                <MudText Typo="Typo.h6">Finance Management Console</MudText>
            </div>
        </MudHidden>

        @* Mobile View Logo and Title (Clickable) *@
        <MudHidden Breakpoint="Breakpoint.SmAndUp">
             <div class="d-flex align-center ml-2 cursor-pointer brand-link" @onclick='() => NavigationManager.NavigateTo("/", true)'>
                <MudImage Src="favicon.png" Width="24" Height="24" Class="mr-2" />
                <MudText Typo="Typo.h6">FMC</MudText>
            </div>
        </MudHidden>
        
        <MudSpacer />

        @* ── NOTIFICATION BELL ── *@
        <AuthorizeView Roles="@($"{Roles.SuperAdmin},{Roles.CEO},{Roles.Maker},{Roles.Approver}")" Context="notifState">
            <Authorized>
                <MudMenu @bind-Open="_notifOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                         Dense="true" PopoverClass="fmc-notif-popover mud-elevation-25">
                    <ActivatorContent>
                        <div class="fmc-bell-wrap @(_notifOpen ? "fmc-bell-active" : "")" @onclick="ToggleNotif" @onclick:stopPropagation="true">
                            <MudIcon Icon="@Icons.Material.Filled.NotificationsNone" Class="fmc-bell-icon" />
                            @if (_alertCount > 0)
                            {
                                <span class="fmc-notif-badge">@(_alertCount > 9 ? "9+" : _alertCount.ToString())</span>
                            }
                        </div>
                    </ActivatorContent>
                    <ChildContent>
                        <div class="fmc-notif-panel">
                            <div class="fmc-notif-header">
                                <div>
                                    <MudText Typo="Typo.body2" Style="font-weight: 800;">System Alerts</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @(_alertCount == 0 ? "All systems operational" : $"{_alertCount} item{(_alertCount == 1 ? "" : "s")} need attention")
                                    </MudText>
                                </div>
                                @if (_alertCount > 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled"
                                             Style="font-size:0.65rem; font-weight:800; height:20px; padding:0 8px;">
                                        @_alertCount
                                    </MudChip>
                                }
                            </div>

                            @if (_alertCount == 0)
                            {
                                <div class="fmc-notif-empty">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color: var(--mud-palette-success); font-size: 2rem;" />
                                    <MudText Typo="Typo.body2" Style="font-weight:600; margin-top:8px;">No Issues Found</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">All tenants are healthy</MudText>
                                </div>
                            }
                            else
                            {
                                <div class="fmc-notif-body">
                                    @foreach (var notif in _notifications)
                                    {
                                        <div class="fmc-notif-item" @onclick="@(() => HandleAlertClick(notif))">
                                            <div class="fmc-notif-dot fmc-dot-@notif.Severity"></div>
                                            <div class="fmc-notif-item-content">
                                                <div class="d-flex align-center justify-space-between">
                                                    <MudText Typo="Typo.body2" Style="font-weight:700;">@notif.Title</MudText>
                                                    <span class="fmc-notif-count-badge fmc-badge-@notif.Severity">@notif.Count</span>
                                                </div>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="line-height:1.3;">@notif.Description</MudText>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            <div class="fmc-notif-footer">
                                <MudButton FullWidth="true" Variant="Variant.Text" Color="Color.Primary"
                                           Style="text-transform:none; font-weight:700; font-size:0.8rem;"
                                           Href="/">View Dashboard</MudButton>
                            </div>
                        </div>
                    </ChildContent>
                </MudMenu>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Context="authState">
            <Authorized>
                @* ACCOUNT DROPDOWN (Avatar & Name as Trigger) *@
                <MudMenu @bind-Open="_userMenuOpen" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" 
                         Dense="true" Class="ml-1" PopoverClass="mud-elevation-25">
                    <ActivatorContent>
                        <div class="d-flex align-center cursor-pointer pa-1 rounded-pill user-menu-trigger" @onclick="ToggleUserMenu" @onclick:stopPropagation="true">
                            <div class="fmc-nav-username d-flex align-center mr-3 ml-2">
                                <MudText Typo="Typo.body2">@GetDisplayName(authState.User)</MudText>
                            </div>
                            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Style="font-weight: 600;">
                                @GetInitials(authState.User)
                            </MudAvatar>
                        </div>
                    </ActivatorContent>
                    <ChildContent>
                            <div class="pa-4" style="min-width: 220px; background-color: var(--mud-palette-surface); border-bottom: 1px solid var(--mud-palette-divider);">
                                <div class="d-flex align-start mb-1">
                                    <MudText Typo="Typo.body2" Color="Color.Primary"><b>@GetDisplayName(authState.User)</b></MudText>
                                    @if (!string.IsNullOrEmpty(GetOrganization(authState.User)))
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Class="ml-1 px-1 py-0 ma-0 text-xs" Style="height: 16px; font-size: 0.65rem; align-self: flex-start; margin-top: -2px !important;">
                                            @GetOrganization(authState.User)
                                        </MudChip>
                                    }
                                </div>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="text-transform: uppercase; letter-spacing: 1px; font-weight: 500;">@GetRoleName(authState.User)</MudText>
                            </div>
                            <div class="py-2" style="background-color: var(--mud-palette-surface);">
                                <MudMenuItem Icon="@Icons.Material.Filled.Person" OnClick="@(() => NavigationManager.NavigateTo("/profile"))">Edit Profile</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Settings" OnClick="@(() => NavigationManager.NavigateTo("/settings"))">Account Settings</MudMenuItem>
                                
                                <AuthorizeView Roles="@FMC.Shared.Auth.Roles.SuperAdmin" Context="adminContext">
                                    <Authorized>
                                        <MudDivider Class="my-2" />
                                        <MudMenuItem Icon="@Icons.Material.Filled.CorporateFare" IconColor="Color.Info" OnClick="@(() => NavigationManager.NavigateTo("/admin/organizations"))">Manage System Tenants</MudMenuItem>
                                    </Authorized>
                                </AuthorizeView>

                                <MudDivider Class="my-2" />
                                <MudMenuItem Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error" OnClick="LogoutAsync"><b>Logout</b></MudMenuItem>
                            </div>
                        </ChildContent>
                    </MudMenu>
                </Authorized>
            <NotAuthorized>
                <MudButton Href="/login" Variant="Variant.Text" Color="Color.Inherit" Class="mr-2">Log In</MudButton>
                <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Primary" Class="mr-3">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    @* Navigation Sidebar - Wrapped in AuthorizeView to prevent guest visibility *@
    <AuthorizeView>
        <Authorized>
            <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Anchor="Anchor.Left" Style="border-right: 1px solid var(--mud-palette-divider);">
                <NavMenu />
            </MudDrawer>
        </Authorized>
    </AuthorizeView>

    @* Main Page Content *@
    <MudMainContent Class="pa-4 pt-16">
        @Body
    </MudMainContent>
</MudLayout>

<style>
    .brand-link:hover { opacity: 0.8; }
    .user-menu-trigger:hover {
        background-color: var(--mud-palette-action-default-hover);
        border-radius: 20px;
    }

    @@media (max-width: 960px) {
        .fmc-nav-username { display: none !important; }
    }

    /* ── Notification Bell ── */
    .fmc-bell-wrap {
        position: relative;
        width: 38px; height: 38px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 10px;
        cursor: pointer;
        margin-right: 6px;
        transition: background-color 0.15s;
    }
    .fmc-bell-wrap:hover, .fmc-bell-active {
        background-color: var(--mud-palette-action-default-hover);
    }
    .fmc-bell-icon {
        font-size: 1.3rem !important;
        color: var(--mud-palette-text-secondary);
        transition: color 0.15s;
    }
    .fmc-bell-wrap:hover .fmc-bell-icon { color: var(--mud-palette-text-primary); }
    .fmc-notif-badge {
        position: absolute;
        top: 4px; right: 4px;
        min-width: 16px; height: 16px;
        background: var(--mud-palette-error);
        color: #fff;
        border-radius: 50px;
        font-size: 0.55rem;
        font-weight: 900;
        display: flex; align-items: center; justify-content: center;
        padding: 0 4px;
        border: 2px solid var(--mud-palette-appbar-background);
        letter-spacing: 0;
    }

    /* ── Notification Popover Panel ── */
    .fmc-notif-popover .mud-popover { padding: 0 !important; }
    .fmc-notif-panel {
        width: 340px;
        background-color: var(--mud-palette-surface);
        border-radius: 16px;
        overflow: hidden;
    }
    .fmc-notif-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 20px 14px;
        border-bottom: 1px solid var(--mud-palette-divider);
        background-color: var(--mud-palette-background-grey);
    }
    .fmc-notif-empty {
        padding: 36px 20px;
        display: flex; flex-direction: column; align-items: center;
        text-align: center;
    }
    .fmc-notif-body { padding: 6px 0; }
    .fmc-notif-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 20px;
        cursor: pointer;
        border-bottom: 1px solid var(--mud-palette-divider);
        transition: background-color 0.15s;
    }
    .fmc-notif-item:last-child { border-bottom: none; }
    .fmc-notif-item:hover { background-color: var(--mud-palette-action-default-hover); }
    .fmc-notif-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
        margin-top: 5px;
    }
    .fmc-dot-error   { background: var(--mud-palette-error); }
    .fmc-dot-warning { background: var(--mud-palette-warning); }
    .fmc-dot-info    { background: var(--mud-palette-info); }
    .fmc-notif-item-content { flex: 1; min-width: 0; }
    .fmc-notif-count-badge {
        font-size: 0.6rem; font-weight: 800;
        padding: 1px 7px; border-radius: 50px;
        flex-shrink: 0;
    }
    .fmc-badge-error   { background: rgba(var(--mud-palette-error-rgb), 0.1);   color: var(--mud-palette-error); }
    .fmc-badge-warning { background: rgba(var(--mud-palette-warning-rgb), 0.1); color: var(--mud-palette-warning); }
    .fmc-badge-info    { background: rgba(var(--mud-palette-info-rgb), 0.1);    color: var(--mud-palette-info); }
    .fmc-notif-footer {
        padding: 10px 12px;
        border-top: 1px solid var(--mud-palette-divider);
        background-color: var(--mud-palette-background-grey);
    }
</style>

@code {
    private bool _drawerOpen = true;
    private bool _userMenuOpen = false;
    private bool _notifOpen = false;

    // Notification state
    private int _alertCount;
    private record NotifItem(long Id, string Title, string Description, string Href, string Severity, int Count);
    private List<NotifItem> _notifications = new();

    private async Task HandleAlertClick(NotifItem notif)
    {
        _notifOpen = false;

        // Optimistic UI updates
        _notifications.RemoveAll(n => n.Id == notif.Id && n.Title == notif.Title);
        _alertCount = _notifications.Count;
        StateHasChanged();

        if (notif.Id > 0)
        {
            // Background enterprise resolution for persistent system alerts
            await OrgService.ResolveAlertAsync(notif.Id);
        }
        OrgService.NotifyDataChanged(); // Let other components know an indicator was dismissed

        if (!string.IsNullOrEmpty(notif.Href))
            NavigationManager.NavigateTo(notif.Href);
    }

    private void ToggleNotif() => _notifOpen = !_notifOpen;
    private void ToggleUserMenu() => _userMenuOpen = !_userMenuOpen;

    protected override async Task OnInitializedAsync()
    {
        OrgService.OnDataChanged += HandleDataChanged;
        await LoadAlerts();
    }

    private async void HandleDataChanged()
    {
        await LoadAlerts();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAlerts()
    {
        try
        {
            _notifications.Clear();
            
            var authState = await AuthService.GetAuthenticationStateAsync();
            var user = authState.User;

            // 1. Fetch System Alerts (SuperAdmin only)
            if (user.IsInRole(Roles.SuperAdmin))
            {
                var dbAlerts = await OrgService.GetActiveAlertsAsync();
                foreach (var alert in dbAlerts)
                {
                    _notifications.Add(new NotifItem(
                        alert.Id,
                        alert.Title, 
                        alert.Message, 
                        alert.EntityType == "Organization" ? $"/admin/organizations/{alert.EntityId}" : "/admin/audit",
                        alert.Severity.ToString().ToLower(),
                        1
                    ));
                }
            }

            // 2. Fetch Workflow Alerts (CEO, Maker, Approver)
            if (user.IsInRole(Roles.CEO) || user.IsInRole(Roles.Maker) || user.IsInRole(Roles.Approver))
            {
                var wfAlerts = await OrgService.GetWorkflowAlertsAsync();
                foreach (var alert in wfAlerts)
                {
                    var href = alert.EntityId == "Pending" ? "/pending-requests" : "/transactions";
                    _notifications.Add(new NotifItem(
                        0, // Synthetic ID for transient workflow alerts
                        alert.Title,
                        alert.Message,
                        href,
                        alert.Severity.ToString().ToLower(),
                        1
                    ));
                }
            }

            _alertCount = _notifications.Count;
        }
        catch { /* Fallback for pre-rendering or auth latency */ }
    }

    private async Task LogoutAsync()
    {
        await AuthService.Logout("current");
        NavigationManager.NavigateTo("/login", true);
    }

    void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private string GetDisplayName(System.Security.Claims.ClaimsPrincipal user)
    {
        var firstName = user.FindFirst("firstName")?.Value;
        var lastName  = user.FindFirst("lastName")?.Value;
        if (!string.IsNullOrWhiteSpace(firstName) || !string.IsNullOrWhiteSpace(lastName))
            return $"{firstName} {lastName}".Trim();
        return user.Identity?.Name ?? "User";
    }

    private string GetInitials(System.Security.Claims.ClaimsPrincipal user)
    {
        var firstName = user.FindFirst("firstName")?.Value;
        var lastName  = user.FindFirst("lastName")?.Value;
        if (!string.IsNullOrWhiteSpace(firstName) && !string.IsNullOrWhiteSpace(lastName))
            if (firstName.Length > 0 && lastName.Length > 0)
                return $"{firstName[0]}{lastName[0]}".ToUpper();
        var name = user.Identity?.Name ?? "U";
        return name.Length > 0 ? name[0].ToString().ToUpper() : "U";
    }

    private string GetRoleName(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
            ?? user.FindFirst("role")?.Value
            ?? "User";
    }

    private string GetOrganization(System.Security.Claims.ClaimsPrincipal user)
        => user.FindFirst("organization")?.Value ?? string.Empty;

    public void Dispose() 
    { 
        OrgService.OnDataChanged -= HandleDataChanged;
    }
}
