@using FMC.Shared.DTOs.Admin
@using FMC.Services.Api
@inject OrganizationApiService OrgService
@inject IJSRuntime JSRuntime
@implements IDisposable

<style>
    .fmc-alert-surface { 
        border-radius: 20px; border: 1px solid var(--mud-palette-divider); 
        background: var(--mud-palette-surface); overflow: hidden;
        box-shadow: 0 4px 25px rgba(0,0,0,0.03); margin-bottom: 24px;
    }
    .fmc-alert-header-area { 
        padding: 16px 24px; background: var(--mud-palette-background-grey); 
        border-bottom: 1px solid var(--mud-palette-divider);
        display: flex; align-items: center; justify-content: space-between;
    }
    .fmc-alert-hub-icon { 
        width: 36px; height: 36px; background: rgba(var(--mud-palette-info-rgb), 0.1); 
        border-radius: 10px; display: flex; align-items: center; justify-content: center;
    }
    .fmc-alert-list-hub { display: flex; flex-direction: column; }
    .fmc-alert-row-hub { 
        padding: 16px 24px; display: flex; align-items: center; gap: 16px;
        border-bottom: 1px solid var(--mud-palette-divider); transition: background 0.2s;
        position: relative; flex-wrap: wrap;
    }
    @@media (max-width: 600px) {
        .fmc-alert-row-hub { flex-direction: column; align-items: flex-start; gap: 12px; }
        .fmc-alert-actions-hub { align-self: flex-end; width: 100%; justify-content: flex-end; }
    }
    .fmc-alert-row-hub:last-child { border-bottom: none; }
    .fmc-alert-row-hub:hover { background: var(--mud-palette-action-default-hover); }
    
    .fmc-alert-indicator-hub { position: absolute; left: 0; top: 0; bottom: 0; width: 4px; }
    .fmc-alert-indicator-hub.critical { background: var(--mud-palette-error); }
    .fmc-alert-indicator-hub.warning { background: var(--mud-palette-warning); }
    .fmc-alert-indicator-hub.info { background: var(--mud-palette-info); }

    .fmc-alert-content-hub { flex: 1; min-width: 0; }
    .fmc-alert-entity-title { font-weight: 850; font-size: 0.9rem; }
    .fmc-alert-tag-hub { 
        font-size: 0.6rem; font-weight: 900; padding: 2px 8px; border-radius: 4px; 
        letter-spacing: 0.05em; text-transform: uppercase; margin-right: 8px;
    }
    .fmc-tag-critical { background: rgba(var(--mud-palette-error-rgb), 0.1); color: var(--mud-palette-error); }
    .fmc-tag-warning { background: rgba(var(--mud-palette-warning-rgb), 0.1); color: var(--mud-palette-warning); }
    .fmc-tag-info { background: rgba(var(--mud-palette-info-rgb), 0.1); color: var(--mud-palette-info); }

    .fmc-alert-actions-hub { display: flex; align-items: center; gap: 8px; }
</style>

@if (!_panelDismissed && AnyVisible)
{
    <div class="fmc-alert-surface">
        <div class="fmc-alert-header-area">
            <div class="d-flex align-center gap-3">
                <div class="fmc-alert-hub-icon">
                    <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Color="Color.Info" Size="Size.Small" />
                </div>
                <div>
                    <div class="d-flex align-center gap-1">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 900; letter-spacing: -0.02em;">Intelligence Oversight</MudText>
                        <MudIconButton Icon="@(_isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" 
                                       Size="Size.Small" OnClick="@(() => _isExpanded = !_isExpanded)" 
                                       Style="padding: 2px;" />
                    </div>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@VisibleAlertsCount operational required @(VisibleAlertsCount == 1 ? "action" : "actions") detected</MudText>
                </div>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => DismissPanel())" />
        </div>

        <MudCollapse Expanded="_isExpanded">
            <div class="fmc-alert-list-hub">
                @foreach (var alert in _alerts.Where(a => !_dismissed.Contains(a.EntityId ?? "")))
                {
                    var cssClass = alert.Severity is AlertSeverityDto.Critical or AlertSeverityDto.Security ? "critical" :
                                   alert.Severity == AlertSeverityDto.Warning ? "warning" : "info";
                    
                    var tagColor = alert.Severity is AlertSeverityDto.Critical or AlertSeverityDto.Security ? "fmc-tag-critical" :
                                   alert.Severity == AlertSeverityDto.Warning ? "fmc-tag-warning" : "fmc-tag-info";

                    var btnColor = alert.Severity is AlertSeverityDto.Critical or AlertSeverityDto.Security ? Color.Error :
                                   alert.Severity == AlertSeverityDto.Warning ? Color.Warning : Color.Info;
                    
                    var href = alert.EntityId != null && alert.EntityId.StartsWith("Pending") ? "/pending-requests" : "/transactions";
                    var entityId = alert.EntityId ?? "";
                    // CEO: read-only visibility — cannot resolve, that's the Approver's job
                    bool isPending = alert.EntityId != null && alert.EntityId.StartsWith("Pending");
                    bool isThreshold = alert.EntityId != null && alert.EntityId.StartsWith("Threshold");
                    var actionText = IsCeo ? "View" : (isPending ? "Resolve" : "Acknowledge");
                    var actionVariant = IsCeo ? Variant.Outlined : Variant.Filled;
                    var badgeLabel = isPending ? "ACTION REQUIRED" :
                                     isThreshold ? "CAPACITY ALERT" : "COMPLETED";

                    <div class="fmc-alert-row-hub">
                        <div class="fmc-alert-indicator-hub @cssClass"></div>
                        <div class="fmc-alert-content-hub">
                            <div class="d-flex align-center mb-1">
                                <span class="fmc-alert-tag-hub @tagColor">@badgeLabel</span>
                                <MudText Typo="Typo.body2" Class="fmc-alert-entity-title">@alert.Title</MudText>
                            </div>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @alert.Message
                            </MudText>
                        </div>
                        <div class="fmc-alert-actions-hub">
                            @if (IsCeo)
                            {
                                <MudButton Variant="Variant.Outlined" Color="@btnColor" Size="Size.Small"
                                           Href="@href"
                                           Style="border-radius:8px; text-transform:none; font-weight:800; height:32px;">View</MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Filled" Color="@btnColor" Size="Size.Small"
                                           OnClick="@(() => DismissAlert(entityId))"
                                           Style="border-radius:8px; text-transform:none; font-weight:800; height:32px;">@actionText</MudButton>
                            }
                        </div>
                    </div>
                }
            </div>
        </MudCollapse>
    </div>
}

@code {
    [Parameter] public bool Loading { get; set; }
    [Parameter] public bool IsCeo { get; set; }
    
    private bool _panelDismissed;
    private bool _isExpanded = true;
    private HashSet<string> _dismissed = new();
    private List<SystemAlertDto> _alerts = new();

    private bool AnyVisible => _alerts.Any(a => !_dismissed.Contains(a.EntityId ?? ""));
    private int VisibleAlertsCount => _alerts.Count(a => !_dismissed.Contains(a.EntityId ?? ""));

    private async Task DismissAlert(string entityId)
    {
        _dismissed.Add(entityId);
        await SaveDismissed();
        OrgService.NotifyDataChanged();
        StateHasChanged();
    }

    private async Task SaveDismissed()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "fmc_wf_dismissed", System.Text.Json.JsonSerializer.Serialize(_dismissed));
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "fmc_wf_panel_dismissed", _panelDismissed.ToString());
        }
        catch { }
    }

    private async Task DismissPanel()
    {
        _panelDismissed = true;
        await SaveDismissed();
        OrgService.NotifyDataChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var dictStr = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "fmc_wf_dismissed");
                if (!string.IsNullOrEmpty(dictStr))
                {
                    _dismissed = System.Text.Json.JsonSerializer.Deserialize<HashSet<string>>(dictStr) ?? new();
                }

                // CRITICAL: Pending_* and Threshold_* alerts are action-required.
                // They must NEVER be permanently suppressed — remove them from the
                // dismissed set on every new session so the Approver always sees them
                // until they are actually resolved (approved/rejected).
                var actionRequiredPrefixes = new[] { "Pending_", "Threshold_" };
                var toRestore = _dismissed
                    .Where(id => actionRequiredPrefixes.Any(prefix => id.StartsWith(prefix)))
                    .ToList();

                bool restoredAny = false;
                foreach (var id in toRestore)
                {
                    _dismissed.Remove(id);
                    restoredAny = true;
                }

                if (restoredAny)
                {
                    // Persist the cleaned dismissed set (only informational alerts remain)
                    try { await JSRuntime.InvokeVoidAsync("localStorage.setItem", "fmc_wf_dismissed", System.Text.Json.JsonSerializer.Serialize(_dismissed)); } catch { }
                }

                // Restore panel-dismissed state, but always override it if there are active alerts
                var panelClosedStr = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "fmc_wf_panel_dismissed");
                if (!string.IsNullOrEmpty(panelClosedStr) && bool.TryParse(panelClosedStr, out bool closed))
                {
                    _panelDismissed = closed;
                }

                // If alerts exist that are not individually dismissed, always show the panel
                if (_alerts.Any(a => !_dismissed.Contains(a.EntityId ?? "")))
                {
                    _panelDismissed = false;
                    try { await JSRuntime.InvokeVoidAsync("localStorage.setItem", "fmc_wf_panel_dismissed", "false"); } catch { }
                }

                StateHasChanged();
            }
            catch { }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        OrgService.OnDataChanged += HandleDataChanged;
        await LoadAlerts();
    }

    private async void HandleDataChanged()
    {
        await LoadAlerts();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAlerts()
    {
        try
        {
            var data = await OrgService.GetWorkflowAlertsAsync();
            _alerts = data.ToList();

            // If the panel was dismissed but new undismissed alerts have arrived,
            // resurface it so the Approver is never silently blocked.
            if (_panelDismissed && _alerts.Any(a => !_dismissed.Contains(a.EntityId ?? "")))
            {
                _panelDismissed = false;
                try { await JSRuntime.InvokeVoidAsync("localStorage.setItem", "fmc_wf_panel_dismissed", "false"); } catch { }
            }
        }
        catch { }
    }

    public void Dispose()
    {
        OrgService.OnDataChanged -= HandleDataChanged;
    }
}
