<script type="module" src="@Assets["Components/Layout/ReconnectModal.razor.js"]"></script>

<div id="components-reconnect-modal" data-nosnippet>
    <div class="components-reconnect-container">
        <div class="components-rejoining-animation" aria-hidden="true">
            <div></div>
            <img src="favicon.png" alt="FMC Logo" class="components-reconnect-logo-img" />
        </div>
        
        <p>
            <span class="components-reconnect-first-attempt-visible">Reconnecting to the server...</span>
            <span class="components-reconnect-repeated-attempt-visible">Reconnect failed. Retrying in<span id="components-seconds-to-next-attempt"></span>s...</span>
            <span class="components-reconnect-failed-visible">Connection lost. Please retry or reload.</span>
            <span class="components-pause-visible">Session paused by the server.</span>
            <span class="components-resume-failed-visible">Failed to resume session. Please reload.</span>
        </p>

        <button id="components-reconnect-button" class="components-reconnect-failed-visible">Retry</button>
        <button id="components-resume-button" class="components-pause-visible components-resume-failed-visible">Resume</button>
    </div>
</div>
