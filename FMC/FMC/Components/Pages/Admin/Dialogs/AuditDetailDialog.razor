@using MudBlazor
@using FMC.Shared.DTOs.Admin
@inject ISnackbar Snackbar

<MudDialog Class="fmc-audit-dialog">
    <TitleContent>
        <div class="d-flex align-center gap-3">
            <MudIcon Icon="@GetEventIcon(Log.Action)" Color="@GetEventColor(Log.Action)" Size="Size.Large" />
            <div class="d-flex flex-column">
                <MudText Typo="Typo.h6" Style="font-weight:900;">Forensic Event Trace</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Internal Sequence ID: #@Log.Id.ToString().PadLeft(6, '0')</MudText>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="fmc-detail-container px-2">
            @* CORE IDENTITY *@
            <div class="detail-section mb-6">
                <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6;">Event Identity</MudText>
                <div class="d-flex justify-space-between align-center mt-2 pa-4 fmc-highlight-box">
                    <div>
                        <MudText Style="font-weight:900; font-size:1.1rem; color: var(--mud-palette-primary);">@Log.Action</MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">@Log.CreatedAt.ToString("MMMM dd, yyyy 'at' HH:mm:ss.fff")</MudText>
                    </div>
                    @if (Log.Amount.HasValue)
                    {
                        <div class="text-right">
                            <MudText Style="font-weight:900; font-size:1.2rem; font-family:'JetBrains Mono',monospace;" 
                                     Color="@(Log.Action == "CREDIT" ? Color.Success : Color.Error)">
                                @(Log.Action == "CREDIT" ? "+" : "-")@Log.Amount.Value.ToString("N2")
                            </MudText>
                            <MudText Typo="Typo.caption">Currency Magnitude</MudText>
                        </div>
                    }
                </div>
            </div>

            <MudDivider Class="mb-6 opacity-50" />

            @* ACTOR & CONTEXT *@
            <MudGrid Class="mb-6">
                <MudItem xs="6">
                    <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6;">Operator / Actor</MudText>
                    <div class="d-flex align-center gap-3 mt-2">
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">
                            @(GetInitial(GetFriendlyName()))
                        </MudAvatar>
                        <div>
                            <MudText Style="font-weight:800; font-size:0.9rem;">@GetFriendlyName()</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Authenticated User</MudText>
                        </div>
                    </div>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6;">Target Context</MudText>
                    <div class="mt-2">
                        <MudText Style="font-weight:800; font-size:0.9rem;">@(Log.EntityName ?? Log.Organization ?? "Global Infrastructure")</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Tenant / Entity</MudText>
                    </div>
                </MudItem>
            </MudGrid>

            @* ── BATCH BREAKDOWN (Forensic Detail) ── *@
            @if (Log.Action == "BATCH_SUBMITTED" || (Log.Amount.HasValue && Log.EntityName.Contains("Bulk")))
            {
                <div class="detail-section mb-6">
                    <div class="d-flex align-center gap-2 mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle2" Style="font-weight: 900; letter-spacing: 0.02em;">BATCH BREAKDOWN</MudText>
                    </div>
                    
                    <div class="fmc-breakdown-surface">
                        @if (TryGetBatchData(out var batchData))
                        {
                            <MudTable Items="@batchData.Items" Dense="true" Hover="true" Elevation="0" Style="background: transparent;">
                                <HeaderContent>
                                    <MudTh Style="font-size: 0.65rem; font-weight: 900; opacity: 0.6;">CARDHOLDER</MudTh>
                                    <MudTh Style="font-size: 0.65rem; font-weight: 900; opacity: 0.6; text-align: right;">AMOUNT</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="item">
                                    <MudTd>
                                        <div class="d-flex flex-column">
                                            <MudText Typo="Typo.body2" Style="font-weight: 700; font-size: 0.8rem;">@item.Subscriber</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.65rem;">@MaskAccount(item.CardNumber)</MudText>
                                        </div>
                                    </MudTd>
                                    <MudTd Style="text-align: right;">
                                        <MudText Typo="Typo.body2" Style="font-family:'JetBrains Mono',monospace; font-weight: 800; font-size: 0.85rem;" 
                                                 Color="@(batchData.IsCredit ? Color.Success : Color.Error)">
                                            @(batchData.IsCredit ? "+" : "-")@item.Amount.ToString("N2")
                                        </MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="pa-4">
                                <div class="d-flex justify-space-between align-center mb-3">
                                    <div>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:800;">TOTAL MAGNITUDE</MudText>
                                        <MudText Style="font-weight:900; font-family:'JetBrains Mono',monospace;">@Log.Amount?.ToString("C")</MudText>
                                    </div>
                                    <div class="text-right">
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:800;">OPERATION TYPE</MudText>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Style="font-weight:900; margin:0;">BULK_ALLOTMENT</MudChip>
                                    </div>
                                </div>
                                <MudDivider Class="mb-3 opacity-20" />
                                <MudText Typo="Typo.caption" Style="font-style:italic; opacity:0.7;">
                                    Forensic Note: Detailed itemization is available in the primary transactional ledger.
                                </MudText>
                            </div>
                        }
                    </div>
                </div>
            }

            @* TELEMETRY *@
            <div class="detail-section mb-6">
                <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6;">Network Telemetry</MudText>
                <div class="mt-2 pa-4 fmc-surface-box">
                    <div class="d-flex justify-space-between align-center mb-2">
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Source IP</MudText>
                        <MudText Typo="Typo.body2" Style="font-family:monospace; font-weight:700;">@Log.IpAddress</MudText>
                    </div>
                    <div class="d-flex justify-space-between align-start">
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">Digital Fingerprint</MudText>
                        <MudText Typo="Typo.caption" Style="max-width:200px; text-align:right;">@Log.Device</MudText>
                    </div>
                </div>
            </div>

            @* METADATA / MEMO *@
            <div class="detail-section">
                <MudText Typo="Typo.overline" Style="letter-spacing:0.1em; font-weight:800; opacity:0.6;">Forensic Metadata</MudText>
                <MudPaper Elevation="0" Class="mt-2 pa-4 fmc-memo-box">
                    <MudText Typo="Typo.body2" Style="font-style:italic;">@GetMemo()</MudText>
                </MudPaper>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Default" Style="text-transform:none; font-weight:700; border-radius:10px;">Dismiss</MudButton>
        <MudButton OnClick="CopyRef" Variant="Variant.Filled" Color="Color.Primary" 
                   Style="text-transform:none; font-weight:700; border-radius:10px;">Copy Event ID</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .fmc-audit-dialog { border-radius: 20px !important; }
    .fmc-highlight-box { background: rgba(var(--mud-palette-primary-rgb), 0.05); border-radius: 12px; border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.1); }
    .fmc-surface-box { background: var(--mud-palette-background-grey); border-radius: 12px; border: 1px dashed var(--mud-palette-divider); }
    .fmc-memo-box { background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-divider); border-radius: 12px; color: var(--mud-palette-text-secondary); }
    .fmc-breakdown-surface { background: rgba(var(--mud-palette-info-rgb), 0.02); border-radius: 12px; border: 1px solid var(--mud-palette-divider); max-height: 240px; overflow-y: auto; }
    .opacity-50 { opacity: 0.5; }
    .opacity-20 { opacity: 0.2; }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public AuditLogDto Log { get; set; } = default!;

    private void Close() => MudDialog.Cancel();

    private string GetFriendlyName()
    {
        // Prioritize actual UserName from the system, fallback to PerformedBy if it's not a Guid
        if (!string.IsNullOrWhiteSpace(Log.UserName) && Log.UserName != "Unknown") return Log.UserName;
        
        var name = Log.PerformedBy ?? "System";
        if (Guid.TryParse(name, out _))
        {
            return "Administrative Operator";
        }
        return name;
    }

    private string GetMemo()
    {
        if (string.IsNullOrWhiteSpace(Log.Details)) return Log.Label ?? "No forensic metadata recorded.";
        
        // If details is JSON (starts with {), show the label instead to avoid showing raw JSON in the memo
        if (Log.Details.Trim().StartsWith("{")) return Log.Label ?? "Structured Batch Data Record";
        
        return Log.Details;
    }

    private bool TryGetBatchData(out BatchDetail? data)
    {
        data = null;
        if (string.IsNullOrWhiteSpace(Log.Details) || !Log.Details.Trim().StartsWith("{")) return false;
        
        try {
            data = System.Text.Json.JsonSerializer.Deserialize<BatchDetail>(Log.Details, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            return data != null;
        } catch { return false; }
    }

    private string MaskAccount(string? account)
    {
        if (string.IsNullOrEmpty(account)) return "N/A";
        if (account.Length <= 10) return account;
        return $"{account[..6]}{new string('*', account.Length - 10)}{account[^4..]}";
    }

    private char GetInitial(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return 'S';
        var trimmed = name.Trim();
        return trimmed.Length > 0 ? trimmed.ToUpper()[0] : 'S';
    }

    private void CopyRef()
    {
        Snackbar.Add("Event reference copied to clipboard", Severity.Info);
    }

    private string GetEventIcon(string action)
    {
        return action switch {
            "CREDIT" or "BATCH_SUBMITTED" => Icons.Material.Filled.AddModerator,
            "DEBIT" => Icons.Material.Filled.RemoveModerator,
            "LOGIN" or "LOGIN_SUCCESS" => Icons.Material.Filled.VpnKey,
            _ => Icons.Material.Filled.Hub
        };
    }

    private Color GetEventColor(string action)
    {
        return action switch {
            "CREDIT" or "BATCH_SUBMITTED" => Color.Success,
            "DEBIT" => Color.Error,
            "LOGIN" or "LOGIN_SUCCESS" => Color.Info,
            _ => Color.Primary
        };
    }

    public class BatchDetail {
        public bool IsCredit { get; set; }
        public List<BatchItem> Items { get; set; } = new();
    }
    public class BatchItem {
        public string? CardNumber { get; set; }
        public decimal Amount { get; set; }
        public string? Subscriber { get; set; }
    }
}
