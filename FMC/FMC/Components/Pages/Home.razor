    private void OnGaugeScrub(ChangeEventArgs e, Guid orgId, decimal totalBalance)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any,
                            System.Globalization.CultureInfo.InvariantCulture, out var scrubPct))
        {
            _scrubPositions[orgId] = scrubPct;
            _scrubAmounts[orgId]   = (decimal)(scrubPct / 100.0) * totalBalance;
            _scrubActive[orgId]    = true;
            StateHasChanged();
        }
    }

