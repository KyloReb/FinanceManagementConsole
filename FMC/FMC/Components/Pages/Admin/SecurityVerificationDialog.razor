@using MudBlazor
@using FMC.Services.Api
@using Microsoft.AspNetCore.Components.Authorization

<MudDialog Class="fmc-security-dialog">
    <DialogContent>
        <div class="pa-6 text-center">
            <div class="fmc-security-icon-wrap mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Primary" Size="Size.Large" />
            </div>
            <MudText Typo="Typo.h5" Style="font-weight: 800; letter-spacing: -0.5px;">Security Verification</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2 px-4">
                You are about to authorize a critical financial adjustment. Please re-enter your administrator password to proceed.
            </MudText>

            <div class="mt-8 text-left">
                <MudTextField @bind-Value="_password" 
                               Label="Administrator Password" 
                               Variant="Variant.Outlined" 
                               InputType="@PasswordInput" 
                               Adornment="Adornment.End" 
                               AdornmentIcon="@PasswordInputIcon"
                               OnAdornmentClick="TogglePasswordVisibility"
                               AutoFocus="true"
                               OnKeyDown="HandleKeyDown"
                               FullWidth="true" />
            </div>
            
            @if (_showErrorOverlay)
            {
                <div class="fmc-security-error-overlay">
                    <div class="fmc-security-error-inner">
                        <div class="fmc-security-error-icon">
                            <div class="fmc-glow-pulse"></div>
                            <MudIcon Icon="@Icons.Material.Filled.GppBad" Style="font-size: 2.5rem; color: inherit;" />
                        </div>
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 900; color: #ef5350;">@_errorTitle</MudText>
                        <MudText Typo="Typo.body2" Style="opacity: 0.8; max-width: 280px; line-height: 1.5;">@_errorSubtext</MudText>
                        <MudButton Variant="Variant.Filled"
                                   Style="margin-top: 16px; background-color: #c62828; color: #fff; font-weight: 800; text-transform: none; border-radius: 8px; min-width: 120px;"
                                   OnClick="@(() => { _showErrorOverlay = false; StateHasChanged(); })">Try Again</MudButton>
                    </div>
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <div class="d-flex justify-center w-100 pb-8 px-8">
            <MudButton OnClick="Cancel" Variant="Variant.Text" Class="mr-4" Style="text-transform:none; font-weight:600;">Cancel</MudButton>
            <MudButton Color="Color.Primary" 
                       Variant="Variant.Filled" 
                       OnClick="Submit" 
                       Disabled="@IsButtonDisabled"
                       Style="text-transform:none; font-weight:700; border-radius:12px; height:48px; min-width:160px;">
                @if (_isProcessing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Verifying...</span>
                }
                else if (SecurityState.IsLockedOut)
                {
                    <span>Wait @(SecurityState.RemainingSeconds)s...</span>
                }
                else
                {
                    <span>Authorize Action</span>
                }
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
    .fmc-security-dialog {
        border-radius: 24px !important;
        max-width: 440px !important;
    }
    .fmc-security-icon-wrap {
        width: 80px;
        height: 80px;
        border-radius: 20px;
        background: var(--mud-palette-primary-hover);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }

    .fmc-security-error-overlay {
        position: absolute;
        inset: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(8px) saturate(150%);
        background: rgba(var(--mud-palette-surface-rgb), 0.8);
        animation: fmc-overlay-in 0.3s ease-out;
    }
    .fmc-security-error-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 40px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        max-width: 320px;
        width: 90%;
        animation: fmc-modal-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .fmc-security-error-icon {
        width: 64px;
        height: 64px;
        border-radius: 16px;
        background: rgba(239, 68, 68, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
        position: relative;
        box-shadow: 0 0 20px rgba(239, 68, 68, 0.2);
        color: #ef4444;
        animation: fmc-icon-entrance 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0.1s both;
    }

    .fmc-glow-pulse {
        position: absolute;
        inset: -3px;
        border-radius: 18px;
        opacity: 0;
        border: 2px solid #ef4444;
        animation: fmc-pulse-ring 2s cubic-bezier(0.24, 0, 0.38, 1) infinite;
    }

    @@keyframes fmc-overlay-in { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes fmc-modal-pop {
        from { opacity: 0; transform: scale(0.9) translateY(10px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }
    @@keyframes fmc-icon-entrance {
        from { transform: scale(0) rotate(-20deg); opacity: 0; }
        to { transform: scale(1) rotate(0); opacity: 1; }
    }
    @@keyframes fmc-pulse-ring {
        0% { transform: scale(0.95); opacity: 0.8; }
        50% { transform: scale(1.1); opacity: 0; }
        100% { transform: scale(0.95); opacity: 0; }
    }
</style>

@code {
    [Inject] private AuthService AuthService { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private SecurityStateService SecurityState { get; set; } = default!;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private string _password = "";
    private bool _isProcessing;
    private bool _showPassword;
    
    private bool _showErrorOverlay;
    private string _errorTitle = "";
    private string _errorSubtext = "";

    private void Cancel() => MudDialog.Cancel();

    private InputType PasswordInput => _showPassword ? InputType.Text : InputType.Password;
    private string PasswordInputIcon => _showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !IsButtonDisabled)
        {
            await Submit();
        }
    }

    private async Task Submit()
    {
        if (IsButtonDisabled) return;

        try
        {
            _isProcessing = true;
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var emailClaim = authState.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.Email || c.Type == "email")?.Value;

            if (string.IsNullOrEmpty(emailClaim))
            {
                ShowErrorOverlay("SESSION EXPIRED", "Identity session failure. Please re-login to the console.");
                return;
            }

            var request = new FMC.Shared.DTOs.Auth.LoginRequestDto 
            { 
                Identifier = emailClaim, 
                Password = _password,
                IsStepUp = true 
            };

            var authResult = await AuthService.Login(request);
            if (authResult == null)
            {
                SecurityState.RecordFailure();
                
                if (SecurityState.IsLockedOut)
                {
                    ShowErrorOverlay("ACCOUNT LOCKED", "Too many failed attempts. A security cool-down is now active.");
                }
                else
                {
                    ShowErrorOverlay("VERIFICATION FAILED", $"Incorrect password. {3 - SecurityState.FailedAttempts} attempts remaining.");
                }
                return;
            }

            SecurityState.Reset();
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            ShowErrorOverlay("SECURITY CHECK ERROR", ex.Message);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void ShowErrorOverlay(string title, string subtext)
    {
        _errorTitle = title;
        _errorSubtext = subtext;
        _showErrorOverlay = true;
        StateHasChanged();
    }

    private bool IsButtonDisabled => string.IsNullOrWhiteSpace(_password) || _isProcessing || SecurityState.IsLockedOut;

    protected override void OnInitialized()
    {
        // Start a timer to refresh the state during lockout
        _ = Task.Run(async () => {
            while (true) {
                if (SecurityState.IsLockedOut) await InvokeAsync(StateHasChanged);
                await Task.Delay(1000);
            }
        });
    }
}
