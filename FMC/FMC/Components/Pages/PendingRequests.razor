@page "/pending-requests"
@using FMC.Shared.DTOs
@using FMC.Shared.Auth
@using FMC.Services.Api
@using FMC.Services
@using FMC.Components.Pages.Admin
@using FMC.Components.Pages.Admin.Dialogs
@inject OrganizationApiService OrgService
@inject IReportService ReportGen
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@attribute [Authorize(Roles = "SuperAdmin,CEO,Maker,Approver")]

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-12">
    <div class="d-flex align-center justify-space-between mb-8">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 950; letter-spacing: -0.04em; text-transform: uppercase;" Color="Color.Primary">Operations Center</MudText>
            <MudText Typo="Typo.subtitle1" Style="font-weight: 500; opacity: 0.5;">Comprehensive financial settlement and authorization queue.</MudText>
        </div>
        <div class="d-flex gap-3">
            @if (_isMaker)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => OpenUserSelection(true))"
                           Style="border-radius: 12px; height: 52px; font-weight: 800; text-transform:none; box-shadow: 0 4px 15px rgba(var(--mud-palette-primary-rgb), 0.2);">New Credit</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Surface" StartIcon="@Icons.Material.Filled.Remove" OnClick="@(() => OpenUserSelection(false))"
                           Style="border-radius: 12px; height: 52px; font-weight: 800; text-transform:none; border: 1px solid var(--mud-palette-divider);">New Debit</MudButton>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="/"
                       Style="border-radius: 12px; height: 52px; font-weight: 800; text-transform:none;">Dashboard</MudButton>
        </div>
    </div>

    <div class="fmc-integrated-ledger">
        <div class="fmc-custom-tab-bar">
            <button class="fmc-tab-btn @(GetActiveCls(0))" @onclick="@(() => SetTab(0))">
                <MudIcon Icon="@Icons.Material.Filled.List" Size="Size.Small" Class="mr-2" />
                ALL
            </button>
            <button class="fmc-tab-btn @(GetActiveCls(1))" @onclick="@(() => SetTab(1))">
                <MudIcon Icon="@Icons.Material.Filled.PendingActions" Size="Size.Small" Class="mr-2" />
                ACTION REQUIRED
            </button>
            <button class="fmc-tab-btn @(GetActiveCls(2))" @onclick="@(() => SetTab(2))">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-2" />
                AUTHORIZED
            </button>
            <button class="fmc-tab-btn @(GetActiveCls(3))" @onclick="@(() => SetTab(3))">
                <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Class="mr-2" />
                DENIED
            </button>
        </div>

        <div class="fmc-tab-content pa-4">
            @if (_activeIndex == 0)
            {
                @RenderTable(_allTransactions, "Global")
            }
            else if (_activeIndex == 1)
            {
                @RenderTable(_pendingTransactions, "Pending")
            }
            else if (_activeIndex == 2)
            {
                @RenderTable(_approvedTransactions, "Authorized")
            }
            else if (_activeIndex == 3)
            {
                @RenderTable(_rejectedTransactions, "Denied")
            }
        </div>
    </div>
</MudContainer>

@code {
    private RenderFragment RenderTable(List<TransactionDto> items, string status) => __builder => {
        if (_loading)
        {
            <div class="d-flex justify-center pa-12">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            </div>
        }
        else if (!items.Any())
        {
            <MudPaper Class="pa-16 d-flex flex-column align-center justify-center text-center fmc-empty-state" Elevation="0">
                <MudIcon Icon="@(status == "Pending" ? Icons.Material.Filled.AssignmentTurnedIn : Icons.Material.Filled.History)" 
                         Size="Size.Large" Style="font-size: 6rem; opacity: 0.05;" />
                <MudText Typo="Typo.h5" Class="mt-6" Style="font-weight: 900; opacity: 0.4;">Queue is Empty</MudText>
                <MudText Typo="Typo.body1" Class="mud-text-secondary" Style="max-width:300px;">
                    @(status == "Pending" ? "There are no records requiring immediate authorization." : $"No {status.ToLower()} records found in recent history.")
                </MudText>
            </MudPaper>
        }
        else
        {
            <MudTable Items="@items" Hover="true" Elevation="0" Class="fmc-premium-table" Striped="false" 
                      Filter="new Func<TransactionDto,bool>(FilterFunc)"
                      OnRowClick="@((TableRowClickEventArgs<TransactionDto> e) => OpenDetail(e.Item!))" RowClass="cursor-pointer">
                <ToolBarContent>
                    <MudText Typo="Typo.h6" Style="font-weight: 900; font-size: 0.95rem; letter-spacing: 0.05em; opacity:0.8;">@status.ToUpper() RECORDS</MudText>
                    <MudSpacer />
                    <div class="d-flex align-center gap-4 py-2">
                        @if (_isCeo)
                        {
                            <div class="d-flex gap-2 mr-4">
                                <MudTooltip Text="Export to Excel">
                                    <MudIconButton Icon="@Icons.Custom.FileFormats.FileExcel" Color="Color.Success" Variant="Variant.Outlined" 
                                                   OnClick="ExportToExcel" Style="border-radius: 8px;" />
                                </MudTooltip>
                                <MudTooltip Text="Export to PDF">
                                    <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Error" Variant="Variant.Outlined" 
                                                   OnClick="ExportToPdf" Style="border-radius: 8px;" />
                                </MudTooltip>
                            </div>
                        }

                        <div class="fmc-date-filter-container" style="position: relative;">
                            <MudOverlay Visible="@_datePickerOpen" OnClick="@(() => _datePickerOpen = false)" ZIndex="9998" AutoClose="true" />
                            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.CalendarMonth" 
                                       EndIcon="@Icons.Material.Filled.ArrowDropDown" OnClick="@(() => _datePickerOpen = !_datePickerOpen)"
                                       Style="border-radius: 12px; min-width: 240px; height: 40px; font-weight: 800; text-transform: none; color: var(--mud-palette-text-primary); border-color: var(--mud-palette-divider); position: relative; z-index: 10000;">
                                @(_filterDateRange?.Start?.ToString("MMM dd") ?? "Start") — @(_filterDateRange?.End?.ToString("MMM dd") ?? "End")
                            </MudButton>
                            
                            <MudPopover Open="@_datePickerOpen" AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft" 
                                        Class="fmc-datepicker-popover" Fixed="true" Style="z-index: 9999;">
                                <div class="pa-2" style="background-color: #121212; width: 330px; overflow: hidden;">
                                     <MudDateRangePicker DateRange="_filterDateRange" PickerVariant="PickerVariant.Static" 
                                                         Elevation="0" Color="Color.Primary" Rounded="true" 
                                                         Style="width: 100%;"
                                                         DateRangeChanged="@(async dr => { _filterDateRange = dr; _datePickerOpen = false; StateHasChanged(); })" />
                                </div>
                            </MudPopover>
                        </div>
                                       
                        <MudTextField @bind-Value="_searchString" Placeholder="Filter ledger..." 
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" 
                                      Class="mt-0" Immediate="true" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 300px; border-radius: 12px; font-weight: 700;"></MudTextField>
                    </div>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x=>x.Date))">TIMESTAMP</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x=>x.Subscriber))">IDENTIFIER</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x=>x.AccountNumber ?? ""))">CARD NUMBER</MudTableSortLabel></MudTh>
                    @if (status == "Pending")
                    {
                        <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x=>x.MakerName ?? ""))">INITIATOR</MudTableSortLabel></MudTh>
                    }
                    else if (status == "Global")
                    {
                        <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x=>x.Status))">STATUS</MudTableSortLabel></MudTh>
                    }
                    else
                    {
                        <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x=>x.ApproverName ?? ""))">SETTLED BY</MudTableSortLabel></MudTh>
                    }
                    <MudTh><MudTableSortLabel SortBy="@(new Func<TransactionDto, object>(x=>x.Amount))">SETTLEMENT</MudTableSortLabel></MudTh>
                    <MudTh>ACTION</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Timestamp">
                         <div class="d-flex flex-column">
                             <MudText Style="font-weight: 800; font-size: 0.85rem;">@context.Date.ToString("MMM dd")</MudText>
                             <MudText Typo="Typo.caption" Style="opacity: 0.5;">@context.Date.ToString("HH:mm:ss")</MudText>
                         </div>
                    </MudTd>
                    <MudTd DataLabel="Identifier">
                        <MudText Style="font-weight: 900; color: var(--mud-palette-primary); letter-spacing: -0.01em;">@context.Subscriber</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.5; display: block; max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@context.Label</MudText>
                    </MudTd>
                    <MudTd DataLabel="Card Number">
                        <code class="fmc-card-mono">@MaskAccount(context.AccountNumber)</code>
                    </MudTd>
                    <MudTd DataLabel="Authority">
                        <div class="d-flex align-center">
                            @if (status == "Global")
                            {
                                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Filled" Style="font-weight: 900; font-size: 0.6rem;">@context.Status.ToUpper()</MudChip>
                            }
                            else
                            {
                                <MudAvatar Size="Size.Small" Color="Color.Surface" Class="mr-2" Style="width: 24px; height: 24px; font-size: 0.6rem; border:1px solid var(--mud-palette-divider);">
                                    @((context.ApproverName ?? context.MakerName ?? "S")[0])
                                </MudAvatar>
                                <MudText Typo="Typo.caption" Style="font-weight: 800; opacity: 0.8;">@(context.Status == "Pending" ? context.MakerName : context.ApproverName ?? "System")</MudText>
                            }
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Settlement">
                        <MudText Color="@(context.Amount < 0 ? Color.Error : Color.Success)" Class="fmc-financial-mono" Style="font-weight: 950; font-size: 1.05rem; letter-spacing: -0.02em;">
                            @context.Amount.ToString("C")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Action" @onclick:stopPropagation="true">
                        @if (context.Status == "Pending")
                        {
                            @if (_isApprover && context.MakerId != _currentUserId)
                            {
                                <div class="d-flex gap-2">
                                    <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" OnClick="@(() => HandleApproval(context, true))" Size="Size.Small" Variant="Variant.Filled" Style="border-radius: 8px;" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" OnClick="@(() => HandleApproval(context, false))" Size="Size.Small" Variant="Variant.Outlined" Style="border-radius: 8px;" />
                                </div>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text" Style="font-weight: 950; font-size: 0.65rem; border: 1px solid rgba(var(--mud-palette-warning-rgb), 0.3);">AWAITING</MudChip>
                            }
                        }
                        else
                        {
                             <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Text" Style="font-weight: 950; font-size: 0.65rem;">
                                 @context.Status.ToUpper()
                             </MudChip>
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[]{10, 20, 50, 100}" />
                </PagerContent>
            </MudTable>
        }
    };
}

<style>
    :root { --fmc-font-premium: 'Inter', -apple-system, sans-serif; }
    .fmc-integrated-ledger { border-radius: 20px; border: 1px solid var(--mud-palette-divider); overflow: hidden; background-color: var(--mud-palette-surface); box-shadow: 0 4px 20px rgba(0,0,0,0.15); }
    .fmc-custom-tab-bar { display: flex; width: 100%; background: rgba(var(--mud-palette-primary-rgb), 0.04); height: 64px; border-bottom: 2px solid var(--mud-palette-divider); }
    .fmc-tab-btn { flex: 1; border: none; background: transparent; color: var(--mud-palette-text-secondary); font-weight: 900; font-size: 0.75rem; letter-spacing: 0.1em; display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; border-right: 1px solid rgba(var(--mud-palette-divider-rgb), 0.1); outline: none; }
    .fmc-tab-btn:last-child { border-right: none; }
    .fmc-tab-btn:hover { background: rgba(255,255,255,0.02); color: var(--mud-palette-text-primary); }
    .fmc-tab-btn.active { color: var(--mud-palette-primary); background: rgba(var(--mud-palette-primary-rgb), 0.06); position: relative; }
    .fmc-tab-btn.active::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 4px; background: var(--mud-palette-primary); }
    .fmc-tab-content { min-height: 400px; }
    
    /* GLOBAL PICKER OVERRIDES (Targeting the Portal) */
    .fmc-datepicker-popover .mud-picker-static-header { display: none !important; }
    .fmc-datepicker-popover .mud-picker-header { background-color: #1a1a1c !important; color: var(--mud-palette-primary) !important; }
    .fmc-datepicker-popover .mud-picker-header-label { color: var(--mud-palette-primary) !important; font-weight: 900 !important; }
    .fmc-datepicker-popover .mud-picker-calendar-header { color: white !important; }
    .fmc-datepicker-popover .mud-day { color: #ccc !important; }
    .fmc-premium-table { padding-bottom: 8px; }
    .fmc-premium-table .mud-table-head { background-color: transparent; }
    .fmc-premium-table .mud-th { font-weight: 950 !important; color: var(--mud-palette-text-secondary); font-size: 0.65rem !important; letter-spacing: 0.12em; text-transform: uppercase; padding: 22px 24px !important; border-bottom: 2px solid var(--mud-palette-divider); }
    .fmc-premium-table .mud-td { padding: 18px 24px !important; border-bottom: 1px solid rgba(var(--mud-palette-divider-rgb), 0.2); }
    .fmc-card-mono { font-family: 'Roboto Mono', monospace; font-size: 0.8rem; background: rgba(var(--mud-palette-background-grey-rgb), 0.6); padding: 5px 10px; border-radius: 8px; opacity: 0.9; border: 1px solid var(--mud-palette-divider); color: var(--mud-palette-primary); }
    .fmc-empty-state { border: none; background: transparent !important; }
    
    /* ROBUST DATEPICKER POPOVER */
    .fmc-datepicker-popover { background-color: #121212 !important; border: 1px solid #333 !important; border-radius: 16px !important; box-shadow: 0 15px 50px rgba(0,0,0,0.8) !important; overflow: hidden !important; z-index: 9999 !important; }
    .fmc-date-activator { border: 1px solid var(--mud-palette-divider); border-radius: 12px; min-width: 240px; height: 40px; background: rgba(255,255,255,0.02); transition: all 0.2s; }
    .fmc-date-activator:hover { border-color: var(--mud-palette-primary); background: rgba(var(--mud-palette-primary-rgb), 0.04); }
    
    .mud-picker-static-header { background-color: #1a1a1c !important; }
    .mud-picker-calendar-header { padding: 12px !important; color: white !important; }
    .mud-day { font-weight: 700 !important; border-radius: 10px !important; color: #ddd !important; }
    .mud-day.mud-selected { background-color: var(--mud-palette-primary) !important; color: white !important; font-weight: 900 !important; }
    
    .cursor-pointer { cursor: pointer; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); }
    .cursor-pointer:hover { background-color: rgba(var(--mud-palette-primary-rgb), 0.04) !important; transform: scale(1.002); }
</style>

@code {
    private List<TransactionDto> _allTransactions = new();
    private List<TransactionDto> _pendingTransactions = new();
    private List<TransactionDto> _approvedTransactions = new();
    private List<TransactionDto> _rejectedTransactions = new();
    private bool _loading = true;
    private int _activeIndex = 0;

    private string GetActiveCls(int idx) => _activeIndex == idx ? "active" : "";
    
    private async Task SetTab(int idx)
    {
        _activeIndex = idx;
        await OnTabChanged(idx);
    }
    private bool _isApprover;
    private bool _isMaker;
    private bool _isCeo;
    private string? _currentUserId;
    private string _searchString = "";
    private DateRange? _filterDateRange;
    private bool _datePickerOpen;
    private Guid _orgId;

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private async Task ExportToExcel()
    {
        var filtered = _allTransactions.Where(FilterFunc).ToList();
        var bytes = ReportGen.GenerateExcel($"FMC_Ledger_{_orgId}", filtered);
        await DownloadFile(bytes, $"FMC_Report_{DateTime.Now:yyyyMMdd}.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private async Task ExportToPdf()
    {
        var filtered = _allTransactions.Where(FilterFunc).ToList();
        var bytes = ReportGen.GeneratePdf($"Structural Settlement Report — {DateTime.Now:MMM dd, yyyy}", filtered);
        await DownloadFile(bytes, $"FMC_Settlement_{DateTime.Now:yyyyMMdd}.pdf", "application/pdf");
    }

    private async Task DownloadFile(byte[] bytes, string fileName, string contentType)
    {
        using var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
        await JS.InvokeVoidAsync("fmc_downloadFile", fileName, contentType, streamRef);
    }

    private bool FilterFunc(TransactionDto tx)
    {
        if (_filterDateRange != null && _filterDateRange.Start.HasValue && _filterDateRange.End.HasValue)
        {
            if (tx.Date.Date < _filterDateRange.Start.Value.Date || tx.Date.Date > _filterDateRange.End.Value.Date) 
                return false;
        }

        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        
        if (tx.Subscriber.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if ((tx.AccountNumber ?? "").Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (tx.Amount.ToString().Contains(_searchString)) return true;
        if ((tx.Label ?? "").Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if ((tx.ApproverName ?? "").Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        
        return false;
    }

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var user = authState.User;
        _isApprover = user.IsInRole(Roles.Approver);
        _isMaker = user.IsInRole(Roles.Maker);
        _isCeo = user.IsInRole(Roles.CEO);
        _currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        
        var orgIdClaim = user.FindFirst("OrganizationId")?.Value;
        if (Guid.TryParse(orgIdClaim, out var id))
        {
            _orgId = id;
            await RefreshQueue();
        }
        else
        {
            Snackbar.Add("Organizational context unresolved.", Severity.Error);
            _loading = false;
        }
    }

    private async Task RefreshQueue()
    {
        _loading = true;
        try
        {
            var allHistory = await OrgService.GetOrganizationTransactionsAsync(_orgId, count: 2000); // Increased for comprehensive reports
            _allTransactions = allHistory.ToList();
            _pendingTransactions = _allTransactions.Where(t => t.Status == "Pending").ToList();
            _approvedTransactions = _allTransactions.Where(t => t.Status == "Approved" || t.Status == "Successful").ToList();
            _rejectedTransactions = _allTransactions.Where(t => t.Status == "Rejected").ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Load Failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnTabChanged(int index)
    {
        if (index > 0 && !_approvedTransactions.Any() && !_rejectedTransactions.Any())
        {
            await RefreshQueue();
        }
    }

    private async Task HandleApproval(TransactionDto tx, bool approve)
    {
        try
        {
            bool success = approve 
                ? await OrgService.ApproveTransactionAsync(tx.Id)
                : await OrgService.RejectTransactionAsync(tx.Id, "Rejected by Authorized Personnel");

            if (success)
            {
                Snackbar.Add(approve ? "Execution Successful" : "Settlement Terminated", Severity.Success);
                await RefreshQueue();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task OpenDetail(TransactionDto tx)
    {
        var parameters = new DialogParameters 
        { 
            ["Transaction"] = tx,
            ["IsOwnTransaction"] = tx.MakerId == _currentUserId
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<PendingDetailDialog>("Authorization Protocol", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await RefreshQueue();
        }
    }

    private string MaskAccount(string? account)
    {
        if (string.IsNullOrEmpty(account)) return "ID.NULL";
        if (account.Length <= 10) return account;
        return $"{account[..6]}••••{account[^4..]}";
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Warning,
        "Approved" or "Successful" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Surface
    };

    private async Task OpenUserSelection(bool isCredit)
    {
        var parameters = new DialogParameters { ["OrgId"] = _orgId };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<UserSelectionDialog>("Identity Resolution", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is UserDto selectedUser)
        {
            var adjustParams = new DialogParameters { ["User"] = selectedUser, ["IsCredit"] = isCredit };
            var adjustDialog = await DialogService.ShowAsync<UserBalanceDialog>("Initiate Settlement", adjustParams, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
            var adjustResult = await adjustDialog.Result;
            
            if (adjustResult is not null && !adjustResult.Canceled)
            {
                await RefreshQueue();
            }
        }
    }
}
