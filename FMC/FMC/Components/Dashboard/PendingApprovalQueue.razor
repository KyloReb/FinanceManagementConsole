@using FMC.Shared.DTOs
@using FMC.Shared.Auth
@inject OrganizationApiService OrgService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthProvider

<MudPaper Elevation="0" Class="fmc-glass-surface mb-6">
    <div class="fmc-header-area pa-6" style="border-bottom: 1px solid var(--mud-palette-divider);">
        <div class="d-flex align-center">
            <div class="fmc-header-icon mr-4" style="background: rgba(var(--mud-palette-warning-rgb), 0.1); color: var(--mud-palette-warning); width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                <MudIcon Icon="@Icons.Material.Filled.PendingActions" />
            </div>
            <div>
                <MudText Typo="Typo.h6" Style="font-weight: 800; letter-spacing: -0.01em;">Transaction Approval Queue</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Transactions awaiting verification before commitment</MudText>
            </div>
        </div>
    </div>

    <div class="fmc-content-body pa-0">
        @if (_loading)
        {
            <div class="d-flex justify-center pa-10">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (!_pendingTransactions.Any())
        {
            <div class="pa-10 d-flex flex-column align-center mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Size="Size.Large" Class="mb-2" />
                <MudText>Clear! No transactions currently pending.</MudText>
            </div>
        }
        else
        {
            <MudTable Items="@_pendingTransactions" Hover="true" Breakpoint="Breakpoint.None" Elevation="0" Class="fmc-premium-table">
                <HeaderContent>
                    <MudTh>DATE</MudTh>
                    <MudTh>USER ACCOUNT</MudTh>
                    <MudTh>MAKER</MudTh>
                    <MudTh Style="text-align: right;">AMOUNT</MudTh>
                    @if (_canApprove)
                    {
                        <MudTh Style="text-align: right;">ACTIONS</MudTh>
                    }
                </HeaderContent>
                <RowTemplate Context="tx">
                    <MudTd DataLabel="Date">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mud-text-secondary" />
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@tx.Date.ToString("MMM dd, HH:mm")</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Account">
                        <MudText Typo="Typo.body2" Style="font-weight: 700; color: var(--mud-palette-text-primary);">@tx.Label</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="letter-spacing: 0.05em;">REF: @tx.Id.ToString().Substring(0, 8).ToUpper()</MudText>
                    </MudTd>
                    <MudTd DataLabel="Maker">
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text" Style="font-weight: 700;">@tx.MakerName</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Amount" Style="text-align: right;">
                        <MudText Style="font-weight:900; font-family:'JetBrains Mono',monospace;" Color="@(tx.Amount < 0 ? Color.Error : Color.Success)">
                            @(tx.Amount > 0 ? "+" : "")@tx.Amount.ToString("C")
                        </MudText>
                    </MudTd>
                    @if (_canApprove)
                    {
                        <MudTd Style="text-align: right;">
                            <div class="d-flex align-center justify-end gap-2">
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" Class="fmc-action-btn" Style="padding: 4px 12px !important; border-radius: 8px !important;" OnClick="@(() => Reject(tx.Id))">Reject</MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" Class="fmc-action-btn" Style="color: white !important; padding: 4px 12px !important; border-radius: 8px !important;" OnClick="@(() => Approve(tx.Id))">Approve</MudButton>
                            </div>
                        </MudTd>
                    }
                </RowTemplate>
            </MudTable>
        }
    </div>
</MudPaper>

@code {
    [Parameter] public Guid OrganizationId { get; set; }
    
    private List<TransactionDto> _pendingTransactions = new();
    private bool _loading = true;
    private bool _canApprove = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        _canApprove = authState.User.IsInRole(Roles.Approver);
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _loading = true;
        try
        {
            if (OrganizationId != Guid.Empty)
            {
                _pendingTransactions = await OrgService.GetPendingTransactionsAsync(OrganizationId);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading queue: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Approve(Guid id)
    {
        var success = await OrgService.ApproveTransactionAsync(id);
        if (success)
        {
            Snackbar.Add("Transaction Approved and Committed.", Severity.Success);
            await LoadDataAsync();
        }
        else
        {
            Snackbar.Add("Approval Denied: Possible self-approval violation or system error.", Severity.Error);
        }
    }

    private async Task Reject(Guid id)
    {
        // Simple prompt for reason
        var reason = "Manual Rejection by Approver";
        var success = await OrgService.RejectTransactionAsync(id, reason);
        if (success)
        {
            Snackbar.Add("Transaction Rejected.", Severity.Warning);
            await LoadDataAsync();
        }
    }
}
