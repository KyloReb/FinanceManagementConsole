@code {
    #region Injections & State
    
    [CascadingParameter] 
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;
    
    [Inject] 
    private IJSRuntime JS { get; set; } = default!;

    private Guid _orgId;
    private string? _currentUserId;
    private bool _isApprover;
    private bool _isMaker;
    private bool _isCeo;

    // Data Collections
    private List<TransactionDto> _allTransactions = new();
    private List<TransactionDto> _pendingTransactions = new();
    private List<TransactionDto> _approvedTransactions = new();
    private List<TransactionDto> _rejectedTransactions = new();
    private List<TransactionGroup> _pendingGroups = new();

    // UI State
    private bool _loading = true;
    private int _activeIndex = 0;
    private string _searchString = "";
    private DateRange? _filterDateRange;
    private bool _datePickerOpen;

    #endregion

    #region Lifecycle Methods

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var user = authState.User;
        
        // Resolve RBAC permissions
        _isApprover = user.IsInRole(Roles.Approver);
        _isMaker = user.IsInRole(Roles.Maker);
        _isCeo = user.IsInRole(Roles.CEO);
        _currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        
        var orgIdClaim = user.FindFirst("OrganizationId")?.Value;
        if (Guid.TryParse(orgIdClaim, out var id))
        {
            _orgId = id;
            await LoadQueueDataAsync();
        }
        else
        {
            Snackbar.Add("Organizational context unresolved.", Severity.Error);
            _loading = false;
        }
    }

    #endregion

    #region Data Loading & Structuring

    /// <summary>
    /// Fetches the latest transaction history from the backend and segregates it into the appropriate tab queues.
    /// Also groups pending requests into 'TransactionGroups' for bulk-approval compatibility.
    /// </summary>
    private async Task LoadQueueDataAsync()
    {
        _loading = true;
        try
        {
            var allHistory = await OrgService.GetOrganizationTransactionsAsync(_orgId, count: 2000); 
            _allTransactions = allHistory.ToList();
            
            // Queue filtering
            _pendingTransactions = _allTransactions.Where(t => t.Status == "Pending").ToList();
            _approvedTransactions = _allTransactions.Where(t => t.Status == "Approved" || t.Status == "Successful").ToList();
            _rejectedTransactions = _allTransactions.Where(t => t.Status == "Rejected").ToList();

            // Group pending requests by BatchId, leaving standalone transactions as groups of 1.
            _pendingGroups = _pendingTransactions
                .GroupBy(t => t.BatchId)
                .Select(g => new TransactionGroup 
                { 
                    BatchId = g.Key, 
                    Transactions = g.ToList() 
                })
                .OrderByDescending(g => g.Date)
                .ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Load Failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    #endregion

    #region UI & Tab Helpers

    /// <summary>
    /// Retrieves the active CSS class for tab highlights.
    /// </summary>
    private string GetActiveTabClass(int idx) => _activeIndex == idx ? "active" : string.Empty;
    
    /// <summary>
    /// Switches the active view tab. Triggers a data refresh if necessary to ensure data is fresh.
    /// </summary>
    private async Task SetTabAsync(int idx)
    {
        _activeIndex = idx;
        if (idx > 0 && !_approvedTransactions.Any() && !_rejectedTransactions.Any())
        {
            await LoadQueueDataAsync();
        }
    }

    /// <summary>
    /// Maps transaction status to a standard MudBlazor color code.
    /// </summary>
    private Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Warning,
        "Approved" or "Successful" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Surface
    };

    /// <summary>
    /// Obfuscates account numbers leaving only the first 6 and last 4 visible.
    /// </summary>
    private string GetMaskedAccount(string? account)
    {
        if (string.IsNullOrEmpty(account)) return "ID.NULL";
        if (account.Length <= 10) return account;
        return $"{account[..6]}••••{account[^4..]}";
    }

    /// <summary>
    /// Filters the main transaction list based on the search string and date range constraints.
    /// </summary>
    private bool FilterFunc(TransactionDto tx)
    {
        // Check date bounds
        if (_filterDateRange?.Start.HasValue == true && _filterDateRange?.End.HasValue == true)
        {
            if (tx.Date.Date < _filterDateRange.Start.Value.Date || tx.Date.Date > _filterDateRange.End.Value.Date) 
                return false;
        }

        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        
        // String comparisons
        if (tx.Subscriber.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if ((tx.AccountNumber ?? "").Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if (tx.Amount.ToString().Contains(_searchString)) return true;
        if ((tx.Label ?? "").Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        if ((tx.ApproverName ?? "").Contains(_searchString, StringComparison.OrdinalIgnoreCase)) return true;
        
        return false;
    }

    #endregion

    #region Interaction Handlers (Modals & Approvals)

    /// <summary>
    /// Opens the new transaction modal for manual debits/credits.
    /// </summary>
    private async Task OpenUserSelectionAsync(bool isCredit)
    {
        var parameters = new DialogParameters { ["OrgId"] = _orgId };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<UserSelectionDialog>("Identity Resolution", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is UserDto selectedUser)
        {
            var adjustParams = new DialogParameters { ["User"] = selectedUser, ["IsCredit"] = isCredit };
            var adjustDialog = await DialogService.ShowAsync<UserBalanceDialog>("Initiate Settlement", adjustParams, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
            var adjustResult = await adjustDialog.Result;
            
            if (adjustResult is not null && !adjustResult.Canceled)
            {
                await LoadQueueDataAsync();
            }
        }
    }

    /// <summary>
    /// Opens the bulk upload modal via Excel.
    /// </summary>
    private async Task OpenBulkUploadAsync()
    {
        var parameters = new DialogParameters { ["OrgId"] = _orgId };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<BulkUploadDialog>("Bulk Cardholder Upload", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadQueueDataAsync();
        }
    }

    /// <summary>
    /// Opens the detailed transaction review modal.
    /// </summary>
    private async Task OpenDetailAsync(TransactionDto tx)
    {
        var parameters = new DialogParameters 
        { 
            ["Transaction"] = tx,
            ["IsOwnTransaction"] = tx.MakerId == _currentUserId
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<PendingDetailDialog>("Authorization Protocol", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadQueueDataAsync();
        }
    }

    /// <summary>
    /// Primary handler for processing authorizations on single transactions.
    /// </summary>
    private async Task HandleApprovalAsync(TransactionDto tx, bool approve)
    {
        try
        {
            bool success = approve 
                ? await OrgService.ApproveTransactionAsync(tx.Id)
                : await OrgService.RejectTransactionAsync(tx.Id, "Rejected by Authorized Personnel");

            if (success)
            {
                Snackbar.Add(approve ? "Execution Successful" : "Settlement Terminated", Severity.Success);
                await LoadQueueDataAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Authorization Failed: {ex.Message}", Severity.Error);
        }
    }

    /// <summary>
    /// Secondary handler for processing bulk batch approvals/rejections from the UI.
    /// </summary>
    private async Task HandleGroupApprovalAsync(TransactionGroup group, bool approve)
    {
        try
        {
            if (group.BatchId.HasValue)
            {
                if (approve)
                {
                    await OrgService.ApproveBatchAsync(group.BatchId.Value);
                    Snackbar.Add("Bulk Batch Authorized Successfully", Severity.Success);
                }
                else
                {
                    // Require rejection reasoning for entire batches
                    var parameters = new DialogParameters { ["ContentText"] = "Enter rejection reason for this entire batch." };
                    var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small };
                    
                    var dialog = await DialogService.ShowAsync<RejectionDialog>("Batch Rejection", parameters, options);
                    var result = await dialog.Result;

                    if (result is not null && !result.Canceled)
                    {
                        var reason = result.Data as string ?? "Batch rejected by approver.";
                        await OrgService.RejectBatchAsync(group.BatchId.Value, reason);
                        Snackbar.Add("Bulk Batch Denied", Severity.Warning);
                    }
                    else return; // Cancelled reasoning prompt
                }
            }
            else
            {
                var tx = group.Transactions.First();
                await HandleApprovalAsync(tx, approve);
            }
            
            await LoadQueueDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Batch Error: {ex.Message}", Severity.Error);
        }
    }

    #endregion

    #region Export Helpers

    /// <summary>
    /// Generates an Excel report of the currently filtered ledger and triggers a browser download.
    /// </summary>
    private async Task ExportToExcelAsync()
    {
        var filtered = _allTransactions.Where(FilterFunc).ToList();
        var bytes = ReportGen.GenerateExcel($"FMC_Ledger_{_orgId}", filtered);
        await DownloadFileAsync(bytes, $"FMC_Report_{DateTime.Now:yyyyMMdd}.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    /// <summary>
    /// Generates a PDF report of the currently filtered ledger and triggers a browser download.
    /// </summary>
    private async Task ExportToPdfAsync()
    {
        var filtered = _allTransactions.Where(FilterFunc).ToList();
        var bytes = ReportGen.GeneratePdf($"Structural Settlement Report — {DateTime.Now:MMM dd, yyyy}", filtered);
        await DownloadFileAsync(bytes, $"FMC_Settlement_{DateTime.Now:yyyyMMdd}.pdf", "application/pdf");
    }

    private async Task DownloadFileAsync(byte[] bytes, string fileName, string contentType)
    {
        using var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
        await JS.InvokeVoidAsync("fmc_downloadFile", fileName, contentType, streamRef);
    }

    #endregion

    #region Models

    /// <summary>
    /// A UI-only DTO used to visually group multiple pending transactions that belong to the same BatchId.
    /// </summary>
    public class TransactionGroup
    {
        public Guid? BatchId { get; set; }
        public List<TransactionDto> Transactions { get; set; } = new();
        
        public decimal TotalAmount => Transactions.Sum(t => t.Amount);
        public string? Label => Transactions.FirstOrDefault()?.Label;
        public string? MakerName => Transactions.FirstOrDefault()?.MakerName;
        public DateTime Date => Transactions.FirstOrDefault()?.Date ?? DateTime.UtcNow;
        
        /// <summary>
        /// Used by the UI to toggle the accordion visibility of child transactions.
        /// </summary>
        public bool ShowDetails { get; set; }
    }

    #endregion
}
