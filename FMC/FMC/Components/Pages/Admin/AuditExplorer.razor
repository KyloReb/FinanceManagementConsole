@page "/admin/audit"
@using MudBlazor
@using FMC.Shared.Auth
@using FMC.Shared.DTOs.Admin
@using FMC.Components.Pages.Admin.Dialogs
@attribute [Authorize(Roles = Roles.SuperAdmin + "," + Roles.CEO + "," + Roles.Maker + "," + Roles.Approver + "," + Roles.SuperAdminApprover)]
@inject OrganizationApiService OrgService
@inject ThemeService ThemeService
@inject ISnackbar Snackbar
@inject IBrowserViewportService ViewportService
@inject IDialogService DialogService
@implements IAsyncDisposable
@implements IBrowserViewportObserver

<PageTitle>Audit Intelligence | FMC</PageTitle>

<style>
    /* Absolute Symmetrical Centered Forensic Tooltip - Bypassing Blazor Isolation & CSS Caching */
    .fmc-premium-table .mud-table-row {
        position: relative !important;
        z-index: 1 !important;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1) !important;
    }
    
    .fmc-premium-table .mud-table-row:hover {
        z-index: 10 !important; /* Lifts the hovered row above all sibling columns and cells but keeps it safely behind modal dialogs (z-index: 1400+) */
    }
    
    .fmc-premium-table .fmc-row-tooltip {
        position: absolute !important;
        bottom: 115% !important;
        left: 50% !important;
        width: 320px !important;
        background: #1E1E1E !important; /* Solid Premium Dark Background in Dark Mode */
        border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.25) !important;
        border-radius: 12px !important;
        padding: 14px !important;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5), 0 0 25px rgba(var(--mud-palette-primary-rgb), 0.15) !important;
        backdrop-filter: blur(25px) saturate(120%) !important;
        color: var(--mud-palette-text-primary) !important;
        z-index: 100 !important; /* Stays at the top of the row's children but below modal dialog overlays */
        opacity: 0 !important;
        visibility: hidden !important;
        transform: translateX(-50%) translateY(8px) scale(0.97) !important;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1) !important;
        pointer-events: none !important; /* CRITICAL: Allows mouse to pass through the tooltip to break hover trap */
        text-align: left !important;
    }

    /* Opaque Background for Light Mode - Checked strictly against html class */
    html:not(.dark) .fmc-premium-table .fmc-row-tooltip {
        background: #ffffff !important;
        color: #1e293b !important;
        border: 1px solid rgba(0, 0, 0, 0.08) !important;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08), 0 0 25px rgba(var(--mud-palette-primary-rgb), 0.05) !important;
    }
    html:not(.dark) .fmc-premium-table .tooltip-val {
        color: #0f172a !important;
    }
    html:not(.dark) .fmc-premium-table .tooltip-lbl {
        color: #64748b !important;
    }

    .fmc-premium-table .mud-table-row:hover .fmc-row-tooltip {
        opacity: 1 !important;
        visibility: visible !important;
        transform: translateX(-50%) translateY(0) scale(1) !important;
    }

    /* Downward positioning override for first three rows to prevent layout clipping */
    .fmc-premium-table .mud-table-row:nth-of-type(-n+3) .fmc-row-tooltip {
        bottom: auto !important;
        top: 115% !important;
        transform: translateX(-50%) translateY(-8px) scale(0.97) !important;
    }
    .fmc-premium-table .mud-table-row:nth-of-type(-n+3):hover .fmc-row-tooltip {
        opacity: 1 !important;
        visibility: visible !important;
        transform: translateX(-50%) translateY(0) scale(1) !important;
    }

    /* High-Fidelity Ledger Bar Styles */
    .fmc-premium-table .fmc-ledger-bar { 
        width: 4px !important; 
        height: 24px !important; 
        border-radius: 4px !important; 
        background-color: var(--mud-palette-divider) !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important; 
        display: inline-block !important;
    }
    .fmc-premium-table .fmc-ledger-bar.credit { background-color: #10b981 !important; }
    .fmc-premium-table .fmc-ledger-bar.debit { background-color: #f43f5e !important; }
    .fmc-premium-table .fmc-ledger-bar.security { background-color: #818cf8 !important; }
    .fmc-premium-table .fmc-ledger-bar.neutral { background-color: #9ca3af !important; }
    
    html:not(.dark) .fmc-premium-table .fmc-ledger-bar.credit { background-color: #059669 !important; }
    html:not(.dark) .fmc-premium-table .fmc-ledger-bar.debit { background-color: #d90429 !important; }
    html:not(.dark) .fmc-premium-table .fmc-ledger-bar.security { background-color: #3b82f6 !important; }
    html:not(.dark) .fmc-premium-table .fmc-ledger-bar.neutral { background-color: #4b5563 !important; }

    .fmc-premium-table .mud-table-row:hover .fmc-ledger-bar { 
        transform: scaleY(1.3) scaleX(1.5) !important; 
    }

    /* Completely strip out left cell borders to ensure the vertical white line is gone */
    .fmc-premium-table td {
        border-left: none !important;
    }

    /* Tooltip Internal Structure */
    .fmc-row-tooltip .tooltip-header {
        font-size: 0.58rem !important;
        font-weight: 950 !important;
        letter-spacing: 0.08em !important;
        display: flex !important;
        align-items: center !important;
        margin-bottom: 8px !important;
        opacity: 0.8 !important;
    }
    .fmc-row-tooltip .tooltip-header.credit { color: #10b981 !important; }
    .fmc-row-tooltip .tooltip-header.debit { color: #f43f5e !important; }
    .fmc-row-tooltip .tooltip-header.security { color: #818cf8 !important; }
    .fmc-row-tooltip .tooltip-header.neutral { color: #9ca3af !important; }

    .fmc-row-tooltip .tooltip-body {
        display: flex !important;
        flex-direction: column !important;
        gap: 5px !important;
    }
    .fmc-row-tooltip .tooltip-row {
        display: flex !important;
        justify-content: space-between !important;
        align-items: center !important;
        font-size: 0.72rem !important;
    }
    .fmc-row-tooltip .tooltip-lbl {
        font-weight: 550 !important;
        color: rgba(255, 255, 255, 0.38) !important;
        font-size: 0.68rem !important;
        letter-spacing: 0.02em !important;
    }
    .fmc-row-tooltip .tooltip-val {
        font-weight: 750 !important;
        color: rgba(255, 255, 255, 0.9) !important;
        text-align: right !important;
    }
    .fmc-row-tooltip .tooltip-val.mono {
        font-family: 'JetBrains Mono', monospace !important;
        font-size: 0.68rem !important;
    }
    .fmc-row-tooltip .tooltip-val.highlighted-val {
        font-weight: 950 !important;
        font-family: 'JetBrains Mono', monospace !important;
        font-size: 0.76rem !important;
        color: #ffffff !important;
        text-shadow: 0 0 8px rgba(255, 255, 255, 0.12) !important;
    }
    html:not(.dark) .fmc-row-tooltip .tooltip-val.highlighted-val {
        color: #000000 !important;
        text-shadow: none !important;
    }
    .fmc-row-tooltip .tooltip-val.credit { color: #10b981 !important; }
    .fmc-row-tooltip .tooltip-val.debit { color: #f43f5e !important; }
    .fmc-row-tooltip .tooltip-val.security { color: #818cf8 !important; }
    .fmc-row-tooltip .tooltip-val.neutral { color: #9ca3af !important; }

    .fmc-row-tooltip .tooltip-footer {
        margin-top: 8px !important;
        padding-top: 8px !important;
        border-top: 1px solid rgba(255, 255, 255, 0.08) !important;
        font-size: 0.58rem !important;
        font-weight: 900 !important;
        letter-spacing: 0.05em !important;
        color: rgba(255, 255, 255, 0.35) !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        text-transform: uppercase !important;
    }
    html:not(.dark) .fmc-row-tooltip .tooltip-footer {
        border-top-color: rgba(0, 0, 0, 0.06) !important;
        color: rgba(0, 0, 0, 0.4) !important;
    }
</style>

<div class="fmc-ledger-root @(ThemeService.IsDarkMode ? "fmc-dark-mode" : "fmc-light-mode")">
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mt-md-8 mb-12">
    @* PLATINUM HEADER AREA *@
    <div class="fmc-audit-header mb-8 flex-wrap gap-4">
        <div class="d-flex align-center">
            <div class="fmc-audit-bar mr-4"></div>
            <div>
                <MudText Typo="Typo.h4" Class="fmc-audit-hero-text">Audit Intelligence Explorer</MudText>
                <MudText Typo="Typo.body1" Class="fmc-audit-subtitle d-none d-sm-block">Securing the network through forensic visibility and financial compliance.</MudText>
            </div>
        </div>
    </div>


    @* UNIFIED FORENSIC SURFACE *@
    <MudPaper Elevation="0" Class="fmc-main-surface">
        <div class="fmc-header-area">
            @* TOP TIER: SEARCH *@
            <div class="fmc-identity-row mb-3">
                 <div class="d-flex align-center">
                    <div class="fmc-header-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.Search" Color="Color.Primary" /></div>
                    <div class="mr-6">
                        <MudText Typo="Typo.h6" Style="font-weight: 800; letter-spacing: -0.01em;">Forensic Query</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Filter the intelligence stream</MudText>
                    </div>
                </div>

                <div class="fmc-identity-search ml-auto" style="min-width: 320px; max-width: 400px;">
                    <div class="fmc-search-pill">
                        <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" Class="fmc-search-pill-icon" />
                        <input type="text" class="fmc-search-pill-input" placeholder="Filter by Action, Context, or Label..." 
                               value="@_searchString" @oninput="OnSearchChanged" />
                    </div>
                </div>
            </div>

            @* BOTTOM TIER: ORCHESTRATION (DATES, CATEGORIES, EXPORTS) *@
            <div class="fmc-orchestration-row">
                <div class="fmc-temporal-filter">
                    <div class="fmc-date-group mr-3">
                        <button class="fmc-date-btn @(_query.Category == null ? "active" : "")" @onclick='() => SetCategory(null)'>ALL CAT</button>
                        <button class="fmc-date-btn @(_query.Category == "financial" ? "active" : "")" @onclick='() => SetCategory("financial")'>FINANCIAL</button>
                        <button class="fmc-date-btn @(_query.Category == "auth" ? "active" : "")" @onclick='() => SetCategory("auth")'>SECURITY</button>
                        <button class="fmc-date-btn @(_query.Category == "error" ? "active" : "")" @onclick='() => SetCategory("error")'>ERRORS</button>
                    </div>
                    <div class="fmc-date-group mr-3">
                        <button class="fmc-date-btn @(_activeDateRange == "all" ? "active" : "")" @onclick='() => SetQuickDate("all")'>ALL</button>
                        <button class="fmc-date-btn @(_activeDateRange == "today" ? "active" : "")" @onclick='() => SetQuickDate("today")'>TODAY</button>
                        <button class="fmc-date-btn @(_activeDateRange == "7d" ? "active" : "")" @onclick='() => SetQuickDate("7d")'>7D</button>
                        <button class="fmc-date-btn @(_activeDateRange == "30d" ? "active" : "")" @onclick='() => SetQuickDate("30d")'>30D</button>
                        <button class="fmc-date-btn @(_activeDateRange == "1y" ? "active" : "")" @onclick='() => SetQuickDate("1y")'>1Y</button>
                    </div>
                    <div class="fmc-custom-date-wrap">
                        <div class="fmc-date-input-box">
                            <span class="fmc-date-label">START DATE</span>
                            <input type="date" value="@(_dateRange.Start?.ToString("yyyy-MM-dd"))" @onchange='(e) => UpdateDate(e, true)' class="fmc-raw-date" />
                        </div>
                        <div class="fmc-date-sep"></div>
                        <div class="fmc-date-input-box">
                            <span class="fmc-date-label">END DATE</span>
                            <input type="date" value="@(_dateRange.End?.ToString("yyyy-MM-dd"))" @onchange='(e) => UpdateDate(e, false)' class="fmc-raw-date" />
                        </div>
                    </div>
                </div>

                <div class="fmc-action-toolbar ml-3">
                    <button class="fmc-premium-action excel" @onclick="ExportExcel">
                        <MudIcon Icon="@Icons.Custom.FileFormats.FileExcel" Size="Size.Small" Class="mr-2" />
                        <span>XLS EXPORT</span>
                    </button>
                    <button class="fmc-premium-action pdf" @onclick="ExportPdf">
                        <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Small" Class="mr-2" />
                        <span>PDF AUDIT</span>
                    </button>
                </div>
            </div>
        </div>

    @if (_loading)
    {
        @if (!_isMobile)
        {
            @* Desktop skeleton rows matching table layout *@
            @for (int i = 0; i < 8; i++)
            {
                <div class="d-flex align-center pa-4 px-6" style="border-bottom: 1px solid var(--mud-palette-divider); gap: 24px;">
                    <div style="flex:1;" class="d-flex align-center gap-3">
                        <div class="fmc-skel" style="width:4px; height:24px;"></div>
                        <div style="flex:1;">
                            <div class="fmc-skel fmc-skel-line mb-2" style="width:70%;"></div>
                            <div class="fmc-skel fmc-skel-line" style="width:40%;"></div>
                        </div>
                    </div>
                    <div style="flex:1;">
                        <div class="fmc-skel fmc-skel-line mb-2" style="width:80%;"></div>
                        <div class="fmc-skel fmc-skel-line" style="width:50%;"></div>
                    </div>
                    <div style="flex:1;" class="d-flex justify-center">
                        <div class="fmc-skel fmc-skel-pill"></div>
                    </div>
                    <div style="flex:1;" class="text-right">
                        <div class="fmc-skel fmc-skel-line ml-auto" style="width:80px; height: 18px;"></div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="fmc-mobile-loading" style="padding:8px;">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="fmc-audit-mobile-card" style="opacity:@(1 - i * 0.2);">
                        <div class="fmc-mobile-top pa-3 d-flex justify-space-between align-center">
                            <div class="d-flex align-center gap-2">
                                <div class="fmc-page-skel" style="width:8px;height:8px;border-radius:50%;"></div>
                                <div class="fmc-page-skel" style="width:140px;height:12px;"></div>
                            </div>
                            <div class="text-right">
                                <div class="fmc-page-skel" style="width:50px;height:10px;margin-bottom:2px;"></div>
                                <div class="fmc-page-skel" style="width:40px;height:8px;margin-left:auto;"></div>
                            </div>
                        </div>
                        <div class="fmc-mobile-mid px-3 pb-3 pt-1">
                            <div class="d-flex justify-space-between align-end">
                                <div style="flex:1;margin-right:16px;">
                                    <div class="fmc-page-skel" style="width:50px;height:8px;margin-bottom:4px;"></div>
                                    <div class="fmc-page-skel" style="width:80%;height:10px;"></div>
                                </div>
                                <div class="text-right">
                                    <div class="fmc-page-skel" style="width:90px;height:12px;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
    else
    {
        @if (!_isMobile)
        {
        @* DESKTOP ANALYTICS TABLE *@
        <MudTable @ref="_table" Items="@_searchResult.Items" Hover="true" Elevation="0" Loading="@_loading" 
                 OnRowClick="@((TableRowClickEventArgs<AuditLogDto> args) => { if (args.Item != null) ShowDetail(args.Item); })" T="AuditLogDto" 
                 RowClassFunc="@((item, idx) => $"fmc-row-hover {(item.Action == "CREDIT" ? "credit" : (item.Action == "DEBIT" ? "debit" : "info"))}")"
                 Filter="new Func<AuditLogDto,bool>(FilterFunc)" Class="fmc-premium-table">
                    <LoadingContent>
                        @for (int i = 0; i < 8; i++)
                        {
                            <div class="d-flex align-center pa-4 px-6" style="border-bottom: 1px solid var(--mud-palette-divider); gap: 24px;">
                                <div style="flex:1;" class="d-flex align-center gap-3">
                                    <div class="fmc-skel" style="width:4px; height:24px;"></div>
                                    <div style="flex:1;">
                                        <div class="fmc-skel fmc-skel-line mb-2" style="width:70%;"></div>
                                        <div class="fmc-skel fmc-skel-line" style="width:40%;"></div>
                                    </div>
                                </div>
                                <div style="flex:1;">
                                    <div class="fmc-skel fmc-skel-line mb-2" style="width:80%;"></div>
                                    <div class="fmc-skel fmc-skel-line" style="width:50%;"></div>
                                </div>
                                <div style="flex:1;" class="d-flex justify-center">
                                    <div class="fmc-skel fmc-skel-pill"></div>
                                </div>
                                <div style="flex:1;" class="text-right">
                                    <div class="fmc-skel fmc-skel-line ml-auto" style="width:80px; height: 18px;"></div>
                                </div>
                            </div>
                        }
                    </LoadingContent>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<AuditLogDto, object>(x => x.CreatedAt)">TIMESTAMP</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AuditLogDto, object>(x => x.Action)">EVENT IDENTITY</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<AuditLogDto, object>(x => x.EntityName ?? x.Organization ?? string.Empty)">CONTEXT</MudTableSortLabel></MudTh>
                        <MudTh Style="text-align:right;"><MudTableSortLabel SortBy="new Func<AuditLogDto, object>(x => x.Amount ?? 0m)">MAGNITUDE</MudTableSortLabel></MudTh>
                        <MudTh>TELEMETRY</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        @{
                            var actUpper = context.Action?.ToUpper() ?? "";
                            var isApproved = actUpper == "TRANSACTION_APPROVED" || actUpper == "BATCH_APPROVED" || actUpper == "APPROVE" || actUpper == "APPROVAL_SUCCESS";
                            var isBatchSubmit = actUpper == "BATCH_SUBMITTED";
                            var isBatchCancel = actUpper == "BATCH_CANCELLED";
                            
                                        var isCredit = isApproved || actUpper.Contains("CREDIT") || actUpper.Contains("DEPOSIT") || actUpper.Contains("WALLET_ADJUSTED") || actUpper.Contains("FUNDED") || actUpper.Contains("ADJUSTMENT_REQUESTED") || (actUpper.Contains("SUCCESS") && !actUpper.Contains("DEBIT") && !actUpper.Contains("LOGIN"));
                            var isDebit = isBatchCancel || actUpper.Contains("DEBIT") || actUpper.Contains("WITHDRAW") || actUpper.Contains("REJECTED") || actUpper.Contains("FAILED") || actUpper == "BATCH_REJECTED" || actUpper.Contains("DEBITED");
                            var isSecurity = isBatchSubmit || actUpper.Contains("LOGIN") || actUpper.Contains("AUTH") || actUpper.Contains("PASSWORD_RESET");
                            var isNeutral = actUpper.Contains("LOGOUT") || actUpper.Contains("VIEW") || actUpper.Contains("READ");
                            
                            var color = isApproved ? Color.Success : 
                                        (isBatchSubmit ? Color.Info : 
                                        (isBatchCancel ? Color.Error : 
                                        (isCredit ? Color.Success : 
                                        (isDebit ? Color.Error : 
                                        (isSecurity ? Color.Info : 
                                        (isNeutral ? Color.Default : Color.Info))))));

                            var icon = isApproved ? Icons.Material.Filled.CheckCircle : 
                                       (isBatchSubmit ? Icons.Material.Filled.Backup : 
                                       (isBatchCancel ? Icons.Material.Filled.Cancel : 
                                       (isCredit ? Icons.Material.Filled.AddCircle : 
                                       (isDebit ? Icons.Material.Filled.RemoveCircle : 
                                       (isSecurity ? Icons.Material.Filled.Shield : 
                                       (isNeutral ? Icons.Material.Filled.ExitToApp : Icons.Material.Filled.Hub))))));
                        }
                        <MudTd>
                            <!-- Premium Floating Forensic Tooltip -->
                            <div class="fmc-row-tooltip">
                                <div class="tooltip-header @(isCredit ? "credit" : (isDebit ? "debit" : (isSecurity ? "security" : "neutral")))">
                                    <MudIcon Icon="@icon" Size="Size.Small" Class="mr-1" />
                                    <span>FORENSIC TELEMETRY STREAM</span>
                                </div>
                                <div class="tooltip-body">
                                    <div class="tooltip-row">
                                        <span class="tooltip-lbl">OPERATION:</span>
                                        <span class="tooltip-val @(isCredit ? "credit" : (isDebit ? "debit" : (isSecurity ? "security" : "neutral")))">@FormatAction(context.Action)</span>
                                    </div>
                                    <div class="tooltip-row">
                                        <span class="tooltip-lbl">CONTEXT / ACTOR:</span>
                                        <span class="tooltip-val">@(string.IsNullOrWhiteSpace(context.EntityName) || context.EntityName == "N/A" ? (context.Organization ?? "System Core Gateway") : context.EntityName)</span>
                                    </div>
                                    <div class="tooltip-row">
                                        <span class="tooltip-lbl">TELEMETRY ENDPOINT:</span>
                                        <span class="tooltip-val mono">@(context.IpAddress ?? "::1 (Local Loopback)")</span>
                                    </div>
                                    <div class="tooltip-row">
                                        <span class="tooltip-lbl">PLATFORM CONSOLE:</span>
                                        <span class="tooltip-val">@(context.Label ?? "FMC Secure Terminal")</span>
                                    </div>
                                    <div class="tooltip-row" style="margin-top: 4px; border-top: 1px dashed rgba(255,255,255,0.08); padding-top: 4px;">
                                        <span class="tooltip-lbl">SESSION AUDITOR:</span>
                                        <span class="tooltip-val">@(context.PerformedBy ?? "System Root")</span>
                                    </div>
                                    <div class="tooltip-row">
                                        <span class="tooltip-lbl">MAGNITUDE VALUE:</span>
                                        <span class="tooltip-val mono highlighted-val">@(context.Amount.HasValue ? $"₱{context.Amount.Value:N2}" : "NOT APPLICABLE")</span>
                                    </div>
                                    <div class="tooltip-row">
                                        <span class="tooltip-lbl">ISO TIMESTAMP:</span>
                                        <span class="tooltip-val mono highlighted-val">@context.CreatedAt.ToDisplayString("yyyy-MM-dd HH:mm:ss.fff")</span>
                                    </div>
                                </div>
                                <div class="tooltip-footer">
                                    <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Size="Size.Small" Class="mr-1" style="font-size: 0.6rem;" />
                                    <span>CLICK ROW FOR FULL EVENT LEDGER TRACE</span>
                                </div>
                            </div>

                            <div class="d-flex align-center gap-3">
                                <div class="fmc-ledger-bar @(isCredit ? "credit" : (isDebit ? "debit" : (isSecurity ? "security" : "neutral")))"></div>
                                <div class="d-flex flex-column">
                                    <MudText Typo="Typo.body2" Style="font-weight:900; letter-spacing: -0.02em;">@context!.CreatedAt.ToDisplayString("MMM dd, yyyy")</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700; opacity: 0.6;">@context!.CreatedAt.ToDisplayString("HH:mm:ss")</MudText>
                                </div>
                            </div>
                        </MudTd>
                        <MudTd>
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@icon" Color="@color" Size="Size.Small" />
                                <MudText Color="@color" Style="font-weight:900; letter-spacing:0.04em; font-size:0.7rem;">@FormatAction(context.Action)</MudText>
                            </div>
                        </MudTd>
                        <MudTd>
                            <div class="d-flex flex-column">
                                <MudText Style="font-weight:800; font-size:0.75rem;" Class="text-truncate">@(string.IsNullOrWhiteSpace(context.EntityName) || context.EntityName == "N/A" ? (context.Organization ?? "System Boundary") : context.EntityName)</MudText>
                                @if (!string.IsNullOrEmpty(context.Label))
                                {
                                    <MudText Typo="Typo.caption" Style="font-size:0.6rem; opacity:0.6; font-weight:700;" Class="text-truncate">@context.Label</MudText>
                                }
                            </div>
                        </MudTd>
                         <MudTd Style="text-align:right">
                            @if (context.Amount.HasValue)
                            {
                                <MudText Style="font-weight:950; font-family:'JetBrains Mono',monospace; font-size:1.15rem;" 
                                         Color="@(isCredit ? Color.Success : Color.Error)">
                                    @(isCredit ? "+" : "-")₱@(Math.Abs(context.Amount.Value).ToString("N2"))
                                </MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-disabled" Style="font-weight:900; font-size:0.65rem;">N/A</MudText>
                            }
                        </MudTd>
                        <MudTd>
                            <div class="d-flex flex-column">
                                <MudText Style="font-size:0.65rem; font-family:'JetBrains Mono',monospace; font-weight:700;">@context.IpAddress</MudText>
                                <MudText Typo="Typo.caption" Style="font-size:0.55rem; opacity:0.6; font-weight:800;" Class="text-truncate">@context.Device</MudText>
                            </div>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <div class="fmc-empty-state premium-empty-state pa-8 d-flex flex-column align-center justify-center">
                            <div class="fmc-empty-glow"></div>
                            
                            <div class="fmc-scanner-container mb-4">
                                <div class="fmc-scanner-ring ring-1"></div>
                                <div class="fmc-scanner-ring ring-2"></div>
                                <div class="fmc-scanner-line"></div>
                                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Class="fmc-premium-empty-icon" />
                            </div>

                            <MudText Typo="Typo.h6" Class="fmc-empty-title fmc-gradient-text" Style="font-weight: 900; letter-spacing: -0.02em;">No Matching Forensic Traces</MudText>
                            
                            @if (!string.IsNullOrWhiteSpace(_searchString))
                            {
                                <MudText Typo="Typo.body2" Class="fmc-empty-subtitle px-4 py-2 mt-2 fmc-query-badge">
                                    No records matched: <span class="fmc-query-highlight">"@_searchString"</span>
                                </MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Class="fmc-empty-subtitle mt-2">No activities recorded within the selected parameters.</MudText>
                            }

                            <div class="mt-6">
                                <MudButton Variant="Variant.Filled" 
                                           Color="Color.Primary" 
                                           StartIcon="@Icons.Material.Filled.SettingsBackupRestore" 
                                           OnClick="ResetSearchFilters" 
                                           Class="fmc-btn-premium-action px-6 py-2"
                                           Style="border-radius: 12px; font-weight: 800; font-size: 0.75rem; letter-spacing: 0.05em;">
                                    RESET SEARCH FILTERS
                                </MudButton>
                            </div>
                        </div>
                    </NoRecordsContent>
                    <PagerContent>
                        @if (!_loading && _searchResult.Items.Any(FilterFunc) && _table != null && ((_table.CurrentPage + 1) * _table.RowsPerPage >= _table.GetFilteredItemsCount()))
                        {
                            <div class="fmc-end-of-stream-wrap" style="padding: 20px 0;">
                                <div class="fmc-end-indicator">
                                    <div class="fmc-end-line"></div>
                                    <span class="fmc-end-text">END OF FORENSIC AUDIT STREAM</span>
                                    <div class="fmc-end-line"></div>
                                </div>
                            </div>
                        }
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
        }
        else
        {
            @if (!_searchResult.Items.Any(FilterFunc))
            {
                <div class="fmc-empty-state premium-empty-state pa-8 d-flex flex-column align-center justify-center">
                    <div class="fmc-empty-glow"></div>
                    
                    <div class="fmc-scanner-container mb-4">
                        <div class="fmc-scanner-ring ring-1"></div>
                        <div class="fmc-scanner-ring ring-2"></div>
                        <div class="fmc-scanner-line"></div>
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Class="fmc-premium-empty-icon" />
                    </div>

                    <MudText Typo="Typo.h6" Class="fmc-empty-title fmc-gradient-text" Style="font-weight: 900; letter-spacing: -0.02em;">No Forensic Traces</MudText>
                    
                    @if (!string.IsNullOrWhiteSpace(_searchString))
                    {
                        <MudText Typo="Typo.body2" Class="fmc-empty-subtitle px-4 py-2 mt-2 fmc-query-badge">
                            No records matched: <span class="fmc-query-highlight">"@_searchString"</span>
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="fmc-empty-subtitle mt-2">No activities recorded within the selected parameters.</MudText>
                    }

                    <div class="mt-6">
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   StartIcon="@Icons.Material.Filled.SettingsBackupRestore" 
                                   OnClick="ResetSearchFilters" 
                                   Class="fmc-btn-premium-action px-6 py-2"
                                   Style="border-radius: 12px; font-weight: 800; font-size: 0.75rem; letter-spacing: 0.05em;">
                                    RESET SEARCH FILTERS
                        </MudButton>
                    </div>
                </div>
            }
            else
            {
                @* MOBILE FORENSIC DOSSIER LIST *@
                var mobileFiltered = _searchResult.Items.Where(FilterFunc).ToList();
                var mTotal = mobileFiltered.Count;
                var mPages = _mobilePageSize >= mTotal ? 1 : (int)Math.Ceiling((double)mTotal / _mobilePageSize);
                if (_mobileCurrentPage >= mPages) _mobileCurrentPage = Math.Max(0, mPages - 1);
                var mItems = mobileFiltered.Skip(_mobileCurrentPage * _mobilePageSize).Take(_mobilePageSize).ToList();
                <div class="d-flex flex-column gap-2 mb-2">
                    @foreach (var log in mItems)
                    {
                        <div class="fmc-audit-mobile-card" @onclick="@(() => ShowDetail(log))">
                            <div class="fmc-mobile-top pa-3 d-flex justify-space-between align-center">
                                <div class="d-flex align-center gap-2">
                                    @{
                                        var actUpper = log.Action?.ToUpper() ?? "";
                                        var isApproved = actUpper == "TRANSACTION_APPROVED" || actUpper == "BATCH_APPROVED" || actUpper == "APPROVE" || actUpper == "APPROVAL_SUCCESS";
                                        var isBatchSubmit = actUpper == "BATCH_SUBMITTED";
                                        var isBatchCancel = actUpper == "BATCH_CANCELLED";
                                        
                            var isCredit = isApproved || actUpper.Contains("CREDIT") || actUpper.Contains("DEPOSIT") || actUpper.Contains("WALLET_ADJUSTED") || actUpper.Contains("FUNDED") || actUpper.Contains("ADJUSTMENT_REQUESTED") || (actUpper.Contains("SUCCESS") && !actUpper.Contains("DEBIT") && !actUpper.Contains("LOGIN"));
                                        var isDebit = isBatchCancel || actUpper.Contains("DEBIT") || actUpper.Contains("WITHDRAW") || actUpper.Contains("REJECTED") || actUpper.Contains("FAILED") || actUpper == "BATCH_REJECTED" || actUpper.Contains("DEBITED");
                                        var colorClass = isCredit ? "success" : (isDebit ? "error" : "info");
                                    }
                                    <div class="fmc-audit-pulse @colorClass"></div>
                                    <MudText Style="font-weight:950; font-size:0.75rem;">@FormatAction(log.Action)</MudText>
                                </div>
                                <div class="text-right d-flex flex-column">
                                    <MudText Style="font-weight:950; font-size:0.7rem;">@log.CreatedAt.ToDisplayString("HH:mm")</MudText>
                                    <MudText Style="font-size:0.55rem; opacity:0.6; font-weight:800; margin-top:-2px;">@log.CreatedAt.ToDisplayString("MM/dd")</MudText>
                                </div>
                            </div>
                            <div class="fmc-mobile-mid px-3 pb-3 pt-1">
                                <div class="d-flex justify-space-between align-end">
                                    <div class="flex-grow-1 mr-4 overflow-hidden">
                                         <MudText Style="font-size:0.55rem; font-weight:900; opacity:0.5; letter-spacing:0.05em; text-transform:uppercase; display:block;">Context</MudText>
                                         <MudText Style="font-weight:800; font-size:0.75rem;" Class="text-truncate">@(string.IsNullOrWhiteSpace(log.EntityName) || log.EntityName == "N/A" ? (log.Organization ?? "System") : log.EntityName)</MudText>
                                    </div>
                                    <div class="text-right">
                                        @if (log.Amount.HasValue)
                                        {
                                            <MudText Style="font-weight:950; font-family:'JetBrains Mono',monospace; font-size:0.8rem;" 
                                                     Color="@(isCredit ? Color.Success : Color.Error)">
                                                @(isCredit ? "+" : "-")₱@(Math.Abs(log.Amount.Value).ToString("N0"))
                                            </MudText>
                                        }
                                        else
                                        {
                                             <MudText Style="font-size:0.7rem; font-weight:950; opacity:0.3;">TRACE ONLY</MudText>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @* Mobile Paginator *@
                <div class="fmc-mobile-audit-pager">
                    <div class="fmc-mobile-pager-row">
                        <span class="fmc-mobile-pager-label">Rows:</span>
                        <div class="fmc-mobile-pager-options">
                            @foreach (var s in new[] { 10, 25, 50 })
                            {
                                <button class="fmc-mobile-pager-btn @(_mobilePageSize == s ? "active" : "")"
                                        @onclick="@(() => { _mobilePageSize = s; _mobileCurrentPage = 0; StateHasChanged(); })">@s</button>
                            }
                            <button class="fmc-mobile-pager-btn @(_mobilePageSize >= mTotal ? "active" : "")"
                                    @onclick="@(() => { _mobilePageSize = mTotal; _mobileCurrentPage = 0; StateHasChanged(); })">All</button>
                        </div>
                    </div>
                    <div class="fmc-mobile-pager-nav">
                        <button class="fmc-mobile-nav-btn" @onclick="@(() => { _mobileCurrentPage = 0; StateHasChanged(); })" disabled="@(_mobileCurrentPage == 0)"><MudIcon Icon="@Icons.Material.Filled.FirstPage" Size="Size.Small"/></button>
                        <button class="fmc-mobile-nav-btn" @onclick="@(() => { _mobileCurrentPage--; StateHasChanged(); })" disabled="@(_mobileCurrentPage == 0)"><MudIcon Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small"/></button>
                        <span>@(_mobileCurrentPage + 1) of @mPages</span>
                        <button class="fmc-mobile-nav-btn" @onclick="@(() => { _mobileCurrentPage++; StateHasChanged(); })" disabled="@(_mobileCurrentPage >= mPages - 1)"><MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"/></button>
                        <button class="fmc-mobile-nav-btn" @onclick="@(() => { _mobileCurrentPage = mPages - 1; StateHasChanged(); })" disabled="@(_mobileCurrentPage >= mPages - 1)"><MudIcon Icon="@Icons.Material.Filled.LastPage" Size="Size.Small"/></button>
                    </div>
                </div>
            }
        }
    }
    </MudPaper>
</MudContainer>
</div>


@code {
    private MudTable<AuditLogDto> _table = default!;
    private bool _loading = true;
    private bool _isMobile;
    private AuditLogQueryDto _query = new() { PageSize = 25 };
    private AuditLogSearchResultDto _searchResult = new();
    private DateRange _dateRange = new(DateTime.Today.AddDays(-7), DateTime.Today);
    private string _activeDateRange = "7d";
    private string _searchString = "";
    private int _mobilePageSize = 10;
    private int _mobileCurrentPage = 0;

    [Inject] private IReportService ReportService { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private int _financialCount => _searchResult.Items.Count(i => i.Action == "CREDIT" || i.Action == "DEBIT");
    private int _authCount => _searchResult.Items.Count(i => i.Action != "CREDIT" && i.Action != "DEBIT" && i.Action != "CLIENT_CRASH");
    private int _errorCount => _searchResult.Items.Count(i => i.Action == "CLIENT_CRASH");

    protected override async Task OnInitializedAsync()
    {
        if (!RendererInfo.IsInteractive) return;
        await PerformSearch();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isMobile = await ViewportService.GetCurrentBreakpointAsync() <= Breakpoint.Sm;
            await ViewportService.SubscribeAsync(this, fireImmediately: true);
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        await ViewportService.UnsubscribeAsync(this);
    }

    Guid IBrowserViewportObserver.Id { get; } = Guid.NewGuid();

    MudBlazor.Services.ResizeOptions? IBrowserViewportObserver.ResizeOptions { get; } = new()
    {
        ReportRate = 100,
        NotifyOnBreakpointOnly = true
    };

    Task IBrowserViewportObserver.NotifyBrowserViewportChangeAsync(BrowserViewportEventArgs args)
    {
        var mobile = args.Breakpoint <= Breakpoint.Sm;
        if (_isMobile != mobile)
        {
            _isMobile = mobile;
            return InvokeAsync(StateHasChanged);
        }
        return Task.CompletedTask;
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        _searchString = e.Value?.ToString() ?? "";
    }

    private bool FilterFunc(AuditLogDto log)
    {
        if (string.IsNullOrWhiteSpace(_searchString)) return true;
        
        var query = _searchString.Trim().ToLowerInvariant();
        if (log.Action?.ToLowerInvariant().Contains(query) == true) return true;
        if (log.EntityName?.ToLowerInvariant().Contains(query) == true) return true;
        if (log.Organization?.ToLowerInvariant().Contains(query) == true) return true;
        if (log.Label?.ToLowerInvariant().Contains(query) == true) return true;
        if (log.Details?.ToLowerInvariant().Contains(query) == true) return true;
        if (log.IpAddress?.ToLowerInvariant().Contains(query) == true) return true;
        
        return false;
    }

    private void ShowDetail(AuditLogDto log)
    {
        var parameters = new DialogParameters<AuditDetailDialog> { { x => x.Log, log } };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        DialogService.ShowAsync<AuditDetailDialog>("Forensic Data Trace", parameters, options);
    }

    private async Task PerformSearch()
    {
        try
        {
            _loading = true;
            _mobileCurrentPage = 0;
            _query.FromDate = _dateRange.Start;
            _query.ToDate = _dateRange.End?.AddDays(1).AddTicks(-1); // End of the day

            _searchResult = await OrgService.SearchAuditLogsAsync(_query);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Forensic Retrieval Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SetCategory(string? category)
    {
        _query.Category = category;
        await PerformSearch();
    }

    private async Task SetQuickDate(string range)
    {
        _activeDateRange = range;
        var today = DateTime.Today;
        
        switch (range)
        {
            case "all":
                _dateRange = new DateRange(null, null);
                break;
            case "today":
                _dateRange = new DateRange(today, today);
                break;
            case "7d":
                _dateRange = new DateRange(today.AddDays(-7), today);
                break;
            case "30d":
                _dateRange = new DateRange(today.AddDays(-30), today);
                break;
            case "1y":
                _dateRange = new DateRange(today.AddYears(-1), today);
                break;
        }
        await PerformSearch();
    }

    private async Task UpdateDate(ChangeEventArgs e, bool isStart)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
        {
            if (isStart) _dateRange = new DateRange(dt, _dateRange.End);
            else _dateRange = new DateRange(_dateRange.Start, dt);
            _activeDateRange = "custom";
            await PerformSearch();
        }
    }

    private string GetActiveFilterString()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(_searchString)) parts.Add($"Query: '{_searchString.Trim()}'");
        parts.Add($"Category: {(_query.Category?.ToUpper() ?? "ALL")}");
        parts.Add($"Date: {_dateRange.Start:MM/dd/yyyy} to {(_dateRange.End ?? DateTime.Today):MM/dd/yyyy}");
        return string.Join(" | ", parts);
    }

    private async Task ExportExcel()
    {
        var filteredData = _table?.FilteredItems?.ToList() ?? _searchResult.Items.Where(FilterFunc).ToList();
        if (!filteredData.Any()) return;
        var bytes = ReportService.GenerateAuditExcel("Forensic Intelligence Log", filteredData, GetActiveFilterString());
        await DownloadFile("AuditIntelligence.xlsx", bytes, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        Snackbar.Add("Forensic log exported as Excel successfully.", Severity.Success);
    }

    private async Task ExportPdf()
    {
        var filteredData = _table?.FilteredItems?.ToList() ?? _searchResult.Items.Where(FilterFunc).ToList();
        if (!filteredData.Any()) return;
        var bytes = ReportService.GenerateAuditPdf("Forensic Intelligence Log", filteredData, GetActiveFilterString());
        await DownloadFile("AuditIntelligence.pdf", bytes, "application/pdf");
        Snackbar.Add("Forensic log exported as PDF successfully.", Severity.Success);
    }

    private async Task ResetSearchFilters()
    {
        _searchString = "";
        _query.Category = null;
        var today = DateTime.Today;
        _dateRange = new DateRange(today.AddDays(-7), today);
        _activeDateRange = "7d";
        await PerformSearch();
    }

    private async Task DownloadFile(string fileName, byte[] content, string contentType)
    {
        using var streamRef = new DotNetStreamReference(new MemoryStream(content));
        await JS.InvokeVoidAsync("fmc_downloadFile", fileName, contentType, streamRef);
    }

    private string FormatAction(string? action)
    {
        if (string.IsNullOrEmpty(action)) return string.Empty;
        var upper = action.ToUpperInvariant();
        return upper switch
        {
            "TRANSACTION_APPROVED" => "Transaction Approved",
            "BATCH_SUBMITTED" => "Batch Submitted",
            "BATCH_CANCELLED" => "Batch Cancelled",
            "BATCH_REJECTED" => "Batch Rejected",
            "TRANSACTION_REJECTED" => "Transaction Rejected",
            "SYNC_LIMIT" => "Sync Limit",
            "WALLET_ADJUSTED" => "Wallet Adjusted",
            "EXHAUSTION_WARNING" => "Exhaustion Warning",
            "APPROVAL_SUCCESS" => "Approval Success",
            "CLIENT_CRASH" => "Client Error Crash",
            _ => System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(action.Replace("_", " ").ToLower())
        };
    }
}
