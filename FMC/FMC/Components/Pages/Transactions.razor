@page "/transactions"
@attribute [Authorize]

<PageTitle>Transactions</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Transactions</MudText>

<MudTable T="TransactionDto" Items="@_transactions" Hover="true" Bordered="true" Striped="true" Breakpoint="Breakpoint.Sm" Filter="new Func<TransactionDto,bool>(FilterFunc1)" SelectedItem="_selectedItem" SelectedItemChanged="@((TransactionDto? item) => OnSelectedItemChanged(item))" Loading="@_loading">
    <ToolBarContent>
        <MudText Typo="Typo.h6">History</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportExcel" Class="ml-4">Excel</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.PictureAsPdf" OnClick="ExportPdf" Class="ml-2">PDF</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog" Class="ml-4">Add Transaction</MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Date)">Date</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Label)">Label</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Category)">Category</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<TransactionDto, object>(x => x.Amount)">Amount</MudTableSortLabel></MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Date">@context!.Date.ToShortDateString()</MudTd>
        <MudTd DataLabel="Label">@context!.Label</MudTd>
        <MudTd DataLabel="Category">@context!.Category</MudTd>
        <MudTd DataLabel="Amount">
            <MudText Color="@(context!.Amount < 0 ? Color.Error : Color.Success)">
                @context!.Amount.ToString("C")
            </MudText>
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Disabled="true" />
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    private List<TransactionDto> _transactions = new();
    private string _searchString = "";
    private TransactionDto? _selectedItem;

    [Inject] private ApiFinanceService FinanceService { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!RendererInfo.IsInteractive) return;
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        try
        {
            _loading = true;
            _transactions = await FinanceService.GetRecentTransactionsAsync(100);
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading transactions: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnSelectedItemChanged(TransactionDto? item)
    {
        _selectedItem = item;
    }

    private bool FilterFunc1(TransactionDto? transaction) => transaction != null && FilterFunc(transaction, _searchString);

    private bool FilterFunc(TransactionDto transaction, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (transaction.Label.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (transaction.Category.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private async Task OpenAddDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<AddTransactionDialog>("Add Transaction", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is TransactionDto newTransaction)
        {
            await FinanceService.AddTransactionAsync(newTransaction);
            await LoadTransactions();
            Snackbar.Add("Transaction added successfully", Severity.Success);
        }
    }

    private async Task ExportExcel()
    {
        var bytes = ReportService.GenerateExcel(_transactions);
        await DownloadFile("Transactions.xlsx", bytes);
    }

    private async Task ExportPdf()
    {
        var bytes = ReportService.GeneratePdf(_transactions);
        await DownloadFile("Transactions.pdf", bytes);
    }

    private async Task DownloadFile(string fileName, byte[] content)
    {
        using var streamRef = new DotNetStreamReference(new MemoryStream(content));
        await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
    }

    [Inject] private IReportService ReportService { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
}
