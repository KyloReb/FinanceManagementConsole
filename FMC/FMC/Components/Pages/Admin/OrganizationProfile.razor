@page "/admin/organizations/{Id:guid}"
@using FMC.Shared.Auth
@using FMC.Shared.DTOs.Organization
@using FMC.Shared.DTOs.User
@using FMC.Services.Api
@using FMC.Services
@using FMC.Components.Dashboard
@using MudBlazor
@attribute [Authorize(Roles = $"{Roles.SuperAdmin},{Roles.CEO},{Roles.Maker},{Roles.Approver},{Roles.SuperAdminApprover}")]
@inject OrganizationApiService OrganizationService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthProvider
@inject IReportService ReportService
@inject IJSRuntime JS
<div class="fmc-profile-viewport">
<PageTitle>Subscriber Profile | FMC</PageTitle>
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mt-md-8 mb-12">
    @if (_loading)
    {
        <style>
            .profile-skel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; }
            .fmc-skel { background: rgba(var(--mud-palette-primary-rgb), 0.08); border-radius: 8px; position: relative; overflow: hidden; }
            .fmc-skel::after { content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent); animation: fmc-shimmer 1.5s infinite; }
            .fmc-skel-line { height: 12px; margin-bottom: 8px; }
            @@keyframes fmc-shimmer { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
        </style>
        <div class="profile-skel-header">
            <div class="d-flex align-center">
                <div class="fmc-skel" style="width: 40px; height: 40px; border-radius: 50%; margin-right: 16px;"></div>
                <div class="fmc-skel" style="width: 50px; height: 50px; border-radius: 12px; margin-right: 16px;"></div>
                <div>
                    <div class="fmc-skel fmc-skel-line" style="width: 250px; height: 32px; border-radius: 8px;"></div>
                    <div class="fmc-skel fmc-skel-line" style="width: 150px; height: 16px; border-radius: 4px; margin-top: 8px;"></div>
                </div>
            </div>
            <div class="fmc-skel" style="width: 120px; height: 36px; border-radius: 10px;"></div>
        </div>

        <MudGrid>
            <MudItem xs="12" md="4" lg="3">
                <MudPaper Elevation="0" Class="fmc-glass-surface pa-6 mb-6">
                    <div class="fmc-skel fmc-skel-line mb-6" style="width: 60%; height: 16px;"></div>
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="mb-4">
                            <div class="fmc-skel fmc-skel-line" style="width: 40%; height: 10px; margin-bottom: 6px;"></div>
                            <div class="fmc-skel fmc-skel-line" style="width: 80%; height: 18px;"></div>
                        </div>
                    }
                </MudPaper>

                <MudPaper Elevation="0" Class="fmc-glass-surface pa-6 mb-6">
                    <div class="fmc-skel fmc-skel-line mb-6" style="width: 70%; height: 16px;"></div>
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="d-flex align-center gap-3 mb-4">
                            <div class="fmc-skel" style="width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;"></div>
                            <div style="flex-grow: 1;">
                                <div class="fmc-skel fmc-skel-line" style="width: 50%; height: 12px; margin-bottom: 4px;"></div>
                                <div class="fmc-skel fmc-skel-line" style="width: 70%; height: 10px; margin-bottom: 4px;"></div>
                                <div class="fmc-skel fmc-skel-line" style="width: 30%; height: 14px; border-radius: 4px;"></div>
                            </div>
                        </div>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="8" lg="9">
                <MudPaper Elevation="0" Class="fmc-glass-surface pa-6 mb-6" Style="height: 180px;">
                    <div class="d-flex align-center justify-space-between mb-6">
                        <div>
                            <div class="fmc-skel fmc-skel-line" style="width: 100px; height: 12px;"></div>
                            <div class="fmc-skel fmc-skel-line mt-2" style="width: 220px; height: 32px;"></div>
                        </div>
                        <div class="d-flex gap-2">
                            <div class="fmc-skel" style="width: 100px; height: 36px; border-radius: 8px;"></div>
                            <div class="fmc-skel" style="width: 80px; height: 36px; border-radius: 8px;"></div>
                            <div class="fmc-skel" style="width: 80px; height: 36px; border-radius: 8px;"></div>
                        </div>
                    </div>
                    <div class="d-flex align-center gap-3 mb-4">
                        <div style="flex-grow: 1;">
                            <div class="fmc-skel fmc-skel-line" style="width: 50px; height: 10px;"></div>
                            <div class="fmc-skel fmc-skel-line mt-1" style="width: 150px; height: 20px;"></div>
                        </div>
                        <div class="fmc-skel" style="width: 1px; height: 30px; background: var(--mud-palette-divider);"></div>
                        <div style="flex-grow: 1;">
                            <div class="fmc-skel fmc-skel-line" style="width: 80px; height: 10px;"></div>
                            <div class="fmc-skel fmc-skel-line mt-1" style="width: 180px; height: 20px;"></div>
                        </div>
                    </div>
                    <div class="fmc-skel" style="width: 100%; height: 6px; border-radius: 3px;"></div>
                </MudPaper>

                <MudPaper Elevation="0" Class="fmc-glass-surface pa-6 mb-6">
                    <div class="d-flex align-center justify-space-between mb-6">
                        <div>
                            <div class="fmc-skel fmc-skel-line" style="width: 180px; height: 20px;"></div>
                            <div class="fmc-skel fmc-skel-line mt-1" style="width: 250px; height: 12px;"></div>
                        </div>
                        <div class="d-flex gap-2">
                            <div class="fmc-skel" style="width: 110px; height: 36px; border-radius: 8px;"></div>
                            <div class="fmc-skel" style="width: 110px; height: 36px; border-radius: 8px;"></div>
                        </div>
                    </div>
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="d-flex align-center pa-4" style="border-bottom: 1px solid var(--mud-palette-divider); gap: 24px;">
                            <div style="flex:1;" class="d-flex align-center gap-3">
                                <div class="fmc-skel" style="width:4px; height:24px;"></div>
                                <div style="flex:1;">
                                    <div class="fmc-skel fmc-skel-line mb-2" style="width:70%;"></div>
                                    <div class="fmc-skel fmc-skel-line" style="width:40%;"></div>
                                </div>
                            </div>
                            <div style="flex:1;">
                                <div class="fmc-skel fmc-skel-line mb-2" style="width:80%;"></div>
                                <div class="fmc-skel fmc-skel-line" style="width:50%;"></div>
                            </div>
                            <div style="flex:1;" class="d-flex justify-center">
                                <div class="fmc-skel" style="width: 80px; height: 20px; border-radius: 10px;"></div>
                            </div>
                            <div style="flex:1;" class="text-right">
                                <div class="fmc-skel fmc-skel-line ml-auto" style="width:80px; height: 18px;"></div>
                            </div>
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    else if (_org == null)
    {
        <div class="pa-10 text-center">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Large" />
            <MudText Typo="Typo.h6" Class="mt-4">Subscriber Not Found</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="@(() => Navigation.NavigateTo("/"))">Return to Dashboard</MudButton>
        </div>
    }
    else
    {
        @if (_showSyncSuccess)
        {
            <div class="fmc-premium-notification success">
                <div class="fmc-notification-glow"></div>
                <div class="fmc-notification-content">
                    <div class="fmc-notification-icon-container">
                        <MudIcon Icon="@Icons.Material.Filled.Verified" Class="fmc-notification-icon" />
                    </div>
                    <div class="fmc-notification-text-wrap">
                        <MudText Typo="Typo.subtitle2" Class="fmc-notification-title">Sync Complete</MudText>
                        <MudText Typo="Typo.caption" Class="fmc-notification-msg">Wallet balance reset to available mother-account cash. Usage cleared for the new period.</MudText>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Class="fmc-notification-close" OnClick="@(() => _showSyncSuccess = false)" Size="Size.Small" />
                </div>
            </div>
        }

            var totalLimit = _org.WalletLimit;           // Authorized liquidity ceiling
            // Usage = active cardholder deployment; negative values shown as zero
            var usage = Math.Max(0, _org.Usage); 
            var disposableBalance = _org.RemainingBalance;
            var hasLimit = totalLimit > 0;
            var usagePct = hasLimit ? (double)(usage / totalLimit) * 100.0 : 0;

            RenderFragment liquidityCard = @<MudPaper Elevation="0" Class="fmc-glass-surface pa-6 pa-md-8 accent-primary w-100">
                 <div class="d-flex flex-column gap-6">
                     @* TOP ROW: WALLET LIMIT + ACTIONS *@
                     <div class="d-flex flex-column flex-sm-row align-start align-sm-center justify-space-between gap-4">
                         <div>
                             <MudText Typo="Typo.subtitle2" Class="fmc-section-label">WALLET BALANCE</MudText>
                             <div class="d-flex align-center gap-3 mt-1">
                                 @if (_isBalanceVisible)
                                 {
                                     <MudText Class="fmc-balance-val fmc-money">@totalLimit.ToString("C")</MudText>
                                 }
                                 else
                                 {
                                     <MudText Class="fmc-balance-val fmc-money mud-text-secondary" Style="letter-spacing: 0.1em; padding-top:4px;">••••••••</MudText>
                                 }
                                 <MudTooltip Text="@(_isBalanceVisible ? "Hide Balance" : "Show Balance")">
                                     <MudIconButton Icon="@(_isBalanceVisible ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)" 
                                                    OnClick="ToggleBalanceVisibility" Size="Size.Small" Class="mud-text-secondary" />
                                 </MudTooltip>
                             </div>
                         </div>
                         <div class="fmc-profile-actions-row" style="z-index: 2;">
                             <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Sync" 
                                        OnClick="HandleSyncLimitAsync" Class="fmc-action-btn fmc-btn-sync">SYNC LIMIT</MudButton>
                             <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.RemoveCircleOutline" 
                                        OnClick="@(() => OpenOrgBalanceDialog(false))" Class="fmc-action-btn fmc-btn-debit">DEBIT</MudButton>
                             <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.AddCircleOutline" 
                                        OnClick="@(() => OpenOrgBalanceDialog(true))" Class="fmc-action-btn fmc-btn-credit">CREDIT</MudButton>
                         </div>
                     </div>

                     @* BOTTOM ROW: USAGE AND TOTAL LIMIT *@
                     <div class="fmc-liquidity-matrix">
                         <div class="fmc-matrix-item">
                             <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:800;">USAGE</MudText>
                             <div class="d-flex align-center gap-3">
                                 <MudText Typo="Typo.h6" Class="fmc-money">@usage.ToString("C0")</MudText>
                                 @if (hasLimit)
                                 {
                                     <span class="fmc-util-pill @(usagePct >= 90 ? "critical" : usagePct >= 80 ? "warning" : "normal")">
                                         @usagePct.ToString("F1")%
                                     </span>
                                 }
                             </div>
                         </div>
                         <div class="fmc-matrix-divider"></div>
                         <div class="fmc-matrix-item">
                             <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:800;">REMAINING BALANCE</MudText>
                             <MudText Typo="Typo.h6" Class="fmc-money">@disposableBalance.ToString("C")</MudText>
                         </div>
                         @* UTILIZATION BAR *@
                         <div class="fmc-full-util-wrap mt-2">
                             <div class="fmc-full-util-bar">
                                 <div class="fmc-full-util-fill @(usagePct >= 95 ? "critical" : usagePct >= 80 ? "warning" : "normal")" 
                                       style="width: @(Math.Min(usagePct, 100).ToString("F0"))%;"></div>
                             </div>
                         </div>
                     </div>
                 </div>

                 <div class="fmc-watermark-icon">
                     <MudIcon Icon="@Icons.Material.Filled.AccountBalance" />
                 </div>
            </MudPaper>;

        <MudMessageBox @ref="_mbox" Title="Capacity Synchronization" CancelText="Cancel">
            <MessageContent>
                Reset wallet balance to mother-account cash on hand and clear usage for a new period? Cardholder ledger balances are not changed.
            </MessageContent>
            <YesButton>
                <MudButton Variant="Variant.Filled" Color="Color.Info" Class="px-6" Style="text-transform:none; font-weight:800; border-radius:10px;">Confirm Sync</MudButton>
            </YesButton>
        </MudMessageBox>

        <div class="fmc-profile-header mb-8 d-flex align-center justify-space-between flex-wrap gap-4">
            <div class="d-flex align-center">
                <MudTooltip Text="Return to Dashboard">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Class="mr-4" OnClick="@(() => Navigation.NavigateTo("/"))" />
                </MudTooltip>
                <div class="fmc-org-icon mr-4">
                    <MudText Typo="Typo.h4" Style="font-weight: 800; color: var(--mud-palette-primary);">@_org.Name?[0]</MudText>
                </div>
                <div>
                    <div class="d-flex align-center flex-wrap gap-3">
                        <MudText Typo="Typo.h4" Style="font-weight: 900; letter-spacing: -0.02em;">@_org.Name</MudText>
                        <div class="fmc-status-indicator @(_org.IsActive ? "active" : "suspended")" style="margin-top: 2px;">
                            <div class="fmc-pulse"></div>
                            <span style="font-weight: 800;">@(_org.IsActive ? "OPERATIONAL" : "SUSPENDED")</span>
                        </div>
                    </div>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1" Style="letter-spacing: 0.05em; text-transform: uppercase;">SUBSCRIBER PROFILE • @_org.Id.ToString().Split('-')[0]</MudText>
                </div>
            </div>
            <div class="d-flex align-center gap-2">
                @if (_isSuperAdmin)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" 
                               OnClick="OpenEditDialog" Style="border-radius:10px; font-weight:800; text-transform:none;">Modify Entity</MudButton>
                }
            </div>
       </div>

       @* Mobile VIP Placement: Liquidity First *@
       @if (_org!.Name != "Nationlink/Infoserve Inc.")
       {
           <div class="d-block d-md-none mb-6">
               @liquidityCard
           </div>
       }

       <MudGrid>
           <MudItem xs="12" md="4" lg="3">
                <MudPaper Elevation="0" Class="fmc-glass-surface pa-6 mb-6">
                    <MudText Typo="Typo.subtitle2" Class="fmc-section-label mb-4">ENTITY DETAILS</MudText>
                    
                    <div class="mb-4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">DESIGNATED CEO</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 700;">@(_org.CeoName ?? "Unassigned")</MudText>
                    </div>

                    <div class="mb-4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">SUBSCRIBER ACCOUNT</MudText>
                        <MudText Typo="Typo.body1" Style="font-weight: 700; font-family: 'JetBrains Mono', monospace;">
                            @MaskAccountNumber(_org.AccountNumber)
                        </MudText>
                    </div>

                    <div class="mb-4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">CREATED ON</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@_org.CreatedAt.ToString("MMM dd, yyyy")</MudText>
                    </div>

                    <div class="mb-4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">ACCOUNT NUMBER</MudText>
                        <MudText Typo="Typo.body2" Style="font-weight: 700; letter-spacing: 0.1em;" Color="Color.Primary">
                            @MaskAccountNumber(GetStableAccountNumber(_org.Id.ToString(), _org.AccountNumber))
                        </MudText>
                    </div>

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-1">BUSINESS DESCRIPTION</MudText>
                    <MudText Typo="Typo.body2">@(_org.Description ?? "No description provided.")</MudText>
                </MudPaper>

                @* ── LEADERSHIP & OPERATIONS TEAM (Relocated to Column 1) ── *@
                <MudPaper Elevation="0" Class="fmc-glass-surface pa-6 mb-6">
                    <MudText Typo="Typo.subtitle2" Class="fmc-section-label mb-4">LEADERSHIP & OPERATIONS</MudText>
                    <div class="fmc-sidebar-staff-list">
                        @foreach (var user in _staff.Take(10))
                        {
                            <div class="d-flex align-start gap-3 mb-4 cursor-pointer fmc-sidebar-user-item" @onclick="@(() => Navigation.NavigateTo($"/profile/{user.Id}"))">
                                <MudAvatar Color="@GetRoleColor(user.Role)" Size="Size.Small" Variant="Variant.Filled" Style="font-weight: 800; font-size: 0.7rem; width:28px; height:28px;">@user.DisplayName?[0]</MudAvatar>
                                <div style="min-width: 0;">
                                    <div class="d-flex align-center flex-wrap gap-1">
                                        <MudText Typo="Typo.body2" Style="font-weight: 800; font-size: 0.8rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@user.DisplayName</MudText>
                                        <div class="fmc-mini-dot @(user.IsActive ? "active" : "inactive")"></div>
                                    </div>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-1" Style="font-size: 0.7rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@user.Email</MudText>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@GetRoleColor(user.Role)" 
                                             Style="font-weight: 900; font-size: 0.6rem; height: 16px; margin-left: -8px; padding: 0 4px;">@user.Role</MudChip>
                                </div>
                            </div>
                        }
                    </div>
                </MudPaper>

                @if (_org!.Name != "Nationlink/Infoserve Inc.")
                {
                    <MudPaper Elevation="0" Class="fmc-glass-surface pa-6 accent-info mb-6">
                        <MudText Typo="Typo.subtitle2" Class="fmc-section-label mb-2">SYSTEM TENANTS</MudText>
                        <MudText Typo="Typo.h3" Class="d-none d-sm-block fmc-money mt-1 mb-1">@_cardholders.Count</MudText>
                        <MudText Typo="Typo.h5" Class="d-block d-sm-none fmc-money mt-1 mb-1">@_cardholders.Count</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Registered Cardholders</MudText>
                    </MudPaper>
                }
           </MudItem>

           <MudItem xs="12" md="8" lg="9">
                @* Desktop Standard Placement: Liquidity Flow *@
                @if (_org!.Name != "Nationlink/Infoserve Inc.")
                {
                    <div class="d-none d-md-block mb-6">
                        @liquidityCard
                    </div>
                }

                <div class="mb-6">
                    <PendingApprovalQueue OrganizationId="Id" OrganizationName="@_org?.Name" />
                </div>

                @if (_org!.Name != "Nationlink/Infoserve Inc.")
                {
                    <MudPaper Elevation="0" Class="fmc-glass-surface pa-6">
                        <div class="d-none d-md-block">
                            <MudTable Items="@_cardholders" Filter="new Func<UserDto,bool>(FilterFunc)" Hover="true" Breakpoint="Breakpoint.None" Elevation="0" Class="fmc-premium-table">
                                <ToolBarContent>
                                    <div class="d-flex flex-column">
                                        <div class="d-flex align-center gap-2">
                                            <MudText Typo="Typo.h6" Style="font-weight: 800;" Class="mb-0">Registered Cardholders</MudText>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text" Style="font-weight: 950; font-size: 0.65rem; border: 1px solid var(--mud-palette-divider);">@_cardholders.Count ROWS</MudChip>
                                        </div>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:700;">@_cardholders.Count Identifiable Units Found</MudText>
                                    </div>
                                    <MudSpacer />
                                    <MudTextField @bind-Value="_searchString" Placeholder="Search cardholders..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" Immediate="true"></MudTextField>
                                </ToolBarContent>
                                <HeaderContent>
                                    <MudTh><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.DisplayName)">IDENTITY</MudTableSortLabel></MudTh>
                                    <MudTh Style="text-align: right;"><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Balance)">LEDGER</MudTableSortLabel></MudTh>
                                </HeaderContent>
                                <RowTemplate Context="userCtx">
                                    <MudTd DataLabel="Identity">
                                        <div class="d-flex align-center gap-3 fmc-hover-user" style="cursor: pointer; padding: 4px; border-radius: 8px; transition: all 0.2s;" @onclick="@(() => Navigation.NavigateTo($"/profile/{userCtx.Id}"))">
                                            <MudAvatar Color="Color.Default" Size="Size.Small" Style="@($"background-color: {GetAvatarColor(userCtx.DisplayName)} !important; color: white; font-weight: 950; font-size: 0.7rem;")">@(GetInitials(userCtx))</MudAvatar>
                                            <div>
                                                <div class="d-flex align-center gap-2">
                                                    <MudText Typo="Typo.body2" Style="font-weight: 700; color: var(--mud-palette-text-primary);">@userCtx.DisplayName</MudText>
                                                    <MudChip T="string" Size="Size.Small" Color="@(userCtx.IsActive ? Color.Success : Color.Error)" Style="height: 18px; font-size: 0.65rem; padding: 0 6px;">@(userCtx.IsActive ? "Active" : "Suspended")</MudChip>
                                                </div>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary d-block">@userCtx.Email</MudText>
                                                <MudText Typo="Typo.caption" Class="d-block mud-text-secondary mt-1" Style="letter-spacing: 0.05em;">Acct: <span style="font-weight: 600;">@MaskAccountNumber(GetStableAccountNumber(userCtx.Id, userCtx.AccountNumber))</span></MudText>
                                            </div>
                                        </div>
                                    </MudTd>
                                    <MudTd DataLabel="Ledger" Style="text-align: right;">
                                        <MudText Class="fmc-money" Typo="Typo.body2" Color="@(userCtx.Balance < 0 ? Color.Error : Color.Default)">@userCtx.Balance.ToString("C")</MudText>
                                    </MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4">No cardholders found.</MudText>
                                </NoRecordsContent>
                                <PagerContent>
                                    <MudTablePager PageSizeOptions="new int[]{10, 25, 50, 100}" RowsPerPageString="Rows per page:" />
                                </PagerContent>
                            </MudTable>
                        </div>

                        <div class="d-block d-md-none fmc-mobile-list" style="max-height: 400px; overflow-y: auto; padding-right: 4px;">
                            @if (_cardholders.Any())
                            {
                                @foreach (var userCtx in _cardholders.Where(FilterFunc))
                                {
                                    <div class="fmc-mobile-user-card mb-3 pa-4">
                                        <div class="d-flex align-center justify-space-between mb-3">
                                            <div class="d-flex align-center gap-3 fmc-hover-user" style="cursor: pointer; padding: 4px; border-radius: 8px; transition: all 0.2s;" @onclick="@(() => Navigation.NavigateTo($"/profile/{userCtx.Id}"))">
                                                <MudAvatar Color="Color.Default" Size="Size.Small" Style="@($"background-color: {GetAvatarColor(userCtx.DisplayName)} !important; color: white; font-weight: 950; font-size: 0.7rem;")">@(GetInitials(userCtx))</MudAvatar>
                                                <div>
                                                    <div class="d-flex align-center gap-2 mb-1">
                                                        <MudText Typo="Typo.body1" Style="font-weight: 800; font-size: 0.95rem; color: var(--mud-palette-text-primary);">@userCtx.DisplayName</MudText>
                                                    </div>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@userCtx.Email</MudText>
                                                    <MudText Typo="Typo.caption" Class="d-block mud-text-secondary mt-1" Style="letter-spacing: 0.05em;">Acct: <span style="font-weight: 600;">@MaskAccountNumber(GetStableAccountNumber(userCtx.Id, userCtx.AccountNumber))</span></MudText>
                                                </div>
                                            </div>
                                            <MudText Class="fmc-money" Typo="Typo.body2" Style="font-weight: 900;" Color="@(userCtx.Balance < 0 ? Color.Error : Color.Default)">@userCtx.Balance.ToString("C")</MudText>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Class="mud-text-secondary pa-4 text-center">No affiliated cardholders found.</MudText>
                            }
                        </div>
                    </MudPaper>
                }
           </MudItem>
       </MudGrid>
    }
</MudContainer>
</div>

@* Styles isolated to OrganizationProfile.razor.css *@

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private MudMessageBox _mbox { get; set; } = default!;
    private OrganizationDto? _org;
    private List<UserDto> _staff = new();
    private List<UserDto> _cardholders = new();

    private bool _isBalanceVisible = true;
    private string _searchString = "";
    private bool _showSyncSuccess = false;

    // Filter toolbar state
    private string _activeDateFilter = "all";
    private string? _activeCategory = null;
    private DateTime? _filterStart = null;
    private DateTime? _filterEnd = null;

    private bool FilterFunc(UserDto user)
    {
        // Text search
        if (!string.IsNullOrWhiteSpace(_searchString))
        {
            if (user.DisplayName?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) != true &&
                user.Role?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) != true)
                return false;
        }
        // Category filter
        if (_activeCategory == "financial" && user.Balance == 0) return false;
        if (_activeCategory == "security" && user.IsActive) return false;
        // Date filter: based on CreatedAt
        if (_filterStart.HasValue && user.CreatedAt < _filterStart.Value) return false;
        if (_filterEnd.HasValue && user.CreatedAt > _filterEnd.Value.AddDays(1).AddTicks(-1)) return false;
        return true;
    }

    private void ToggleBalanceVisibility()
    {
        _isBalanceVisible = !_isBalanceVisible;
    }

    private void SetCategory(string? category)
    {
        _activeCategory = category;
    }

    private void SetDateFilter(string key)
    {
        _activeDateFilter = key;
        var today = DateTime.Today;
        (_filterStart, _filterEnd) = key switch
        {
            "today" => ((DateTime?)today, (DateTime?)today),
            "7d"    => (today.AddDays(-7), today),
            "30d"   => (today.AddDays(-30), today),
            "1y"    => (today.AddYears(-1), today),
            _       => ((DateTime?)null, (DateTime?)null), // "all"
        };
    }

    private void OnStartDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
        { _filterStart = dt; _activeDateFilter = "custom"; }
    }

    private void OnEndDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
        { _filterEnd = dt; _activeDateFilter = "custom"; }
    }

    private async Task ExportXls()
    {
        if (_org == null || !_cardholders.Any()) { Snackbar.Add("No cardholder data to export.", Severity.Warning); return; }
        var data = _cardholders.Where(FilterFunc).ToList();
        var filterLabel = BuildFilterLabel();
        var bytes = ReportService.GenerateCardholderExcel(_org.Name, data, filterLabel);
        await DownloadFile($"Cardholders_{_org.Name.Replace(" ","_")}_{DateTime.Now:yyyyMMdd}.xlsx", bytes, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        Snackbar.Add("Cardholder ledger exported as Excel.", Severity.Success);
    }

    private async Task ExportPdf()
    {
        if (_org == null || !_cardholders.Any()) { Snackbar.Add("No cardholder data to export.", Severity.Warning); return; }
        var data = _cardholders.Where(FilterFunc).ToList();
        var filterLabel = BuildFilterLabel();
        var bytes = ReportService.GenerateCardholderPdf(_org.Name, data, filterLabel);
        await DownloadFile($"CardholderAudit_{_org.Name.Replace(" ","_")}_{DateTime.Now:yyyyMMdd}.pdf", bytes, "application/pdf");
        Snackbar.Add("Cardholder audit report downloaded.", Severity.Success);
    }

    private string BuildFilterLabel()
    {
        if (_filterStart.HasValue && _filterEnd.HasValue)
            return $"Registered: {_filterStart:MM/dd/yyyy} – {_filterEnd:MM/dd/yyyy}";
        if (_filterStart.HasValue) return $"From: {_filterStart:MM/dd/yyyy}";
        if (_filterEnd.HasValue)   return $"To: {_filterEnd:MM/dd/yyyy}";
        return "All Records";
    }

    private async Task DownloadFile(string fileName, byte[] content, string contentType)
    {
        using var streamRef = new DotNetStreamReference(new MemoryStream(content));
        await JS.InvokeVoidAsync("fmc_downloadFile", fileName, contentType, streamRef);
    }

    private bool _isMaker;
    private bool _isApprover;
    private bool _isSuperAdmin;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        _isSuperAdmin = state.User.IsInRole(Roles.SuperAdmin);
        _isMaker = state.User.IsInRole(Roles.Maker);
        _isApprover = state.User.IsInRole(Roles.Approver) || state.User.IsInRole(Roles.CEO) || _isSuperAdmin || state.User.IsInRole(Roles.SuperAdminApprover);
        await LoadProfileDataAsync();
    }

    private async Task LoadProfileDataAsync()
    {
        try
        {
            _loading = true;
            _org = await OrganizationService.GetByIdAsync(Id);
            if (_org != null)
            {
                var allUsers = await OrganizationService.GetUsersAsync(Id);
                _staff = allUsers.Where(u => u.Role != Roles.User).ToList();
                _cardholders = allUsers.Where(u => u.Role == Roles.User).ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Validation error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenOrgBalanceDialog(bool isCredit)
    {
        if (_org == null) return;

        var parameters = new DialogParameters<OrganizationBalanceDialog>
        {
            { x => x.Organization, _org },
            { x => x.IsCredit, isCredit }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<OrganizationBalanceDialog>("", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadProfileDataAsync();
        }
    }

    private async Task OpenUserBalanceDialog(UserDto user, bool isCredit)
    {
        var parameters = new DialogParameters<UserBalanceDialog>
        {
            { x => x.User, user },
            { x => x.IsCredit, isCredit }
        } ;

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<UserBalanceDialog>("", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadProfileDataAsync();
        }
    }

    private async Task OpenEditDialog()
    {
        if (_org == null) return;
        
        var parameters = new DialogParameters<OrganizationDialog>
        {
            { x => x.OrganizationToEdit, _org }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<OrganizationDialog>("Modify Organization", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadProfileDataAsync();
        }
    }

    private async Task HandleSyncLimitAsync()
    {
        var result = await _mbox.ShowAsync();
        if (result == true)
        {
            try 
            {
                var success = await OrganizationService.SyncLimitAsync(Id);
                if (success)
                {
                    _showSyncSuccess = true;
                    StateHasChanged();
                    await LoadProfileDataAsync();
                    
                    // Auto fade out toast after 4.5 seconds
                    _ = Task.Delay(4500).ContinueWith(_ =>
                    {
                        _showSyncSuccess = false;
                        InvokeAsync(StateHasChanged);
                    });
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Sync Failed: {ex.Message}", Severity.Error);
            }
        }
    }

    private Color GetRoleColor(string role) => role switch
    {
        Roles.SuperAdmin => Color.Error,
        Roles.CEO => Color.Primary,
        Roles.Maker => Color.Info,
        Roles.Approver => Color.Success,
        _ => Color.Default
    };

    private string MaskAccountNumber(string acct)
    {
        if (string.IsNullOrEmpty(acct) || acct.Length < 10) return acct ?? "N/A";
        return $"{acct.Substring(0, 6)} {new string('*', acct.Length - 10)} {acct.Substring(acct.Length - 4)}";
    }

    private string GetStableAccountNumber(string id, string? currentAcct)
    {
        if (!string.IsNullOrWhiteSpace(currentAcct) && currentAcct != "N/A" && currentAcct.Length > 10) return currentAcct;
        var rnd = new Random(id.GetHashCode());
        long r1 = rnd.Next(10000, 99999);
        long r2 = rnd.Next(100000, 999999);
        return "63641" + r1.ToString("D5") + r2.ToString("D6");
    }
    private string GetAvatarColor(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "#7c4dff";
        string[] colors = { "#4f46e5", "#e11d48", "#059669", "#7c3aed", "#d97706", "#2563eb" };
        var index = Math.Abs(name.GetHashCode()) % colors.Length;
        return colors[index];
    }

    private string GetInitials(UserDto user)
    {
        if (string.IsNullOrWhiteSpace(user.DisplayName)) return "U";
        var parts = user.DisplayName.Split(' ');
        if (parts.Length < 2) return user.DisplayName.Substring(0, Math.Min(2, user.DisplayName.Length)).ToUpper();
        return $"{parts[0][0]}{parts[1][0]}".ToUpper();
    }
}
