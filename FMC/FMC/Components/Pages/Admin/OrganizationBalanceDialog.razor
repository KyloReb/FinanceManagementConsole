@using FMC.Shared.DTOs.Organization
@using MudBlazor
@using FMC.Services.Api
@using Microsoft.AspNetCore.Components.Authorization

<MudDialog Class="fmc-balance-dialog">
    <DialogContent>
        <div class="pa-4">
            <div class="d-flex align-center mb-6">
                <MudIcon Icon="@(IsCredit ? Icons.Material.Filled.AddCircle : Icons.Material.Filled.RemoveCircle)" 
                         Color="@(IsCredit ? Color.Success : Color.Error)" Size="Size.Large" Class="mr-3" />
                <div class="d-flex flex-column">
                    <MudText Typo="Typo.h6" Style="font-weight: 800;">@(IsCredit ? "Credit Wallet" : "Debit Wallet")</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Adjusting funds for @Organization.Name</MudText>
                </div>
            </div>

            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <MudNumericField T="decimal?"
                                     Value="_amount"
                                     ValueChanged="OnAmountChanged"
                                     Label="Adjustment Amount" Variant="Variant.Outlined" 
                                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Payments"
                                     Format="N0" HideSpinButtons="true" Min="0.01m"
                                     Placeholder="e.g. 5,000" Class="fmc-amount-field"
                                     Validation="@(new Func<decimal?, string?>(ValidateAmount))" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_label" Label="Ledger Note / Reason" 
                                  Placeholder="e.g. Monthly Subscription Fee, Manual Adjustment..."
                                  Variant="Variant.Outlined" Lines="2" />
                </MudItem>

                <MudItem xs="12">
                    <MudAlert Severity="MudBlazor.Severity.Warning" Class="mb-3 fmc-security-alert">
                        You are authorizing a structural modification to the organization's core liquidity.
                    </MudAlert>
                    <MudTextField @bind-Value="_adminPassword" Label="Confirm Administrator Password" 
                                  Variant="Variant.Outlined" InputType="@PasswordInput" 
                                  Adornment="Adornment.End" AdornmentIcon="@PasswordInputIcon"
                                  OnAdornmentClick="TogglePasswordVisibility"
                                  Immediate="true"
                                  HelperText="Please enter your authentication credentials to authorize" Required="true" />
                </MudItem>
            </MudGrid>

            <div class="mt-8 pa-4 fmc-impact-box">
                <div class="d-flex justify-space-between mb-2">
                    <MudText Typo="Typo.body2">Current Balance:</MudText>
                    <MudText Typo="Typo.body2" Style="font-weight: 700;">@Organization.TotalBalance.ToString("C")</MudText>
                </div>
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.body2">Resulting Balance:</MudText>
                    <MudText Typo="Typo.body1" Style="font-weight: 900;" 
                             Color="@((CalculateNewBalance() ?? 0) < 0 ? MudBlazor.Color.Error : MudBlazor.Color.Success)">
                        @((CalculateNewBalance() ?? 0).ToString("C"))
                    </MudText>
                </div>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="fmc-dialog-footer">
            <MudButton OnClick="Cancel" Variant="Variant.Text" Style="text-transform:none; font-weight: 600;">Discard</MudButton>
            <MudSpacer />
            <MudButton Color="@(IsCredit ? MudBlazor.Color.Success : MudBlazor.Color.Error)" 
                       Variant="Variant.Filled" 
                       Disabled="@(!IsFormValid())" 
                       OnClick="SubmitAsync"
                       Style="text-transform:none; font-weight: 700; border-radius: 10px; padding: 10px 28px;">
                @if (_isProcessing)
                {
                    <MudProgressCircular Size="MudBlazor.Size.Small" Indeterminate="true" Class="mr-2" />
                    <MudText>Processing...</MudText>
                }
                else
                {
                    <MudText>Confirm @(IsCredit ? "Credit" : "Debit")</MudText>
                }
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

<style>
    .fmc-balance-dialog { 
        border-radius: 20px !important; 
        overflow: hidden; 
        background-color: var(--mud-palette-surface) !important;
    }
    .fmc-amount-field .mud-input-root { 
        font-size: 1.75rem !important; 
        font-weight: 900 !important; 
        color: var(--mud-palette-primary) !important; 
    }
    .fmc-impact-box { 
        background-color: var(--mud-palette-background-grey); 
        border-radius: 14px; 
        border: 1px solid var(--mud-palette-divider);
        padding: 16px;
    }
    .fmc-dialog-footer {
        padding: 20px 32px;
        display: flex;
        align-items: center;
        width: 100%;
        background-color: var(--mud-palette-background-grey);
        border-top: 1px solid var(--mud-palette-divider);
    }
</style>

@code {
    [Inject] private OrganizationApiService OrgService { get; set; } = default!;
    [Inject] private AuthService AuthService { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    [CascadingParameter] MudBlazor.IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public OrganizationDto Organization { get; set; } = default!;
    [Parameter] public bool IsCredit { get; set; }

    private decimal? _amount;
    private string _label = "";
    private string _adminPassword = "";
    private bool _isProcessing;
    private bool _showPassword;

    private InputType PasswordInput => _showPassword ? InputType.Text : InputType.Password;
    private string PasswordInputIcon => _showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private string? ValidateAmount(decimal? value)
    {
        if (value == null || value <= 0) return "Amount must be greater than 0";
        return null;
    }

    private void OnAmountChanged(decimal? value)
    {
        _amount = value;
        StateHasChanged(); // Refresh button state and Resulting Balance preview
    }

    private bool IsFormValid()
    {
        return (_amount ?? 0) > 0 && !string.IsNullOrWhiteSpace(_adminPassword) && !_isProcessing;
    }

    private decimal? CalculateNewBalance()
    {
        if (_amount == null) return Organization.TotalBalance;
        return IsCredit ? Organization.TotalBalance + _amount : Organization.TotalBalance - _amount;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        if (!IsFormValid()) return;

        try
        {
            _isProcessing = true;

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var emailClaim = authState.User.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.Email || c.Type == "email")?.Value;
            
            if (string.IsNullOrEmpty(emailClaim))
            {
                 Snackbar.Add("Session error. Missing email claim. Please log out and back in.", MudBlazor.Severity.Error);
                 return;
            }

            var authResult = await AuthService.Login(new FMC.Shared.DTOs.Auth.LoginRequestDto { Identifier = emailClaim, Password = _adminPassword });
            if (authResult == null)
            {
                Snackbar.Add("Security Authorization Failed: Invalid password.", MudBlazor.Severity.Error);
                _isProcessing = false;
                return;
            }

            decimal adjustment = IsCredit ? (_amount ?? 0) : -(_amount ?? 0);
            var success = await OrgService.AdjustBalanceAsync(Organization.Id, adjustment, _label);
            
            if (success)
            {
                OrgService.NotifyDataChanged();
                Snackbar.Add($"Ledger updated successfully for {Organization.Name}", MudBlazor.Severity.Success);
                MudDialog.Close(MudBlazor.DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Failed to update organization ledger.", MudBlazor.Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"System Error: {ex.Message}", MudBlazor.Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }
}
