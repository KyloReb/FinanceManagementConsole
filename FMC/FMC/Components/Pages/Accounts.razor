    private async Task ConfirmDeleteUser(UserDto user)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var currentUserEmail = authState.User.Identity?.Name;
        
        if (string.Equals(user.Email, currentUserEmail, StringComparison.OrdinalIgnoreCase))
        {
            Snackbar.Add("Security Violation: You cannot delete your own account.", Severity.Error);
            return;
        }

        var result = await DialogService.ShowMessageBoxAsync("Confirm Deletion", 
            $"Are you sure you want to permanently remove {user.DisplayName}? This will revoke all system access for this staff member.", 
            yesText: "Delete Account", cancelText: "Cancel");

        if (result == true)
        {
            var success = await AdminService.DeleteUserAsync(user.Id);
            if (success)
            {
                Snackbar.Add("Staff account successfully decommissioned.", Severity.Success);
                await LoadUsers();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add("Failed to remove staff account.", Severity.Error);
            }
        }
    }
