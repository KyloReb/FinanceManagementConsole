}
</div>

@code {
    #region ── UI State & Data ──
    private bool _loading = true;
    private bool _isCeo;
    private bool _isSuperAdmin;
    private bool _isSuperAdminApprover;
    private bool _showOversightPanel = true;
    private string _pendingPanelMaxHeight => _isSuperAdminApprover ? "655px" : "475px";
    private string _currentUserName = "Approver";
    private List<OrganizationDto> _organizations = new();
    private List<UserDto> _users = new();
    private List<AuditLogDto> _auditLogs = new();
    private List<AuditLogDto> _allAuditLogs = new();
    private static readonly HashSet<string> PendingInitiationActions = new()
    {
        "ADJUSTMENT_REQUESTED", "DEBIT_REQUESTED", "INITIATE_CREDIT", "INITIATE_DEBIT"
    };
    private int _auditLogLimit = 10;
    private bool _auditLoading = true;
    private int _pendingCount;
    private bool _pendingLoading;
    private bool _pendingSortAscending;
    private Guid? _homeApprovingId;
    private bool _homeShowOverlay;
    private string _homeOverlayTitle = "";
    private string _homeOverlaySubtext = "";
    private bool _homeOverlaySuccess;
    private List<FMC.Shared.DTOs.TransactionDto> _pendingTransactions = new();
    private string _activeAuditRange = "7d";
    private AuditLogQueryDto _auditQuery = new() { PageSize = 20 };
    private string _walletSearchQuery = "";
    private int _walletPageSize = 5;

    // Charting & Analytics
    private double[] _pieData = Array.Empty<double>();
    private string[] _pieLabels = Array.Empty<string>();
    private List<OrganizationDto> _topSubscribers = new();
    private decimal _totalBalance = 0;
    private decimal _monthlyExpenses = 0;
    private int _activeBudgetsCount = 0;
    private List<TransactionDto> _recentTransactions = new();
    private double[] _chartData = Array.Empty<double>();
    private string[] _chartLabels = Array.Empty<string>();
    private List<ChartSeries<double>> _donutSeries = new();
    private List<ChartSeries<double>> _lineChartSeries = new();
    private string[] _lineChartLabels = Array.Empty<string>();
    private ChartOptions _lineChartOptions = new() { ChartPalette = new[] { "#2ecc71", "#e74c3c" } };
    private string _selectedTimeframe = "Daily";
    private List<ChartSeries<double>> _utilizationSeries = new();
    private ChartOptions _utilizationOptions = new() { ChartPalette = new[] { "#e74c3c", "#3498db" } };

    // Gauge Scrubber State
    private Dictionary<Guid, double> _scrubPositions = new();
    private Dictionary<Guid, decimal> _scrubAmounts = new();
    private Dictionary<Guid, bool> _scrubActive = new();
    private Dictionary<Guid, bool> _cardCollapsed = new();
    private string _walletSortOrder = "util_high";
    private string _cardholderSearch = "";
    #endregion

    #region ── UI Handlers ──
    private async Task RefreshPendingRequests()
    {
        if (_pendingLoading || _organizations.Count == 0) return;
        try
        {
            _pendingLoading = true;
            StateHasChanged();
            var pendingTasks = _organizations.Select(o => OrgService.GetPendingTransactionsAsync(o.Id));
            var pendingResults = await Task.WhenAll(pendingTasks);
            var pendingItems = pendingResults
                .SelectMany(r => r)
                .Where(t => t.Category == "Org Adjustment Pending")
                .ToList();
            _pendingTransactions = _pendingSortAscending
                ? pendingItems.OrderBy(t => t.Date).ToList()
                : pendingItems.OrderByDescending(t => t.Date).ToList();
            _pendingCount = _pendingTransactions.Count;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to refresh pending requests: {ex.Message}", Severity.Error);
        }
        finally
        {
            _pendingLoading = false;
            StateHasChanged();
        }
    }

    private void TogglePendingSort()
    {
        _pendingSortAscending = !_pendingSortAscending;
        _pendingTransactions = _pendingSortAscending
            ? _pendingTransactions.OrderBy(t => t.Date).ToList()
            : _pendingTransactions.OrderByDescending(t => t.Date).ToList();
    }

    private string GetSortLabel() => _walletSortOrder switch
    {
        "alpha" => "Alphabetical",
        "util_high" => "Highest Utilization",
        "util_low" => "Lowest Utilization",
        "recent" => "Recently Credited",
        _ => "Sort By"
    };
    private bool _allMinimized = false;
    private void ToggleUtilizationSort()
    {
        if (_walletSortOrder == "util_high") _walletSortOrder = "util_low";
        else _walletSortOrder = "util_high";
    }
    private void ToggleAlphaSort()
    {
        if (_walletSortOrder == "alpha") _walletSortOrder = "alpha_desc";
        else _walletSortOrder = "alpha";
    }
    private void ToggleAllCards()
    {
        _allMinimized = !_allMinimized;
        foreach (var org in _organizations)
        {
            _cardCollapsed[org.Id] = _allMinimized;
        }
    }
    private void ToggleCardCollapse(Guid orgId)
    {
        if (_cardCollapsed.ContainsKey(orgId))
            _cardCollapsed[orgId] = !_cardCollapsed[orgId];
        else
            _cardCollapsed[orgId] = true;
    }
    #endregion

    #region ── Lifecycle & Core Logic ──
    protected override async Task OnInitializedAsync()
    {
        if (!RendererInfo.IsInteractive) return;
        try 
        {
            _loading = true;
            
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            _isCeo = user.IsInRole(Roles.CEO);
            _isSuperAdmin = user.IsInRole(Roles.SuperAdmin);
            _isSuperAdminApprover = user.IsInRole(Roles.SuperAdminApprover);
            try { var me = await AuthService.GetCurrentUserAsync(); if (me != null) _currentUserName = me.DisplayName; }
            catch { _currentUserName = user.Identity?.Name ?? "Approver"; }
            
            if (_isSuperAdmin || _isSuperAdminApprover || _isCeo || user.IsInRole(Roles.Maker) || user.IsInRole(Roles.Approver))
            {
                if (!user.IsInRole(Roles.SuperAdmin) && !user.IsInRole(Roles.SuperAdminApprover))
                {
                    var orgIdClaim = user.FindFirst("OrganizationId")?.Value;
                    if (Guid.TryParse(orgIdClaim, out var orgId))
                    {
                        var orgTask = OrgService.GetByIdAsync(orgId);
                        var usersTask = OrgService.GetUsersAsync(orgId);
                        var auditTask = OrgService.GetRecentAuditLogsAsync(_auditLogLimit, "financial");
                        var allAuditTask = OrgService.GetRecentAuditLogsAsync(30, null);
                        
                        await Task.WhenAll(orgTask, usersTask, auditTask, allAuditTask);
                        
                        var org = await orgTask;
                        if (org != null) 
                        {
                            _organizations = new List<OrganizationDto> { org };
                            _totalBalance = org.TotalBalance;
                        }
                        
                        _users = (await usersTask).ToList();
                        _auditLogs = (await auditTask).ToList();
                        _allAuditLogs = (await allAuditTask).ToList();
                        _allAuditLogs = _allAuditLogs.Where(l => !PendingInitiationActions.Contains(l.Action)).ToList();
                    }
                }
                else // SuperAdmin
                {
                    var orgsTask = OrgService.GetOrganizationsAsync();
                    var auditTask = OrgService.GetRecentAuditLogsAsync(_auditLogLimit, "financial");
                    var allAuditTask = OrgService.GetRecentAuditLogsAsync(30, null);
                    
                    await Task.WhenAll(orgsTask, auditTask, allAuditTask);
                    
                    _organizations = (await orgsTask).Where(o => o.Name != "Nationlink/Infoserve Inc.").ToList();
                    _auditLogs = (await auditTask).ToList();
                    _allAuditLogs = (await allAuditTask).ToList();

                    // Load pending transactions across all organizations (SuperAdmin-initiated only)
                    try
                    {
                        _pendingLoading = true;
                        var pendingTasks = _organizations.Select(o => OrgService.GetPendingTransactionsAsync(o.Id));
                        var pendingResults = await Task.WhenAll(pendingTasks);
                        var pendingItems = pendingResults
                            .SelectMany(r => r)
                            .Where(t => t.Category == "Org Adjustment Pending")
                            .ToList();
                        _pendingTransactions = _pendingSortAscending
                            ? pendingItems.OrderBy(t => t.Date).ToList()
                            : pendingItems.OrderByDescending(t => t.Date).ToList();
                        _pendingCount = _pendingTransactions.Count;
                    }
                    finally
                    {
                        _pendingLoading = false;
                    }
                }
                
                PrepareLineChartData();
                _auditLoading = false;
            }
            else 
            {
                _totalBalance = await FinanceService.GetTotalBalanceAsync();
                _monthlyExpenses = await FinanceService.GetMonthlyExpensesAsync();
                var budgets = await FinanceService.GetAccountsAsync();
                _activeBudgetsCount = budgets.Count;
                _recentTransactions = await FinanceService.GetRecentTransactionsAsync(5);

                var groupedData = _recentTransactions
                    .Where(t => t.Amount < 0)
                    .GroupBy(t => t.Category)
                    .Select(g => new { Category = g.Key, Amount = (double)Math.Abs(g.Sum(t => t.Amount)) })
                    .ToList();

                _chartData = groupedData.Select(d => d.Amount).ToArray();
                _chartLabels = groupedData.Select(d => d.Category).ToArray();
                _donutSeries = new List<ChartSeries<double>> { new ChartSeries<double> { Name = "Allocation", Data = _chartData } };
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Dashboard Load Failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }

        ThemeService.OnChange += HandleThemeChanged;
    }

    private void HandleThemeChanged() => InvokeAsync(StateHasChanged);

    private async Task RefreshDashboard() 
    {
        _auditLoading = true;
        StateHasChanged();
        await OnInitializedAsync();
    }

    private async Task HandleOversightDismissed(bool dismissed)
    {
        _showOversightPanel = false;
        StateHasChanged();
    }

    private async void OpenPendingDetail(FMC.Shared.DTOs.TransactionDto tx)
    {
        var parameters = new DialogParameters { ["Transaction"] = tx, ["IsOwnTransaction"] = false };
        await DialogService.ShowAsync<FMC.Components.Pages.Admin.Dialogs.PendingDetailDialog>("Transaction Details", parameters, new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });
    }

    private async Task HandleHomeApproveAsync(Guid txId)
    {
        if (_homeApprovingId != null) return;
        var tx = _pendingTransactions.FirstOrDefault(t => t.Id == txId);
        if (tx == null) return;

        var secOpts = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, BackdropClick = false };
        var secDialog = await DialogService.ShowAsync<FMC.Components.Pages.Admin.SecurityVerificationDialog>("Security Verification", new DialogParameters(), secOpts);
        var secResult = await secDialog.Result;
        if (secResult is null || secResult.Canceled) return;

        _homeApprovingId = txId;
        StateHasChanged();
        try
        {
            await OrgService.ApproveTransactionAsync(txId);
            _homeApprovingId = null;
            _homeOverlayTitle = "TRANSACTION AUTHORIZED";
            _homeOverlaySubtext = $"₱{Math.Abs(tx.Amount):N2} {(tx.Amount >= 0 ? "credit" : "debit")} for {tx.Subscriber} has been approved.";
            _homeOverlaySuccess = true;
            _homeShowOverlay = true;
            StateHasChanged();
        }
        catch (Exception ex) { Snackbar.Add($"Approval failed: {ex.Message}", Severity.Error); }
        finally { _homeApprovingId = null; }
    }

    private async Task HandleHomeRejectAsync(Guid txId)
    {
        if (_homeApprovingId != null) return;
        var tx = _pendingTransactions.FirstOrDefault(t => t.Id == txId);
        if (tx == null) return;

        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirm Rejection",
            $"Deny the ₱{Math.Abs(tx.Amount):N2} {(tx.Amount >= 0 ? "credit" : "debit")} request for {tx.Subscriber}?",
            "Yes, Reject", "Cancel");
        if (confirm != true) return;

        var reasonParams = new DialogParameters
        {
            ["Title"] = "Reject Request",
            ["ContentText"] = $"Please provide a reason for rejecting the ₱{Math.Abs(tx.Amount):N2} request for {tx.Subscriber}. (optional)"
        };
        var reasonDialog = await DialogService.ShowAsync<FMC.Components.Pages.Admin.Dialogs.RejectionDialog>("Reject Transaction", reasonParams, new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small });
        var reasonResult = await reasonDialog.Result;
        if (reasonResult is null || reasonResult.Canceled) return;

        var reason = (reasonResult.Data as string)?.Trim();
        if (string.IsNullOrEmpty(reason)) reason = $"Rejected by {_currentUserName}.";

        _homeApprovingId = txId;
        StateHasChanged();
        try
        {
            await OrgService.RejectTransactionAsync(txId, reason);
            _homeApprovingId = null;
            _homeOverlayTitle = "REQUEST DENIED";
            _homeOverlaySubtext = $"₱{Math.Abs(tx.Amount):N2} {(tx.Amount >= 0 ? "credit" : "debit")} for {tx.Subscriber} has been rejected.";
            _homeOverlaySuccess = false;
            _homeShowOverlay = true;
            StateHasChanged();
        }
        catch (Exception ex) { Snackbar.Add($"Rejection failed: {ex.Message}", Severity.Error); }
        finally { _homeApprovingId = null; }
    }
