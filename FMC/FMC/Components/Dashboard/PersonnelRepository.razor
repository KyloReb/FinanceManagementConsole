@using FMC.Shared.Auth
@using FMC.Shared.DTOs.User
@using FMC.Shared.DTOs.Organization
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthProvider
@inject OrganizationApiService OrgService

<MudPaper Elevation="0" Class="fmc-main-surface">
    <div class="fmc-header-area d-flex flex-wrap gap-4 align-center justify-space-between" style="padding: 24px 32px;">
        <div class="d-flex align-center flex-grow-1" style="min-width: 280px;">
            <div class="fmc-header-icon mr-4"><MudIcon Icon="@Icons.Material.Filled.CreditCard" Color="Color.Primary" /></div>
            <div>
                <MudText Typo="Typo.h6" Style="font-weight: 800; letter-spacing: -0.01em; line-height: 1.2;">Active Cardholder Registry</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Real-time ledger balances across your active cards</MudText>
            </div>
        </div>
        <div class="fmc-control-orchestrator d-flex align-center gap-4 flex-grow-1" style="min-width: 300px; justify-content: flex-end;">
            <MudButton Variant="Variant.Text" 
                       Color="Color.Primary" 
                       StartIcon="@Icons.Material.Filled.People" 
                       Href="/accounts"
                       Style="font-weight: 800; text-transform:none; white-space: nowrap;">
                View All Cardholders
            </MudButton>
            <div class="fmc-search-box" style="flex: 1; max-width: 400px; min-width: 200px;">
                <MudTextField @bind-Value="_searchString" 
                               Placeholder="Search cardholders..." 
                               Adornment="Adornment.Start" 
                               AdornmentIcon="@Icons.Material.Filled.Search" 
                               Variant="Variant.Outlined" 
                               Margin="Margin.None"
                               Class="fmc-premium-search" />
            </div>
        </div>
    </div>

    @* ── DESKTOP TABLE ── *@
    <div class="fmc-desktop-table">
        <MudTable Items="@_filteredUsers" Hover="true" Elevation="0" Loading="@Loading" Class="fmc-premium-table lean-table">
            <HeaderContent>
                <MudTh Class="fmc-registry-col-lean"><MudTableSortLabel SortBy="new Func<UserDto, object>(x=>x.DisplayName)">CARDHOLDER / IDENTITY</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<UserDto, object>(x=>x.Balance)" InitialDirection="SortDirection.Descending">BAL.</MudTableSortLabel></MudTh>
                <MudTh Style="text-align:right;">OPS</MudTh>
            </HeaderContent>
            <RowTemplate Context="userItem">
                <MudTd>
                    <div class="d-flex align-center gap-2">
                        <MudAvatar Color="Color.Info" Style="width: 28px; height: 28px; font-size: 0.75rem; font-weight: 800;">@userItem.DisplayName?[0]</MudAvatar>
                        <div class="flex-grow-1" style="min-width: 0;">
                            <div class="d-flex align-center gap-1">
                                <MudText Style="font-weight:900; font-size: 0.8rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@userItem.DisplayName</MudText>
                                <MudChip T="string" Size="Size.Small" Color="@(userItem.IsActive ? Color.Success : Color.Error)" 
                                         Variant="Variant.Filled" 
                                         Style="font-weight: 900; height: 16px; font-size: 0.55rem; padding: 0 6px; margin: 0;">
                                    @(userItem.IsActive ? "ACTIVE" : "OFF")
                                </MudChip>
                            </div>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.65rem; opacity: 0.8; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                @MaskAccount(userItem.AccountNumber) · <span style="font-weight: 700;">@userItem.Role</span>
                            </MudText>
                        </div>
                    </div>
                </MudTd>
                <MudTd>
                    <MudText Class="fmc-financial-mono" Style="font-size: 0.85rem;"
                             Color="@(userItem.Balance < 0 ? Color.Error : Color.Info)">
                        @userItem.Balance.ToString("C")
                    </MudText>
                </MudTd>
                <MudTd Style="text-align:right;">
                    <div class="d-flex align-center justify-end gap-1">
                        @if (_isMaker)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Success"
                                           Size="Size.Small"
                                           OnClick="@(() => OpenUserAdjustmentDialog(userItem, true))"
                                           Style="padding: 4px;" />
                            <MudIconButton Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="@(() => OpenUserAdjustmentDialog(userItem, false))"
                                           Style="padding: 4px;" />
                        }
                    </div>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <div class="pa-6 d-flex flex-column align-center mud-text-secondary">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Medium" Class="mb-1" />
                    <MudText Typo="Typo.caption">No results found.</MudText>
                </div>
            </NoRecordsContent>
        </MudTable>
    </div>

    @* ── MOBILE CARDS ── *@
    <div class="fmc-mobile-cards">
        @if (Loading)
        {
            @for (int i = 0; i < 3; i++)
            {
                <div class="fmc-mobile-card">
                    <MudSkeleton Width="60%" Height="18px" Class="mb-1" />
                    <MudSkeleton Width="40%" Height="14px" />
                </div>
            }
        }
        else if (!_filteredUsers.Any())
        {
            <div class="pa-6 d-flex flex-column align-center mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Medium" />
                <MudText Typo="Typo.caption">No personnel found.</MudText>
            </div>
        }
        else
        {
            @foreach (var user in _filteredUsers)
            {
                <div class="fmc-mobile-card pa-3">
                    <div class="d-flex align-center justify-space-between">
                        <div class="d-flex align-center gap-2">
                             <MudAvatar Color="Color.Info" Style="width: 24px; height: 24px; font-size: 0.65rem;">@user.DisplayName?[0]</MudAvatar>
                             <div>
                                 <MudText Style="font-weight:900; font-size: 0.75rem;">@user.DisplayName</MudText>
                                 <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-size: 0.6rem;">@user.Role · @(user.IsActive ? "Active" : "Off")</MudText>
                             </div>
                        </div>
                        <div class="d-flex align-center gap-1">
                             <MudText Class="fmc-financial-mono" Style="font-size: 0.8rem;" Color="@(user.Balance < 0 ? Color.Error : Color.Info)">
                                 @user.Balance.ToString("C")
                             </MudText>
                             @if (_isMaker)
                             {
                                 <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Success" OnClick="@(() => OpenUserAdjustmentDialog(user, true))" />
                             }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</MudPaper>

@code {
    [Parameter] public List<UserDto> Users { get; set; } = new();
    [Parameter] public List<FMC.Shared.DTOs.Admin.AuditLogDto> RecentLogs { get; set; } = new();
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback OnActionCompleted { get; set; }

    private string _searchString = "";

    private IEnumerable<UserDto> _filteredUsers {
        get {
            // Enforcement: Only Roles.User are "Cardholders" with wallets. 
            // All staff (CEO, Maker, Approver) are identity-only and should not appear in this registry.
            var query = Users.Where(u => u.Role == Roles.User).AsEnumerable();
            
            if (!string.IsNullOrWhiteSpace(_searchString)) {
                query = query.Where(u => u.DisplayName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) 
                                     || (u.Email?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            // Enhanced Interaction Logic: Display users who were recently debited or credited first
            var priorityUsers = RecentLogs
                .Where(l => l.Action == "CREDIT" || l.Action == "DEBIT")
                .Select(l => l.UserId) 
                .Distinct()
                .ToList();

            query = query.OrderBy(u => {
                var idx = priorityUsers.IndexOf(u.Id);
                return idx == -1 ? int.MaxValue : idx;
            }).ThenBy(u => u.DisplayName);
            
            return query.Take(10);
        }
    }

    private bool _isMaker;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        _isMaker = state.User.IsInRole(Roles.Maker);
    }

    private Color GetRoleColor(string role) => role switch
    {
        Roles.SuperAdmin => Color.Error,
        Roles.CEO => Color.Primary,
        Roles.Maker => Color.Info,
        Roles.Approver => Color.Success,
        _ => Color.Default
    };

    private async Task OpenUserAdjustmentDialog(UserDto user, bool isCredit)
    {
        var parameters = new DialogParameters { ["User"] = user, ["IsCredit"] = isCredit };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<FMC.Components.Pages.Admin.UserBalanceDialog>("Adjust Personal Ledger", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await OnActionCompleted.InvokeAsync();
        }
    }

    private string MaskAccount(string? account)
    {
        if (string.IsNullOrEmpty(account)) return "N/A";
        if (account.Length <= 10) return account;
        return $"{account[..6]}{new string('*', account.Length - 10)}{account[^4..]}";
    }
}

<style>
    .fmc-premium-table.lean-table .mud-th { padding: 10px 14px !important; font-size: 0.6rem !important; }
    .fmc-premium-table.lean-table .mud-td { padding: 10px 14px !important; }
    .fmc-registry-col-lean { min-width: 140px; }
</style>
