@using FMC.Shared.Auth
@using FMC.Shared.DTOs
@using FMC.Shared.DTOs.User
@using FMC.Shared.DTOs.Organization
@using FMC.Components.Pages.Admin
@using FMC.Components.Pages.Admin.Dialogs
@using FMC.Services.Api
@inject OrganizationApiService OrgService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ThemeService ThemeService

<div class="fmc-maker-root @(ThemeService.IsDarkMode ? "fmc-dark-mode" : "fmc-light-mode")">
<MudGrid Spacing="4">
    <MudItem xs="12">
        <div class="d-flex flex-wrap align-center justify-space-between mb-4 gap-4">
            <div>
                <MudText Typo="Typo.h4" Style="font-weight: 900; letter-spacing: -0.02em;">Organization Operations</MudText>
                <MudText Typo="Typo.subtitle2" Class="mud-text-secondary" Style="font-weight: 700;">@_roleDisplay AUTHENTICATED · @Organization.Name.ToUpper()</MudText>
            </div>
            @if (_isMaker)
            {
                <div class="d-flex gap-3">
                    <MudButton Variant="Variant.Filled" OnClick="@(() => OpenUserSelection(true))"
                               StartIcon="@Icons.Material.Filled.Add"
                               Class="fmc-enterprise-btn credit">New Credit</MudButton>
                    <MudButton Variant="Variant.Filled" Disabled="true"
                               StartIcon="@Icons.Material.Filled.Remove"
                               Class="fmc-enterprise-btn debit">New Debit</MudButton>
                    <MudButton Variant="Variant.Filled" OnClick="OpenBulkUpload"
                               StartIcon="@Icons.Material.Filled.FileUpload"
                               Class="fmc-enterprise-btn bulk">Bulk Upload</MudButton>
                </div>
            }
        </div>
    </MudItem>

    @* KPI CARDS *@
    @{
        var walletBalance = Organization.TotalBalance;
        var balanceUsed   = Organization.Usage;
        var currentBal    = walletBalance - balanceUsed;
        var usedPct       = walletBalance > 0 ? (balanceUsed / walletBalance) * 100m : 0m;
        var remainPct     = 100m - usedPct;
        var balColor      = usedPct >= 80m ? "Color.Error" : (usedPct >= 60m ? "Color.Warning" : "Color.Success");
    }
    <MudItem xs="12" sm="6" md="3">
        <div class="fmc-glass-card">
            <div class="fmc-card-content">
                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">WALLET BALANCE</MudText>
                <div class="d-flex align-end mt-1">
                    <MudText Typo="Typo.h4" Class="fmc-financial-value fmc-responsive-val">@walletBalance.ToString("C")</MudText>
                </div>
                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:700;">Total credited by admin</MudText>
            </div>
            <div class="fmc-card-icon-bg primary"><MudIcon Icon="@Icons.Material.Filled.Wallet" /></div>
            <div class="fmc-card-progress primary"></div>
        </div>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <div class="fmc-glass-card">
            <div class="fmc-card-content">
                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">CURRENT BALANCE</MudText>
                <div class="d-flex align-end gap-2 mt-1">
                    <MudText Typo="Typo.h4" Class="fmc-financial-value fmc-responsive-val"
                             Color="@(usedPct >= 80m ? Color.Error : (usedPct >= 60m ? Color.Warning : Color.Success))">
                        @currentBal.ToString("C")
                    </MudText>
                </div>
                <div class="d-flex align-center gap-1 mt-1">
                    <MudProgressLinear Value="@((double)remainPct)" Max="100"
                                       Color="@(usedPct >= 80m ? Color.Error : (usedPct >= 60m ? Color.Warning : Color.Success))"
                                       Rounded="true" Style="height:6px; flex:1;" />
                    <MudText Typo="Typo.caption" Style="font-weight:900; font-size:0.65rem; white-space:nowrap;">@remainPct.ToString("F0")% left</MudText>
                </div>
            </div>
            <div class="fmc-card-icon-bg success"><MudIcon Icon="@Icons.Material.Filled.AccountBalance" /></div>
            <div class="fmc-card-progress success"></div>
        </div>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <div class="fmc-glass-card">
            <div class="fmc-card-content">
                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">BALANCE USED</MudText>
                <div class="d-flex align-end mt-1">
                    <MudText Typo="Typo.h4" Class="fmc-financial-value fmc-responsive-val" Color="Color.Info">@balanceUsed.ToString("C")</MudText>
                </div>
                <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:700;">@usedPct.ToString("F1")% of wallet allocated</MudText>
            </div>
            <div class="fmc-card-icon-bg info"><MudIcon Icon="@Icons.Material.Filled.Payments" /></div>
            <div class="fmc-card-progress info"></div>
        </div>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <div class="fmc-glass-card">
            <div class="fmc-card-content">
                <MudText Typo="Typo.subtitle2" Class="fmc-card-label">PENDING APPROVALS</MudText>
                <div class="d-flex align-center justify-space-between mt-1">
                    <MudText Typo="Typo.h3" Style="font-weight: 900; font-family: 'Roboto Mono', monospace;">@_pendingTransactions.Count</MudText>
                    @if (_pendingTransactions.Any())
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled" Style="font-weight: 900; height: 18px;">AWAITING</MudChip>
                    }
                </div>
            </div>
            <div class="fmc-card-icon-bg warning"><MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" /></div>
            <div class="fmc-card-progress warning"></div>
        </div>
    </MudItem>

    @* ── INTELLIGENCE OVERSIGHT (WORKFLOW ALERTS) ── *@
    <MudItem xs="12">
        <WorkflowAlertPanel Loading="Loading" />
    </MudItem>


    @* ── OPERATIONAL ROW: Balanced Height Sync ── *@
    <MudItem xs="12">
        <div class="d-flex flex-wrap gap-6 fmc-operational-row" style="align-items: stretch;">
            @* LEFT: ACTIVITY LOG (Master Height) *@
            <div class="fmc-panel-container" style="flex: 8; min-width: 320px;">
                <AuditLogPanel Logs="_allAuditLogs" Loading="_auditLoading" OnRefresh="RefreshAuditLogs" />
            </div>

            @* RIGHT: PENDING QUEUE (Slave Height) *@
            <div class="fmc-panel-container" style="flex: 4; min-width: 320px;">
                <MudPaper Class="fmc-main-surface fmc-pending-paper" Elevation="0" Style="height: 820px; display: grid; grid-template-rows: auto 1fr; overflow: hidden; min-height: 0; transform: translateZ(0);">
                    <div class="pa-6 pb-0" style="grid-row: 1;">
                        <div class="d-flex align-center justify-space-between mb-4">
                            <div class="d-flex align-center">
                                <div class="fmc-header-icon fmc-warning-icon-bg mr-3">
                                    <MudIcon Icon="@Icons.Material.Filled.PendingActions" Color="Color.Warning" />
                                </div>
                                <div>
                                    <MudText Typo="Typo.h6" Style="font-weight: 900;">Pending</MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Awaiting authorization</MudText>
                                </div>
                            </div>
                            <div class="d-flex align-center">
                                <MudTooltip Text="Full View">
                                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Color="Color.Primary" Size="Size.Small" Href="/pending-requests" />
                                </MudTooltip>
                                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Default" Size="Size.Small" OnClick="RefreshPendingQueue" Disabled="_loadingData" />
                            </div>
                        </div>
                    </div>

                    <div style="grid-row: 2; display: flex; flex-direction: column; min-height: 0; overflow: hidden;">
                        @* CUSTOM HIGH-FIDELITY TABS (Replacing MudTabs for strict scroll control) *@
                        <div class="fmc-custom-tabs-header">
                            <button class="fmc-tab-btn @(_activeTab == 0 ? "active" : "")" @onclick="@(() => _activeTab = 0)">
                                <MudIcon Icon="@Icons.Material.Filled.FormatListBulleted" Size="Size.Small" Class="mr-2" />
                                QUEUE
                            </button>
                            <button class="fmc-tab-btn @(_activeTab == 1 ? "active" : "")" @onclick="@(() => _activeTab = 1)">
                                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="mr-2" />
                                TODAY
                            </button>
                        </div>

                        <div class="fmc-tab-content-root">
                        @if (_activeTab == 0)
                        {
                            @if (_loadingData)
                            {
                                <div class="fmc-skeleton-list">
                                    @for (int i = 0; i < 3; i++)
                                    {
                                        <div class="fmc-skeleton-card">
                                            <div class="d-flex justify-space-between align-start mb-3">
                                                <div style="flex:1; margin-right: 12px;">
                                                    <div class="fmc-skel fmc-skel-line" style="width: 60%; margin-bottom: 8px;"></div>
                                                    <div class="fmc-skel fmc-skel-line fmc-skel-sm" style="width: 40%;"></div>
                                                </div>
                                                <div class="fmc-skel fmc-skel-line" style="width: 80px;"></div>
                                            </div>
                                            <div class="fmc-skel fmc-skel-line fmc-skel-sm" style="width: 90%; margin-bottom: 12px;"></div>
                                            <div style="border-top: 1px dashed var(--mud-palette-divider); padding-top: 10px; display: flex; gap: 8px;">
                                                <div class="fmc-skel fmc-skel-btn"></div>
                                                <div class="fmc-skel fmc-skel-btn"></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else if (!_pendingTransactions.Any())
                            {
                                <div class="d-flex flex-column align-center justify-center pa-10 text-center" style="border: 2px dashed var(--mud-palette-divider); border-radius: 16px; min-height: 300px; margin: 16px;">
                                    <MudIcon Icon="@Icons.Material.Filled.FactCheck" Size="Size.Large" Style="opacity: 0.1;" />
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary mt-3">All clear! No pending allotment requests.</MudText>
                                </div>
                            }
                            else
                            {
                                <div class="fmc-scroll-list">
                                    @foreach (var group in GroupTransactions(_pendingTransactions))
                                    {
                                        @if (group.IsBatch)
                                        {
                                            <div class="fmc-op-card mb-4 status-batch" @onclick="@(() => OpenBatchDetail(group))" style="background: rgba(var(--mud-palette-info-rgb), 0.03); cursor: pointer;">
                                                <div class="d-flex justify-space-between align-start mb-1 gap-2">
                                                    <div class="flex-grow-1" style="min-width: 0;">
                                                        <div class="d-flex align-center gap-2 mb-1">
                                                            <MudChip T="string" Color="Color.Info" Size="Size.Small" Style="font-weight: 900; margin: 0; height: 18px; font-size: 0.6rem;">BATCH</MudChip>
                                                            <MudText Typo="Typo.body2" Style="font-weight: 900; color: var(--mud-palette-info); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Bulk Credit Allotment</MudText>
                                                        </div>
                                                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block" Style="font-size: 0.7rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">ID: @group.BatchId?.ToString()[..8]... • @group.Transactions.Count items</MudText>
                                                    </div>
                                                    <div class="text-right flex-shrink-0">
                                                        <MudText Typo="Typo.h6" Color="Color.Success" Style="font-weight: 900; font-family: 'Roboto Mono', monospace;">
                                                            @group.TotalAmount.ToString("C")
                                                        </MudText>
                                                    </div>
                                                </div>

                                                <div class="fmc-op-footer mt-3 pt-2" style="border-top: 1px dashed var(--mud-palette-divider);">
                                                    <div class="d-flex align-center mb-2" style="opacity: 0.6; gap: 6px;">
                                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Style="font-size: 0.75rem;" />
                                                        <span style="font-size: 0.62rem; font-weight: 700;">@group.Transactions.First().MakerName</span>
                                                        <span style="font-size: 0.60rem; margin-left: auto;">@group.Transactions.First().Date.ToLocalTime().ToString("MMM dd, yyyy · HH:mm")</span>
                                                    </div>
                                                    <div class="d-flex gap-2 w-100" @onclick:stopPropagation="true">
                                                        @if (_isApprover)
                                                        {
                                                            <button class="fmc-action-btn approve fmc-btn-full" @onclick="@(() => HandleBatchApproval(group.BatchId!.Value, true))">
                                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                                                Approve
                                                            </button>
                                                            <button class="fmc-action-btn reject fmc-btn-full" @onclick="@(() => HandleBatchApproval(group.BatchId!.Value, false))">
                                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                                                Reject
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <span class="fmc-status-pill awaiting">AWAITING</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            var tx = group.Transactions.First();
                                            <div class="fmc-op-card mb-4 status-pending" @onclick="@(() => OpenTransactionDetail(tx))" style="cursor: pointer;">
                                                <div class="d-flex justify-space-between align-start mb-2">
                                                    <div class="flex-grow-1 mr-2" style="min-width: 0;">
                                                        <MudText Typo="Typo.body2" Style="font-weight: 900; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@tx.Subscriber</MudText>
                                                        <div class="d-flex align-center mt-n1" style="opacity: 0.6;">
                                                            <MudIcon Icon="@Icons.Material.Filled.CreditCard" Size="Size.Small" Style="font-size: 0.75rem; margin-right: 4px;" />
                                                            <MudText Typo="Typo.caption" Style="font-family: 'Roboto Mono', monospace; font-size: 0.7rem;">@MaskAccount(tx.AccountNumber)</MudText>
                                                        </div>
                                                    </div>
                                                    <div class="text-right flex-shrink-0">
                                                        <MudText Color="@(tx.Amount < 0 ? Color.Error : Color.Success)" Style="font-weight: 900; font-family: 'Roboto Mono', monospace;">
                                                            @tx.Amount.ToString("C")
                                                        </MudText>
                                                    </div>
                                                </div>
                                                
                                                <MudText Typo="Typo.caption" Class="d-block mb-3 mud-text-secondary" Style="font-style: italic; line-height: 1.1; font-size: 0.75rem;">@tx.Label</MudText>

                                                <div class="fmc-op-footer mt-2 pt-2 px-1" style="border-top: 1px dashed var(--mud-palette-divider);" @onclick:stopPropagation="true">
                                                    <div class="d-flex align-center mb-2" style="opacity: 0.6; gap: 6px;">
                                                        <MudIcon Icon="@Icons.Material.Filled.HistoryEdu" Size="Size.Small" Style="font-size: 0.75rem;" />
                                                        <span style="font-size: 0.62rem; font-weight: 700;">@tx.MakerName</span>
                                                        <span style="font-size: 0.60rem; margin-left: auto;">@tx.Date.ToLocalTime().ToString("MMM dd, yyyy · HH:mm")</span>
                                                    </div>
                                                    <div class="d-flex align-center">
                                                        @if (_isApprover)
                                                        {
                                                            <div class="d-flex gap-1 ml-auto">
                                                                <button class="fmc-icon-action approve" title="Approve" @onclick="@(() => HandleApproval(tx, true))">
                                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                                                </button>
                                                                <button class="fmc-icon-action reject" title="Reject" @onclick="@(() => HandleApproval(tx, false))">
                                                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                                                </button>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <span class="fmc-status-pill pending ml-auto">PENDING</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            @if (_loadingData)
                            {
                                <div class="fmc-skeleton-list">
                                    @for (int i = 0; i < 3; i++)
                                    {
                                        <div class="fmc-skeleton-card">
                                            <div class="d-flex justify-space-between align-start mb-3">
                                                <div style="flex:1; margin-right: 12px;">
                                                    <div class="fmc-skel fmc-skel-line" style="width: 55%; margin-bottom: 8px;"></div>
                                                    <div class="fmc-skel fmc-skel-line fmc-skel-sm" style="width: 35%;"></div>
                                                </div>
                                                <div class="fmc-skel fmc-skel-chip"></div>
                                            </div>
                                            <div class="fmc-skel fmc-skel-line fmc-skel-sm" style="width: 80%; margin-bottom: 8px;"></div>
                                            <div class="fmc-skel fmc-skel-line fmc-skel-sm" style="width: 50%;"></div>
                                        </div>
                                    }
                                </div>
                            }
                            else if (!_todayTransactions.Any())
                            {
                                <div class="d-flex flex-column align-center justify-center pa-10 text-center" style="border: 2px dashed var(--mud-palette-divider); border-radius: 16px; min-height: 300px; margin: 16px;">
                                    <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Style="opacity: 0.1;" />
                                    <MudText Typo="Typo.body2" Class="mud-text-secondary mt-3">No transactions processed today yet.</MudText>
                                </div>
                            }
                            else
                            {
                                <div class="fmc-scroll-list">
                                    @foreach (var tx in _todayTransactions)
                                    {
                                        <div class="fmc-op-card mb-4 status-@tx.Status.ToLower()" @onclick="@(() => OpenTransactionDetail(tx))" style="cursor: pointer;">
                                            <div class="d-flex justify-space-between align-start mb-2">
                                                <div class="flex-grow-1 mr-2">
                                                    <MudText Typo="Typo.body2" Style="font-weight: 900;">@tx.Subscriber</MudText>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@tx.Label</MudText>
                                                </div>
                                                <div class="text-right">
                                                    <MudText Color="@(tx.Amount < 0 ? Color.Error : Color.Success)" Class="fmc-financial-mono">
                                                        @(tx.Amount.ToString("C"))
                                                    </MudText>
                                                    <MudChip T="string" Size="Size.Small" Color="@(tx.Status == "Approved" ? Color.Success : tx.Status == "Rejected" ? Color.Error : Color.Warning)" 
                                                             Variant="Variant.Text" Style="font-weight: 950; margin: 0; font-size: 0.65rem;">@tx.Status.ToUpper()</MudChip>
                                                </div>
                                            </div>
                                            <div class="d-flex justify-space-between align-center mt-2" style="opacity: 0.6;">
                                                <MudText Typo="Typo.caption">Time: @tx.Date.ToString("HH:mm")</MudText>
                                                <MudText Typo="Typo.caption">Maker: @tx.MakerName</MudText>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                    </div>
                </MudPaper>
            </div>
        </div>
    </MudItem>

    @* ── REGISTERED CARDHOLDER REGISTRY (Full Width at Bottom) ── *@
    @{
        var mkCardholders = Users.Where(u => !string.IsNullOrWhiteSpace(u.AccountNumber)).ToList();
    }
    @if (mkCardholders.Any())
    {
        <MudItem xs="12">
            <MudPaper Elevation="0" Class="fmc-main-surface pa-6" Style="border-radius:24px; border:1px solid var(--mud-palette-divider); background:var(--mud-palette-surface);">
                <div class="d-flex align-center justify-space-between mb-4">
                    <div class="d-flex align-center gap-3">
                        <div style="width:44px; height:44px; display:flex; align-items:center; justify-content:center; background:rgba(var(--mud-palette-info-rgb),0.1); border-radius:14px;">
                            <MudIcon Icon="@Icons.Material.Filled.ContactPage" Color="Color.Info" />
                        </div>
                        <div>
                            <MudText Typo="Typo.h6" Style="font-weight:950; letter-spacing:-0.02em;">Registered Cardholder Registry</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:700;">Enrolled personnel &amp; individual wallet allocation</MudText>
                        </div>
                    </div>
                    <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small"
                             Icon="@Icons.Material.Filled.Group"
                             Style="font-weight:900; font-size:0.65rem;">
                        @mkCardholders.Count ENROLLED
                    </MudChip>
                </div>

                <MudTextField @bind-Value="_cardholderSearch" Placeholder="Search cardholders..." Adornment="Adornment.Start" 
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mb-4"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" />

                @* Desktop Table *@
                <div class="d-none d-md-block">
                    <MudTable Items="@mkCardholders" Hover="true" Elevation="0" Dense="true" Style="background:transparent;"
                              Filter="new Func<UserDto,bool>(FilterCardholders)">
                        <HeaderContent>
                            <MudTh Style="font-size:0.65rem; font-weight:900; letter-spacing:0.08em; color:var(--mud-palette-text-secondary);">
                                <MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.DisplayName)">CARDHOLDER</MudTableSortLabel>
                            </MudTh>
                            <MudTh Style="font-size:0.65rem; font-weight:900; letter-spacing:0.08em; color:var(--mud-palette-text-secondary); text-align:right;">
                                <MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Balance)">WALLET BALANCE</MudTableSortLabel>
                            </MudTh>
                            @if (_isMaker)
                            {
                                <MudTh Style="font-size:0.65rem; font-weight:900; letter-spacing:0.08em; color:var(--mud-palette-text-secondary); text-align:center;">ACTIONS</MudTh>
                            }
                        </HeaderContent>
                        <RowTemplate Context="ch">
                            <MudTd>
                                <div class="d-flex align-center gap-3">
                                    <MudAvatar Color="Color.Info" Size="Size.Small" Style="font-size:0.75rem; font-weight:900;">
                                        @(ch.FirstName?[0])@(ch.LastName?[0])
                                    </MudAvatar>
                                    <div>
                                        <div class="d-flex align-center gap-2">
                                            <MudText Style="font-weight:800; font-size:0.85rem;">@ch.DisplayName</MudText>
                                            <MudChip T="string" Color="@(ch.IsActive ? Color.Success : Color.Error)" Size="Size.Small" Variant="Variant.Outlined" Style="font-size: 0.55rem; font-weight: 900; padding: 0 6px; height: 18px; line-height: 1.2; text-transform: uppercase; letter-spacing: 0.05em; background: rgba(var(--mud-palette-success-rgb), 0.1);">
                                                @(ch.IsActive ? "ACTIVE" : "SUSPENDED")
                                            </MudChip>
                                        </div>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-family:'JetBrains Mono',monospace; font-size:0.65rem;">
                                            @MaskAccount(ch.AccountNumber)
                                        </MudText>
                                    </div>
                                </div>
                            </MudTd>
                            <MudTd Style="text-align:right;">
                                <MudText Style="font-family:'JetBrains Mono',monospace; font-weight:900;"
                                         Color="@(ch.Balance < 0 ? Color.Error : Color.Success)">
                                    @ch.Balance.ToString("C")
                                </MudText>
                            </MudTd>
                            @if (_isMaker)
                            {
                                <MudTd Style="text-align:center;">
                                    <MudTooltip Text="Debit Disabled">
                                        <MudIconButton Icon="@Icons.Material.Filled.RemoveCircleOutline" Color="Color.Default" Size="Size.Small" Disabled="true" />
                                    </MudTooltip>
                                    <MudTooltip Text="Credit">
                                        <MudIconButton Icon="@Icons.Material.Filled.AddCircleOutline" Color="Color.Success" Size="Size.Small" OnClick="@(() => OpenBalanceAdjustment(ch, true))" />
                                    </MudTooltip>
                                </MudTd>
                            }
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[]{10, 25, 50}" />
                        </PagerContent>
                    </MudTable>
                </div>

                @* Mobile Cards *@
                <div class="d-block d-md-none">
                    @foreach (var ch in mkCardholders)
                    {
                        <div style="padding:14px 0; border-bottom:1px solid var(--mud-palette-divider);">
                            <div class="d-flex align-center justify-space-between mb-2">
                                <div class="d-flex align-center gap-3">
                                    <MudAvatar Color="Color.Info" Size="Size.Small" Style="font-size:0.75rem; font-weight:900;">
                                        @(ch.FirstName?[0])@(ch.LastName?[0])
                                    </MudAvatar>
                                    <div>
                                        <div class="d-flex align-center gap-2">
                                            <MudText Style="font-weight:800; font-size:0.85rem;">@ch.DisplayName</MudText>
                                            <MudChip T="string" Color="@(ch.IsActive ? Color.Success : Color.Error)" Size="Size.Small" Variant="Variant.Outlined" Style="font-size: 0.55rem; font-weight: 900; padding: 0 6px; height: 18px; line-height: 1.2; text-transform: uppercase; letter-spacing: 0.05em; background: rgba(var(--mud-palette-success-rgb), 0.1);">
                                                @(ch.IsActive ? "ACTIVE" : "SUSP")
                                            </MudChip>
                                        </div>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-family:'JetBrains Mono',monospace; font-size:0.65rem;">
                                            @MaskAccount(ch.AccountNumber)
                                        </MudText>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <MudText Style="font-family:'JetBrains Mono',monospace; font-weight:900;"
                                             Color="@(ch.Balance < 0 ? Color.Error : Color.Success)">
                                        @ch.Balance.ToString("C")
                                    </MudText>
                                </div>
                            </div>
                            @if (_isMaker)
                            {
                                <div class="d-flex justify-end gap-2 mt-2">
                                    <MudButton StartIcon="@Icons.Material.Filled.RemoveCircleOutline" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small" Disabled="true">Debit</MudButton>
                                    <MudButton StartIcon="@Icons.Material.Filled.AddCircleOutline" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => OpenBalanceAdjustment(ch, true))">Credit</MudButton>
                                </div>
                            }
                        </div>
                    }
                </div>
            </MudPaper>
        </MudItem>
    }
    
    @if (_showSuccessOverlay)
    {
        <div class="fmc-page-success-overlay">
            <div class="fmc-page-success-inner">
                <div class="fmc-page-success-icon">
                    <div class="fmc-glow-pulse"></div>
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="font-size: 3.5rem; color: inherit;" />
                </div>
                <MudText Typo="Typo.h5" Style="font-weight: 950; letter-spacing: 0.05em; color: var(--mud-palette-success); margin-bottom: 8px;">@_successTitle</MudText>
                <MudText Typo="Typo.body1" Style="opacity: 0.75; max-width: 380px; text-align: center; line-height: 1.7;">@_successSubtext</MudText>
                <MudButton Variant="Variant.Filled"
                           Style="margin-top: 24px; background-color: #2e7d32; color: #fff; font-weight: 900; text-transform: none; border-radius: 10px; min-width: 140px; height: 44px;"
                           OnClick="@(() => { _showSuccessOverlay = false; StateHasChanged(); })">Done</MudButton>
            </div>
        </div>
    }

    @if (_showErrorOverlay)
    {
        <div class="fmc-page-error-overlay">
            <div class="fmc-page-error-inner">
                <div class="fmc-page-error-icon">
                    <div class="fmc-glow-pulse"></div>
                    <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Style="font-size: 3rem; color: inherit;" />
                </div>
                <MudText Typo="Typo.h5" Style="font-weight: 950; letter-spacing: 0.05em; color: #ef5350; margin-bottom: 8px;">@_errorTitle</MudText>
                <MudText Typo="Typo.body1" Style="opacity: 0.75; max-width: 380px; text-align: center; line-height: 1.7;">@_errorSubtext</MudText>
                <MudButton Variant="Variant.Filled"
                           Style="margin-top: 24px; background-color: #c62828; color: #fff; font-weight: 900; text-transform: none; border-radius: 10px; min-width: 140px; height: 44px;"
                           OnClick="@(() => { _showErrorOverlay = false; StateHasChanged(); })">Dismiss</MudButton>
            </div>
        </div>
    }
</MudGrid>
</div>

@* Styles moved to MakerDashboard.razor.css *@

@code {
    [Parameter] public OrganizationDto Organization { get; set; } = new();
    [Parameter] public List<UserDto> Users { get; set; } = new();
    [Parameter] public bool Loading { get; set; }
    [Parameter] public EventCallback OnActionCompleted { get; set; }

    private List<TransactionDto> _pendingTransactions = new();
    private List<TransactionDto> _todayTransactions = new();
    private List<AuditLogDto> _allAuditLogs = new();
    private bool _loadingData;
    private bool _auditLoading;
    private bool _isApprover;
    private bool _isMaker;
    private string? _currentUserId;
    private string _cardholderSearch = "";
    private string _roleDisplay = "Operations";
    private int _activeTab = 0; // 0 = Queue, 1 = Today
    private bool _showErrorOverlay;
    private string _errorTitle = "";
    private string _errorSubtext = "";
    private bool _showSuccessOverlay;
    private string _successTitle = "";
    private string _successSubtext = "";

    private bool FilterCardholders(UserDto user)
    {
        if (string.IsNullOrWhiteSpace(_cardholderSearch)) return true;
        if (user.DisplayName.Contains(_cardholderSearch, StringComparison.OrdinalIgnoreCase)) return true;
        if ((user.AccountNumber ?? "").Contains(_cardholderSearch, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    }

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var user = authState.User;
        _isApprover = user.IsInRole(Roles.Approver);
        _isMaker = user.IsInRole(Roles.Maker);
        _currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        
        if (user.IsInRole(Roles.Maker)) _roleDisplay = "MAKER";
        else if (user.IsInRole(Roles.Approver)) _roleDisplay = "APPROVER";
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Organization.Id != Guid.Empty)
        {
            await LoadDashboardData();
        }
    }

    private async Task LoadDashboardData()
    {
        await Task.WhenAll(RefreshPendingQueue(), RefreshAuditLogs());
    }

    private async Task RefreshPendingQueue()
    {
        if (_loadingData) return;
        _loadingData = true;
        try
        {
            var pendingTask = OrgService.GetPendingTransactionsAsync(Organization.Id);
            var todayTask = OrgService.GetTodayTransactionsAsync(Organization.Id);
            
            await Task.WhenAll(pendingTask, todayTask);
            
            _pendingTransactions = await pendingTask;
            _todayTransactions = await todayTask;
        }
        catch (Exception ex)
        {
            ShowApprovalError($"Failed to sync operational queue: {ex.Message}", false);
        }
        finally
        {
            _loadingData = false;
        }
    }

    private async Task RefreshAuditLogs()
    {
        if (_auditLoading) return;
        _auditLoading = true;
        try
        {
            _allAuditLogs = await OrgService.GetRecentAuditLogsAsync(count: 20);
        }
        catch (Exception ex)
        {
            ShowApprovalError($"Failed to sync audit logs: {ex.Message}", false);
        }
        finally
        {
            _auditLoading = false;
        }
    }

    private async Task HandleApproval(TransactionDto tx, bool approve)
    {
        if (approve)
        {
            // Security gate: require password re-verification before committing any approval
            var secOpts = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, BackdropClick = false };
            var secDialog = await DialogService.ShowAsync<SecurityVerificationDialog>("Security Verification", new DialogParameters(), secOpts);
            var secResult = await secDialog.Result;
            if (secResult is null || secResult.Canceled) return;
        }
        else
        {
            string rejectMarkup = @"
                <div class='d-flex flex-column align-center text-center pt-6 pb-2 px-2'>
                    <div class='mb-4' style='background: rgba(239,68,68,0.1); border-radius: 50%; width:72px; height:72px; display:flex; align-items:center; justify-content:center; box-shadow: 0 0 20px rgba(239,68,68,0.2);'>
                        <svg style='width:36px;height:36px;color:#ef4444;' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'></circle><line x1='15' y1='9' x2='9' y2='15'></line><line x1='9' y1='9' x2='15' y2='15'></line></svg>
                    </div>
                    <h3 style='font-weight:900;letter-spacing:0.05em;font-size:1.1rem;color:var(--mud-palette-text-primary);margin-bottom:8px;'>REJECT TRANSACTION</h3>
                    <p style='color:var(--mud-palette-text-secondary);font-size:0.85rem;line-height:1.6;max-width:280px;'>This will permanently reject the pending request. The Maker will be notified and the transaction cannot be recovered.</p>
                </div>
            ";
            var rejectOptions = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, NoHeader = true };
            bool? result = await DialogService.ShowMessageBoxAsync(title: default, markupMessage: new MarkupString(rejectMarkup), yesText: "Confirm Reject", cancelText: "Go Back", options: rejectOptions);
            if (result != true) return;
        }

        try
        {
            bool success = false;
            if (approve)
            {
                success = await OrgService.ApproveTransactionAsync(tx.Id);
            }
            else
            {
                success = await OrgService.RejectTransactionAsync(tx.Id, "Rejected by Approver");
            }

            if (success)
            {
                ShowSuccessOverlay(approve ? "TRANSACTION APPROVED" : "TRANSACTION REJECTED", 
                                 approve ? "The ledger has been updated and funds allocated." : "The request has been removed from the queue.");
                await LoadDashboardData();
                await OnActionCompleted.InvokeAsync();
            }
            else
            {
                ShowApprovalError("Authorization could not be completed. Verify account balance.", false);
            }
        }
        catch (Exception ex)
        {
            ShowApprovalError(ex.Message, false);
        }
    }

    private async Task OpenTransactionDetail(TransactionDto tx)
    {
        var parameters = new DialogParameters 
        { 
            ["Transaction"] = tx,
            ["IsOwnTransaction"] = tx.MakerId == _currentUserId
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<PendingDetailDialog>("Transaction Context", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadDashboardData();
            await OnActionCompleted.InvokeAsync();
        }
    }

    private async Task OpenBatchDetail(TransactionGroup group)
    {
        if (group.Transactions == null || !group.Transactions.Any()) return;
        
        var firstTx = group.Transactions.First();
        var batchTx = new TransactionDto 
        {
            Id = group.BatchId ?? Guid.Empty,
            Subscriber = "Bulk Credit Allotment",
            AccountNumber = "MULTIPLE",
            Amount = group.TotalAmount,
            Date = firstTx.Date,
            MakerName = firstTx.MakerName,
            MakerId = firstTx.MakerId,
            Status = "Pending",
            Label = $"Batch: {group.Transactions.Count} items",
            SubTransactions = group.Transactions
        };

        var parameters = new DialogParameters 
        { 
            ["Transaction"] = batchTx,
            ["IsOwnTransaction"] = batchTx.MakerId == _currentUserId
        };
        // Use MaxWidth.Medium for batch dialogs to comfortably display the table
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<PendingDetailDialog>("Batch Context", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadDashboardData();
            await OnActionCompleted.InvokeAsync();
        }
    }

    private async Task OpenUserSelection(bool isCredit)
    {
        var parameters = new DialogParameters { ["OrgId"] = Organization.Id };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<UserSelectionDialog>("Identity Resolution", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is UserDto selectedUser)
        {
            await OpenBalanceAdjustment(selectedUser, isCredit);
        }
    }

    private async Task OpenBalanceAdjustment(UserDto user, bool isCredit)
    {
        var adjustParams = new DialogParameters { ["User"] = user, ["IsCredit"] = isCredit };
        var adjustDialog = await DialogService.ShowAsync<UserBalanceDialog>(isCredit ? "Credit Wallet" : "Debit Wallet", adjustParams, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var adjustResult = await adjustDialog.Result;
        
        if (adjustResult is not null && !adjustResult.Canceled)
        {
            await LoadDashboardData();
            await OnActionCompleted.InvokeAsync();
        }
    }

    private async Task OpenBulkUpload()
    {
        var parameters = new DialogParameters { ["OrgId"] = Organization.Id };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<BulkUploadDialog>("Bulk Cardholder Upload", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadDashboardData();
            await OnActionCompleted.InvokeAsync();
        }
    }

    private string MaskAccount(string? account)
    {
        if (string.IsNullOrEmpty(account)) return "ACCOUNT N/A";
        if (account.Length <= 10) return account;
        return $"{account[..6]}{new string('*', account.Length - 10)}{account[^4..]}";
    }

    private IEnumerable<TransactionGroup> GroupTransactions(IEnumerable<TransactionDto> txs)
    {
        return txs.GroupBy(t => t.BatchId ?? Guid.Empty)
            .Select(g => new TransactionGroup
            {
                BatchId = g.Key == Guid.Empty ? null : g.Key,
                Transactions = g.ToList(),
                TotalAmount = g.Sum(t => t.Amount),
                IsBatch = g.Key != Guid.Empty
            });
    }

    private async Task HandleBatchApproval(Guid batchId, bool approve)
    {
        if (approve)
        {
            // Security gate: require password re-verification before committing batch approval
            var secOpts = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, BackdropClick = false };
            var secDialog = await DialogService.ShowAsync<SecurityVerificationDialog>("Security Verification", new DialogParameters(), secOpts);
            var secResult = await secDialog.Result;
            if (secResult is null || secResult.Canceled) return;
        }
        else
        {
            string batchRejectMarkup = @"
                <div class='d-flex flex-column align-center text-center pt-6 pb-2 px-2'>
                    <div class='mb-4' style='background: rgba(239,68,68,0.1); border-radius: 50%; width:72px; height:72px; display:flex; align-items:center; justify-content:center; box-shadow: 0 0 20px rgba(239,68,68,0.2);'>
                        <svg style='width:36px;height:36px;color:#ef4444;' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'></circle><line x1='15' y1='9' x2='9' y2='15'></line><line x1='9' y1='9' x2='15' y2='15'></line></svg>
                    </div>
                    <h3 style='font-weight:900;letter-spacing:0.05em;font-size:1.1rem;color:var(--mud-palette-text-primary);margin-bottom:8px;'>REJECT BATCH</h3>
                    <p style='color:var(--mud-palette-text-secondary);font-size:0.85rem;line-height:1.6;max-width:280px;'>This will reject the <b>entire batch</b> and all its transactions. This action is permanent and cannot be undone.</p>
                </div>
            ";
            var rejectOptions = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, NoHeader = true };
            bool? result = await DialogService.ShowMessageBoxAsync(title: default, markupMessage: new MarkupString(batchRejectMarkup), yesText: "Confirm Reject", cancelText: "Go Back", options: rejectOptions);
            if (result != true) return;
        }

        try
        {
            var group = GroupTransactions(_pendingTransactions).FirstOrDefault(g => g.BatchId == batchId);
            int count = group?.Transactions.Count ?? 0;

            bool success = false;
            if (approve)
            {
                success = await OrgService.ApproveBatchAsync(batchId);
            }
            else
            {
                success = await OrgService.RejectBatchAsync(batchId, "Rejected via Dashboard");
            }

            if (success)
            {
                ShowSuccessOverlay(approve ? "BATCH AUTHORIZED" : "BATCH REJECTED", 
                                 approve ? "The entire batch has been securely processed." : "The batch and its transactions have been denied.");
                await LoadDashboardData();
                await OnActionCompleted.InvokeAsync();
            }
            else
            {
                ShowApprovalError("Batch authorization could not be completed.", true, count);
            }
        }
        catch (Exception ex)
        {
            ShowApprovalError(ex.Message, true, GroupTransactions(_pendingTransactions).FirstOrDefault(g => g.BatchId == batchId)?.Transactions.Count ?? 0);
        }
    }

    private class TransactionGroup
    {
        public Guid? BatchId { get; set; }
        public List<TransactionDto> Transactions { get; set; } = new();
        public decimal TotalAmount { get; set; }
        public bool IsBatch { get; set; }
    }

    #region Premium Error Handling

    private void ShowApprovalError(string rawMessage, bool isBatch, int batchCount = 0)
    {
        bool isLiquidityError = rawMessage.Contains("insufficient", StringComparison.OrdinalIgnoreCase)
                             || rawMessage.Contains("liquidity", StringComparison.OrdinalIgnoreCase);

        var batchNote = isBatch && batchCount > 0
            ? $" ({batchCount} settlement{(batchCount > 1 ? "s" : "")})"
            : string.Empty;

        _errorTitle = isLiquidityError ? "INSUFFICIENT LIQUIDITY" : (isBatch ? "BATCH FAILED" : "ACTION FAILED");
        
        if (isLiquidityError)
        {
            _errorSubtext = $"The organization's corporate float does not have enough balance to cover this settlement{batchNote}. Contact your SuperAdmin to top-up the wallet.";
        }
        else
        {
            _errorSubtext = rawMessage;
        }

        _showErrorOverlay = true;
        StateHasChanged();
    }

    private void ShowSuccessOverlay(string title, string subtext)
    {
        _successTitle = title;
        _successSubtext = subtext;
        _showSuccessOverlay = true;
        StateHasChanged();
    }

    #endregion
}

<style>
    /* Full-page error overlay — mirrors the dialog success overlay pattern */
    .fmc-page-error-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(8px);
        background: rgba(0, 0, 0, 0.55);
        animation: fmc-overlay-in 0.25s ease;
    }
    .fmc-page-error-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }
    .fmc-page-error-icon {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        background: rgba(211, 47, 47, 0.12);
        box-shadow: 0 0 40px rgba(211, 47, 47, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 8px;
        animation: fmc-icon-pop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @@keyframes fmc-overlay-in {
        from { opacity: 0; }
        to   { opacity: 1; }
    }
    @@keyframes fmc-icon-pop {
        from { transform: scale(0.5); opacity: 0; }
        to   { transform: scale(1);   opacity: 1; }
    }

    .fmc-page-success-overlay {
        background: rgba(0, 0, 0, 0.6);
    }
    .fmc-page-success-icon {
        background: rgba(67, 160, 71, 0.12);
        box-shadow: 0 0 40px rgba(67, 160, 71, 0.3);
    }
</style>
