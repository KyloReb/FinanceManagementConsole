@page "/reports"
@attribute [Authorize]
@using FMC.Shared.Auth
@using FMC.Shared.DTOs.Organization
@using FMC.Shared.DTOs.User
@using FMC.Shared.Utils
@using Microsoft.JSInterop
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthProvider
@inject OrganizationApiService OrgService
@inject IReportService ReportGen
@inject IJSRuntime JS

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    @* ── REPORTS HEADER ── *@
    <div class="d-flex align-center justify-space-between mb-8">
        <div class="d-flex align-center">
            <div class="fmc-reports-accent mr-5"></div>
            <div class="d-flex flex-column">
                <MudText Typo="Typo.h3" Class="fmc-hero-text">Intelligence Terminal</MudText>
                <MudText Typo="Typo.subtitle1" Class="fmc-subtitle">Forensic Reporting & Capital Analytics Hub</MudText>
            </div>
        </div>
    </div>

    @* ── REPORT CONTROLS ── *@
    <div class="fmc-reports-controls">
        <div class="fmc-reports-controls-row">
            <div class="fmc-report-pills">
                <button class="fmc-report-pill @(IsSelected("all") ? "active" : "")" @onclick='() => { ToggleReport("all"); }'>ALL</button>
                @foreach (var t in GetAllTypes())
                {
                    <button class="fmc-report-pill @(IsSelected(t) ? "active" : "")" @onclick='() => { ToggleReport(t); }'>@GetReportTitle(t).ToUpper()</button>
                }
            </div>
        </div>
        <div class="fmc-reports-controls-row">
            @if (_isAdmin)
            {
                <div class="fmc-org-select-inline">
                    <MudSelect T="string" Label="Organization" @bind-Value="_selectedOrgId" Variant="Variant.Outlined" Margin="Margin.Dense" Class="fmc-select-input" AnchorOrigin="Origin.BottomCenter">
                        <MudSelectItem Value="@("all")">All Organizations</MudSelectItem>
                        @foreach (var org in _organizations)
                        {
                            <MudSelectItem Value="@org.Id.ToString()">@org.Name</MudSelectItem>
                        }
                    </MudSelect>
                </div>
            }
            <div class="fmc-temporal-filter">
                <div class="fmc-date-group">
                    <button class="fmc-date-btn @(_activeDateRange == "all" ? "active" : "")" @onclick='async () => { SetQuickDate("all"); await Reload(); }'>ALL</button>
                    <button class="fmc-date-btn @(_activeDateRange == "today" ? "active" : "")" @onclick='async () => { SetQuickDate("today"); await Reload(); }'>TODAY</button>
                    <button class="fmc-date-btn @(_activeDateRange == "7d" ? "active" : "")" @onclick='async () => { SetQuickDate("7d"); await Reload(); }'>7D</button>
                    <button class="fmc-date-btn @(_activeDateRange == "30d" ? "active" : "")" @onclick='async () => { SetQuickDate("30d"); await Reload(); }'>30D</button>
                    <button class="fmc-date-btn @(_activeDateRange == "1y" ? "active" : "")" @onclick='async () => { SetQuickDate("1y"); await Reload(); }'>1Y</button>
                </div>
                <div class="fmc-custom-date-wrap">
                    <div class="fmc-date-input-box">
                        <span class="fmc-date-label">START</span>
                        <input type="date" value="@(_startDate?.ToString("yyyy-MM-dd"))" @onchange='(e) => { UpdateDate(e, true); }' class="fmc-raw-date" />
                    </div>
                    <div class="fmc-date-sep"></div>
                    <div class="fmc-date-input-box">
                        <span class="fmc-date-label">END</span>
                        <input type="date" value="@(_endDate?.ToString("yyyy-MM-dd"))" @onchange='(e) => { UpdateDate(e, false); }' class="fmc-raw-date" />
                    </div>
                </div>
            </div>
            <div class="fmc-reports-actions">
                @if (_dataLoaded)
                {
                    <button class="fmc-report-export-btn" title="Export as Excel" @onclick="ExportExcel">
                        <svg xmlns="http://www.w3.org/2000/svg" height="16" width="16" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 18H9v-2h4v2zm6-9h-5V4.5L19 11z"/></svg>
                        Excel
                    </button>
                    <button class="fmc-report-export-btn" title="Export as PDF" @onclick="ExportPdf">
                        <svg xmlns="http://www.w3.org/2000/svg" height="16" width="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-8.5 7.5c0 .83-.67 1.5-1.5 1.5H9v2H7.5V7H10c.83 0 1.5.67 1.5 1.5v1zm5 2c0 .83-.67 1.5-1.5 1.5h-2.5V7H15c.83 0 1.5.67 1.5 1.5v3zm4-3H19v1h1.5V11H19v2h-1.5V7h3v1.5zM9 9.5h1v-1H9v1zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm10 5.5h1v-3h-1v3z"/></svg>
                        PDF
                    </button>
                }
            </div>
        </div>
    </div>

    @* ── REPORT CONTENT (loading skeleton) ── *@
    @if (_reportLoading)
    {
        <div class="fmc-skel-surface">
            <div class="fmc-skel-controls">
                <div class="fmc-skel fmc-skel-select" style="width:80px;"></div>
                <div class="fmc-skel fmc-skel-select" style="width:180px;"></div>
                <div class="fmc-skel fmc-skel-select" style="width:200px;"></div>
                <div class="fmc-skel fmc-skel-select" style="width:120px;"></div>
            </div>
            <div class="fmc-skel-kpi-row">
                <div class="fmc-skel-card"><div class="fmc-skel fmc-skel-icon"></div><div class="fmc-skel-body"><div class="fmc-skel fmc-skel-line" style="width:50%;"></div><div class="fmc-skel fmc-skel-line" style="width:70%;height:18px;margin-top:4px;"></div></div></div>
                <div class="fmc-skel-card"><div class="fmc-skel fmc-skel-icon"></div><div class="fmc-skel-body"><div class="fmc-skel fmc-skel-line" style="width:50%;"></div><div class="fmc-skel fmc-skel-line" style="width:70%;height:18px;margin-top:4px;"></div></div></div>
                <div class="fmc-skel-card"><div class="fmc-skel fmc-skel-icon"></div><div class="fmc-skel-body"><div class="fmc-skel fmc-skel-line" style="width:50%;"></div><div class="fmc-skel fmc-skel-line" style="width:70%;height:18px;margin-top:4px;"></div></div></div>
                <div class="fmc-skel-card"><div class="fmc-skel fmc-skel-icon"></div><div class="fmc-skel-body"><div class="fmc-skel fmc-skel-line" style="width:50%;"></div><div class="fmc-skel fmc-skel-line" style="width:70%;height:18px;margin-top:4px;"></div></div></div>
            </div>
            <div class="fmc-skel-table">
                <div class="fmc-skel fmc-skel-table-hdr"></div>
                @for (int i = 0; i < 5; i++)
                {
                    <div class="fmc-skel-table-row">
                        <div class="fmc-skel fmc-skel-line" style="width:@(60 + i * 5)%;"></div>
                        <div class="fmc-skel fmc-skel-line" style="width:@(50 + i * 4)%;"></div>
                        <div class="fmc-skel fmc-skel-line" style="width:@(40 + i * 3)%;"></div>
                    </div>
                }
            </div>
        </div>
    }
    else if (_dataLoaded)
    {
        @foreach (var type in GetDisplayTypes())
        {
            <div class="fmc-report-panel">
            @* ── KPI row (outside surface, above the table) ── *@
            @if (type == "disbursement")
            {
                <div class="fmc-kpi-row">
                    <div class="fmc-kpi-card"><div class="fmc-kpi-icon-wrap primary"><svg xmlns="http://www.w3.org/2000/svg" height="20" width="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg></div><div class="fmc-kpi-body"><div class="fmc-kpi-label">Total Amount</div><div class="fmc-kpi-value success">₱@(_transactionData.Sum(t => Math.Abs(t.Amount)).ToString("N2"))</div></div></div>
                    <div class="fmc-kpi-card"><div class="fmc-kpi-icon-wrap info"><svg xmlns="http://www.w3.org/2000/svg" height="20" width="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-5-5 1.41-1.41L11 13.17V7h2v6.17l2.59-2.58L17 12l-5 5z"/></svg></div><div class="fmc-kpi-body"><div class="fmc-kpi-label">Transactions</div><div class="fmc-kpi-value">@_transactionData.Count</div></div></div>
                    <div class="fmc-kpi-card"><div class="fmc-kpi-icon-wrap info"><svg xmlns="http://www.w3.org/2000/svg" height="20" width="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-5-5 1.41-1.41L11 13.17V7h2v6.17l2.59-2.58L17 12l-5 5z"/></svg></div><div class="fmc-kpi-body"><div class="fmc-kpi-label">Completed</div><div class="fmc-kpi-value" style="color:var(--mud-palette-success);">@_transactionData.Count(t => t.Status is "Completed" or "Approved")</div></div></div>
                </div>
            }
            else if (type == "orghealth")
            {
                <div class="fmc-kpi-row">
                    <div class="fmc-kpi-card"><div class="fmc-kpi-icon-wrap primary"><svg xmlns="http://www.w3.org/2000/svg" height="20" width="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg></div><div class="fmc-kpi-body"><div class="fmc-kpi-label">Total Balance</div><div class="fmc-kpi-value success">₱@(_orgHealthData.Sum(o => o.TotalBalance).ToString("N2"))</div></div></div>
                    <div class="fmc-kpi-card"><div class="fmc-kpi-icon-wrap info"><svg xmlns="http://www.w3.org/2000/svg" height="20" width="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-5-5 1.41-1.41L11 13.17V7h2v6.17l2.59-2.58L17 12l-5 5z"/></svg></div><div class="fmc-kpi-body"><div class="fmc-kpi-label">Organizations</div><div class="fmc-kpi-value">@_orgHealthData.Count</div></div></div>
                </div>
            }
            else if (type == "cardholders")
            {
                <div class="fmc-kpi-row">
                    <div class="fmc-kpi-card"><div class="fmc-kpi-icon-wrap primary"><svg xmlns="http://www.w3.org/2000/svg" height="20" width="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg></div><div class="fmc-kpi-body"><div class="fmc-kpi-label">Total Balance</div><div class="fmc-kpi-value success">₱@(_cardholderData.Sum(u => u.Balance).ToString("N2"))</div></div></div>
                    <div class="fmc-kpi-card"><div class="fmc-kpi-icon-wrap info"><svg xmlns="http://www.w3.org/2000/svg" height="20" width="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-5-5 1.41-1.41L11 13.17V7h2v6.17l2.59-2.58L17 12l-5 5z"/></svg></div><div class="fmc-kpi-body"><div class="fmc-kpi-label">Cardholders</div><div class="fmc-kpi-value">@_cardholderData.Count</div></div></div>
                    <div class="fmc-kpi-card"><div class="fmc-kpi-icon-wrap success"><svg xmlns="http://www.w3.org/2000/svg" height="20" width="20" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></div><div class="fmc-kpi-body"><div class="fmc-kpi-label">Active</div><div class="fmc-kpi-value" style="color:var(--mud-palette-success);">@_cardholderData.Count(u => u.IsActive)</div></div></div>
                </div>
            }
            else if (type == "audit")
            {
                <div class="fmc-kpi-row">
                    <div class="fmc-kpi-card"><div class="fmc-kpi-icon-wrap primary"><svg xmlns="http://www.w3.org/2000/svg" height="20" width="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg></div><div class="fmc-kpi-body"><div class="fmc-kpi-label">Total Amount</div><div class="fmc-kpi-value success">₱@(_auditData.Sum(a => Math.Abs(a.Amount ?? 0)).ToString("N2"))</div></div></div>
                    <div class="fmc-kpi-card"><div class="fmc-kpi-icon-wrap info"><svg xmlns="http://www.w3.org/2000/svg" height="20" width="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-5-5 1.41-1.41L11 13.17V7h2v6.17l2.59-2.58L17 12l-5 5z"/></svg></div><div class="fmc-kpi-body"><div class="fmc-kpi-label">Entries</div><div class="fmc-kpi-value">@_auditData.Count</div></div></div>
                </div>
            }
            else if (type == "compensation")
            {
                <div class="fmc-kpi-row">
                    <div class="fmc-kpi-card"><div class="fmc-kpi-icon-wrap primary"><svg xmlns="http://www.w3.org/2000/svg" height="20" width="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg></div><div class="fmc-kpi-body"><div class="fmc-kpi-label">Net Total</div><div class="fmc-kpi-value success">₱@(_compensationData.Sum(r => Math.Abs(r.NetAmount)).ToString("N2"))</div></div></div>
                    <div class="fmc-kpi-card"><div class="fmc-kpi-icon-wrap info"><svg xmlns="http://www.w3.org/2000/svg" height="20" width="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-5-5 1.41-1.41L11 13.17V7h2v6.17l2.59-2.58L17 12l-5 5z"/></svg></div><div class="fmc-kpi-body"><div class="fmc-kpi-label">Subscribers</div><div class="fmc-kpi-value">@_compensationData.Count</div></div></div>
                </div>
            }

            <div class="fmc-reports-surface">
                <div class="fmc-surface-header">
                    <MudText Typo="Typo.h6" Style="font-weight: 800;">@GetReportTitle(type)</MudText>
                    <MudSpacer />
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@GetDateRangeLabel()</MudText>
                </div>
                <div class="fmc-desktop-table">
                    <div class="fmc-report-table-wrap">
                        @if (type == "orghealth")
                        {
                            <MudTable Items="@_orgHealthData" Dense="true" Hover="true" Elevation="0" Class="fmc-reports-table" RowsPerPage="10" Context="row">
                                <HeaderContent><MudTh>ORGANIZATION</MudTh><MudTh>WALLET BALANCE</MudTh><MudTh>AVAILABLE BALANCE</MudTh><MudTh>USAGE</MudTh><MudTh>REMAINING</MudTh><MudTh>USAGE %</MudTh></HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="ORG"><MudText Typo="Typo.body2" Style="font-weight:700;">@row.Name</MudText></MudTd>
                                    <MudTd DataLabel="WALLET">₱@row.RemainingBalance.ToString("N2")</MudTd>
                                    <MudTd DataLabel="AVAILABLE">₱@row.TotalBalance.ToString("N2")</MudTd>
                                    <MudTd DataLabel="USAGE">₱@row.Usage.ToString("N2")</MudTd>
                                    <MudTd DataLabel="REMAINING">₱@row.RemainingBalance.ToString("N2")</MudTd>
                                    <MudTd DataLabel="USAGE %"><div class="d-flex align-center gap-2"><MudProgressLinear Color="Color.Primary" Value="@(row.WalletLimit > 0 ? (double)(row.Usage / row.WalletLimit * 100) : 0)" Size="Size.Small" Class="rounded-pill" Style="flex:1;max-width:100px;" /><span>@(row.WalletLimit > 0 ? (row.Usage / row.WalletLimit * 100).ToString("N1") : "0.0")%</span></div></MudTd>
                                </RowTemplate>
                                <PagerContent><MudTablePager PageSizeOptions="new int[]{5, 10, 25, 50}" /></PagerContent>
                            </MudTable>
                        }
                        else if (type == "cardholders")
                        {
                            <MudTable Items="@_cardholderData" Dense="true" Hover="true" Elevation="0" Class="fmc-reports-table" RowsPerPage="10" Context="row">
                                <HeaderContent><MudTh>NAME</MudTh><MudTh>EMAIL</MudTh><MudTh>ACCOUNT NUMBER</MudTh><MudTh>BALANCE</MudTh><MudTh>STATUS</MudTh></HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="NAME"><MudText Typo="Typo.body2" Style="font-weight:700;">@row.DisplayName</MudText></MudTd>
                                    <MudTd DataLabel="EMAIL">@MaskEmail(row.Email)</MudTd>
                                    <MudTd DataLabel="ACCOUNT">@(string.IsNullOrEmpty(row.AccountNumber) ? "N/A" : FinanceUtils.MaskCard(row.AccountNumber))</MudTd>
                                    <MudTd DataLabel="BALANCE">₱@row.Balance.ToString("N2")</MudTd>
                                    <MudTd DataLabel="STATUS"><MudChip T="string" Color="@(row.IsActive ? Color.Success : Color.Default)" Size="Size.Small" Variant="Variant.Text" Style="font-weight:800;font-size:0.6rem;">@(row.IsActive ? "Active" : "Inactive")</MudChip></MudTd>
                                </RowTemplate>
                                <PagerContent><MudTablePager PageSizeOptions="new int[]{5, 10, 25, 50}" /></PagerContent>
                            </MudTable>
                        }
                        else if (type == "compensation")
                        {
                            <MudTable Items="@_compensationData" Dense="true" Hover="true" Elevation="0" Class="fmc-reports-table" RowsPerPage="10" Context="row">
                                <HeaderContent><MudTh>SUBSCRIBER</MudTh><MudTh>ACCOUNT NUMBER</MudTh><MudTh>TOTAL CREDITS</MudTh><MudTh>TOTAL DEBITS</MudTh><MudTh>NET AMOUNT</MudTh><MudTh>TX COUNT</MudTh></HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="SUBSCRIBER"><MudText Typo="Typo.body2" Style="font-weight:700;">@row.Subscriber</MudText></MudTd>
                                    <MudTd DataLabel="ACCOUNT">@(string.IsNullOrEmpty(row.AccountNumber) ? "N/A" : row.AccountNumber)</MudTd>
                                    <MudTd DataLabel="CREDITS" Style="color:var(--mud-palette-success);font-weight:700;">₱@row.TotalCredits.ToString("N2")</MudTd>
                                    <MudTd DataLabel="DEBITS" Style="color:var(--mud-palette-error);font-weight:700;">₱@row.TotalDebits.ToString("N2")</MudTd>
                                    <MudTd DataLabel="NET" Style="@GetNetStyle(row.NetAmount)">₱@row.NetAmount.ToString("N2")</MudTd>
                                    <MudTd DataLabel="TX">@row.TransactionCount</MudTd>
                                </RowTemplate>
                                <PagerContent><MudTablePager PageSizeOptions="new int[]{5, 10, 25, 50}" /></PagerContent>
                            </MudTable>
                        }
                        else if (type == "audit")
                        {
                            <MudTable Items="@_auditData" Dense="true" Hover="true" Elevation="0" Class="fmc-reports-table" RowsPerPage="10" Context="row">
                                <HeaderContent><MudTh>DATE</MudTh><MudTh>ACTION</MudTh><MudTh>PERFORMED BY</MudTh><MudTh>ENTITY</MudTh><MudTh>AMOUNT</MudTh><MudTh>LABEL</MudTh></HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="DATE">@row.CreatedAt.ToLocalTime().ToString("MMM dd HH:mm")</MudTd>
                                    <MudTd DataLabel="ACTION"><MudChip T="string" Color="@GetChipColor(row.Action)" Size="Size.Small" Variant="Variant.Text" Style="font-weight:800;font-size:0.6rem;">@row.Action</MudChip></MudTd>
                                    <MudTd DataLabel="PERFORMED BY">@row.PerformedBy</MudTd>
                                    <MudTd DataLabel="ENTITY">@(row.EntityName ?? row.Organization ?? "-")</MudTd>
                                    <MudTd DataLabel="AMOUNT">@(row.Amount.HasValue ? "₱" + Math.Abs(row.Amount.Value).ToString("N2") : "-")</MudTd>
                                    <MudTd DataLabel="LABEL">@row.Label</MudTd>
                                </RowTemplate>
                                <PagerContent><MudTablePager PageSizeOptions="new int[]{5, 10, 25, 50}" /></PagerContent>
                            </MudTable>
                        }
                        else
                        {
                            <MudTable Items="@_transactionData" Dense="true" Hover="true" Elevation="0" Class="fmc-reports-table" RowsPerPage="10" Context="row">
                                <HeaderContent><MudTh>DATE</MudTh><MudTh>ORGANIZATION</MudTh><MudTh>SUBSCRIBER</MudTh><MudTh>AMOUNT</MudTh><MudTh>CATEGORY</MudTh><MudTh>STATUS</MudTh><MudTh>LABEL</MudTh></HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="DATE">@row.Date.ToLocalTime().ToString("MMM dd HH:mm")</MudTd>
                                    <MudTd DataLabel="ORG"><MudText Typo="Typo.body2" Style="font-weight:700;">@(row.OrganizationId.HasValue && _orgNameMap.TryGetValue(row.OrganizationId.Value, out var on) ? on : "N/A")</MudText></MudTd>
                                    <MudTd DataLabel="SUBSCRIBER">@(row.Category is "System Adjustment" or "Org Adjustment Pending" ? "Mother Account" : row.Subscriber)</MudTd>
                                    <MudTd DataLabel="AMOUNT" Style="@GetAmountStyle(row.Amount)">@(row.Amount >= 0 ? "+" : "")₱@(Math.Abs(row.Amount).ToString("N2"))</MudTd>
                                    <MudTd DataLabel="CATEGORY"><MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Text" Style="font-weight:800;font-size:0.6rem;">@row.Category</MudChip></MudTd>
                                    <MudTd DataLabel="STATUS"><MudChip T="string" Color="@GetStatusColor(row.Status)" Size="Size.Small" Variant="Variant.Text" Style="font-weight:800;font-size:0.6rem;">@row.Status</MudChip></MudTd>
                                    <MudTd DataLabel="LABEL"><MudText Typo="Typo.caption">@row.Label</MudText></MudTd>
                                </RowTemplate>
                                <PagerContent><MudTablePager PageSizeOptions="new int[]{5, 10, 25, 50}" /></PagerContent>
                            </MudTable>
                        }
                    </div>
                </div>
                @* ── Mobile cards grouped inside same surface ── *@
                <div class="fmc-mobile-cards">
                @if (type == "orghealth")
                {
                    <div class="fmc-mobile-surface">
                        @{ var p = GetMobilePage(type); var m = GetMobileMaxPage(type); }
                        @foreach (var item in _orgHealthData.Skip((p - 1) * _mobilePageSize).Take(_mobilePageSize))
                        {
                            <div class="fmc-mobile-card @(_expandedRows.Contains(item) ? "expanded" : "")" @onclick="() => ToggleExpand(item)">
                                <div class="fmc-card-priority">
                                    <div class="fmc-card-cell fmc-org">@item.Name</div>
                                    <div class="fmc-card-cell fmc-num">₱@item.RemainingBalance.ToString("N2")</div>
                                    <div class="fmc-card-cell fmc-num">@(item.WalletLimit > 0 ? (item.Usage / item.WalletLimit * 100).ToString("N1") : "0.0")%</div>
                                    <div class="fmc-card-cell fmc-num">₱@item.TotalBalance.ToString("N2")</div>
                                </div>
                                <div class="fmc-card-detail">
                                    <div class="fmc-card-detail-row"><span class="fmc-detail-label">REMAINING</span><span class="fmc-num">₱@item.RemainingBalance.ToString("N2")</span></div>
                                    <div class="fmc-card-detail-row"><span class="fmc-detail-label">USAGE</span><span class="fmc-num">₱@item.Usage.ToString("N2")</span></div>
                                </div>
                            </div>
                        }
                        @RenderMobilePager(type)
                    </div>
                }
                else if (type == "cardholders")
                {
                    <div class="fmc-mobile-surface">
                        @{ var p = GetMobilePage(type); var m = GetMobileMaxPage(type); }
                        @foreach (var item in _cardholderData.Skip((p - 1) * _mobilePageSize).Take(_mobilePageSize))
                        {
                            <div class="fmc-mobile-card @(_expandedRows.Contains(item) ? "expanded" : "")" @onclick="() => ToggleExpand(item)">
                                <div class="fmc-card-priority">
                                    <div class="fmc-card-cell fmc-org">@item.DisplayName</div>
                                    <div class="fmc-card-cell">@MaskEmail(item.Email)</div>
                                    <div class="fmc-card-cell">@(string.IsNullOrEmpty(item.AccountNumber) ? "N/A" : FinanceUtils.MaskCard(item.AccountNumber))</div>
                                    <div class="fmc-card-cell fmc-card-amount">
                                        ₱@item.Balance.ToString("N2")
                                        <span class="fmc-badge fmc-badge-@(item.IsActive ? "success" : "default")">@(item.IsActive ? "Active" : "Inactive")</span>
                                    </div>
                                </div>
                            </div>
                        }
                        @RenderMobilePager(type)
                    </div>
                }
                else if (type == "compensation")
                {
                    <div class="fmc-mobile-surface">
                        @{ var p = GetMobilePage(type); var m = GetMobileMaxPage(type); }
                        @foreach (var item in _compensationData.Skip((p - 1) * _mobilePageSize).Take(_mobilePageSize))
                        {
                            <div class="fmc-mobile-card @(_expandedRows.Contains(item) ? "expanded" : "")" @onclick="() => ToggleExpand(item)">
                                <div class="fmc-card-priority">
                                    <div class="fmc-card-cell fmc-org">@item.Subscriber</div>
                                    <div class="fmc-card-cell fmc-num" style="@GetNetStyle(item.NetAmount)">₱@item.NetAmount.ToString("N2")</div>
                                    <div class="fmc-card-cell fmc-num">@item.TransactionCount</div>
                                    <div class="fmc-card-cell">@(string.IsNullOrEmpty(item.AccountNumber) ? "N/A" : item.AccountNumber)</div>
                                </div>
                                <div class="fmc-card-detail">
                                    <div class="fmc-card-detail-row"><span class="fmc-detail-label">CREDITS</span><span class="fmc-num" style="color:var(--mud-palette-success);font-weight:700;">₱@item.TotalCredits.ToString("N2")</span></div>
                                    <div class="fmc-card-detail-row"><span class="fmc-detail-label">DEBITS</span><span class="fmc-num" style="color:var(--mud-palette-error);font-weight:700;">₱@item.TotalDebits.ToString("N2")</span></div>
                                </div>
                            </div>
                        }
                        @RenderMobilePager(type)
                    </div>
                }
                else if (type == "audit")
                {
                    <div class="fmc-mobile-surface">
                        @{ var p = GetMobilePage(type); var m = GetMobileMaxPage(type); }
                        @foreach (var item in _auditData.Skip((p - 1) * _mobilePageSize).Take(_mobilePageSize))
                        {
                            <div class="fmc-mobile-card @(_expandedRows.Contains(item) ? "expanded" : "")" @onclick="() => ToggleExpand(item)">
                                <div class="fmc-card-priority">
                                    <div class="fmc-card-cell">@item.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</div>
                                    <div class="fmc-card-cell">@(item.EntityName ?? item.Organization ?? "-")</div>
                                    <div class="fmc-card-cell">@item.PerformedBy</div>
                                    <div class="fmc-card-cell fmc-card-amount">
                                        @(item.Amount.HasValue ? "₱" + Math.Abs(item.Amount.Value).ToString("N2") : "-")
                                        <span class="fmc-badge fmc-badge-@GetBadgeClass(item.Action)">@item.Action</span>
                                    </div>
                                </div>
                                <div class="fmc-card-detail">
                                    <div class="fmc-card-detail-row"><span class="fmc-detail-label">LABEL</span><span>@item.Label</span></div>
                                </div>
                            </div>
                        }
                        @RenderMobilePager(type)
                    </div>
                }
                else
                {
                    <div class="fmc-mobile-surface">
                        @{ var p = GetMobilePage(type); var m = GetMobileMaxPage(type); }
                        @foreach (var item in _transactionData.Skip((p - 1) * _mobilePageSize).Take(_mobilePageSize))
                        {
                            <div class="fmc-mobile-card @(_expandedRows.Contains(item) ? "expanded" : "")" @onclick="() => ToggleExpand(item)">
                                <div class="fmc-card-priority">
                                    <div class="fmc-card-cell">@item.Date.ToLocalTime().ToString("MM/dd HH:mm")</div>
                                    <div class="fmc-card-cell">@(item.OrganizationId.HasValue && _orgNameMap.TryGetValue(item.OrganizationId.Value, out var on) ? on : "N/A")</div>
                                    <div class="fmc-card-cell">@(item.Category is "System Adjustment" or "Org Adjustment Pending" ? "Mother Account" : item.Subscriber)</div>
                                    <div class="fmc-card-cell fmc-card-amount" style="@GetAmountStyle(item.Amount)">
                                        @(item.Amount >= 0 ? "+" : "")₱@(Math.Abs(item.Amount).ToString("N2"))
                                        <span class="fmc-badge fmc-badge-@GetBadgeClass(item.Status)">@item.Status</span>
                                    </div>
                                </div>
                                <div class="fmc-card-detail">
                                    <div class="fmc-card-detail-row"><span class="fmc-detail-label">CATEGORY</span><span>@item.Category</span></div>
                                    <div class="fmc-card-detail-row"><span class="fmc-detail-label">LABEL</span><span>@item.Label</span></div>
                                </div>
                            </div>
                        }
                        @RenderMobilePager(type)
                    </div>
                }
            </div>
        </div>
        </div>
        <div class="fmc-report-section-gap"></div>
        }
    }
</MudContainer>

@code {
    private HashSet<string> _selectedReports = new() { "all" };
    private string _selectedOrgId = "";
    private bool _isAdmin;
    private bool _isCeo;
    private bool _reportLoading;
    private bool _dataLoaded;
    private string _activeDateRange = "7d";
    private DateTime? _startDate;
    private DateTime? _endDate;

    private List<OrganizationDto> _organizations = new();
    private List<TransactionDto> _transactionData = new();
    private List<OrganizationDto> _orgHealthData = new();
    private List<AuditLogDto> _auditData = new();
    private List<UserDto> _cardholderData = new();
    private List<CompensationRegisterRow> _compensationData = new();
    private Dictionary<Guid, string> _orgNameMap = new();
    private HashSet<object> _expandedRows = new();
    private int _mobilePageSize = 10;
    private Dictionary<string, int> _mobilePage = new();

    private int GetMobileCount(string type) => type switch
    {
        "orghealth" => _orgHealthData.Count,
        "cardholders" => _cardholderData.Count,
        "compensation" => _compensationData.Count,
        "audit" => _auditData.Count,
        _ => _transactionData.Count
    };
    private int GetMobileMaxPage(string type) => Math.Max(1, (int)Math.Ceiling((double)GetMobileCount(type) / _mobilePageSize));
    private int GetMobilePage(string type) => _mobilePage.GetValueOrDefault(type, 1);
    private void SetMobilePage(string type, int p)
    {
        if (p < 1) p = 1;
        var max = GetMobileMaxPage(type);
        if (p > max) p = max;
        _mobilePage[type] = p;
    }

    private RenderFragment RenderMobilePager(string type) => @<div class="fmc-mobile-pager">
        <select class="fmc-pager-select" @onchange="@((ChangeEventArgs e) => { _mobilePageSize = int.Parse(e.Value?.ToString() ?? "10"); SetMobilePage(type, 1); })">
            <option value="5" selected="@(_mobilePageSize == 5)">5</option>
            <option value="10" selected="@(_mobilePageSize == 10)">10</option>
            <option value="25" selected="@(_mobilePageSize == 25)">25</option>
            <option value="50" selected="@(_mobilePageSize == 50)">50</option>
        </select>
        <div class="fmc-pager-nav">
            <button class="fmc-pager-btn" @onclick="@(() => SetMobilePage(type, 1))" disabled="@(GetMobilePage(type) <= 1)">«</button>
            <button class="fmc-pager-btn" @onclick="@(() => SetMobilePage(type, GetMobilePage(type) - 1))" disabled="@(GetMobilePage(type) <= 1)">‹</button>
            <span class="fmc-pager-info">@GetMobilePage(type) / @GetMobileMaxPage(type)</span>
            <button class="fmc-pager-btn" @onclick="@(() => SetMobilePage(type, GetMobilePage(type) + 1))" disabled="@(GetMobilePage(type) >= GetMobileMaxPage(type))">›</button>
            <button class="fmc-pager-btn" @onclick="@(() => SetMobilePage(type, GetMobileMaxPage(type)))" disabled="@(GetMobilePage(type) >= GetMobileMaxPage(type))">»</button>
        </div>
    </div>;

    private void ToggleExpand(object item)
    {
        if (!_expandedRows.Remove(item))
            _expandedRows.Add(item);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _isAdmin = user.IsInRole(Roles.SuperAdmin) || user.IsInRole(Roles.SuperAdminApprover);
        _isCeo = user.IsInRole(Roles.CEO);

        _organizations = await OrgService.GetOrganizationsAsync();
        _organizations = _organizations.Where(o => o.Name != "Nationlink/Infoserve Inc.").ToList();
        _orgNameMap = _organizations.ToDictionary(o => o.Id, o => o.Name);

        if (_isCeo)
        {
            var orgClaim = user.FindFirst("OrganizationId")?.Value;
            if (Guid.TryParse(orgClaim, out var ceoOrgId))
                _selectedOrgId = ceoOrgId.ToString();
        }

        SetQuickDate("7d");
        await LoadAllReports();
        _dataLoaded = true;
    }

    private void SetQuickDate(string range)
    {
        _activeDateRange = range;
        var today = DateTime.Today;
        switch (range)
        {
            case "today":
                _startDate = today;
                _endDate = today.AddDays(1).AddTicks(-1);
                break;
            case "7d":
                _startDate = today.AddDays(-7);
                _endDate = today.AddDays(1).AddTicks(-1);
                break;
            case "30d":
                _startDate = today.AddDays(-30);
                _endDate = today.AddDays(1).AddTicks(-1);
                break;
            case "1y":
                _startDate = today.AddYears(-1);
                _endDate = today.AddDays(1).AddTicks(-1);
                break;
            default:
                _startDate = null;
                _endDate = null;
                break;
        }
    }

    private void UpdateDate(ChangeEventArgs e, bool isStart)
    {
        _activeDateRange = "custom";
        if (DateTime.TryParse(e.Value?.ToString(), out var d))
        {
            if (isStart) _startDate = d;
            else _endDate = d.AddDays(1).AddTicks(-1);
        }
        _ = Reload();
    }

    private async Task Reload()
    {
        _dataLoaded = false;
        StateHasChanged();
        await LoadAllReports();
        _dataLoaded = true;
        StateHasChanged();
    }

    private async Task LoadAllReports()
    {
        _reportLoading = true;
        StateHasChanged();

        try
        {
            var tasks = new List<Task>();
            foreach (var type in GetAllTypes())
                tasks.Add(LoadSingleReport(type));
            await Task.WhenAll(tasks);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Report load failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _reportLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadSingleReport(string type)
    {
        switch (type)
        {
            case "orghealth": await LoadOrgHealth(); break;
            case "cardholders": await LoadCardholders(); break;
            case "audit": await LoadAuditLogs(); break;
            case "compensation": await LoadCompensationRegister(); break;
            default: await LoadDisbursement(); break;
        }
    }

    private async Task LoadDisbursement()
    {
        var allTx = new List<TransactionDto>();
        var orgsToQuery = GetTargetOrgs();

        foreach (var org in orgsToQuery)
        {
            var tx = await OrgService.SearchTransactionsAsync(org.Id, _startDate, _endDate, status: null);
            if (_isAdmin)
                tx = tx.Where(t => t.Category is "System Adjustment" or "Org Adjustment Pending").ToList();
            allTx.AddRange(tx);
        }

        _transactionData = allTx.OrderByDescending(t => t.Date).ToList();
    }

    private async Task LoadOrgHealth()
    {
        var orgs = _isAdmin ? _organizations : new List<OrganizationDto>();
        var targetOrgs = GetTargetOrgs();
        if (!_isAdmin && targetOrgs.Any())
        {
            var org = await OrgService.GetByIdAsync(targetOrgs.First().Id);
            if (org != null) orgs.Add(org);
        }
        _orgHealthData = orgs.OrderBy(o => o.Name).ToList();
    }

    private async Task LoadCardholders()
    {
        var allUsers = new List<UserDto>();
        var orgsToQuery = GetTargetOrgs();

        foreach (var org in orgsToQuery)
        {
            var users = await OrgService.GetUsersAsync(org.Id);
            allUsers.AddRange(users);
        }

        _cardholderData = allUsers
            .Where(u => u.Role == Roles.User)
            .OrderBy(u => u.DisplayName)
            .ToList();
    }

    private async Task LoadAuditLogs()
    {
        var query = new AuditLogQueryDto
        {
            FromDate = _startDate,
            ToDate = _endDate,
            PageSize = 200
        };
        var result = await OrgService.SearchAuditLogsAsync(query);
        _auditData = result.Items.OrderByDescending(a => a.CreatedAt).ToList();
    }

    private async Task LoadCompensationRegister()
    {
        var orgsToQuery = GetTargetOrgs();
        var allTx = new List<TransactionDto>();

        foreach (var org in orgsToQuery)
        {
            var tx = await OrgService.SearchTransactionsAsync(org.Id, _startDate, _endDate);
            allTx.AddRange(tx);
        }

        var grouped = allTx
            .GroupBy(t => new { t.Subscriber, t.AccountNumber, OrgName = _orgNameMap.TryGetValue(t.OrganizationId ?? Guid.Empty, out var n) ? n : "N/A" })
            .Select(g => new CompensationRegisterRow
            {
                Subscriber = g.Key.Subscriber,
                AccountNumber = g.Key.AccountNumber ?? "",
                TotalCredits = g.Where(t => t.Amount > 0).Sum(t => t.Amount),
                TotalDebits = g.Where(t => t.Amount < 0).Sum(t => Math.Abs(t.Amount)),
                TransactionCount = g.Count(),
                OrganizationName = g.Key.OrgName
            })
            .OrderByDescending(r => r.NetAmount)
            .ToList();

        _compensationData = grouped;
    }

    private List<OrganizationDto> GetTargetOrgs()
    {
        if (Guid.TryParse(_selectedOrgId, out var orgId))
        {
            var org = _organizations.FirstOrDefault(o => o.Id == orgId);
            if (org != null) return new List<OrganizationDto> { org };
        }
        return _organizations;
    }

    private string GetDateRangeLabel()
    {
        if (_startDate.HasValue && _endDate.HasValue)
            return $"{_startDate:MMM dd, yyyy} — {_endDate:MMM dd, yyyy}";
        if (_startDate.HasValue)
            return $"From {_startDate:MMM dd, yyyy}";
        return "All time";
    }

    private static string GetReportTitle(string type) => type switch
    {
        "disbursement" => "Disbursement Summary",
        "orghealth" => "Organization Wallet Health",
        "audit" => "Audit Intelligence Log",
        "cardholders" => "Cardholder Registry",
        "compensation" => "Compensation Register",
        _ => "Report"
    };

    private List<string> GetAllTypes() => _isAdmin
        ? new() { "disbursement", "orghealth", "audit", "cardholders" }
        : new() { "compensation", "disbursement", "audit", "cardholders" };

    private List<string> GetDisplayTypes()
    {
        if (_selectedReports.Contains("all"))
            return GetAllTypes();
        return GetAllTypes().Where(t => _selectedReports.Contains(t)).ToList();
    }

    private void ToggleReport(string type)
    {
        if (type == "all")
        {
            _selectedReports.Clear();
            _selectedReports.Add("all");
        }
        else
        {
            _selectedReports.Remove("all");
            if (!_selectedReports.Remove(type))
                _selectedReports.Add(type);
            if (_selectedReports.Count == GetAllTypes().Count)
            {
                _selectedReports.Clear();
                _selectedReports.Add("all");
            }
        }
    }

    private bool IsSelected(string type) => type == "all"
        ? _selectedReports.Contains("all")
        : _selectedReports.Contains(type) || _selectedReports.Contains("all");

    private string GetOrgTitle() => Guid.TryParse(_selectedOrgId, out var oid) && _orgNameMap.TryGetValue(oid, out var n) ? n : "All Organizations";

    private async Task ExportExcel()
    {
        try
        {
            var filterLabel = GetDateRangeLabel();
            foreach (var type in GetDisplayTypes())
            {
                byte[] bytes = type switch
                {
                    "orghealth" => ReportGen.GenerateOrgHealthExcel(GetReportTitle(type), _orgHealthData, filterLabel),
                    "cardholders" => ReportGen.GenerateCardholderExcel(GetOrgTitle(), _cardholderData, filterLabel),
                    "audit" => ReportGen.GenerateAuditExcel(GetReportTitle(type), _auditData, filterLabel),
                    "compensation" => ReportGen.GenerateCompensationRegisterExcel(GetReportTitle(type), _compensationData, filterLabel),
                    _ => ReportGen.GenerateExcel(GetReportTitle(type), _transactionData, filterLabel),
                };
                string fileName = $"FMC_{GetReportTitle(type).Replace(" ", "")}_{DateTime.Now:yyyyMMdd}.xlsx";
                using var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
                await JS.InvokeVoidAsync("fmc_downloadFile", fileName, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", streamRef);
            }
            Snackbar.Add($"Reports exported as Excel.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportPdf()
    {
        try
        {
            var filterLabel = GetDateRangeLabel();
            foreach (var type in GetDisplayTypes())
            {
                byte[] bytes = type switch
                {
                    "orghealth" => ReportGen.GenerateOrgHealthPdf(GetReportTitle(type), _orgHealthData, filterLabel),
                    "cardholders" => ReportGen.GenerateCardholderPdf(GetOrgTitle(), _cardholderData, filterLabel),
                    "audit" => ReportGen.GenerateAuditPdf(GetReportTitle(type), _auditData, filterLabel),
                    "compensation" => ReportGen.GenerateCompensationRegisterPdf(GetReportTitle(type), _compensationData, filterLabel),
                    _ => ReportGen.GeneratePdf(GetReportTitle(type), _transactionData, filterLabel),
                };
                string fileName = $"FMC_{GetReportTitle(type).Replace(" ", "")}_{DateTime.Now:yyyyMMdd}.pdf";
                using var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
                await JS.InvokeVoidAsync("fmc_downloadFile", fileName, "application/pdf", streamRef);
            }
            Snackbar.Add($"Reports exported as PDF.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

    private static string GetNetStyle(decimal amount) => $"font-weight:700; color:{(amount >= 0 ? "var(--mud-palette-success)" : "var(--mud-palette-error)")};";
    private static string GetAmountStyle(decimal amount) => $"font-weight:700; color:{(amount >= 0 ? "var(--mud-palette-success)" : "var(--mud-palette-error)")};";

    private static string MaskEmail(string? email)
    {
        if (string.IsNullOrWhiteSpace(email)) return "—";
        var at = email.IndexOf('@');
        if (at <= 1) return email;
        return $"{email[0]}***{email[at..]}";
    }

    private Color GetChipColor(string action) => action switch
    {
        "CREDIT" or "INITIATE_CREDIT" or "WALLET_FUNDED" => Color.Success,
        "DEBIT" or "INITIATE_DEBIT" or "WALLET_DEBITED" => Color.Error,
        "APPROVED" or "TRANSACTION_APPROVED" => Color.Success,
        "REJECTED" => Color.Error,
        _ => Color.Primary
    };

    private Color GetStatusColor(string status) => status switch
    {
        "Completed" or "Approved" or "Successful" => Color.Success,
        "Pending" => Color.Warning,
        "Rejected" => Color.Error,
        _ => Color.Default
    };

    private string GetBadgeClass(string status) => status switch
    {
        "Completed" or "Approved" or "Successful" or "Active"
            or "CREDIT" or "INITIATE_CREDIT" or "WALLET_FUNDED" or "APPROVED" or "TRANSACTION_APPROVED" => "success",
        "Pending" => "warning",
        "Rejected" or "DEBIT" or "INITIATE_DEBIT" or "WALLET_DEBITED" or "REJECTED" => "error",
        _ => "default"
    };
}
