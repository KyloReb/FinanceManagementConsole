@using FMC.Shared.DTOs.User
@using FMC.Services.Api
@inject OrganizationApiService OrgService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-weight: 800;">Target Identity Selection</MudText>
    </TitleContent>
    <DialogContent>
        <div class="pa-2">
            <MudTextField @bind-Value="_searchString" Label="Search Cardholders" 
                          Variant="Variant.Outlined" Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Search" Class="mb-4"
                          Immediate="true" />

            <div style="max-height: 400px; overflow-y: auto;">
                @if (_loading)
                {
                    <div class="d-flex justify-center pa-8">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    </div>
                }
                else if (!FilteredUsers.Any())
                {
                    <div class="text-center pa-8">
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No matching cardholders found.</MudText>
                    </div>
                }
                else
                {
                    <MudGrid Spacing="2">
                        @foreach (var user in FilteredUsers)
                        {
                            <MudItem xs="12" sm="6">
                                <div @onclick="@(() => SelectUser(user))" class="pa-3" style="border-radius: 12px; border: 1px solid var(--mud-palette-divider); cursor: pointer; transition: all 0.2s ease-in-out;" onmouseover="this.style.background='rgba(var(--mud-palette-primary-rgb), 0.05)'" onmouseout="this.style.background='transparent'">
                                    <div class="d-flex align-center">
                                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium" Class="mr-3">
                                            @user.FirstName?[0]@user.LastName?[0]
                                        </MudAvatar>
                                        <div class="flex-grow-1" style="min-width: 0;">
                                            <MudText Typo="Typo.body1" Style="font-weight: 800; line-height: 1.1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@user.DisplayName</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary d-block" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@FinanceUtils.MaskCard(user.AccountNumber) · @user.Role</MudText>
                                        </div>
                                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="opacity: 0.3; flex-shrink: 0;" />
                                    </div>
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                }
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    
    private List<UserDto> _users = new();
    private string _searchString = "";
    private bool _loading = true;

    private IEnumerable<UserDto> FilteredUsers => _users
        .Where(u => string.IsNullOrEmpty(_searchString) || 
                   u.DisplayName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) || 
                   (u.AccountNumber?.Contains(_searchString) ?? false));

    [Parameter] public Guid OrgId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (OrgId != Guid.Empty)
        {
            _loading = true;
            var allUsers = await OrgService.GetUsersAsync(OrgId);
            _users = allUsers.Where(u => !string.IsNullOrWhiteSpace(u.AccountNumber)).ToList();
            _loading = false;
        }
    }

    private void SelectUser(UserDto user) => MudDialog.Close(DialogResult.Ok(user));
    private void Cancel() => MudDialog.Cancel();
}
