@using FMC.Shared.DTOs.Organization

@if (!_dismissed && !Loading)
{
    <div class="fmc-settlement-panel mb-6">
        <div class="fmc-settlement-header">
            <div class="d-flex align-center gap-3">
                <div class="fmc-settlement-icon-wrap @(IsBalanceHealthy ? "healthy" : "warning")">
                    <MudIcon Icon="@(IsBalanceHealthy ? Icons.Material.Filled.FactCheck : Icons.Material.Filled.AccountBalanceWallet)"
                             Size="Size.Small" Style="color: white;" />
                </div>
                <div>
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 950; letter-spacing: -0.02em; line-height: 1.1;">
                        Payroll Settlement Status
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight: 700;">
                        @(IsBalanceHealthy ? "Liquidity verified for next disbursement cycle" : "Immediate funding required for payroll continuity")
                    </MudText>
                </div>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _dismissed = true)" />
        </div>

        <div class="fmc-settlement-body">
            <div class="fmc-settlement-row">
                <div class="fmc-settlement-stripe @(IsBalanceHealthy ? "healthy" : "warning")"></div>
                <div class="fmc-settlement-main">
                    <div class="d-flex flex-column flex-md-row justify-space-between align-start align-md-center gap-4">
                        <div class="fmc-settlement-info">
                            <div class="d-flex align-center gap-2 mb-1">
                                <span class="fmc-settlement-tag @(IsBalanceHealthy ? "healthy-tag" : "warning-tag")">
                                    @(IsBalanceHealthy ? "READY FOR SETTLEMENT" : "FUNDING REQUIRED")
                                </span>
                                <span class="fmc-settlement-date">CYCLE: @DateTime.Now.ToString("MMMM yyyy")</span>
                            </div>
                            <MudText Typo="Typo.body2" Style="font-weight: 800; line-height: 1.4;">
                                @if (IsBalanceHealthy)
                                {
                                    <span>Your corporate float of <b class="fmc-money">@Metrics?.TotalBalance.ToString("C0")</b> is sufficient for upcoming payroll operations.</span>
                                }
                                else
                                {
                                    <span>Corporate float is below safety threshold (<b class="fmc-money">@Metrics?.TotalBalance.ToString("C0")</b>). Settlement may be delayed.</span>
                                }
                            </MudText>
                        </div>
                        
                        <div class="fmc-settlement-actions">
                            @if (!IsBalanceHealthy)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.AddCard" 
                                           Class="fmc-settlement-btn" Style="text-transform:none; font-weight:800; border-radius:10px;">
                                    Top-up Float
                                </MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.CheckCircle" 
                                           Class="fmc-settlement-btn" Style="text-transform:none; font-weight:800; border-radius:10px;">
                                    View Payout Schedule
                                </MudButton>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .fmc-settlement-panel {
        border-radius: 20px; overflow: hidden;
        border: 1px solid var(--mud-palette-divider);
        background: var(--mud-palette-surface);
        box-shadow: 0 4px 24px rgba(0,0,0,0.04);
    }

    .fmc-settlement-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 20px;
        background: var(--mud-palette-background-grey);
        border-bottom: 1px solid var(--mud-palette-divider);
    }

    .fmc-settlement-icon-wrap {
        width: 36px; height: 36px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .fmc-settlement-icon-wrap.healthy { background: var(--mud-palette-success); }
    .fmc-settlement-icon-wrap.warning { background: var(--mud-palette-warning); }

    .fmc-settlement-body { display: flex; flex-direction: column; }

    .fmc-settlement-row {
        padding: 20px; position: relative;
        background: var(--mud-palette-surface);
    }

    .fmc-settlement-stripe {
        position: absolute; left: 0; top: 0; bottom: 0; width: 4px;
    }
    .fmc-settlement-stripe.healthy { background: var(--mud-palette-success); }
    .fmc-settlement-stripe.warning { background: var(--mud-palette-warning); }

    .fmc-settlement-main { flex: 1; min-width: 0; }

    .fmc-settlement-tag {
        font-size: 0.6rem; font-weight: 950; padding: 2px 10px;
        border-radius: 6px; letter-spacing: 0.05em; text-transform: uppercase;
    }
    .healthy-tag { background: rgba(var(--mud-palette-success-rgb), 0.1); color: var(--mud-palette-success); }
    .warning-tag { background: rgba(var(--mud-palette-warning-rgb), 0.1); color: var(--mud-palette-warning); }

    .fmc-settlement-date {
        font-size: 0.6rem; font-weight: 800; color: var(--mud-palette-text-secondary);
        background: var(--mud-palette-background-grey); padding: 2px 10px; border-radius: 6px;
    }

    .fmc-money {
        font-family: 'JetBrains Mono', monospace;
        font-weight: 900; font-variant-numeric: tabular-nums;
    }

    .fmc-settlement-btn { height: 40px; box-shadow: none; white-space: nowrap; }

    @@media (max-width: 600px) {
        .fmc-settlement-actions { width: 100%; }
        .fmc-settlement-btn { width: 100%; }
    }
</style>

@code {
    [Parameter] public OrganizationDashboardMetricsDto? Metrics { get; set; }
    [Parameter] public bool Loading { get; set; }

    private bool _dismissed;

    private const decimal SafetyThreshold = 250_000m; // Higher threshold for payroll context

    private bool IsBalanceHealthy => Metrics != null && Metrics.TotalBalance >= SafetyThreshold;
}
