@using FMC.Shared.DTOs.Admin
@using FMC.Services.Api
@inject AdminService AdminService
@implements IDisposable

@inject FMC.Services.ThemeService ThemeService

@code {
    [Parameter] public bool IsLoading { get; set; }
}

<div class="health-pulse-panel fmc-main-surface @(_health?.Status.ToLower()) @(ThemeService.IsDarkMode ? "dark-theme" : "light-theme")">
    <div class="panel-header">
        <div class="status-indicator">
            <div class="pulse-ring" style="background: @(_health?.StatusColor ?? "#b2bec3")"></div>
            <div class="pulse-dot" style="background: @(_health?.StatusColor ?? "#b2bec3")"></div>
        </div>
        <div class="header-text">
            <h3>Infrastructure Health Pulse</h3>
            <span class="uptime-text">UPTIME: @FormatUptime(_health?.Uptime)</span>
        </div>
        <div class="live-badge">LIVE TELEMETRY</div>
    </div>

    @if (IsLoading || _health == null)
    {
        <div class="metrics-grid">
            <div class="metric-card">
                <div class="skeleton-box mb-4" style="height: 12px; width: 40%;"></div>
                <div class="d-flex justify-space-between mb-4">
                    <div class="skeleton-box" style="height: 32px; width: 25%;"></div>
                    <div class="skeleton-box" style="height: 32px; width: 25%;"></div>
                    <div class="skeleton-box" style="height: 32px; width: 25%;"></div>
                </div>
                <div class="skeleton-box" style="height: 6px; width: 100%;"></div>
            </div>
            <div class="metric-card">
                <div class="skeleton-box mb-4" style="height: 12px; width: 40%;"></div>
                <div class="perf-stats">
                    <div class="d-flex justify-space-between"><div class="skeleton-box" style="height: 14px; width: 30%;"></div><div class="skeleton-box" style="height: 14px; width: 20%;"></div></div>
                    <div class="d-flex justify-space-between"><div class="skeleton-box" style="height: 14px; width: 30%;"></div><div class="skeleton-box" style="height: 14px; width: 20%;"></div></div>
                    <div class="d-flex justify-space-between"><div class="skeleton-box" style="height: 14px; width: 30%;"></div><div class="skeleton-box" style="height: 14px; width: 20%;"></div></div>
                </div>
            </div>
        </div>
        <div class="infrastructure-list">
            <div class="d-flex justify-space-between py-2"><div class="skeleton-box" style="height: 16px; width: 40%;"></div><div class="skeleton-box" style="height: 16px; width: 20%;"></div></div>
            <div class="d-flex justify-space-between py-2"><div class="skeleton-box" style="height: 16px; width: 40%;"></div><div class="skeleton-box" style="height: 16px; width: 20%;"></div></div>
        </div>
        <!-- Error skeleton -->
        <div class="error-section">
            <div class="skeleton-box" style="height: 14px; width: 30%;"></div>
            <div class="skeleton-box mt-3" style="height: 40px; width: 100%;"></div>
        </div>
    }
    else
    {
        <div class="metrics-grid">
            <!-- Job Pipeline Card -->
            <div class="metric-card">
                <div class="card-label">Async Job Pipeline</div>
                <div class="job-stats">
                    <div class="stat">
                        <span class="stat-value">@_health.JobPipeline.Active</span>
                        <span class="stat-label">Active</span>
                    </div>
                    <div class="stat">
                        <span class="stat-value @(_health.JobPipeline.Failed > 0 ? "warning" : "")">@_health.JobPipeline.Failed</span>
                        <span class="stat-label">Failed</span>
                    </div>
                    <div class="stat">
                        <span class="stat-value">@_health.JobPipeline.Queued</span>
                        <span class="stat-label">Queued</span>
                    </div>
                </div>
                <div class="throughput-bar">
                    <div class="bar-fill" style="width: @(CalculateThroughputPct(_health.JobPipeline))%"></div>
                </div>
            </div>

            <!-- Performance Card -->
            <div class="metric-card">
                <div class="card-label">Computational Load</div>
                <div class="perf-stats">
                    <div class="perf-item">
                        <span class="p-label">PROCESSOR USAGE</span>
                        <span class="p-value">@_health.Performance.CpuUsagePct.ToString("F1")%</span>
                    </div>
                    <div class="perf-item">
                        <span class="p-label">MEMORY ALLOCATION</span>
                        <span class="p-value">@_health.Performance.MemoryUsageMb.ToString("F0") MB</span>
                    </div>
                    <div class="perf-item">
                        <span class="p-label">NETWORK LATENCY</span>
                        <span class="p-value">@_health.Performance.AvgRequestLatencyMs.ToString("F0") ms</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="infrastructure-list">
            @foreach (var item in _health.Infrastructure)
            {
                <div class="infra-item">
                    <span class="infra-name">@item.Name</span>
                    <div class="infra-status @item.Status.ToLower()">
                        <span class="latency">@item.LatencyMs</span>
                        <div class="status-pill">@item.Status</div>
                    </div>
                </div>
            }
        </div>

        <!-- Recent Client Errors -->
        <div class="error-section">
            <div class="error-section-header" @onclick="ToggleErrorSection">
                <div class="error-section-title">
                    <span class="error-section-icon">&#9888;</span>
                    <span>Recent Client Errors</span>
                    <span class="error-count-badge @(_clientErrors.Count > 0 ? "has-errors" : "")">@_clientErrors.Count</span>
                </div>
                <div class="error-section-toggle">
                    <span>@(_showErrors ? "Hide" : "Show")</span>
                    <span class="toggle-chevron @(_showErrors ? "open" : "")">&#9660;</span>
                </div>
            </div>

            @if (_showErrors)
            {
                @if (_isLoadingErrors)
                {
                    <div class="error-loading">
                        <div class="skeleton-box" style="height: 36px; width: 100%;"></div>
                        <div class="skeleton-box mt-2" style="height: 36px; width: 100%;"></div>
                    </div>
                }
                else if (_clientErrors.Count == 0)
                {
                    <div class="error-empty">
                        <span class="error-empty-icon">&#10003;</span>
                        <span>No client errors reported in the last monitoring window</span>
                    </div>
                }
                else if (_clientErrors.Count > 0)
                {
                    var hourlyBins = BuildHourlyBins(_clientErrors);
                    var maxBin = hourlyBins.Values.Count > 0 ? hourlyBins.Values.Max() : 1;
                    <div class="error-chart">
                        <div class="chart-label">24H ERROR FREQUENCY</div>
                        <div class="chart-bars">
                            @foreach (var kvp in hourlyBins.OrderBy(k => k.Key))
                            {
                                var pct = (kvp.Value * 100) / Math.Max(maxBin, 1);
                                <div class="chart-bar-group">
                                    <div class="chart-bar" style="height: @pct%"></div>
                                    <span class="chart-bar-label">@kvp.Key.ToString("HH")</span>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="error-list">
                        @foreach (var err in _clientErrors)
                        {
                            var isExpanded = _expandedErrorId == err.Id;
                            <div class="error-entry @(isExpanded ? "expanded" : "")">
                                <div class="error-entry-header" @onclick="() => ToggleErrorDetail(err.Id)">
                                    <div class="error-entry-summary">
                                        <span class="error-msg">@TruncateMessage(err.Details, 80)</span>
                                        <span class="error-time">@FormatRelativeTime(err.CreatedAt)</span>
                                    </div>
                                    <div class="error-entry-meta">
                                        <span class="error-component">@(err.EntityName ?? "N/A")</span>
                                        <span class="error-expand-icon">@(isExpanded ? "&#9650;" : "&#9660;")</span>
                                    </div>
                                </div>
                                @if (isExpanded)
                                {
                                    <div class="error-detail">
                                        <div class="error-detail-row">
                                            <span class="error-detail-label">User</span>
                                            <span class="error-detail-value">@(err.PerformedBy ?? "Unknown")</span>
                                        </div>
                                        <div class="error-detail-row">
                                            <span class="error-detail-label">Device</span>
                                            <span class="error-detail-value">@(err.Device ?? "N/A")</span>
                                        </div>
                                        <div class="error-detail-row">
                                            <span class="error-detail-label">Time</span>
                                            <span class="error-detail-value">@err.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                        </div>
                                        <div class="error-trace-box">
                                            <pre>@err.Details</pre>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private SystemHealthDto? _health;
    private Timer? _timer;
    private List<AuditLogDto> _clientErrors = new();
    private bool _isLoadingErrors;
    private bool _showErrors = true;
    private long? _expandedErrorId;

    protected override async Task OnInitializedAsync()
    {
        await RefreshHealth();
        
        // Polling every 30 seconds to maintain real-time visibility without overhead
        _timer = new Timer(async _ => 
        {
            await InvokeAsync(async () => 
            {
                await RefreshHealth();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    [Inject] private FMC.Services.GlobalAlertService GlobalAlert { get; set; } = default!;

    private async Task RefreshHealth()
    {
        try
        {
            _health = await AdminService.GetSystemHealthPulseAsync();
            await LoadClientErrors();
            
            // Phase 1: Hybrid Notification Integration
            if (_health != null)
            {
                if (_health.Status.Equals("Unhealthy", StringComparison.OrdinalIgnoreCase))
                {
                    GlobalAlert.SetAlert(
                        "CRITICAL INFRASTRUCTURE DEGRADATION: One or more core systems are offline.", 
                        "error"
                    );
                }
                else if (_health.Status.Equals("Degraded", StringComparison.OrdinalIgnoreCase))
                {
                    GlobalAlert.SetAlert(
                        "SYSTEM ADVISORY: Performance is degraded. Background jobs may be delayed.", 
                        "warning"
                    );
                }
                else if (_health.Status.Equals("Healthy", StringComparison.OrdinalIgnoreCase))
                {
                    // Only clear if the current alert was a health-related one
                    if (GlobalAlert.CurrentAlert.Message.Contains("SYSTEM") || GlobalAlert.CurrentAlert.Message.Contains("INFRASTRUCTURE"))
                    {
                        GlobalAlert.ClearAlert();
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Health Refresh Error: {ex.Message}");
            GlobalAlert.SetAlert("TELEMETRY LOST: Unable to reach the health diagnostic engine.", "error");
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task LoadClientErrors()
    {
        _isLoadingErrors = true;
        try
        {
            _clientErrors = await AdminService.GetRecentClientErrorsAsync(10);
        }
        catch
        {
            // Silent fail — errors section stays empty
        }
        finally
        {
            _isLoadingErrors = false;
        }
    }

    private void ToggleErrorSection()
    {
        _showErrors = !_showErrors;
        if (!_showErrors)
            _expandedErrorId = null;
    }

    private void ToggleErrorDetail(long id)
    {
        _expandedErrorId = _expandedErrorId == id ? null : id;
    }

    private static string TruncateMessage(string? message, int maxLen)
    {
        if (string.IsNullOrEmpty(message)) return "No details";
        return message.Length <= maxLen ? message : message[..maxLen] + "...";
    }

    private static Dictionary<DateTime, int> BuildHourlyBins(List<AuditLogDto> errors)
    {
        var bins = new Dictionary<DateTime, int>();
        var now = DateTime.UtcNow;
        for (int i = 23; i >= 0; i--)
        {
            var hour = now.AddHours(-i).Date.AddHours(now.AddHours(-i).Hour);
            bins[hour] = 0;
        }
        foreach (var err in errors)
        {
            var hourKey = err.CreatedAt.ToUniversalTime().Date.AddHours(err.CreatedAt.ToUniversalTime().Hour);
            if (bins.ContainsKey(hourKey))
                bins[hourKey]++;
        }
        return bins;
    }

    private static string FormatRelativeTime(DateTime dt)
    {
        var span = DateTime.UtcNow - dt.ToUniversalTime();
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return $"{(int)span.TotalDays}d ago";
    }

    private string FormatUptime(TimeSpan? uptime)
    {
        if (!uptime.HasValue) return "0h 0m";
        return $"{(int)uptime.Value.TotalHours}h {uptime.Value.Minutes}m";
    }

    private int CalculateThroughputPct(JobPipelineDto pipeline)
    {
        int total = pipeline.Active + pipeline.Queued + pipeline.Succeeded;
        if (total == 0) return 0;
        return Math.Min(100, (pipeline.Succeeded * 100) / total);
    }

    public void Dispose() => _timer?.Dispose();
}
