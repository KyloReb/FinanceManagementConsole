@page "/accounts"
@using FMC.Shared.DTOs
@using FMC.Shared.Auth
@using FMC.Shared.DTOs.Organization
@using MudBlazor.Services
@implements IAsyncDisposable
@implements IBrowserViewportObserver
@attribute [Authorize(Roles = Roles.SuperAdmin + "," + Roles.CEO + "," + Roles.Maker + "," + Roles.Approver)]
@inject FMC.Services.Api.AdminService AdminService
@inject FMC.Services.Api.OrganizationApiService OrganizationService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IBrowserViewportService BrowserViewportService
@inject IDialogService DialogService

<PageTitle>Financial Account Inventory | FMC</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mt-md-8 mb-12">
    @* PLATINUM HEADER AREA *@
    <div class="fmc-acc-header mb-8 flex-wrap gap-4">
        <div class="d-flex align-center">
            <div class="fmc-acc-bar mr-4"></div>
            <div>
                <MudText Typo="Typo.h4" Class="fmc-acc-hero-text">Capital Account Inventory</MudText>
                <MudText Typo="Typo.body1" Class="fmc-acc-subtitle d-none d-sm-block">Comprehensive institutional oversight of all liquidity endpoints.</MudText>
            </div>
        </div>
        @if (_isCEOOrAdmin)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" 
                       Size="Size.Large" Class="fmc-acc-action-btn">Initiate New Account</MudButton>
        }
    </div>

    <div class="mb-4">
    </div>

    @if (_loading)
    {
        <div class="d-flex flex-column align-center justify-center py-20">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" Class="mb-4" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary">Synthesizing fiscal records...</MudText>
        </div>
    }
    else
    {
        @if (!_isMobile)
        {
        <div class="fmc-acc-surface mb-10">
            <div class="pa-6 border-b border-divider d-flex align-center justify-space-between flex-wrap gap-4" style="background: var(--fmc-staff-surface);">
                <div class="d-flex align-center gap-3">
                    <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Style="color: var(--fmc-accent-staff);" />
                    <MudText Typo="Typo.h6" Style="font-weight: 900; letter-spacing: -0.01em;">ADMINISTRATIVE ACCESS MATRIX</MudText>
                </div>
                <div style="width: 320px;">
                    <MudTextField @bind-Value="_staffSearchString" Placeholder="Filter staff accounts..." 
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.FilterList" 
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="fmc-acc-input"
                                  Clearable="true" Immediate="true" />
                </div>
            </div>
            <MudTable Items="@FilteredStaff" Hover="true" Elevation="0" Class="fmc-acc-table"
                      OnRowClick="@((TableRowClickEventArgs<UserDto> e) => Navigation.NavigateTo($"/profile/{e.Item!.Id}"))" RowClass="cursor-pointer">
                <HeaderContent>
                    <MudTh Class="fmc-th"><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.DisplayName)">STAFF IDENTITY</MudTableSortLabel></MudTh>
                    <MudTh Class="fmc-th"><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Organization ?? string.Empty)">ORGANIZATION</MudTableSortLabel></MudTh>
                    <MudTh Class="fmc-th"><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Role)">SYSTEM ROLE</MudTableSortLabel></MudTh>
                </HeaderContent>
                <RowTemplate Context="staff">
                    <MudTd>
                        <div class="d-flex align-center">
                            <MudAvatar Color="Color.Default" Class="mr-3 staff" Style="@($"background-color: {GetAvatarColor(staff.DisplayName)} !important; color: white; font-weight: 950; font-size: 0.8rem;")">@(GetInitials(staff))</MudAvatar>
                            <div>
                                <MudText Typo="Typo.body1" Style="font-weight:900;">@staff.DisplayName</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@staff.Email</MudText>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2" Style="font-weight:800;">@(staff.Organization ?? "SYSTEM CORE")</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">Identity-Only Account</MudText>
                    </MudTd>
                    <MudTd>
                        <span class="fmc-role-tag @(staff.Role == Roles.SuperAdmin ? "admin" : (staff.Role == Roles.CEO ? "ceo" : (staff.Role == Roles.Maker ? "maker" : "approver")))">@staff.Role</span>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>

        @* BANKING STATUS LEGEND *@
        <div class="d-flex align-center justify-center gap-6 mb-10 pa-4 fmc-legend-panel flex-wrap">
            <div class="d-flex align-center gap-2">
                <div class="fmc-status-dot active"></div>
                <MudText Typo="Typo.caption" Style="font-weight: 800; opacity: 0.8;">REGISTERED / ACTIVE</MudText>
            </div>
            <div class="d-flex align-center gap-2">
                <div class="fmc-status-dot dormant"></div>
                <MudText Typo="Typo.caption" Style="font-weight: 800; opacity: 0.8;">INACTIVE / DORMANT</MudText>
            </div>
            <div class="d-flex align-center gap-2">
                <div class="fmc-status-dot suspended"></div>
                <MudText Typo="Typo.caption" Style="font-weight: 800; opacity: 0.8;">BLOCKED / SUSPENDED</MudText>
            </div>
            <div class="d-flex align-center gap-2">
                <div class="fmc-status-dot uninitialized"></div>
                <MudText Typo="Typo.caption" Style="font-weight: 800; opacity: 0.8;">NEW ACCOUNT PENDING</MudText>
            </div>
        </div>

        <div class="fmc-acc-surface">
            <div class="pa-6 border-b border-divider d-flex align-center justify-space-between flex-wrap gap-4" style="background: var(--fmc-cardholder-surface);">
                <div class="d-flex align-center gap-3">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Style="color: var(--fmc-accent-premium);" />
                    <MudText Typo="Typo.h6" Style="font-weight: 900; letter-spacing: -0.01em;">REGISTERED CARDHOLDER REGISTRY</MudText>
                </div>
                <div style="width: 320px;">
                    <MudTextField @bind-Value="_searchString" Placeholder="Search cardholders..." 
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="fmc-acc-input"
                                  Clearable="true" Immediate="true" />
                </div>
            </div>
            <MudTable Items="@FilteredCardholders" Hover="true" Elevation="0" Class="fmc-acc-table" HorizontalScrollbar="true"
                      OnRowClick="@((TableRowClickEventArgs<UserDto> e) => Navigation.NavigateTo($"/profile/{e.Item!.Id}"))" RowClass="cursor-pointer">
                <HeaderContent>
                    <MudTh Class="fmc-th"><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.DisplayName)">CARDHOLDER IDENTITY</MudTableSortLabel></MudTh>
                    <MudTh Class="fmc-th"><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Organization ?? string.Empty)">SUBSCRIBER</MudTableSortLabel></MudTh>
                    <MudTh Class="fmc-th" Style="text-align:right"><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Balance)">AVAILABLE LIQUIDITY</MudTableSortLabel></MudTh>
                    @if (_canAdjust)
                    {
                        <MudTh Class="fmc-th" Style="text-align:right">ACTIONS</MudTh>
                    }
                </HeaderContent>
                <RowTemplate Context="cardholder">
                    <MudTd Class="py-5">
                        <div class="d-flex align-center">
                            <MudAvatar Color="Color.Default" Class="mr-3" Style="@($"background-color: {GetAvatarColor(cardholder.DisplayName)} !important; color: white; font-weight: 950; font-size: 0.8rem;")">@(GetInitials(cardholder))</MudAvatar>
                            <div>
                                <div class="d-flex align-center gap-2">
                                    <MudText Typo="Typo.body1" Style="font-weight:900; letter-spacing:-0.02em;">@cardholder.DisplayName</MudText>
                                    <MudTooltip Text="@GetStatusText(cardholder)">
                                        <div class="fmc-status-dot @GetStatusClass(cardholder)"></div>
                                    </MudTooltip>
                                </div>
                                <MudText Typo="Typo.caption" Class="fmc-card-mono">@MaskCard(cardholder.AccountNumber)</MudText>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2" Style="font-weight:800;">@(cardholder.Organization ?? "EXTERNAL")</MudText>
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">Subscriber Unit</MudText>
                    </MudTd>
                    <MudTd Style="text-align:right">
                        <MudText Typo="Typo.body1" Class="fmc-money fmc-table-balance">
                            ₱@cardholder.Balance.ToString("N2")
                        </MudText>
                    </MudTd>
                    <MudTd Style="text-align:right" @onclick:stopPropagation="true">
                        @if (_canAdjust)
                        {
                            <div class="d-flex justify-end gap-2">
                                <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" 
                                               OnClick="@(() => OpenUserAdjustmentDialog(cardholder, true))" Class="fmc-action-circle" />
                                <MudIconButton Icon="@Icons.Material.Filled.Remove" Color="Color.Error" Variant="Variant.Filled" Size="Size.Small" 
                                               OnClick="@(() => OpenUserAdjustmentDialog(cardholder, false))" Class="fmc-action-circle" />
                            </div>
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </div>
        }
        else
        {
            @* MOBILE CARDHOLDER VIEW (Staff views are usually desktop-focused for admins) *@
            <div class="d-flex flex-column gap-3">
                <MudText Typo="Typo.subtitle2" Class="fmc-acc-card-label ml-2">CARDHOLDER REGISTRY</MudText>
                @foreach (var user in FilteredCardholders)
                {
                    <div class="fmc-acc-mobile-card cursor-pointer" @onclick="@(() => Navigation.NavigateTo($"/profile/{user.Id}"))">
                        <div class="fmc-mobile-header pa-4">
                            <div class="d-flex justify-space-between align-start">
                                <div class="d-flex gap-3">
                                    <MudAvatar Color="Color.Default" Style="@($"background-color: {GetAvatarColor(user.DisplayName)} !important; color: white; font-weight: 950;")">@(GetInitials(user))</MudAvatar>
                                    <div class="d-flex flex-column">
                                        <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 6px; line-height: 1;">
                                            <MudText Typo="Typo.body1" Inline="true" Style="font-weight:950; letter-spacing:-0.02em;">@user.DisplayName</MudText>
                                            <div class="fmc-status-dot @GetStatusClass(user)" style="width:6px; height:6px;"></div>
                                        </div>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="font-weight:700; font-family:'JetBrains Mono', monospace; font-size: 0.6rem;">@(MaskCard(user.AccountNumber))</MudText>
                                    </div>
                                </div>
                                <div class="text-right d-flex flex-column align-end">
                                    <MudText Typo="Typo.body1" Class="fmc-money" Style="color: var(--mud-palette-info); font-size:1rem;">₱@user.Balance.ToString("N0")</MudText>
                                    <MudText Typo="Typo.caption" Style="font-size:0.55rem; font-weight:950; opacity:0.5; letter-spacing:0.05em;">BALANCE</MudText>
                                </div>
                            </div>
                        </div>
                        <div class="fmc-mobile-body px-4 py-3">
                            <div class="d-flex justify-space-between align-center mb-2">
                                <MudText Typo="Typo.caption" Style="font-weight:900; opacity:0.5; letter-spacing:0.05em;">ORGANIZATION</MudText>
                                <MudText Typo="Typo.caption" Style="font-weight:900; color: var(--mud-palette-text-primary);">@(user.Organization ?? "INDIVIDUAL")</MudText>
                            </div>
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.caption" Style="font-weight:900; opacity:0.5; letter-spacing:0.05em;">IDENTITY ROLE</MudText>
                                    <span class="fmc-role-tag s-small @(user.Role == Roles.SuperAdmin ? "admin" : (user.Role == Roles.CEO ? "ceo" : "user"))">@user.Role</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</MudContainer>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;700&display=swap');

    :root {
        --fmc-accent-premium: #4f46e5; /* Indigo 600 */
        --fmc-accent-staff: #e11d48; /* Rose 600 */
        --fmc-accent-success: #059669; /* Emerald 600 */
        --fmc-staff-surface: rgba(225, 29, 72, 0.04);
        --fmc-cardholder-surface: rgba(79, 70, 229, 0.04);
    }

    .fmc-legend-panel {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 16px;
    }

    /* ACCOUNT INVENTORY PREMIUM DESIGN */
    .fmc-acc-header { display: flex; align-items: center; justify-content: space-between; }
    .fmc-acc-bar { width: 6px; height: 54px; background: linear-gradient(to bottom, var(--fmc-accent-premium), var(--fmc-accent-staff)); border-radius: 4px; }
    .fmc-acc-hero-text { font-weight: 950; letter-spacing: -0.05em; color: var(--mud-palette-text-primary); }
    .fmc-acc-subtitle { color: var(--mud-palette-text-secondary); opacity: 0.7; font-weight: 600; margin-top: -4px; }
    .fmc-acc-action-btn { border-radius: 12px; text-transform:none; font-weight: 900; padding: 12px 32px !important; background-color: var(--fmc-accent-premium) !important; color: white !important; }

    /* Glass KPI Cards */
    .fmc-acc-glass-card {
        padding: 24px; border-radius: 28px; background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider); position: relative; overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 20px rgba(0,0,0,0.01);
    }
    .fmc-acc-glass-card:hover { transform: translateY(-3px); box-shadow: 0 15px 40px rgba(0,0,0,0.06); border-color: var(--fmc-accent-premium); }
    .fmc-acc-card-label { letter-spacing: 0.15em; opacity: 0.6; font-weight: 900; font-size: 0.65rem; text-transform: uppercase; margin-bottom: 8px; }
    .fmc-acc-kpi-val { font-weight: 950; letter-spacing: -0.03em; line-height:1; font-family: 'Roboto Mono', monospace; }
    .fmc-acc-card-icon { position: absolute; right: -10px; bottom: -10px; opacity: 0.05; font-size: 6rem !important; }
    
    .fmc-acc-glass-card.accent-premium { border-left: 6px solid var(--fmc-accent-premium); }
    .fmc-acc-glass-card.accent-administrative { border-left: 6px solid #8b5cf6; } 
    .fmc-acc-glass-card.accent-staff { border-left: 6px solid var(--fmc-accent-staff); }

    /* Repository Surface */
    .fmc-acc-surface { border-radius: 28px; border: 1px solid var(--mud-palette-divider); overflow: hidden; box-shadow: 0 4px 30px rgba(0,0,0,0.02); background: var(--mud-palette-surface); width: 100%; }
    .fmc-acc-table { width: 100% !important; }
    .fmc-acc-table .mud-table-root { width: 100% !important; border-collapse: collapse !important; table-layout: auto !important; }
    .fmc-acc-table .mud-table-head { display: table-header-group !important; border-bottom: 2px solid var(--mud-palette-divider) !important; width: 100% !important; }
    .fmc-acc-table .mud-th { font-weight: 900; color: var(--mud-palette-text-secondary); font-size: 0.65rem; letter-spacing: 0.15em; padding: 20px 24px; background: rgba(0,0,0,0.01); text-transform: uppercase; border-bottom: none !important; }
    .fmc-acc-table .mud-td { padding: 16px 24px; border-bottom: 1px solid var(--mud-palette-divider); }

    .fmc-th { border-bottom: none !important; }

    /* Role Badges */
    .fmc-role-tag { padding: 4px 12px; border-radius: 10px; font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em; display: inline-flex; align-items: center; }
    .fmc-role-tag.admin { background: #fee2e2; color: #991b1b; }
    .fmc-role-tag.ceo { background: #e0e7ff; color: #3730a3; }
    .fmc-role-tag.maker { background: #fef3c7; color: #92400e; }
    .fmc-role-tag.approver { background: #dcfce7; color: #166534; }
    .fmc-role-tag.user { background: #f0f9ff; color: #075985; }

    .fmc-avatar-shadow { box-shadow: 0 8px 20px -5px rgba(99, 102, 241, 0.4); }
    .fmc-avatar-shadow.staff { box-shadow: 0 8px 20px -5px rgba(244, 63, 94, 0.4); }

    /* Financial Typography */
    .fmc-money { font-family: 'Roboto Mono', monospace !important; font-variant-numeric: tabular-nums !important; letter-spacing: -0.02em !important; font-weight: 700 !important; }
    .fmc-card-mono { font-family: 'Roboto Mono', monospace; font-size: 0.72rem; opacity: 0.7; font-weight: 700; color: var(--fmc-accent-premium); }
    .fmc-table-balance { font-size: 1.25rem; color: var(--fmc-accent-premium); font-weight: 800 !important; }

    .fmc-status-dot { width: 8px; height: 8px; border-radius: 50%; transition: all 0.2s; }
    .fmc-status-dot.active { background: var(--fmc-accent-success); box-shadow: 0 0 10px var(--fmc-accent-success); }
    .fmc-status-dot.dormant { background: var(--mud-palette-text-disabled); }
    .fmc-status-dot.suspended { background: var(--fmc-accent-staff); box-shadow: 0 0 10px var(--fmc-accent-staff); }
    .fmc-status-dot.uninitialized { background: #0ea5e9; box-shadow: 0 0 10px #0ea5e9; }

    .fmc-action-circle { border-radius: 50% !important; width: 32px; height: 32px; min-width: 32px; padding: 0 !important; }

    .border-b { border-bottom: 1px solid var(--mud-palette-divider); }
    
    @@media (max-width: 600px) {
        .fmc-acc-hero-text { font-size: 1.6rem !important; }
        .fmc-acc-header { gap: 12px; }
        .fmc-acc-action-btn { width: 100%; border-radius: 16px; }
    }
</style>

@code {
    private List<UserDto>? _users;
    private OrganizationDto? _organization;
    private bool _loading = true;
    private string _searchString = "";
    private string _staffSearchString = "";
    private bool _isOrgScoped = false;
    private bool _isCEOOrAdmin = false;
    private bool _canAdjust = false;
    private bool _isMobile = false;
    public Guid Id { get; } = Guid.NewGuid();
    public ResizeOptions ResizeOptions { get; } = new() { ReportRate = 100, NotifyOnBreakpointOnly = true };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _isCEOOrAdmin = user.IsInRole(Roles.CEO) || user.IsInRole(Roles.SuperAdmin);
        _isOrgScoped = !user.IsInRole(Roles.SuperAdmin);
        
        // Strict Enforcement: Only the MAKER role has direct balance adjustment authority 
        // to maintain the 4-eyes principle. SuperAdmins and CEOs are oversight only.
        _canAdjust = user.IsInRole(Roles.Maker);
        
        await LoadData(user);
    }

    private async Task LoadData(System.Security.Claims.ClaimsPrincipal user)
    {
        try
        {
            _loading = true;
            await LoadUsers();

            if (_isOrgScoped)
            {
                var orgIdStr = user.FindFirst("OrganizationId")?.Value;
                if (Guid.TryParse(orgIdStr, out var orgId))
                {
                    _organization = await OrganizationService.GetByIdAsync(orgId);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to generate account inventory trace: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isMobile = await BrowserViewportService.GetCurrentBreakpointAsync() < Breakpoint.Sm;
            await BrowserViewportService.SubscribeAsync(this);
            StateHasChanged();
        }
    }

    public async Task NotifyBrowserViewportChangeAsync(BrowserViewportEventArgs e)
    {
        var mobile = e.Breakpoint < Breakpoint.Sm;
        if (_isMobile != mobile)
        {
            _isMobile = mobile;
            await InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        await BrowserViewportService.UnsubscribeAsync(this);
    }

    private async Task LoadUsers()
    {
        _users = await AdminService.GetUsersAsync();
    }

    private IEnumerable<UserDto> FilteredCardholders => 
        _users?.Where(u => u.Role == Roles.User && 
                          (string.IsNullOrWhiteSpace(_searchString) || 
                           u.DisplayName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                           (u.Email ?? "").Contains(_searchString, StringComparison.OrdinalIgnoreCase))) ?? Enumerable.Empty<UserDto>();

    private IEnumerable<UserDto> FilteredStaff => 
        _users?.Where(u => u.Role != Roles.User && 
                          (string.IsNullOrWhiteSpace(_staffSearchString) || 
                           u.DisplayName.Contains(_staffSearchString, StringComparison.OrdinalIgnoreCase) ||
                           (u.Email ?? "").Contains(_staffSearchString, StringComparison.OrdinalIgnoreCase))) ?? Enumerable.Empty<UserDto>();

    private string MaskCard(string? number)
    {
        if (string.IsNullOrWhiteSpace(number) || number.Length < 10) return "UNAVAILABLE";
        // Display 6-XXXXX-4 format
        return $"{number.Substring(0, 6)} • • • {number.Substring(number.Length - 4)}";
    }

    private string GetStatusClass(UserDto user)
    {
        if (!user.IsActive) return "suspended";
        if (user.LastLoginAt == null) return "uninitialized";
        if (user.LastLoginAt < DateTime.UtcNow.AddMonths(-3)) return "dormant";
        return "active";
    }

    private string GetStatusText(UserDto user)
    {
        if (!user.IsActive) return "Blocked/Suspended";
        if (user.LastLoginAt == null) return "Pending Initial Login";
        if (user.LastLoginAt < DateTime.UtcNow.AddMonths(-3)) return "Dormant (90+ Days Inactive)";
        return "Active & Operational";
    }

    private string GetAvatarColor(string seed)
    {
        string[] colors = { "#4f46e5", "#e11d48", "#059669", "#7c3aed", "#d97706", "#2563eb" };
        var index = Math.Abs(seed.GetHashCode()) % colors.Length;
        return colors[index];
    }

    private string GetInitials(UserDto user)
    {
        if (string.IsNullOrWhiteSpace(user.DisplayName)) return "U";
        var parts = user.DisplayName.Split(' ');
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper();
    }

    private async Task OpenUserAdjustmentDialog(UserDto user, bool isCredit)
    {
        var parameters = new DialogParameters { ["User"] = user, ["IsCredit"] = isCredit };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<FMC.Components.Pages.Admin.UserBalanceDialog>("Adjust Liquidity Endpoint", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadUsers();
            StateHasChanged();
        }
    }
}
