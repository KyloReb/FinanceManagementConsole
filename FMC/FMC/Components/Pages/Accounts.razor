@page "/accounts"
@using FMC.Shared.DTOs
@using FMC.Shared.Auth
@attribute [Authorize(Roles = Roles.SuperAdmin + "," + Roles.CEO)]
@inject FMC.Services.Api.AdminService AdminService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Financial Account Inventory | FMC</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <div class="d-flex align-center justify-space-between mb-8">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight:900; letter-spacing:-1px;">Capital Account Inventory</MudText>
            <MudText Typo="Typo.body1" Class="mud-text-secondary">Comprehensive institutional oversight of all liquidity endpoints.</MudText>
        </div>
        <div class="d-flex gap-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Size="Size.Large" Style="border-radius:12px; text-transform:none; font-weight:800;">Initiate New Account</MudButton>
        </div>
    </div>

    @* Analytics Overview Cards *@
    <MudGrid Spacing="3" Class="mb-8">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="0" Class="pa-6 fmc-stat-card">
                <div class="d-flex align-center mb-3">
                    <div class="fmc-stat-icon-wrapper primary">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Primary" />
                    </div>
                </div>
                <MudText Typo="Typo.caption" Style="font-weight:800; opacity:0.6; letter-spacing:1px;">TOTAL SYSTEM LIQUIDITY</MudText>
                <MudText Typo="Typo.h5" Style="font-weight:900; font-family: 'JetBrains Mono', monospace;">₱@(_users?.Sum(u => u.Balance).ToString("N2") ?? "0.00")</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="0" Class="pa-6 fmc-stat-card">
                <div class="d-flex align-center mb-3">
                    <div class="fmc-stat-icon-wrapper success">
                        <MudIcon Icon="@Icons.Material.Filled.Group" Color="Color.Success" />
                    </div>
                </div>
                <MudText Typo="Typo.caption" Style="font-weight:800; opacity:0.6; letter-spacing:1px;">ACTIVE ENDPOINTS</MudText>
                <MudText Typo="Typo.h5" Style="font-weight:900;">@(_users?.Count ?? 0)</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Tools Bar *@
    <MudPaper Elevation="0" Class="pa-4 mb-4 d-flex align-center justify-space-between fmc-toolbar">
        <div class="d-flex align-center flex-grow-1 mr-4">
            <MudTextField @bind-Value="_searchString" Placeholder="Filter by name, email, or institutional ID..." 
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" 
                          Variant="Variant.Outlined" Margin="Margin.Dense" Class="fmc-search-field"
                          Clearable="true" Immediate="true" />
        </div>
        <div class="d-flex gap-2">
            <MudSelect T="string" Label="Entity Status" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="fmc-filter-select" Style="width:150px;">
                <MudSelectItem Value="@("All")">All Accounts</MudSelectItem>
                <MudSelectItem Value="@("Active")">Active Only</MudSelectItem>
                <MudSelectItem Value="@("Flagged")">Flagged</MudSelectItem>
            </MudSelect>
        </div>
    </MudPaper>

    @if (_loading)
    {
        <div class="d-flex justify-center py-20">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        </div>
    }
    else
    {
        <MudTable Items="@FilteredUsers" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Class="fmc-account-table" HorizontalScrollbar="true">
            <HeaderContent>
                <MudTh Class="fmc-th">INSTITUTIONAL IDENTITY</MudTh>
                <MudTh Class="fmc-th">AUTHORITY / ROLE</MudTh>
                <MudTh Class="fmc-th">TENANT AFFILIATION</MudTh>
                <MudTh Class="fmc-th" Style="text-align:right">LIQUIDITY BALANCE</MudTh>
                <MudTh Class="fmc-th" Style="text-align:right">ACTIONS</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Identity" Class="py-4">
                    <div class="d-flex align-center">
                        <MudAvatar Color="Color.Primary" Class="mr-3" Style="font-weight:700;">@(GetInitials(context))</MudAvatar>
                        <div>
                            <MudText Typo="Typo.body1" Style="font-weight:800; letter-spacing:-0.3px;">@context.DisplayName</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Email</MudText>
                        </div>
                    </div>
                </MudTd>
                <MudTd DataLabel="Role">
                    <div class="d-flex gap-1 flex-wrap">
                        @foreach (var role in context.Roles)
                        {
                            <span class="fmc-mini-badge @(role == Roles.SuperAdmin ? "admin" : "user")">@role</span>
                        }
                    </div>
                </MudTd>
                <MudTd DataLabel="Organization">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.body2" Style="font-weight:700;">@(context.Organization ?? "Independent Node")</MudText>
                        <MudText Typo="Typo.caption" Style="opacity:0.5; font-family:monospace;">ID: @(context.OrganizationId?.ToString().Substring(0, 8) ?? "N/A")</MudText>
                    </div>
                </MudTd>
                <MudTd DataLabel="Balance" Style="text-align:right">
                    <MudText Typo="Typo.body1" Style="font-weight:800; font-family: 'JetBrains Mono', monospace; font-size:1.05rem;">
                        ₱@context.Balance.ToString("N2")
                    </MudText>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align:right">
                    <div class="d-flex justify-end gap-2">
                        <MudTooltip Text="Forensic Profile Trace">
                            <MudIconButton Icon="@Icons.Material.Filled.QueryStats" Color="Color.Primary" Size="Size.Small" 
                                           OnClick="@(() => Navigation.NavigateTo($"/profile/{context.Id}"))"
                                           Style="background: rgba(var(--mud-palette-primary-rgb), 0.1); border-radius:8px;" />
                        </MudTooltip>
                        <MudTooltip Text="Direct Adjustment">
                            <MudIconButton Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Info" Size="Size.Small"
                                           Style="background: rgba(var(--mud-palette-info-rgb), 0.1); border-radius:8px;" />
                        </MudTooltip>
                        <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Color="Color.Default" Size="Size.Small" />
                    </div>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    }
</MudContainer>

<style>
    .fmc-account-table {
        background-color: transparent !important;
        border-radius: 16px;
        overflow: hidden;
    }
    .fmc-account-table .mud-table-head {
        background-color: var(--mud-palette-background-grey);
        border-bottom: 2px solid var(--mud-palette-lines-default);
    }
    .fmc-th { font-weight: 800 !important; font-size: 0.75rem !important; letter-spacing: 0.5px; opacity: 0.7; }
    
    .fmc-stat-card {
        border-radius: 20px;
        border: 1px solid var(--mud-palette-lines-default);
        background: linear-gradient(135deg, var(--mud-palette-surface) 0%, var(--mud-palette-background-grey) 100%);
    }
    .fmc-stat-icon-wrapper {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .fmc-stat-icon-wrapper.primary { background: rgba(var(--mud-palette-primary-rgb), 0.1); }
    .fmc-stat-icon-wrapper.success { background: rgba(var(--mud-palette-success-rgb), 0.1); }

    .fmc-toolbar {
        border-radius: 16px;
        border: 1px solid var(--mud-palette-lines-default);
        background-color: var(--mud-palette-surface) !important;
    }
    .fmc-search-field .mud-input-outlined { border-radius: 12px; }
    .fmc-filter-select .mud-input-outlined { border-radius: 12px; }

    .fmc-mini-badge {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.65rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .fmc-mini-badge.admin { background: rgba(var(--mud-palette-error-rgb), 0.08); color: var(--mud-palette-error); }
    .fmc-mini-badge.user { background: rgba(var(--mud-palette-info-rgb), 0.08); color: var(--mud-palette-info); }
</style>

@code {
    private List<UserDto>? _users;
    private bool _loading = true;
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        try
        {
            _loading = true;
            _users = await AdminService.GetUsersAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Failed to generate account inventory trace.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private IEnumerable<UserDto> FilteredUsers => 
        _users?.Where(u => string.IsNullOrWhiteSpace(_searchString) || 
                          u.DisplayName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                          u.Email.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ?? Enumerable.Empty<UserDto>();

    private string GetInitials(UserDto user)
    {
        if (string.IsNullOrWhiteSpace(user.DisplayName)) return "U";
        var parts = user.DisplayName.Split(' ');
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper();
    }
}
